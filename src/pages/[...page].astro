---
import type { GetStaticPaths, Page } from "astro";
import type { CollectionEntry } from "astro:content";
import Pagination from "../components/control/Pagination.astro";
import PostPage from "../components/PostPage.astro";
import { PAGE_SIZE } from "../constants/constants";
import MainGridLayout from "../layouts/MainGridLayout.astro";
import { getSortedPosts } from "../utils/content-utils";
import { hasMarkdownPostsOnDisk } from "../utils/post-files";

type PostsPage = Page<CollectionEntry<"posts">>;

export const getStaticPaths = (async ({ paginate }) => {
	if (!hasMarkdownPostsOnDisk()) {
		return [
			{
				params: { page: undefined },
				props: {
					page: {
						data: [] as CollectionEntry<"posts">[],
						start: 0,
						end: 0,
						size: PAGE_SIZE,
						total: 0,
						currentPage: 1,
						lastPage: 1,
						url: {
							current: "/",
							prev: undefined,
							next: undefined,
							first: undefined,
							last: undefined,
						},
					} satisfies PostsPage,
				},
			},
		];
	}

	const allBlogPosts = await getSortedPosts();
	return paginate(allBlogPosts, { pageSize: PAGE_SIZE });
}) satisfies GetStaticPaths;

interface Props {
	page: PostsPage;
}

const { page }: Props = Astro.props;
const len = page.data.length;
---

<MainGridLayout>
	{
		len > 0 ? (
			<>
				<PostPage page={page}></PostPage>
				<Pagination
					class="mx-auto onload-animation"
					page={page}
					style={`animation-delay: calc(var(--content-delay) + ${len * 50}ms)`}
				></Pagination>
			</>
		) : (
			<section class="card-base mx-auto mb-4 w-full rounded-[var(--radius-large)] px-8 py-10 text-center onload-animation">
				<h1 class="mb-3 text-2xl font-bold text-black/85 dark:text-white/85">暂时还没有文章</h1>
				<p class="text-black/55 dark:text-white/55">首页文章流目前为空，后续发布内容后会自动出现在这里。</p>
			</section>
		)
	}
</MainGridLayout>

<script is:inline>
	const notifyHomePageReady = () => {
		window.requestAnimationFrame(() => {
			document.dispatchEvent(
				new CustomEvent("alf:page-ready", {
					detail: { path: window.location.pathname },
				}),
			);
		});
	};

	document.addEventListener("astro:page-load", notifyHomePageReady);
	document.addEventListener("DOMContentLoaded", notifyHomePageReady);
</script>
