---
import ArchivePanel from "@components/ArchivePanel.svelte";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getSortedArchiveEntries } from "../utils/content-utils";

const sortedPostsList = await getSortedArchiveEntries();
const initialTags = Astro.url.searchParams.getAll("tag");
const initialCategories = Astro.url.searchParams.getAll("category");
const initialSerieses = Astro.url.searchParams.getAll("series");
const initialUncategorized = Astro.url.searchParams.has("uncategorized");
---

<MainGridLayout title={i18n(I18nKey.archive)}>
    <ArchivePanel
        sortedPosts={sortedPostsList}
        initialTags={initialTags}
        initialCategories={initialCategories}
        initialSerieses={initialSerieses}
        initialUncategorized={initialUncategorized}
        client:load
    ></ArchivePanel>
</MainGridLayout>

