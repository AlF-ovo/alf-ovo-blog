---
import { Icon } from "astro-icon/components";
import Layout from "../layouts/Layout.astro";

type ActivityPoint = {
	label: string;
	publish: number;
	update: number;
	delete: number;
};

type ActivityDataset = {
	label: string;
	points: ActivityPoint[];
};

type ActivityMetric = ActivityPoint & {
	total: number;
	x: number;
	publishY: number;
	updateY: number;
	deleteY: number;
};

const buildDailyPoints = (
	startDate: Date,
	publish: number[],
	update: number[],
	remove: number[],
): ActivityPoint[] =>
	publish.map((value: number, index: number) => {
		const date = new Date(startDate);
		date.setDate(startDate.getDate() + index);

		return {
			label: `${String(date.getMonth() + 1).padStart(2, "0")}/${String(date.getDate()).padStart(2, "0")}`,
			publish: value,
			update: update[index],
			delete: remove[index],
		};
	});

const buildMonthlyPoints = (
	startDate: Date,
	publish: number[],
	update: number[],
	remove: number[],
): ActivityPoint[] =>
	publish.map((value: number, index: number) => {
		const date = new Date(startDate);
		date.setMonth(startDate.getMonth() + index);

		return {
			label: `${date.getMonth() + 1}月`,
			publish: value,
			update: update[index],
			delete: remove[index],
		};
	});

const chartDatasets: Record<"week" | "month" | "year", ActivityDataset> = {
	week: {
		label: "近7日",
		points: buildDailyPoints(
			new Date(2026, 3, 11),
			[2, 1, 3, 1, 4, 2, 5],
			[1, 2, 2, 1, 3, 4, 2],
			[0, 1, 0, 1, 1, 0, 1],
		),
	},
	month: {
		label: "近1个月",
		points: buildDailyPoints(
			new Date(2026, 2, 19),
			[
				1, 0, 2, 1, 3, 2, 1, 4, 2, 1, 3, 2, 4, 1, 2, 3, 2, 1, 4, 2, 1, 3, 2, 5,
				2, 1, 4, 3, 2, 4,
			],
			[
				0, 1, 1, 2, 1, 3, 2, 1, 2, 3, 1, 2, 1, 4, 2, 2, 3, 1, 2, 4, 2, 1, 3, 2,
				1, 2, 3, 2, 4, 3,
			],
			[
				0, 0, 1, 0, 1, 0, 1, 1, 0, 1, 0, 1, 0, 2, 1, 0, 1, 0, 1, 1, 0, 1, 0, 2,
				1, 0, 1, 1, 0, 1,
			],
		),
	},
	year: {
		label: "近1年",
		points: buildMonthlyPoints(
			new Date(2025, 4, 1),
			[8, 6, 9, 5, 10, 7, 11, 8, 9, 12, 10, 13],
			[14, 12, 16, 11, 17, 13, 18, 15, 16, 19, 17, 21],
			[2, 1, 2, 1, 3, 2, 2, 1, 2, 3, 2, 4],
		),
	},
};

const getChartMetrics = (points: ActivityPoint[]): ActivityMetric[] => {
	const maxTotal = Math.max(
		...points.map(
			(point: ActivityPoint) => point.publish + point.update + point.delete,
		),
		1,
	);
	const denominator = Math.max(points.length - 1, 1);

	return points.map((point: ActivityPoint, index: number) => {
		const total = point.publish + point.update + point.delete;
		const x = (index / denominator) * 100;

		return {
			...point,
			total,
			x,
			publishY: 100 - (point.publish / maxTotal) * 100,
			updateY: 100 - (point.update / maxTotal) * 100,
			deleteY: 100 - (point.delete / maxTotal) * 100,
		};
	});
};

const summarizeDataset = (dataset: ActivityDataset) =>
	`本${dataset.label}共发布 ${dataset.points.reduce((sum: number, point: ActivityPoint) => sum + point.publish, 0)} 篇，修改 ${dataset.points.reduce((sum: number, point: ActivityPoint) => sum + point.update, 0)} 次，删除 ${dataset.points.reduce((sum: number, point: ActivityPoint) => sum + point.delete, 0)} 次。`;

const defaultRange = "week";
const defaultDataset = chartDatasets[defaultRange];
const defaultMetrics = getChartMetrics(defaultDataset.points);
const defaultSummary = summarizeDataset(defaultDataset);
const chartDataJson = JSON.stringify(chartDatasets);
const recentUpdates = [
	{
		title: "《Astro 部署记录》",
		time: "2026-04-17 08:12",
	},
	{
		title: "《Fuwari 主题初始化》",
		time: "2026-04-16 22:48",
	},
	{
		title: "《博客导航结构调整》",
		time: "2026-04-16 19:35",
	},
];
const dashboardMetrics = {
	updatedPosts: 3,
	updatedWords: 4286,
	totalUsage: "86 小时 24 分",
	totalUsageNote: "近 30 天累计写作、整理与调试时间",
	lastVisitedPost: {
		title: "《Fuwari 仪表盘改造记录》",
		url: "/posts/guide/",
		excerpt:
			"记录仪表盘布局、时间切换图表、最近修改侧栏和欢迎语打字机效果的调整过程。",
	},
	latestEssayPost: {
		title: "《雨后的窗口与凌晨的终端》",
		url: "/posts/markdown/",
		excerpt:
			"写一点与二进制无关的东西，关于深夜、重复、停顿，以及那些在终端熄灭后还留在脑海里的杂乱想法。",
	},
};
