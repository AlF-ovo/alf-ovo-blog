		border: 1px solid rgba(148, 163, 184, 0.16);
		box-shadow: 0 10px 24px rgba(15, 23, 42, 0.08);
	}

	:global(.dark) .ghost-button {
		background: rgba(15, 23, 42, 0.76);
		border-color: rgba(148, 163, 184, 0.12);
	}

	.profile-chip {
		gap: 0.75rem;
		padding: 0.45rem 0.55rem 0.45rem 0.45rem;
	}

	.profile-avatar {
		width: 2.65rem;
		height: 2.65rem;
		background: linear-gradient(135deg, #0f766e, #2563eb);
		color: white;
		font-weight: 800;
	}

	.profile-name {
		margin: 0;
		font-size: 0.92rem;
		font-weight: 700;
	}

	.profile-role {
		margin: 0;
		font-size: 0.76rem;
		color: rgba(100, 116, 139, 0.82);
	}

	:global(.dark) .profile-role {
		color: rgba(148, 163, 184, 0.82);
	}

	.dashboard-card {
		border-radius: 1.6rem;
		padding: 1.2rem;
	}

	.hero-panel {
		display: flex;
		justify-content: space-between;
		gap: 1.25rem;
		background:
			linear-gradient(135deg, rgba(255, 255, 255, 0.94), rgba(240, 253, 250, 0.9)),
			radial-gradient(circle at right top, rgba(37, 99, 235, 0.1), transparent 15rem);
	}

	:global(.dark) .hero-panel {
		background:
			linear-gradient(135deg, rgba(15, 23, 42, 0.94), rgba(15, 23, 42, 0.86)),
			radial-gradient(circle at right top, rgba(20, 184, 166, 0.14), transparent 16rem);
	}

	.hero-title {
		margin-top: 0.35rem;
		font-size: clamp(1.35rem, 2.8vw, 1.9rem);
		font-weight: 800;
	}

	.hero-title-typing {
		display: inline-flex;
		align-items: baseline;
		gap: 0.08em;
		font-family: "Courier New", "SFMono-Regular", Consolas, monospace;
		letter-spacing: -0.02em;
		min-height: 1.4em;
	}

	.hero-title-cursor {
		display: inline-block;
		color: rgba(37, 99, 235, 0.95);
		animation: blink-cursor 900ms steps(1) infinite;
	}

	:global(.dark) .hero-title-cursor {
		color: rgba(94, 234, 212, 0.95);
	}

	.hero-copy {
		max-width: 42rem;
		margin: 0.75rem 0 0;
		color: rgba(71, 85, 105, 0.9);
		line-height: 1.75;
	}

	:global(.dark) .hero-copy {
		color: rgba(203, 213, 225, 0.82);
	}

	.hero-actions {
		gap: 0.75rem;
		align-self: flex-start;
	}

	.dashboard-hint-overlay {
		position: fixed;
		inset: 0;
		z-index: 50;
		display: grid;
		place-items: center;
		padding: 1.5rem;
		background: rgba(15, 23, 42, 0.48);
		backdrop-filter: blur(12px);
	}

	.dashboard-hint-overlay[hidden] {
		display: none;
	}

	.dashboard-hint-card {
		width: min(42rem, 100%);
		display: grid;
		gap: 1rem;
		padding: 1.2rem;
		border-radius: 1.5rem;
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(248, 250, 252, 0.94)),
			radial-gradient(circle at top right, rgba(20, 184, 166, 0.12), transparent 16rem);
		border: 1px solid rgba(148, 163, 184, 0.22);
		box-shadow: 0 30px 80px rgba(15, 23, 42, 0.28);
	}

	:global(.dark) .dashboard-hint-card {
		background:
			linear-gradient(180deg, rgba(15, 23, 42, 0.96), rgba(15, 23, 42, 0.92)),
			radial-gradient(circle at top right, rgba(20, 184, 166, 0.14), transparent 16rem);
		border-color: rgba(148, 163, 184, 0.16);
	}

	.dashboard-hint-head {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 1rem;
	}

	.dashboard-hint-eyebrow,
	.dashboard-hint-title {
		margin: 0;
	}

	.dashboard-hint-eyebrow {
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: rgba(14, 116, 144, 0.82);
	}

	.dashboard-hint-title {
		margin-top: 0.35rem;
		font-size: 1.25rem;
		font-weight: 800;
		color: rgba(15, 23, 42, 0.96);
	}

	:global(.dark) .dashboard-hint-title {
		color: rgba(248, 250, 252, 0.94);
	}

	.dashboard-hint-close {
		width: 2.75rem;
		height: 2.75rem;
		display: grid;
		place-items: center;
		border: 0;
		border-radius: 999px;
		background: rgba(226, 232, 240, 0.72);
		color: rgba(15, 23, 42, 0.86);
		transition: 180ms ease;
	}

	.dashboard-hint-close:hover {
		background: rgba(203, 213, 225, 0.88);
	}

	:global(.dark) .dashboard-hint-close {
		background: rgba(30, 41, 59, 0.9);
		color: rgba(226, 232, 240, 0.88);
	}

	.dashboard-hint-textbox {
		min-height: 18rem;
		width: 100%;
		resize: vertical;
		padding: 1rem 1.05rem;
		border: 1px solid rgba(148, 163, 184, 0.22);
		border-radius: 1rem;
		background: rgba(255, 255, 255, 0.86);
		color: rgba(15, 23, 42, 0.92);
		font: 0.92rem/1.75 "JetBrains Mono Variable", "Courier New", monospace;
		white-space: pre-wrap;
	}

	.dashboard-hint-textbox:focus {
		outline: 2px solid rgba(20, 184, 166, 0.3);
		outline-offset: 2px;
	}

	:global(.dark) .dashboard-hint-textbox {
		background: rgba(2, 6, 23, 0.72);
		border-color: rgba(148, 163, 184, 0.18);
		color: rgba(226, 232, 240, 0.9);
	}

	.primary-button,
	.secondary-button,
	.ghost-link {
		padding: 0.8rem 1.1rem;
		font-size: 0.92rem;
		font-weight: 700;
	}

	.primary-button {
		background: linear-gradient(135deg, #14b8a6, #0f766e);
		color: white;
		box-shadow: 0 14px 30px rgba(20, 184, 166, 0.26);
	}

	.secondary-button {
		background: rgba(255, 255, 255, 0.82);
		border: 1px solid rgba(148, 163, 184, 0.18);
		color: rgba(15, 23, 42, 0.82);
	}

	:global(.dark) .secondary-button {
		background: rgba(30, 41, 59, 0.8);
		border-color: rgba(148, 163, 184, 0.14);
		color: rgba(226, 232, 240, 0.88);
	}

	.metrics-grid,
	.module-grid {
		display: grid;
		gap: 1rem;
	}

	.metrics-grid {
		grid-template-columns: repeat(4, minmax(0, 1fr));
	}

	.metric-card {
		display: grid;
		gap: 1rem;
	}

	.metric-head {
		justify-content: space-between;
		color: rgba(71, 85, 105, 0.88);
		font-size: 0.92rem;
	}

	:global(.dark) .metric-head {
		color: rgba(148, 163, 184, 0.84);
	}

	.metric-value {
		height: 3.2rem;
		border-radius: 1rem;
	}

	.metric-value-rich,
	.metric-article {
		height: auto;
		display: grid;
		gap: 0.45rem;
		align-content: start;
	}

	.metric-primary,
	.metric-secondary,
	.metric-footnote,
	.metric-article-excerpt {
		margin: 0;
	}

	.metric-primary {
		font-size: 1.4rem;
		font-weight: 800;
		letter-spacing: -0.04em;
		color: rgba(15, 23, 42, 0.96);
	}

	.metric-secondary,
	.metric-footnote,
	.metric-article-excerpt {
		font-size: 0.84rem;
		line-height: 1.65;
		color: rgba(71, 85, 105, 0.88);
	}

	.metric-badges {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.metric-badge {
		display: inline-flex;
		align-items: center;
		padding: 0.34rem 0.65rem;
		border-radius: 999px;
		background: rgba(37, 99, 235, 0.08);
		color: rgba(37, 99, 235, 0.9);
		font-size: 0.76rem;
		font-weight: 700;
	}

	.metric-badge.is-accent {
		background: rgba(139, 92, 246, 0.1);
		color: rgba(109, 40, 217, 0.92);
	}

	.metric-article-title {
		font-size: 1rem;
		font-weight: 800;
		line-height: 1.5;
		color: rgba(15, 23, 42, 0.96);
		margin: 0;
	}

	.metric-footnote-link {
		font-size: 0.84rem;
		line-height: 1.65;
		color: rgba(37, 99, 235, 0.94);
		text-decoration: none;
		font-weight: 700;
	}

	.metric-footnote-link:hover {
		color: rgba(37, 99, 235, 0.94);
		text-decoration: underline;
	}

	.metric-foot {
		display: flex;
		align-items: center;
	}

	:global(.dark) .metric-primary,
	:global(.dark) .metric-article-title {
		color: rgba(248, 250, 252, 0.96);
	}

	:global(.dark) .metric-secondary,
	:global(.dark) .metric-footnote,
	:global(.dark) .metric-article-excerpt {
		color: rgba(203, 213, 225, 0.82);
	}

	:global(.dark) .metric-badge {
		background: rgba(59, 130, 246, 0.16);
		color: rgba(191, 219, 254, 0.96);
	}

	:global(.dark) .metric-badge.is-accent {
		background: rgba(139, 92, 246, 0.16);
		color: rgba(221, 214, 254, 0.96);
	}

	:global(.dark) .metric-footnote-link {
		color: rgba(125, 211, 252, 0.96);
	}

	:global(.dark) .metric-footnote-link:hover {
		color: rgba(125, 211, 252, 0.96);
	}

	.content-grid {
		display: grid;
		grid-template-columns: minmax(0, 1.55fr) minmax(320px, 0.75fr);
		gap: 1rem;
	}

	.chart-card,
	.wide-card {
		grid-column: 1 / 2;
	}

	.side-card {
		grid-column: 2 / 3;
		grid-row: 1 / 2;
	}

	.section-head {
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 1rem;
	}

	.section-title {
		margin-top: 0.35rem;
		font-size: 1.08rem;
		font-weight: 750;
	}

	.ghost-link {
		background: rgba(20, 184, 166, 0.1);
		color: rgba(15, 118, 110, 0.9);
	}

	:global(.dark) .ghost-link {
		background: rgba(20, 184, 166, 0.14);
		color: rgba(94, 234, 212, 0.88);
	}

	.range-switch {
		position: relative;
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		align-items: center;
		padding: 0.28rem;
		border-radius: 999px;
		background: rgba(226, 232, 240, 0.72);
		border: 1px solid rgba(148, 163, 184, 0.16);
		min-width: min(100%, 18rem);
	}

	:global(.dark) .range-switch {
		background: rgba(15, 23, 42, 0.74);
		border-color: rgba(148, 163, 184, 0.1);
	}

	.range-switch-thumb {
		position: absolute;
		top: 0.28rem;
		bottom: 0.28rem;
		left: 0.28rem;
		width: calc((100% - 0.56rem) / 3);
		border-radius: 999px;
		background: linear-gradient(135deg, rgba(37, 99, 235, 0.92), rgba(99, 102, 241, 0.92));
		box-shadow: 0 10px 22px rgba(37, 99, 235, 0.18);
		transition: transform 220ms ease;
	}

	.range-switch[data-active-index="1"] .range-switch-thumb {
		transform: translateX(100%);
	}

	.range-switch[data-active-index="2"] .range-switch-thumb {
		transform: translateX(200%);
	}

	.range-switch-button {
		position: relative;
		z-index: 1;
		border: 0;
		background: transparent;
		color: rgba(71, 85, 105, 0.92);
		padding: 0.72rem 0.9rem;
		font-size: 0.88rem;
		font-weight: 700;
		border-radius: 999px;
	}

	.range-switch-button.is-active {
		color: white;
	}

	:global(.dark) .range-switch-button {
		color: rgba(203, 213, 225, 0.88);
	}

	:global(.dark) .range-switch-button.is-active {
		color: rgba(248, 250, 252, 0.98);
	}

	.chart-meta {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 0.85rem;
	}

	.chart-legend {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 0.85rem;
		color: rgba(71, 85, 105, 0.86);
		font-size: 0.88rem;
	}

	:global(.dark) .chart-legend,
	:global(.dark) .chart-summary {
		color: rgba(203, 213, 225, 0.8);
	}

	.legend-item {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
	}

	.legend-swatch {
		width: 0.78rem;
		height: 0.78rem;
		border-radius: 999px;
	}

	.legend-swatch.is-publish {
		background: linear-gradient(180deg, rgba(59, 130, 246, 0.96), rgba(37, 99, 235, 0.96));
	}

	.legend-swatch.is-update {
		background: linear-gradient(180deg, rgba(139, 92, 246, 0.96), rgba(124, 58, 237, 0.96));
	}

	.legend-swatch.is-delete {
		background: linear-gradient(180deg, rgba(250, 204, 21, 0.98), rgba(234, 179, 8, 0.94));
	}

	.chart-summary {
		margin: 0;
		color: rgba(71, 85, 105, 0.86);
		font-size: 0.88rem;
		text-align: right;
	}

	.chart-placeholder {
		--chart-dot-fill: rgba(248, 250, 252, 0.96);
		position: relative;
		min-height: 21rem;
		border-radius: 1.25rem;
		padding: 1rem;
		overflow: hidden;
		background:
			linear-gradient(180deg, rgba(248, 250, 252, 0.78), rgba(226, 232, 240, 0.58));
		border: 1px solid rgba(148, 163, 184, 0.16);
	}

	:global(.dark) .chart-placeholder {
		--chart-dot-fill: rgba(15, 23, 42, 0.98);
		background:
			linear-gradient(180deg, rgba(15, 23, 42, 0.88), rgba(30, 41, 59, 0.6));
		border-color: rgba(148, 163, 184, 0.1);
	}

	.grid-lines {
		position: absolute;
		inset: 0;
		background-image:
			linear-gradient(rgba(148, 163, 184, 0.14) 1px, transparent 1px),
			linear-gradient(90deg, rgba(148, 163, 184, 0.12) 1px, transparent 1px);
		background-size: 100% 20%, 12% 100%;
		mask-image: linear-gradient(180deg, transparent 0%, black 18%, black 82%, transparent 100%);
	}

	.chart-scroll {
		position: relative;
		z-index: 1;
		overflow-x: auto;
		padding-bottom: 0.3rem;
	}

	.chart-scroll::-webkit-scrollbar {
		height: 0.45rem;
	}

	.chart-scroll::-webkit-scrollbar-thumb {
		background: rgba(148, 163, 184, 0.38);
		border-radius: 999px;
	}

	.chart-stage {
		position: relative;
		min-width: max(100%, calc(var(--chart-point-count, 7) * var(--chart-column-width, 3.2rem)));
	}

	.chart-svg {
		position: relative;
		display: block;
		width: 100%;
		height: 16rem;
		overflow: visible;
	}

	.chart-area {
		stroke: none;
	}

	.chart-area.is-publish {
		fill: rgba(59, 130, 246, 0.18);
	}

	.chart-area.is-update {
		fill: rgba(139, 92, 246, 0.16);
	}

	.chart-area.is-delete {
		fill: rgba(250, 204, 21, 0.18);
	}

	.chart-line {
		fill: none;
		vector-effect: non-scaling-stroke;
		stroke-linecap: round;
		stroke-linejoin: round;
		filter: drop-shadow(0 0 8px rgba(15, 23, 42, 0.18));
	}

	.chart-line.is-publish {
		stroke: rgb(59, 130, 246);
	}

	.chart-line.is-update {
		stroke: rgb(139, 92, 246);
	}

	.chart-line.is-delete {
		stroke: rgb(250, 204, 21);
	}

	.chart-labels {
		margin-top: 0.7rem;
		display: grid;
		gap: 0.8rem;
		align-items: start;
	}

	.chart-label {
		font-size: 0.76rem;
		font-weight: 700;
		color: rgba(255, 255, 255, 0.96);
		text-align: center;
		white-space: nowrap;
		text-shadow: 0 1px 10px rgba(15, 23, 42, 0.35);
	}

	:global(.dark) .chart-label {
		color: rgba(255, 255, 255, 0.98);
	}

	.stack-skeleton {
		display: grid;
		gap: 0.8rem;
	}

	.mini-stat {
		gap: 0.9rem;
		padding: 0.9rem;
		border-radius: 1rem;
		background: rgba(248, 250, 252, 0.72);
		border: 1px solid rgba(148, 163, 184, 0.14);
	}

	:global(.dark) .mini-stat {
		background: rgba(15, 23, 42, 0.62);
		border-color: rgba(148, 163, 184, 0.1);
	}

	.mini-stat-icon,
	.module-icon {
		width: 2.75rem;
		height: 2.75rem;
		background: rgba(20, 184, 166, 0.12);
		color: rgba(15, 118, 110, 0.92);
	}

	:global(.dark) .mini-stat-icon,
	:global(.dark) .module-icon {
		background: rgba(20, 184, 166, 0.14);
		color: rgba(94, 234, 212, 0.92);
	}

	.mini-stat-body {
		flex: 1;
		display: grid;
		gap: 0.5rem;
	}

	.mini-stat-label,
	.mini-stat-meta-label {
		margin: 0;
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: rgba(100, 116, 139, 0.82);
	}

	.mini-stat-title {
		margin: 0;
		font-size: 0.96rem;
		font-weight: 700;
		line-height: 1.5;
		color: rgba(15, 23, 42, 0.94);
	}

	.mini-stat-meta {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
		font-size: 0.82rem;
		color: rgba(71, 85, 105, 0.86);
	}

	:global(.dark) .mini-stat-label,
	:global(.dark) .mini-stat-meta-label {
		color: rgba(148, 163, 184, 0.8);
	}

	:global(.dark) .mini-stat-title {
		color: rgba(248, 250, 252, 0.94);
	}

	:global(.dark) .mini-stat-meta {
		color: rgba(203, 213, 225, 0.82);
	}

	.table-placeholder {
		display: grid;
		border-radius: 1.2rem;
		border: 1px solid rgba(148, 163, 184, 0.14);
		overflow: hidden;
	}

	.table-row {
		display: grid;
		grid-template-columns: 1.3fr 0.8fr 0.8fr 1fr;
		gap: 0.8rem;
		padding: 0.9rem 1rem;
		align-items: center;
		background: rgba(255, 255, 255, 0.58);
		border-bottom: 1px solid rgba(148, 163, 184, 0.12);
	}

	:global(.dark) .table-row {
		background: rgba(15, 23, 42, 0.5);
		border-bottom-color: rgba(148, 163, 184, 0.1);
	}

	.table-row:last-child {
		border-bottom: 0;
	}

	.table-head-row {
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: rgba(100, 116, 139, 0.85);
		background: rgba(241, 245, 249, 0.85);
	}

	:global(.dark) .table-head-row {
		color: rgba(148, 163, 184, 0.84);
		background: rgba(15, 23, 42, 0.75);
	}

	.module-grid {
		grid-template-columns: repeat(3, minmax(0, 1fr));
	}

	.module-card {
		display: grid;
		gap: 0.75rem;
		padding: 1rem;
		border-radius: 1.1rem;
		background: rgba(248, 250, 252, 0.72);
		border: 1px solid rgba(148, 163, 184, 0.14);
	}

	:global(.dark) .module-card {
		background: rgba(15, 23, 42, 0.58);
		border-color: rgba(148, 163, 184, 0.1);
	}

	.placeholder-block,
	.skeleton-line,
	.pill-placeholder {
		position: relative;
		overflow: hidden;
		background: linear-gradient(90deg, rgba(148, 163, 184, 0.16), rgba(226, 232, 240, 0.7), rgba(148, 163, 184, 0.16));
	}

	:global(.dark) .placeholder-block,
	:global(.dark) .skeleton-line,
	:global(.dark) .pill-placeholder {
		background: linear-gradient(90deg, rgba(71, 85, 105, 0.42), rgba(100, 116, 139, 0.72), rgba(71, 85, 105, 0.42));
	}

	.placeholder-block::after,
	.skeleton-line::after,
	.pill-placeholder::after {
		content: "";
		position: absolute;
		inset: 0;
		transform: translateX(-100%);
		background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.6), transparent);
		animation: shimmer 2.2s infinite;
	}

	:global(.dark) .placeholder-block::after,
	:global(.dark) .skeleton-line::after,
	:global(.dark) .pill-placeholder::after {
		background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.12), transparent);
	}

	.skeleton-line {
		height: 0.72rem;
		border-radius: 999px;
	}

	.pill-placeholder {
		height: 1.5rem;
		width: 5rem;
		border-radius: 999px;
	}

	.w-100 { width: 100%; }
	.w-82 { width: 82%; }
