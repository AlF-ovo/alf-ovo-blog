---
import { Icon } from "astro-icon/components";
import Layout from "../layouts/Layout.astro";
---

<Layout title="Dashboard" description="Dashboard UI example">
	<div class="dashboard-shell">
		<aside class="dashboard-sidebar">
			<div class="brand-block">
				<div class="brand-mark">
					<Icon name="fa6-solid:gauge-high" class="text-[1.35rem]" />
				</div>
				<div>
					<p class="brand-eyebrow">Example</p>
					<h1 class="brand-title">Dashboard</h1>
				</div>
			</div>

			<nav class="menu-block">
				<a class="menu-item is-active" href="#overview">
					<Icon name="fa6-solid:table-columns" />
					<span>仪表盘</span>
				</a>
				<a class="menu-item" href="#workspace">
					<Icon name="fa6-solid:border-all" />
					<span>工作区</span>
				</a>
				<a class="menu-item" href="#usage">
					<Icon name="fa6-solid:chart-line" />
					<span>使用分析</span>
				</a>
				<a class="menu-item" href="#billing">
					<Icon name="fa6-solid:credit-card" />
					<span>账单</span>
				</a>
				<a class="menu-item" href="#settings">
					<Icon name="fa6-solid:gear" />
					<span>设置</span>
				</a>
			</nav>

			<div class="sidebar-panel">
				<p class="panel-label">当前状态</p>
				<div class="status-chip">
					<span class="status-dot"></span>
					<span>占位模式</span>
				</div>
				<div class="stack-skeleton">
					<div class="skeleton-line w-100"></div>
					<div class="skeleton-line w-72"></div>
					<div class="skeleton-line w-56"></div>
				</div>
			</div>
		</aside>

		<div class="dashboard-main">
			<header class="dashboard-topbar">
				<div>
					<p class="topbar-label">AIXJ style example</p>
					<h2 class="topbar-title">仪表盘示例</h2>
				</div>
				<div class="topbar-actions">
					<div class="ghost-input">
						<Icon name="fa6-solid:magnifying-glass" />
						<span>搜索功能占位</span>
					</div>
					<button class="ghost-button" type="button">
						<Icon name="fa6-solid:bell" />
					</button>
					<div class="profile-chip">
						<div class="profile-avatar">A</div>
						<div>
							<p class="profile-name">AlF</p>
							<p class="profile-role">Dashboard Preview</p>
						</div>
					</div>
				</div>
			</header>

			<section id="overview" class="hero-panel dashboard-card">
				<div>
					<p class="hero-eyebrow">Overview</p>
					<h3 class="hero-title">保留结构，内容暂空</h3>
					<p class="hero-copy">
						这是一版按照参考站仪表盘风格制作的空数据示例，先对齐布局、层级、色彩和交互密度。
					</p>
				</div>
				<div class="hero-actions">
					<button class="primary-button" type="button">主操作占位</button>
					<button class="secondary-button" type="button">次操作占位</button>
				</div>
			</section>

			<section class="metrics-grid">
				<article class="metric-card dashboard-card">
					<div class="metric-head">
						<span>总览卡片 A</span>
						<Icon name="fa6-solid:arrow-trend-up" />
					</div>
					<div class="metric-value placeholder-block"></div>
					<div class="metric-foot">
						<div class="skeleton-line w-58"></div>
					</div>
				</article>
				<article class="metric-card dashboard-card">
					<div class="metric-head">
						<span>总览卡片 B</span>
						<Icon name="fa6-solid:chart-column" />
					</div>
					<div class="metric-value placeholder-block"></div>
					<div class="metric-foot">
						<div class="skeleton-line w-46"></div>
					</div>
				</article>
				<article class="metric-card dashboard-card">
					<div class="metric-head">
						<span>总览卡片 C</span>
						<Icon name="fa6-solid:rocket" />
					</div>
					<div class="metric-value placeholder-block"></div>
					<div class="metric-foot">
						<div class="skeleton-line w-62"></div>
					</div>
				</article>
				<article class="metric-card dashboard-card">
					<div class="metric-head">
						<span>总览卡片 D</span>
						<Icon name="fa6-solid:bolt" />
					</div>
					<div class="metric-value placeholder-block"></div>
					<div class="metric-foot">
						<div class="skeleton-line w-52"></div>
					</div>
				</article>
			</section>

			<section class="content-grid">
				<article id="workspace" class="dashboard-card chart-card">
					<div class="section-head">
						<div>
							<p class="section-eyebrow">Workspace</p>
							<h3 class="section-title">主视图区</h3>
						</div>
						<button class="ghost-link" type="button">空内容占位</button>
					</div>
					<div class="chart-placeholder">
						<div class="grid-lines"></div>
						<div class="bars">
							<span class="bar h-32"></span>
							<span class="bar h-56"></span>
							<span class="bar h-44"></span>
							<span class="bar h-68"></span>
							<span class="bar h-38"></span>
							<span class="bar h-74"></span>
							<span class="bar h-48"></span>
						</div>
					</div>
				</article>

				<article id="usage" class="dashboard-card side-card">
					<div class="section-head">
						<div>
							<p class="section-eyebrow">Usage</p>
							<h3 class="section-title">侧栏信息区</h3>
						</div>
					</div>
					<div class="stack-skeleton">
						<div class="mini-stat">
							<div class="mini-stat-icon">
								<Icon name="fa6-solid:layer-group" />
							</div>
							<div class="mini-stat-body">
								<div class="skeleton-line w-68"></div>
								<div class="skeleton-line w-42"></div>
							</div>
						</div>
						<div class="mini-stat">
							<div class="mini-stat-icon">
								<Icon name="fa6-solid:key" />
							</div>
							<div class="mini-stat-body">
								<div class="skeleton-line w-64"></div>
								<div class="skeleton-line w-36"></div>
							</div>
						</div>
						<div class="mini-stat">
							<div class="mini-stat-icon">
								<Icon name="fa6-solid:database" />
							</div>
							<div class="mini-stat-body">
								<div class="skeleton-line w-70"></div>
								<div class="skeleton-line w-40"></div>
							</div>
						</div>
					</div>
				</article>

				<article id="billing" class="dashboard-card wide-card">
					<div class="section-head">
						<div>
							<p class="section-eyebrow">Billing</p>
							<h3 class="section-title">表格区占位</h3>
						</div>
						<button class="ghost-link" type="button">导出占位</button>
					</div>
					<div class="table-placeholder">
						<div class="table-row table-head-row">
							<span>名称</span>
							<span>状态</span>
							<span>日期</span>
							<span>备注</span>
						</div>
						<div class="table-row">
							<div class="skeleton-line w-70"></div>
							<div class="pill-placeholder"></div>
							<div class="skeleton-line w-42"></div>
							<div class="skeleton-line w-58"></div>
						</div>
						<div class="table-row">
							<div class="skeleton-line w-64"></div>
							<div class="pill-placeholder"></div>
							<div class="skeleton-line w-38"></div>
							<div class="skeleton-line w-52"></div>
						</div>
						<div class="table-row">
							<div class="skeleton-line w-76"></div>
							<div class="pill-placeholder"></div>
							<div class="skeleton-line w-48"></div>
							<div class="skeleton-line w-44"></div>
						</div>
					</div>
				</article>

				<article id="settings" class="dashboard-card wide-card">
					<div class="section-head">
						<div>
							<p class="section-eyebrow">Settings</p>
							<h3 class="section-title">模块占位区</h3>
						</div>
					</div>
					<div class="module-grid">
						<div class="module-card">
							<div class="module-icon">
								<Icon name="fa6-solid:key" />
							</div>
							<div class="skeleton-line w-58"></div>
							<div class="skeleton-line w-82"></div>
						</div>
						<div class="module-card">
							<div class="module-icon">
								<Icon name="fa6-solid:shield-halved" />
							</div>
							<div class="skeleton-line w-62"></div>
							<div class="skeleton-line w-76"></div>
						</div>
						<div class="module-card">
							<div class="module-icon">
								<Icon name="fa6-solid:share-nodes" />
							</div>
							<div class="skeleton-line w-54"></div>
							<div class="skeleton-line w-72"></div>
						</div>
					</div>
				</article>
			</section>
		</div>
	</div>
</Layout>

<style>
	:global(body) {
		background:
			radial-gradient(circle at top left, rgba(20, 184, 166, 0.12), transparent 22rem),
			radial-gradient(circle at top right, rgba(59, 130, 246, 0.1), transparent 24rem),
			linear-gradient(180deg, rgba(248, 250, 252, 0.98), rgba(241, 245, 249, 1));
	}

	:global(.dark body) {
		background:
			radial-gradient(circle at top left, rgba(20, 184, 166, 0.16), transparent 22rem),
			radial-gradient(circle at top right, rgba(37, 99, 235, 0.16), transparent 24rem),
			linear-gradient(180deg, rgba(2, 6, 23, 0.98), rgba(15, 23, 42, 1));
	}

	.dashboard-shell {
		min-height: 100vh;
		display: grid;
		grid-template-columns: 280px minmax(0, 1fr);
		gap: 1.25rem;
		padding: 1.25rem;
	}

	.dashboard-sidebar,
	.dashboard-card,
	.ghost-input,
	.profile-chip {
		backdrop-filter: blur(20px);
		background: rgba(255, 255, 255, 0.8);
		border: 1px solid rgba(148, 163, 184, 0.18);
		box-shadow: 0 16px 40px rgba(15, 23, 42, 0.08);
	}

	:global(.dark) .dashboard-sidebar,
	:global(.dark) .dashboard-card,
	:global(.dark) .ghost-input,
	:global(.dark) .profile-chip {
		background: rgba(15, 23, 42, 0.76);
		border-color: rgba(148, 163, 184, 0.12);
		box-shadow: 0 20px 50px rgba(2, 6, 23, 0.38);
	}

	.dashboard-sidebar {
		position: sticky;
		top: 1.25rem;
		align-self: start;
		border-radius: 1.6rem;
		padding: 1.15rem;
		display: flex;
		flex-direction: column;
		gap: 1.1rem;
	}

	.brand-block,
	.menu-item,
	.metric-head,
	.section-head,
	.topbar-actions,
	.profile-chip,
	.mini-stat,
	.table-row,
	.hero-actions {
		display: flex;
		align-items: center;
	}

	.brand-block {
		gap: 0.95rem;
		padding: 0.4rem 0.15rem 0.8rem;
	}

	.brand-mark,
	.profile-avatar,
	.module-icon,
	.mini-stat-icon {
		display: grid;
		place-items: center;
		border-radius: 1rem;
	}

	.brand-mark {
		width: 3rem;
		height: 3rem;
		background: linear-gradient(135deg, #14b8a6, #2563eb);
		color: white;
		box-shadow: 0 12px 24px rgba(20, 184, 166, 0.25);
	}

	.brand-eyebrow,
	.topbar-label,
	.section-eyebrow,
	.hero-eyebrow,
	.panel-label {
		font-size: 0.74rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: rgba(71, 85, 105, 0.72);
	}

	:global(.dark) .brand-eyebrow,
	:global(.dark) .topbar-label,
	:global(.dark) .section-eyebrow,
	:global(.dark) .hero-eyebrow,
	:global(.dark) .panel-label {
		color: rgba(148, 163, 184, 0.82);
	}

	.brand-title,
	.topbar-title,
	.section-title,
	.hero-title {
		margin: 0;
		color: rgba(15, 23, 42, 0.96);
	}

	:global(.dark) .brand-title,
	:global(.dark) .topbar-title,
	:global(.dark) .section-title,
	:global(.dark) .hero-title {
		color: rgba(248, 250, 252, 0.96);
	}

	.brand-title {
		font-size: 1.1rem;
		font-weight: 700;
	}

	.menu-block {
		display: grid;
		gap: 0.32rem;
	}

	.menu-item {
		gap: 0.8rem;
		padding: 0.85rem 0.95rem;
		border-radius: 1rem;
		color: rgba(51, 65, 85, 0.82);
		transition: 180ms ease;
	}

	.menu-item:hover,
	.menu-item.is-active {
		background: rgba(20, 184, 166, 0.12);
		color: rgba(15, 23, 42, 0.96);
	}

	:global(.dark) .menu-item {
		color: rgba(203, 213, 225, 0.84);
	}

	:global(.dark) .menu-item:hover,
	:global(.dark) .menu-item.is-active {
		background: rgba(20, 184, 166, 0.16);
		color: rgba(240, 253, 250, 0.98);
	}

	.sidebar-panel {
		margin-top: auto;
		padding: 1rem;
		border-radius: 1.25rem;
		background: linear-gradient(180deg, rgba(20, 184, 166, 0.08), rgba(37, 99, 235, 0.06));
		border: 1px solid rgba(45, 212, 191, 0.16);
	}

	:global(.dark) .sidebar-panel {
		background: linear-gradient(180deg, rgba(20, 184, 166, 0.12), rgba(37, 99, 235, 0.1));
		border-color: rgba(45, 212, 191, 0.14);
	}

	.status-chip {
		margin-top: 0.65rem;
		display: inline-flex;
		align-items: center;
		gap: 0.55rem;
		padding: 0.45rem 0.75rem;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.72);
		color: rgba(15, 23, 42, 0.78);
		font-size: 0.86rem;
	}

	:global(.dark) .status-chip {
		background: rgba(15, 23, 42, 0.6);
		color: rgba(240, 253, 250, 0.88);
	}

	.status-dot {
		width: 0.55rem;
		height: 0.55rem;
		border-radius: 999px;
		background: linear-gradient(135deg, #34d399, #14b8a6);
		box-shadow: 0 0 0 0.3rem rgba(52, 211, 153, 0.18);
	}

	.dashboard-main {
		min-width: 0;
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}

	.dashboard-topbar {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 0.35rem 0.2rem;
	}

	.topbar-title {
		font-size: clamp(1.8rem, 4vw, 2.45rem);
		font-weight: 800;
		letter-spacing: -0.04em;
	}

	.topbar-actions {
		gap: 0.75rem;
		flex-wrap: wrap;
		justify-content: flex-end;
	}

	.ghost-input,
	.profile-chip {
		border-radius: 1rem;
	}

	.ghost-input {
		gap: 0.7rem;
		padding: 0.85rem 1rem;
		min-width: 14rem;
		color: rgba(71, 85, 105, 0.88);
	}

	:global(.dark) .ghost-input {
		color: rgba(203, 213, 225, 0.82);
	}

	.ghost-button,
	.primary-button,
	.secondary-button,
	.ghost-link {
		border: 0;
		border-radius: 1rem;
		transition: 180ms ease;
	}

	.ghost-button {
		width: 3rem;
		height: 3rem;
		display: grid;
		place-items: center;
		background: rgba(255, 255, 255, 0.78);
		border: 1px solid rgba(148, 163, 184, 0.16);
		box-shadow: 0 10px 24px rgba(15, 23, 42, 0.08);
	}

	:global(.dark) .ghost-button {
		background: rgba(15, 23, 42, 0.76);
		border-color: rgba(148, 163, 184, 0.12);
	}

	.profile-chip {
		gap: 0.75rem;
		padding: 0.45rem 0.55rem 0.45rem 0.45rem;
	}

	.profile-avatar {
		width: 2.65rem;
		height: 2.65rem;
		background: linear-gradient(135deg, #0f766e, #2563eb);
		color: white;
		font-weight: 800;
	}

	.profile-name {
		margin: 0;
		font-size: 0.92rem;
		font-weight: 700;
	}

	.profile-role {
		margin: 0;
		font-size: 0.76rem;
		color: rgba(100, 116, 139, 0.82);
	}

	:global(.dark) .profile-role {
		color: rgba(148, 163, 184, 0.82);
	}

	.dashboard-card {
		border-radius: 1.6rem;
		padding: 1.2rem;
	}

	.hero-panel {
		display: flex;
		justify-content: space-between;
		gap: 1.25rem;
		background:
			linear-gradient(135deg, rgba(255, 255, 255, 0.94), rgba(240, 253, 250, 0.9)),
			radial-gradient(circle at right top, rgba(37, 99, 235, 0.1), transparent 15rem);
	}

	:global(.dark) .hero-panel {
		background:
			linear-gradient(135deg, rgba(15, 23, 42, 0.94), rgba(15, 23, 42, 0.86)),
			radial-gradient(circle at right top, rgba(20, 184, 166, 0.14), transparent 16rem);
	}

	.hero-title {
		margin-top: 0.35rem;
		font-size: clamp(1.35rem, 2.8vw, 1.9rem);
		font-weight: 800;
	}

	.hero-copy {
		max-width: 42rem;
		margin: 0.75rem 0 0;
		color: rgba(71, 85, 105, 0.9);
		line-height: 1.75;
	}

	:global(.dark) .hero-copy {
		color: rgba(203, 213, 225, 0.82);
	}

	.hero-actions {
		gap: 0.75rem;
		align-self: flex-start;
	}

	.primary-button,
	.secondary-button,
	.ghost-link {
		padding: 0.8rem 1.1rem;
		font-size: 0.92rem;
		font-weight: 700;
	}

	.primary-button {
		background: linear-gradient(135deg, #14b8a6, #0f766e);
		color: white;
		box-shadow: 0 14px 30px rgba(20, 184, 166, 0.26);
	}

	.secondary-button {
		background: rgba(255, 255, 255, 0.82);
		border: 1px solid rgba(148, 163, 184, 0.18);
		color: rgba(15, 23, 42, 0.82);
	}

	:global(.dark) .secondary-button {
		background: rgba(30, 41, 59, 0.8);
		border-color: rgba(148, 163, 184, 0.14);
		color: rgba(226, 232, 240, 0.88);
	}

	.metrics-grid,
	.module-grid {
		display: grid;
		gap: 1rem;
	}

	.metrics-grid {
		grid-template-columns: repeat(4, minmax(0, 1fr));
	}

	.metric-card {
		display: grid;
		gap: 1rem;
	}

	.metric-head {
		justify-content: space-between;
		color: rgba(71, 85, 105, 0.88);
		font-size: 0.92rem;
	}

	:global(.dark) .metric-head {
		color: rgba(148, 163, 184, 0.84);
	}

	.metric-value {
		height: 3.2rem;
		border-radius: 1rem;
	}

	.metric-foot {
		display: flex;
		align-items: center;
	}

	.content-grid {
		display: grid;
		grid-template-columns: minmax(0, 1.55fr) minmax(320px, 0.75fr);
		gap: 1rem;
	}

	.chart-card,
	.wide-card {
		grid-column: 1 / 2;
	}

	.side-card {
		grid-column: 2 / 3;
		grid-row: 1 / 2;
	}

	.section-head {
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 1rem;
	}

	.section-title {
		margin-top: 0.35rem;
		font-size: 1.08rem;
		font-weight: 750;
	}

	.ghost-link {
		background: rgba(20, 184, 166, 0.1);
		color: rgba(15, 118, 110, 0.9);
	}

	:global(.dark) .ghost-link {
		background: rgba(20, 184, 166, 0.14);
		color: rgba(94, 234, 212, 0.88);
	}

	.chart-placeholder {
		position: relative;
		min-height: 21rem;
		border-radius: 1.25rem;
		padding: 1rem;
		overflow: hidden;
		background:
			linear-gradient(180deg, rgba(248, 250, 252, 0.78), rgba(226, 232, 240, 0.58));
		border: 1px solid rgba(148, 163, 184, 0.16);
	}

	:global(.dark) .chart-placeholder {
		background:
			linear-gradient(180deg, rgba(15, 23, 42, 0.88), rgba(30, 41, 59, 0.6));
		border-color: rgba(148, 163, 184, 0.1);
	}

	.grid-lines {
		position: absolute;
		inset: 0;
		background-image:
			linear-gradient(rgba(148, 163, 184, 0.14) 1px, transparent 1px),
			linear-gradient(90deg, rgba(148, 163, 184, 0.12) 1px, transparent 1px);
		background-size: 100% 20%, 12% 100%;
		mask-image: linear-gradient(180deg, transparent 0%, black 18%, black 82%, transparent 100%);
	}

	.bars {
		position: relative;
		z-index: 1;
		height: 18rem;
		display: grid;
		grid-template-columns: repeat(7, minmax(0, 1fr));
		align-items: end;
		gap: 0.9rem;
	}

	.bar {
		display: block;
		border-radius: 999px 999px 0.9rem 0.9rem;
		background: linear-gradient(180deg, rgba(45, 212, 191, 0.9), rgba(37, 99, 235, 0.92));
		box-shadow: 0 12px 20px rgba(37, 99, 235, 0.12);
	}

	.h-32 { height: 32%; }
	.h-38 { height: 38%; }
	.h-44 { height: 44%; }
