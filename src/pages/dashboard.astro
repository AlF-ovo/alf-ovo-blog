---
import { Icon } from "astro-icon/components";
import Layout from "../layouts/Layout.astro";
import { getDashboardData } from "../utils/dashboard-data";
import { url } from "../utils/url-utils";

type ActivityPoint = {
	label: string;
	publish: number;
	update: number;
	delete: number;
};

type ActivityDataset = {
	label: string;
	points: ActivityPoint[];
};

type ActivityMetric = ActivityPoint & {
	total: number;
	x: number;
	publishY: number;
	updateY: number;
	deleteY: number;
};

type DashboardSearchItem = {
	title: string;
	type: string;
	description: string;
	time?: string;
	url: string;
};

const chartPalette = {
	publish: {
		line: "rgb(59, 130, 246)",
		glow: "rgba(59, 130, 246, 0.34)",
		area: "rgba(59, 130, 246, 0.1)",
	},
	update: {
		line: "rgb(139, 92, 246)",
		glow: "rgba(139, 92, 246, 0.32)",
		area: "rgba(139, 92, 246, 0.09)",
	},
	delete: {
		line: "rgb(250, 204, 21)",
		glow: "rgba(250, 204, 21, 0.28)",
		area: "rgba(250, 204, 21, 0.1)",
	},
};

const { chartDatasets, recentUpdates, dashboardMetrics } =
	await getDashboardData();

const getChartMetrics = (points: ActivityPoint[]): ActivityMetric[] => {
	const maxTotal = Math.max(
		...points.map(
			(point: ActivityPoint) => point.publish + point.update + point.delete,
		),
		1,
	);
	const denominator = Math.max(points.length - 1, 1);

	return points.map((point: ActivityPoint, index: number) => {
		const total = point.publish + point.update + point.delete;
		const x = (index / denominator) * 100;

		return {
			...point,
			total,
			x,
			publishY: 100 - (point.publish / maxTotal) * 100,
			updateY: 100 - (point.update / maxTotal) * 100,
			deleteY: 100 - (point.delete / maxTotal) * 100,
		};
	});
};

const summarizeDataset = (dataset: ActivityDataset) =>
	`本${dataset.label}共发布 ${dataset.points.reduce((sum: number, point: ActivityPoint) => sum + point.publish, 0)} 篇，修改 ${dataset.points.reduce((sum: number, point: ActivityPoint) => sum + point.update, 0)} 次，删除 ${dataset.points.reduce((sum: number, point: ActivityPoint) => sum + point.delete, 0)} 次。`;

const defaultRange = "week";
const defaultDataset = chartDatasets[defaultRange];
const defaultMetrics = getChartMetrics(defaultDataset.points);
const defaultSummary = summarizeDataset(defaultDataset);
const chartDataJson = JSON.stringify(chartDatasets);
const dashboardHints = {
	write: {
		title: "写文章提示",
		content: `1. 先在仓库根目录运行 pnpm new-post your-slug
2. 新文章默认会生成到 src/content/posts/your-slug.md
3. 如果这篇文章还要放封面或插图，更推荐改成目录结构：
   src/content/posts/your-slug/index.md
4. 图片、附件放在同目录下，例如：
   src/content/posts/your-slug/cover.jpeg
   src/content/posts/your-slug/diagram.png
5. 在 frontmatter 里补全 title、published、description、tags、category
6. 如果用了封面，image 写相对路径，例如 ./cover.jpeg
7. 写完后先本地预览，确认路由、封面和正文都正常
8. 之后再统一 commit 和 push 到 main，现有 Pages 工作流会重新构建`,
	},
	upload: {
		title: "本地上传提示",
		content: `1. 这个项目没有在线上传后台，'本地上传' 的正确含义是把文件放进仓库内容目录
2. 单文件文章可以先改成目录文章，再把资源和 index.md 放在一起：
   src/content/posts/your-slug/index.md
   src/content/posts/your-slug/your-image.png
3. 正文里的图片引用尽量使用相对路径，例如：
   ![desc](./your-image.png)
4. 封面图放在同目录时，frontmatter 里的 image 可以写 ./cover.jpeg
5. 不建议把资源随便丢到仓库根目录或 public 里，这样后续整理文章会很乱
6. 如果是附件、脚本或二进制样例，也建议跟文章放同一个 slug 目录
7. 所有文件进了 src/content/posts 后，再本地检查路径是否能正确渲染
8. 确认无误后再统一 commit 和 push`,
	},
};
const dashboardHintsJson = JSON.stringify(dashboardHints);
const dashboardSearchItems: DashboardSearchItem[] = [
	{
		title: dashboardMetrics.lastVisitedPost.title,
		type: "最近修改",
		description: dashboardMetrics.lastVisitedPost.excerpt,
		url: url(dashboardMetrics.lastVisitedPost.url),
	},
	{
		title: dashboardMetrics.latestPost.title,
		type: "最新文章",
		description: dashboardMetrics.latestPost.excerpt,
		url: url(dashboardMetrics.latestPost.url),
	},
	...recentUpdates.slice(0, 3).map((item) => ({
		title: item.title,
		type: "最近修改",
		description: item.description,
		time: item.time,
		url: url(item.url),
	})),
];
const dashboardSearchJson = JSON.stringify(dashboardSearchItems);
---

<Layout title="Dashboard" description="Dashboard UI example">
	<div class="dashboard-shell" data-sidebar-collapsed="false">
		<aside class="dashboard-sidebar">
			<div class="brand-block">
				<div class="brand-copy-wrap">
					<div class="brand-mark">
						<Icon name="fa6-solid:gauge-high" class="text-[1.35rem]" />
					</div>
					<div class="brand-copy">
						<p class="brand-eyebrow">Example</p>
						<h1 class="brand-title">Dashboard</h1>
					</div>
				</div>
				<button
					class="sidebar-toggle"
					type="button"
					data-sidebar-toggle
					aria-expanded="true"
					aria-label="收起侧边栏"
				>
					<span data-sidebar-toggle-icon>&lt;&lt;</span>
				</button>
			</div>

			<nav class="menu-block">
				<a class="menu-item is-active" href="#overview">
					<Icon name="fa6-solid:table-columns" />
					<span>仪表盘</span>
				</a>
				<a class="menu-item" href="#workspace">
					<Icon name="fa6-solid:border-all" />
					<span>工作区</span>
				</a>
				<a class="menu-item" href={url("/")}>
					<Icon name="fa6-solid:house" />
					<span>主页</span>
				</a>
			</nav>

			<div class="sidebar-panel">
				<p class="panel-label">当前状态</p>
				<div class="status-chip">
					<span class="status-dot"></span>
					<span>占位模式</span>
				</div>
				<div class="stack-skeleton">
					<div class="skeleton-line w-100"></div>
					<div class="skeleton-line w-72"></div>
					<div class="skeleton-line w-56"></div>
				</div>
			</div>
		</aside>

		<div class="dashboard-main">
			<header class="dashboard-topbar">
				<div>
					<p class="topbar-label">AIXJ style example</p>
					<h2 class="topbar-title">AlF-0v0-blog</h2>
				</div>
				<div class="topbar-actions">
					<div class="ghost-input dashboard-search" data-dashboard-search>
						<Icon name="fa6-solid:magnifying-glass" />
						<input
							class="ghost-search-input"
							type="search"
							placeholder="搜索"
							aria-label="搜索"
							autocomplete="off"
							data-dashboard-search-input
						/>
						<div class="search-results" data-dashboard-search-results hidden>
							<div class="search-results-list" data-dashboard-search-list></div>
							<p class="search-empty" data-dashboard-search-empty hidden>没有匹配到示例数据</p>
						</div>
					</div>
					<button class="ghost-button" type="button">
						<Icon name="fa6-solid:bell" />
					</button>
					<div class="profile-chip">
						<div class="profile-avatar">A</div>
						<div>
							<p class="profile-name">AlF</p>
							<p class="profile-role">Dashboard Preview</p>
						</div>
					</div>
				</div>
			</header>

			<section id="overview" class="hero-panel dashboard-card">
				<div>
					<p class="hero-eyebrow">Overview</p>
					<h3 class="hero-title hero-title-typing" data-dashboard-greeting aria-live="polite">
						<span data-dashboard-greeting-text>欢迎回来，AlF！</span>
						<span class="hero-title-cursor" aria-hidden="true">|</span>
					</h3>
					<p class="hero-copy" data-dashboard-intro>
						AlF's blog is a quiet archive of pwn notes, CTF writeups, and scattered reflections, a place where exploit chains, debugging traces, and passing thoughts are written down before they fade into the background.
					</p>
				</div>
				<div class="hero-actions">
					<button class="primary-button" type="button" data-dashboard-hint-trigger="write">写文章</button>
					<button class="secondary-button" type="button" data-dashboard-hint-trigger="upload">本地上传</button>
				</div>
			</section>

			<div class="dashboard-hint-overlay" data-dashboard-hint-overlay hidden>
				<section
					class="dashboard-hint-card"
					data-dashboard-hint-root
					role="dialog"
					aria-modal="true"
					aria-labelledby="dashboard-hint-title"
				>
					<div class="dashboard-hint-head">
						<div>
							<p class="dashboard-hint-eyebrow">Hint</p>
							<h3 class="dashboard-hint-title" id="dashboard-hint-title" data-dashboard-hint-title>
								操作提示
							</h3>
						</div>
						<button
							class="dashboard-hint-close"
							type="button"
							aria-label="关闭提示"
							data-dashboard-hint-close
						>
							<Icon name="fa6-solid:xmark" />
						</button>
					</div>
					<textarea
						class="dashboard-hint-textbox"
						data-dashboard-hint-content
						readonly
						spellcheck="false"
					></textarea>
				</section>
			</div>

			<section class="metrics-grid">
				<article class="metric-card dashboard-card">
					<div class="metric-head">
						<span>新修改文章</span>
						<Icon name="fa6-solid:arrow-trend-up" />
					</div>
					<div class="metric-value metric-value-rich">
						<p class="metric-primary">{dashboardMetrics.updatedPosts} 篇</p>
						<p class="metric-secondary">累计新增与修订 {dashboardMetrics.updatedWords.toLocaleString("zh-CN")} 字</p>
					</div>
					<div class="metric-foot">
						<div class="metric-badges">
							<span class="metric-badge">发布后更新</span>
							<span class="metric-badge is-accent">{dashboardMetrics.updatedWords.toLocaleString("zh-CN")} 字</span>
						</div>
					</div>
				</article>
				<article class="metric-card dashboard-card">
					<div class="metric-head">
						<span>分类概览</span>
						<Icon name="fa6-solid:chart-column" />
					</div>
					<div class="metric-value metric-value-rich">
						<p class="metric-primary">{dashboardMetrics.totalUsage}</p>
						<p class="metric-secondary">{dashboardMetrics.totalUsageNote}</p>
					</div>
					<div class="metric-foot">
						<p class="metric-footnote">数据来自首页“分类”组件对应的文章集合</p>
					</div>
				</article>
				<article class="metric-card dashboard-card">
					<div class="metric-head">
						<span>最近修改文章</span>
						<Icon name="fa6-solid:rocket" />
					</div>
					<div class="metric-value metric-article">
						<p class="metric-article-title">{dashboardMetrics.lastVisitedPost.title}</p>
						<p class="metric-article-excerpt">{dashboardMetrics.lastVisitedPost.excerpt}</p>
					</div>
					<div class="metric-foot">
						<a class="metric-footnote-link" href={dashboardMetrics.lastVisitedPost.url}>
							点击可进入文章详情
						</a>
					</div>
				</article>
				<article class="metric-card dashboard-card">
					<div class="metric-head">
						<span>最新文章</span>
						<Icon name="fa6-solid:bolt" />
					</div>
					<div class="metric-value metric-article">
						<p class="metric-article-title">{dashboardMetrics.latestPost.title}</p>
						<p class="metric-article-excerpt">{dashboardMetrics.latestPost.excerpt}</p>
					</div>
					<div class="metric-foot">
						<a class="metric-footnote-link" href={dashboardMetrics.latestPost.url}>
							点击可进入文章详情
						</a>
					</div>
				</article>
			</section>

			<section class="content-grid">
				<article id="workspace" class="dashboard-card chart-card">
					<div class="section-head">
						<div>
							<p class="section-eyebrow">Workspace</p>
							<h3 class="section-title">近日Blog发布、修改及删除情况</h3>
						</div>
						<div
							class="range-switch"
							data-chart-switch
							data-active-index="0"
							role="tablist"
							aria-label="图表时间范围"
						>
							<span class="range-switch-thumb" aria-hidden="true"></span>
							<button class="range-switch-button is-active" type="button" data-range-option="week" role="tab" aria-selected="true">
								近7日
							</button>
							<button class="range-switch-button" type="button" data-range-option="month" role="tab" aria-selected="false">
								近1个月
							</button>
							<button class="range-switch-button" type="button" data-range-option="year" role="tab" aria-selected="false">
								近1年
							</button>
						</div>
					</div>
					<div class="chart-meta">
						<div class="chart-legend" aria-label="图例">
							<span class="legend-item">
								<span class="legend-swatch is-publish"></span>
								<span>发布</span>
							</span>
							<span class="legend-item">
								<span class="legend-swatch is-update"></span>
								<span>修改</span>
							</span>
							<span class="legend-item">
								<span class="legend-swatch is-delete"></span>
								<span>删除</span>
							</span>
						</div>
						<p class="chart-summary" data-chart-summary>{defaultSummary}</p>
					</div>
					<div class="chart-placeholder" data-chart-root data-default-range={defaultRange}>
						<div class="grid-lines"></div>
						<div class="chart-scroll">
							<div class="chart-stage" data-chart-stage>
								<svg
									class="chart-svg"
									data-chart-svg
									viewBox="0 0 100 100"
									preserveAspectRatio="none"
									aria-label="Blog 活动趋势图"
								>
									<path
										class="chart-area is-publish"
										fill={chartPalette.publish.area}
										stroke="none"
										d={`M 0 100 ${defaultMetrics.map((point) => `L ${point.x} ${point.publishY}`).join(" ")} L 100 100 Z`}
									></path>
									<path
										class="chart-area is-update"
										fill={chartPalette.update.area}
										stroke="none"
										d={`M 0 100 ${defaultMetrics.map((point) => `L ${point.x} ${point.updateY}`).join(" ")} L 100 100 Z`}
									></path>
									<path
										class="chart-area is-delete"
										fill={chartPalette.delete.area}
										stroke="none"
										d={`M 0 100 ${defaultMetrics.map((point) => `L ${point.x} ${point.deleteY}`).join(" ")} L 100 100 Z`}
									></path>
									<path
										class="chart-line is-publish"
										fill="none"
										stroke={chartPalette.publish.line}
										stroke-width="2.1"
										stroke-linecap="round"
										stroke-linejoin="round"
										d={`M ${defaultMetrics.map((point) => `${point.x} ${point.publishY}`).join(" L ")}`}
									></path>
										class="chart-line is-update"
										fill="none"
										stroke={chartPalette.update.line}
										stroke-width="2.1"
										stroke-linecap="round"
										stroke-linejoin="round"
										d={`M ${defaultMetrics.map((point) => `${point.x} ${point.updateY}`).join(" L ")}`}
									></path>
										class="chart-line is-delete"
										fill="none"
										stroke={chartPalette.delete.line}
										stroke-width="2.1"
										stroke-linecap="round"
										stroke-linejoin="round"
										d={`M ${defaultMetrics.map((point) => `${point.x} ${point.deleteY}`).join(" L ")}`}
									></path>
								</svg>
								<div
									class="chart-labels"
									data-chart-labels
									style={`grid-template-columns: repeat(${defaultMetrics.length}, minmax(${defaultMetrics.length > 12 ? "1.9rem" : "3.2rem"}, 1fr));`}
								>
									{
										defaultMetrics.map((point) => (
											<span class="chart-label">{point.label}</span>
										))
									}
								</div>
							</div>
						</div>
					</div>
				</article>

				<article id="settings" class="dashboard-card wide-card">
					<div class="section-head">
						<div>
							<p class="section-eyebrow">Settings</p>
							<h3 class="section-title">模块占位区</h3>
						</div>
					</div>
					<div class="module-grid">
						<div class="module-card">
							<div class="module-icon">
								<Icon name="fa6-solid:key" />
							</div>
							<div class="skeleton-line w-58"></div>
							<div class="skeleton-line w-82"></div>
						</div>
						<div class="module-card">
							<div class="module-icon">
								<Icon name="fa6-solid:shield-halved" />
							</div>
							<div class="skeleton-line w-62"></div>
							<div class="skeleton-line w-76"></div>
						</div>
						<div class="module-card">
							<div class="module-icon">
								<Icon name="fa6-solid:share-nodes" />
							</div>
							<div class="skeleton-line w-54"></div>
							<div class="skeleton-line w-72"></div>
						</div>
					</div>
				</article>
			</section>
		</div>
	</div>
</Layout>

<script id="blog-chart-data" type="application/json" is:inline set:html={chartDataJson}></script>
<script id="dashboard-hint-data" type="application/json" is:inline set:html={dashboardHintsJson}></script>
<script id="dashboard-search-data" type="application/json" is:inline set:html={dashboardSearchJson}></script>
<script is:inline>
	const chartPalette = {
		publish: {
			line: "rgb(59, 130, 246)",
			glow: "rgba(59, 130, 246, 0.34)",
			area: "rgba(59, 130, 246, 0.1)",
		},
		update: {
			line: "rgb(139, 92, 246)",
			glow: "rgba(139, 92, 246, 0.32)",
			area: "rgba(139, 92, 246, 0.09)",
		},
		delete: {
			line: "rgb(250, 204, 21)",
			glow: "rgba(250, 204, 21, 0.28)",
			area: "rgba(250, 204, 21, 0.1)",
		},
	};

	const initDashboardSearch = () => {
		const searchRoot = document.querySelector("[data-dashboard-search]");
		const input = document.querySelector("[data-dashboard-search-input]");
		const results = document.querySelector("[data-dashboard-search-results]");
		const listNode = document.querySelector("[data-dashboard-search-list]");
		const emptyNode = document.querySelector("[data-dashboard-search-empty]");
		const dataNode = document.querySelector("#dashboard-search-data");

		if (!searchRoot || !input || !results || !listNode || !emptyNode || !dataNode) {
			return;
		}

		const items = JSON.parse(dataNode.textContent || "[]");
		const normalize = (value) => String(value || "").trim().toLowerCase();
		const renderResults = (query = "") => {
			const keyword = normalize(query);
			const matchedItems = items
				.filter((item) => {
					if (!keyword) {
						return true;
					}

					return [item.title, item.type, item.description, item.time]
						.some((field) => normalize(field).includes(keyword));
				})
				.slice(0, 5);

			listNode.replaceChildren();

			if (matchedItems.length === 0) {
				emptyNode.hidden = false;
				results.hidden = false;
				return;
			}

			emptyNode.hidden = true;
			matchedItems.forEach((item) => {
				const link = document.createElement("a");
				link.className = "search-result-item";
				link.href = item.url;

				const meta = document.createElement("div");
				meta.className = "search-result-meta";

				const badge = document.createElement("span");
				badge.className = "search-result-badge";
				badge.textContent = item.type;

				if (item.time) {
					const time = document.createElement("time");
					time.className = "search-result-time";
					time.dateTime = item.time;
					time.textContent = item.time;
					meta.append(badge, time);
				} else {
					meta.append(badge);
				}

				const title = document.createElement("p");
				title.className = "search-result-title";
				title.textContent = item.title;

				const description = document.createElement("p");
				description.className = "search-result-description";
				description.textContent = item.description;

				link.append(meta, title, description);
				listNode.append(link);
			});

			results.hidden = false;
		};

		if (searchRoot.dataset.bound === "true") {
			return;
		}

		input.addEventListener("focus", () => {
			renderResults(input.value);
		});

		input.addEventListener("input", () => {
			renderResults(input.value);
		});

		document.addEventListener("click", (event) => {
			if (!searchRoot.contains(event.target)) {
				results.hidden = true;
			}
		});

		input.addEventListener("keydown", (event) => {
			if (event.key === "Escape") {
				results.hidden = true;
				input.blur();
			}
		});

		searchRoot.dataset.bound = "true";
	};

	const setDashboardGreeting = () => {
		const greetingNode = document.querySelector("[data-dashboard-greeting]");
		const greetingTextNode = greetingNode?.querySelector("[data-dashboard-greeting-text]");

		if (!greetingNode || !greetingTextNode) {
			return;
		}

		const greetings = [
			"欢迎回来，AlF！",
			"你回来了，AlF。",
			"好的，AlF，让我们继续。",
		];
		const storageKey = "alf-dashboard-last-greeting";
		let lastGreeting = "";

		try {
			lastGreeting = window.localStorage.getItem(storageKey) || "";
		} catch (_error) {
			lastGreeting = "";
		}

		const availableGreetings =
			greetings.length > 1 ? greetings.filter((greeting) => greeting !== lastGreeting) : greetings;
		const nextGreeting =
			availableGreetings[Math.floor(Math.random() * availableGreetings.length)] || greetings[0];

		try {
			window.localStorage.setItem(storageKey, nextGreeting);
		} catch (_error) {
			// Ignore storage write failures and keep the greeting randomized for this visit.
		}

		const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
		const typingRunId = `${Date.now()}-${Math.random()}`;

		greetingNode.dataset.typingRun = typingRunId;
		greetingNode.dataset.typing = "true";
		greetingTextNode.textContent = "";

		if (prefersReducedMotion) {
			greetingTextNode.textContent = nextGreeting;
			greetingNode.dataset.typing = "false";
			return;
		}

		const typeNextCharacter = (index = 0) => {
			if (greetingNode.dataset.typingRun !== typingRunId) {
				return;
			}

			greetingTextNode.textContent = nextGreeting.slice(0, index + 1);

			if (index + 1 >= nextGreeting.length) {
				greetingNode.dataset.typing = "false";
				return;
			}

			window.setTimeout(() => typeNextCharacter(index + 1), 85);
		};

		typeNextCharacter();
	};

	const setDashboardIntro = () => {
		const introNode = document.querySelector("[data-dashboard-intro]");

		if (!introNode) {
			return;
		}

		const intros = [
			"AlF's blog is a quiet archive of pwn notes, CTF writeups, and scattered reflections, a place where exploit chains, debugging traces, and passing thoughts are written down before they fade into the background.",
			"AlF's blog gathers CTF-pwn articles, exploit records, and occasional essays into one slow-growing corner of the web, where technical details and personal observations are kept with equal care.",
			"AlF's blog is a personal space for pwn writeups, challenge breakdowns, and late-night miscellany, shaped by curiosity, repetition, and the habit of turning difficult moments into something worth recording.",
			"AlF's blog keeps track of CTF-pwn practice, exploit experiments, and fragments of everyday thought, preserving both the precision of technical work and the quieter mood that often surrounds it.",
			"AlF's blog is written between terminals, notes, and passing hours, collecting pwn-related articles, CTF records, and occasional reflections into a small archive of things solved, things attempted, and things remembered.",
			"AlF's blog is a place for exploit writeups, binary notes, CTF-pwn practice, and a few words about everything in between, where technical effort and personal voice are allowed to stay on the same page.",
		];

		const nextIntro = intros[Math.floor(Math.random() * intros.length)];
		introNode.textContent = nextIntro;
	};

	const initSidebarToggle = () => {
		const shell = document.querySelector(".dashboard-shell");
		const toggleButton = document.querySelector("[data-sidebar-toggle]");
		const toggleIcon = document.querySelector("[data-sidebar-toggle-icon]");

		if (!shell || !toggleButton || !toggleIcon) {
			return;
		}

		const storageKey = "alf-dashboard-sidebar-collapsed";
		const applySidebarState = (collapsed) => {
			shell.dataset.sidebarCollapsed = String(collapsed);
			toggleButton.setAttribute("aria-expanded", String(!collapsed));
			toggleButton.setAttribute(
				"aria-label",
				collapsed ? "展开侧边栏" : "收起侧边栏",
			);
			toggleIcon.textContent = collapsed ? ">>" : "<<";
		};

		const savedState = window.localStorage.getItem(storageKey);
		applySidebarState(savedState === "true");

		if (toggleButton.dataset.bound === "true") {
			return;
		}

		toggleButton.addEventListener("click", () => {
			const collapsed = shell.dataset.sidebarCollapsed === "true";
			const nextState = !collapsed;

			applySidebarState(nextState);
			window.localStorage.setItem(storageKey, String(nextState));
		});

		toggleButton.dataset.bound = "true";
	};

	const initDashboardHints = () => {
		const overlay = document.querySelector("[data-dashboard-hint-overlay]");
		const modal = document.querySelector("[data-dashboard-hint-root]");
		const titleNode = document.querySelector("[data-dashboard-hint-title]");
		const contentNode = document.querySelector("[data-dashboard-hint-content]");
		const closeButton = document.querySelector("[data-dashboard-hint-close]");
		const dataNode = document.querySelector("#dashboard-hint-data");
		const triggerButtons = Array.from(
			document.querySelectorAll("[data-dashboard-hint-trigger]"),
		);

		if (
			!overlay ||
			!modal ||
			!titleNode ||
			!contentNode ||
			!closeButton ||
			!dataNode ||
			triggerButtons.length === 0
		) {
			return;
		}

		const hints = JSON.parse(dataNode.textContent || "{}");
		const openHint = (hintKey) => {
			const hint = hints[hintKey];

			if (!hint) {
				return;
			}

			titleNode.textContent = hint.title;
			contentNode.value = hint.content;
			overlay.hidden = false;
			document.body.style.overflow = "hidden";
			window.requestAnimationFrame(() => {
				contentNode.focus();
				contentNode.setSelectionRange(0, 0);
			});
		};

		const closeHint = () => {
			overlay.hidden = true;
			document.body.style.overflow = "";
		};

		if (modal.dataset.bound === "true") {
			return;
		}

		triggerButtons.forEach((button) => {
			button.addEventListener("click", () => {
				openHint(button.dataset.dashboardHintTrigger || "");
			});
		});

		closeButton.addEventListener("click", closeHint);
		overlay.addEventListener("click", (event) => {
			if (event.target === overlay) {
				closeHint();
			}
		});
		document.addEventListener("keydown", (event) => {
			if (event.key === "Escape" && !overlay.hidden) {
				closeHint();
			}
		});

		modal.dataset.bound = "true";
	};

	const initDashboardChart = () => {
		const notifyDashboardReady = () => {
			document.dispatchEvent(
				new CustomEvent("alf:dashboard-ready", {
					detail: { path: window.location.pathname },
				}),
			);
		};

		initSidebarToggle();
		initDashboardHints();
		initDashboardSearch();
		setDashboardGreeting();
		setDashboardIntro();

		const chartRoot = document.querySelector("[data-chart-root]");
		const chartSvg = document.querySelector("[data-chart-svg]");
		const chartLabels = document.querySelector("[data-chart-labels]");
		const chartStage = document.querySelector("[data-chart-stage]");
		const switchRoot = document.querySelector("[data-chart-switch]");
		const summary = document.querySelector("[data-chart-summary]");
		const dataNode = document.querySelector("#blog-chart-data");

		if (
			!chartRoot ||
			!chartSvg ||
			!chartLabels ||
			!chartStage ||
			!switchRoot ||
			!summary ||
			!dataNode
		) {
			notifyDashboardReady();
			return;
		}

		const datasets = JSON.parse(dataNode.textContent || "{}");
		const buttons = Array.from(switchRoot.querySelectorAll("[data-range-option]"));

		const getMetrics = (points) => {
			const maxTotal = Math.max(
				...points.map((point) => point.publish + point.update + point.delete),
				1,
			);
			const denominator = Math.max(points.length - 1, 1);

			return points.map((point, index) => ({
				...point,
				x: (index / denominator) * 100,
				publishY: 100 - (point.publish / maxTotal) * 100,
				updateY: 100 - (point.update / maxTotal) * 100,
				deleteY: 100 - (point.delete / maxTotal) * 100,
			}));
		};

		const buildLinePath = (metrics, key) =>
			`M ${metrics.map((point) => `${point.x} ${point[key]}`).join(" L ")}`;

		const buildAreaPath = (metrics, key) =>
			`M 0 100 ${metrics.map((point) => `L ${point.x} ${point[key]}`).join(" ")} L 100 100 Z`;

		const renderChart = (rangeKey) => {
			const dataset = datasets[rangeKey];

			if (!dataset) {
				return;
			}

			const metrics = getMetrics(dataset.points);
			const minColumnWidth = metrics.length > 20 ? "1.85rem" : metrics.length > 12 ? "2.2rem" : "3.2rem";
			const publishTotal = dataset.points.reduce((sum, point) => sum + point.publish, 0);
			const updateTotal = dataset.points.reduce((sum, point) => sum + point.update, 0);
			const deleteTotal = dataset.points.reduce((sum, point) => sum + point.delete, 0);

			chartStage.style.setProperty("--chart-column-width", minColumnWidth);
			chartStage.style.setProperty("--chart-point-count", String(metrics.length));
			chartSvg.innerHTML = `
				<path class="chart-area is-publish" fill="${chartPalette.publish.area}" stroke="none" d="${buildAreaPath(metrics, "publishY")}"></path>
				<path class="chart-area is-update" fill="${chartPalette.update.area}" stroke="none" d="${buildAreaPath(metrics, "updateY")}"></path>
				<path class="chart-area is-delete" fill="${chartPalette.delete.area}" stroke="none" d="${buildAreaPath(metrics, "deleteY")}"></path>
				<path class="chart-line is-publish" fill="none" stroke="${chartPalette.publish.line}" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round" d="${buildLinePath(metrics, "publishY")}"></path>
				<path class="chart-line is-update" fill="none" stroke="${chartPalette.update.line}" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round" d="${buildLinePath(metrics, "updateY")}"></path>
				<path class="chart-line is-delete" fill="none" stroke="${chartPalette.delete.line}" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round" d="${buildLinePath(metrics, "deleteY")}"></path>
			`;
			chartLabels.style.gridTemplateColumns = `repeat(${metrics.length}, minmax(${minColumnWidth}, 1fr))`;
			chartLabels.innerHTML = metrics
				.map((point) => `<span class="chart-label">${point.label}</span>`)
				.join("");

			summary.textContent = `本${dataset.label}共发布 ${publishTotal} 篇，修改 ${updateTotal} 次，删除 ${deleteTotal} 次。`;
			chartRoot.dataset.range = rangeKey;
			switchRoot.dataset.activeIndex = String(buttons.findIndex((button) => button.dataset.rangeOption === rangeKey));

			buttons.forEach((button) => {
				const isActive = button.dataset.rangeOption === rangeKey;
				button.classList.toggle("is-active", isActive);
				button.setAttribute("aria-selected", String(isActive));
			});
		};

		if (chartRoot.dataset.initialized === "true") {
			renderChart(chartRoot.dataset.range || chartRoot.dataset.defaultRange || "week");
			notifyDashboardReady();
			return;
		}

		buttons.forEach((button) => {
			button.addEventListener("click", () => {
				renderChart(button.dataset.rangeOption || "week");
			});
		});

		chartRoot.dataset.initialized = "true";
		renderChart(chartRoot.dataset.defaultRange || "week");
		notifyDashboardReady();
	};

	document.addEventListener("astro:page-load", initDashboardChart);
	document.addEventListener("DOMContentLoaded", initDashboardChart);
</script>

