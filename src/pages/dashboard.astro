---
import DashboardSurface from "@components/dashboard/DashboardSurface.astro";
import Layout from "../layouts/Layout.astro";
import { getDashboardData } from "../utils/dashboard-data";

const { chartDatasets, recentUpdates, dashboardMetrics } = await getDashboardData();
---

<Layout title="Dashboard" description="AlF 鍗氬鍐呭鎬昏">
	<DashboardSurface
		chartDatasets={chartDatasets}
		recentUpdates={recentUpdates}
		dashboardMetrics={dashboardMetrics}
	/>
</Layout>
