---
import DashboardActivityPanel from "@components/dashboard/DashboardActivityPanel.astro";
import DashboardGuidePanel from "@components/dashboard/DashboardGuidePanel.astro";
import DashboardHero from "@components/dashboard/DashboardHero.astro";
import DashboardMetricsGrid from "@components/dashboard/DashboardMetricsGrid.astro";
import DashboardRecentUpdates from "@components/dashboard/DashboardRecentUpdates.astro";
import DashboardSidebar from "@components/dashboard/DashboardSidebar.astro";
import DashboardTopbar from "@components/dashboard/DashboardTopbar.astro";
import Layout from "../layouts/Layout.astro";
import { profileConfig } from "../config";
import { getDashboardData } from "../utils/dashboard-data";

type ActivityPoint = {
	label: string;
	publish: number;
	update: number;
	delete: number;
};

type ActivityMetric = ActivityPoint & {
	total: number;
	x: number;
	publishY: number;
	updateY: number;
	deleteY: number;
};

const chartPalette = {
	publish: {
		line: "rgb(59, 130, 246)",
		area: "rgba(59, 130, 246, 0.12)",
	},
	update: {
		line: "rgb(14, 165, 233)",
		area: "rgba(14, 165, 233, 0.12)",
	},
	delete: {
		line: "rgb(245, 158, 11)",
		area: "rgba(245, 158, 11, 0.12)",
	},
};

const { chartDatasets, recentUpdates, dashboardMetrics } = await getDashboardData();

const getChartMetrics = (points: ActivityPoint[]): ActivityMetric[] => {
	const maxTotal = Math.max(
		...points.map((point) => point.publish + point.update + point.delete),
		1,
	);
	const denominator = Math.max(points.length - 1, 1);

	return points.map((point, index) => ({
		...point,
		total: point.publish + point.update + point.delete,
		x: (index / denominator) * 100,
		publishY: 100 - (point.publish / maxTotal) * 100,
		updateY: 100 - (point.update / maxTotal) * 100,
		deleteY: 100 - (point.delete / maxTotal) * 100,
	}));
};

const summarizeDataset = (dataset: (typeof chartDatasets)["week"]) =>
	`${dataset.label}共发布 ${dataset.points.reduce((sum, point) => sum + point.publish, 0)} 条，修改 ${dataset.points.reduce((sum, point) => sum + point.update, 0)} 次，删除 ${dataset.points.reduce((sum, point) => sum + point.delete, 0)} 次。`;

const defaultRange = "week";
const defaultDataset = chartDatasets[defaultRange];
const defaultMetrics = getChartMetrics(defaultDataset.points);
const defaultSummary = summarizeDataset(defaultDataset);

const dashboardHints = {
	write: {
		title: "新建内容建议",
		content: `1. 长文默认使用：pnpm new-post -- your-slug
2. 短笔记使用：pnpm new-post -- your-note --type note
3. 新内容会默认生成目录式结构：
   src/content/posts/your-slug/index.md
   或
   src/content/notes/your-note/index.md
4. 图片、exp、附件尽量和 index.md 放在同一个 slug 目录
5. frontmatter 里优先补全 title、description、tags、category、categoryPath、series
6. 发版前至少跑一次 pnpm build，确认路径、图片和分类都正常`,
	},
	organize: {
		title: "内容组织原则",
		content: `1. category 只放一级分类，例如 ctfshow、随笔、站点
2. categoryPath 用来表达层级路径，例如 ["ctfshow", "test_your_nc"]
3. series 用来聚合同一组连续内容，例如 ctfshow-test_your_nc
4. 长文走 posts，短记录走 notes，避免首页文章流越来越杂
5. 新内容优先用目录式结构，别再把资源随手丢到 public 根下
6. 如果内容需要长期维护，优先保证标题、摘要和分类可搜索`,
	},
};

const dashboardSearchItems = [
	{
		title: dashboardMetrics.lastUpdatedEntry.title,
		type: `最近更新 · ${dashboardMetrics.lastUpdatedEntry.kindLabel}`,
		description: dashboardMetrics.lastUpdatedEntry.excerpt,
		url: dashboardMetrics.lastUpdatedEntry.url,
	},
	{
		title: dashboardMetrics.latestPost.title,
		type: `最新文章 · ${dashboardMetrics.latestPost.kindLabel}`,
		description: dashboardMetrics.latestPost.excerpt,
		url: dashboardMetrics.latestPost.url,
	},
	{
		title: dashboardMetrics.latestNote.title,
		type: `最新笔记 · ${dashboardMetrics.latestNote.kindLabel}`,
		description: dashboardMetrics.latestNote.excerpt,
		url: dashboardMetrics.latestNote.url,
	},
	...recentUpdates.map((item) => ({
		title: item.title,
		type: `最近更新 · ${item.kindLabel}`,
		description: item.description,
		time: item.time,
		url: item.url,
	})),
];
---

<Layout title="Dashboard" description="AlF 博客内容总览">
	<div class="dashboard-shell">
		<DashboardSidebar />

		<div class="dashboard-main">
			<DashboardTopbar profileName={profileConfig.name} />
			<DashboardHero
				greeting="这里是博客的内容总览，不再是模板示例。"
				intro="它主要服务于当前这套写作方式：长文进文章流，短记录进札记流；分类负责一级归档，categoryPath 负责层级路径，series 负责系列聚合。"
			/>
			<DashboardMetricsGrid metrics={dashboardMetrics} />

			<div class="dashboard-grid">
				<DashboardActivityPanel
					chartPalette={chartPalette}
					defaultRange={defaultRange}
					defaultMetrics={defaultMetrics}
					defaultSummary={defaultSummary}
				/>
				<DashboardRecentUpdates recentUpdates={recentUpdates} />
				<DashboardGuidePanel />
			</div>
		</div>
	</div>

	<div class="dashboard-hint-overlay" data-dashboard-hint-overlay hidden>
		<section class="dashboard-hint-card" data-dashboard-hint-root role="dialog" aria-modal="true" aria-labelledby="dashboard-hint-title">
			<div class="dashboard-hint-head">
				<div>
					<p class="dashboard-panel-eyebrow">Hint</p>
					<h3 class="dashboard-hint-title" id="dashboard-hint-title" data-dashboard-hint-title>内容提示</h3>
				</div>
				<button class="dashboard-hint-close" type="button" aria-label="关闭提示" data-dashboard-hint-close>
					×
				</button>
			</div>
			<textarea class="dashboard-hint-textbox" data-dashboard-hint-content readonly spellcheck="false"></textarea>
		</section>
	</div>

	<script id="dashboard-chart-data" type="application/json" is:inline set:html={JSON.stringify(chartDatasets)}></script>
	<script id="dashboard-hint-data" type="application/json" is:inline set:html={JSON.stringify(dashboardHints)}></script>
	<script id="dashboard-search-data" type="application/json" is:inline set:html={JSON.stringify(dashboardSearchItems)}></script>

	<script is:inline>
		const chartPalette = {
			publish: { line: "rgb(59, 130, 246)", area: "rgba(59, 130, 246, 0.12)" },
			update: { line: "rgb(14, 165, 233)", area: "rgba(14, 165, 233, 0.12)" },
			delete: { line: "rgb(245, 158, 11)", area: "rgba(245, 158, 11, 0.12)" },
		};

		const buildMetrics = (points) => {
			const maxTotal = Math.max(...points.map((point) => point.publish + point.update + point.delete), 1);
			const denominator = Math.max(points.length - 1, 1);
			return points.map((point, index) => ({
				...point,
				x: (index / denominator) * 100,
				publishY: 100 - (point.publish / maxTotal) * 100,
				updateY: 100 - (point.update / maxTotal) * 100,
				deleteY: 100 - (point.delete / maxTotal) * 100,
			}));
		};

		const buildAreaPath = (metrics, key) => `M 0 100 ${metrics.map((point) => `L ${point.x} ${point[key]}`).join(" ")} L 100 100 Z`;
		const buildLinePath = (metrics, key) => `M ${metrics.map((point) => `${point.x} ${point[key]}`).join(" L ")}`;
		const summarizeDataset = (dataset) =>
			`${dataset.label}共发布 ${dataset.points.reduce((sum, point) => sum + point.publish, 0)} 条，修改 ${dataset.points.reduce((sum, point) => sum + point.update, 0)} 次，删除 ${dataset.points.reduce((sum, point) => sum + point.delete, 0)} 次。`;

		const initDashboardSearch = () => {
			const root = document.querySelector("[data-dashboard-search]");
			const input = document.querySelector("[data-dashboard-search-input]");
			const results = document.querySelector("[data-dashboard-search-results]");
			const listNode = document.querySelector("[data-dashboard-search-list]");
			const emptyNode = document.querySelector("[data-dashboard-search-empty]");
			const dataNode = document.querySelector("#dashboard-search-data");

			if (!root || !input || !results || !listNode || !emptyNode || !dataNode) {
				return;
			}

			const items = JSON.parse(dataNode.textContent || "[]");
			const normalize = (value) => String(value || "").trim().toLowerCase();

			const renderResults = (query = "") => {
				const keyword = normalize(query);
				const matchedItems = items
					.filter((item) => {
						if (!keyword) {
							return true;
						}

						return [item.title, item.type, item.description, item.time].some((field) =>
							normalize(field).includes(keyword),
						);
					})
					.slice(0, 5);

				listNode.replaceChildren();

				if (matchedItems.length === 0) {
					emptyNode.hidden = false;
					results.hidden = false;
					return;
				}

				emptyNode.hidden = true;
				matchedItems.forEach((item) => {
					const link = document.createElement("a");
					link.className = "dashboard-search-result";
					link.href = item.url;
					link.innerHTML = `
						<div class="dashboard-search-result-meta">${item.type}${item.time ? ` · ${item.time}` : ""}</div>
						<div class="dashboard-search-result-title">${item.title}</div>
						<div class="dashboard-search-result-copy">${item.description}</div>
					`;
					listNode.appendChild(link);
				});

				results.hidden = false;
			};

			input.onfocus = () => renderResults(input.value);
			input.oninput = () => renderResults(input.value);
			document.addEventListener("click", (event) => {
				if (!root.contains(event.target)) {
					results.hidden = true;
				}
			});
		};

		const initDashboardHints = () => {
			const dataNode = document.querySelector("#dashboard-hint-data");
			const overlay = document.querySelector("[data-dashboard-hint-overlay]");
			const titleNode = document.querySelector("[data-dashboard-hint-title]");
			const contentNode = document.querySelector("[data-dashboard-hint-content]");
			const closeButton = document.querySelector("[data-dashboard-hint-close]");
			const triggers = document.querySelectorAll("[data-dashboard-hint-trigger]");

			if (!dataNode || !overlay || !titleNode || !contentNode || !closeButton || triggers.length === 0) {
				return;
			}

			const hints = JSON.parse(dataNode.textContent || "{}");

			const openHint = (key) => {
				const hint = hints[key];
				if (!hint) {
					return;
				}

				titleNode.textContent = hint.title;
				contentNode.value = hint.content;
				overlay.hidden = false;
			};

			const closeHint = () => {
				overlay.hidden = true;
			};

			triggers.forEach((trigger) => {
				trigger.onclick = () => openHint(trigger.dataset.dashboardHintTrigger);
			});

			closeButton.onclick = closeHint;
			overlay.onclick = (event) => {
				if (event.target === overlay) {
					closeHint();
				}
			};
		};

		const initDashboardChart = () => {
			const dataNode = document.querySelector("#dashboard-chart-data");
			const chartRoot = document.querySelector("[data-chart-root]");
			const switchRoot = document.querySelector("[data-chart-switch]");
			const summaryNode = document.querySelector("[data-chart-summary]");
			const svg = document.querySelector("[data-chart-svg]");
			const labels = document.querySelector("[data-chart-labels]");
			const stage = document.querySelector("[data-chart-stage]");

			if (!dataNode || !chartRoot || !switchRoot || !summaryNode || !svg || !labels || !stage) {
				return;
			}

			const datasets = JSON.parse(dataNode.textContent || "{}");
			const [publishArea, updateArea, deleteArea, publishLine, updateLine, deleteLine] = svg.querySelectorAll("path");

			const renderChart = (range) => {
				const dataset = datasets[range];
				if (!dataset) {
					return;
				}

				const metrics = buildMetrics(dataset.points);
				switchRoot.dataset.activeIndex = range === "week" ? "0" : range === "month" ? "1" : "2";
				switchRoot.querySelectorAll("[data-range-option]").forEach((button) => {
					const active = button.dataset.rangeOption === range;
					button.classList.toggle("is-active", active);
					button.setAttribute("aria-selected", active ? "true" : "false");
				});

				publishArea.setAttribute("d", buildAreaPath(metrics, "publishY"));
				updateArea.setAttribute("d", buildAreaPath(metrics, "updateY"));
				deleteArea.setAttribute("d", buildAreaPath(metrics, "deleteY"));
				publishLine.setAttribute("d", buildLinePath(metrics, "publishY"));
				updateLine.setAttribute("d", buildLinePath(metrics, "updateY"));
				deleteLine.setAttribute("d", buildLinePath(metrics, "deleteY"));
				summaryNode.textContent = summarizeDataset(dataset);
				stage.style.setProperty("--chart-point-count", String(metrics.length));
				stage.style.setProperty("--chart-column-width", metrics.length > 12 ? "2rem" : "3.4rem");
				labels.style.gridTemplateColumns = `repeat(${metrics.length}, minmax(${metrics.length > 12 ? "2rem" : "3.4rem"}, 1fr))`;
				labels.replaceChildren(
					...metrics.map((point) => {
						const item = document.createElement("span");
						item.className = "dashboard-chart-label";
						item.textContent = point.label;
						return item;
					}),
				);
			};

			switchRoot.querySelectorAll("[data-range-option]").forEach((button) => {
				button.onclick = () => renderChart(button.dataset.rangeOption);
			});

			renderChart(chartRoot.dataset.defaultRange || "week");
		};

		const bootDashboard = () => {
			initDashboardSearch();
			initDashboardHints();
			initDashboardChart();
		};

		document.addEventListener("astro:page-load", bootDashboard);
		document.addEventListener("DOMContentLoaded", bootDashboard);
	</script>
</Layout>

<style is:global>
	.dashboard-shell {
		max-width: 1280px;
		margin: 0 auto;
		padding: 1rem;
		display: grid;
		grid-template-columns: 280px minmax(0, 1fr);
		gap: 1rem;
	}

	.dashboard-sidebar,
	.dashboard-panel,
	.dashboard-hero,
	.dashboard-metric-card {
		border-radius: 1.5rem;
	}

	.dashboard-sidebar {
		position: sticky;
		top: 1rem;
		align-self: start;
		display: grid;
		gap: 1rem;
		padding: 1.25rem;
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(248, 250, 252, 0.92)),
			radial-gradient(circle at top right, rgba(14, 165, 233, 0.12), transparent 16rem);
		border: 1px solid rgba(148, 163, 184, 0.18);
	}

	.dark .dashboard-sidebar {
		background:
			linear-gradient(180deg, rgba(15, 23, 42, 0.96), rgba(15, 23, 42, 0.92)),
			radial-gradient(circle at top right, rgba(14, 165, 233, 0.14), transparent 16rem);
		border-color: rgba(148, 163, 184, 0.12);
	}

	.dashboard-brand,
	.dashboard-nav-link,
	.dashboard-topbar,
	.dashboard-topbar-actions,
	.dashboard-profile-chip,
	.dashboard-panel-head,
	.dashboard-chart-meta,
	.dashboard-chart-legend span,
	.dashboard-hero-actions {
		display: flex;
		align-items: center;
	}

	.dashboard-brand {
		gap: 0.9rem;
	}

	.dashboard-brand-mark,
	.dashboard-profile-avatar {
		width: 3rem;
		height: 3rem;
		display: grid;
		place-items: center;
		border-radius: 1rem;
		background: linear-gradient(135deg, rgba(37, 99, 235, 0.95), rgba(14, 165, 233, 0.95));
		color: white;
		font-weight: 800;
	}

	.dashboard-brand-eyebrow,
	.dashboard-panel-eyebrow,
	.dashboard-topbar-label {
		margin: 0;
		font-size: 0.78rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: rgba(14, 116, 144, 0.9);
	}

	.dashboard-brand-title,
	.dashboard-topbar-title,
	.dashboard-panel-title,
	.dashboard-hero-title,
	.dashboard-recent-title {
		margin: 0.35rem 0 0;
		color: rgba(15, 23, 42, 0.95);
	}

	.dark .dashboard-brand-title,
	.dark .dashboard-topbar-title,
	.dark .dashboard-panel-title,
	.dark .dashboard-hero-title,
	.dark .dashboard-recent-title {
		color: rgba(248, 250, 252, 0.96);
	}

	.dashboard-nav {
		display: grid;
		gap: 0.45rem;
	}

	.dashboard-nav-link {
		gap: 0.7rem;
		padding: 0.8rem 0.9rem;
		border-radius: 1rem;
		text-decoration: none;
		font-weight: 700;
		color: rgba(15, 23, 42, 0.86);
		background: rgba(255, 255, 255, 0.65);
	}

	.dashboard-nav-link:hover {
		background: rgba(37, 99, 235, 0.08);
		color: rgba(37, 99, 235, 0.96);
	}

	.dark .dashboard-nav-link {
		color: rgba(226, 232, 240, 0.92);
		background: rgba(15, 23, 42, 0.58);
	}

	.dashboard-sidebar-card,
	.dashboard-guide-card {
		padding: 1rem;
		border-radius: 1.1rem;
		background: rgba(255, 255, 255, 0.7);
		border: 1px solid rgba(148, 163, 184, 0.16);
	}

	.dark .dashboard-sidebar-card,
	.dark .dashboard-guide-card {
		background: rgba(15, 23, 42, 0.58);
		border-color: rgba(148, 163, 184, 0.1);
	}

	.dashboard-sidebar-title,
	.dashboard-guide-title {
		margin: 0;
		font-size: 0.95rem;
		font-weight: 700;
		color: rgba(15, 23, 42, 0.94);
	}

	.dashboard-sidebar-copy,
	.dashboard-guide-copy,
	.dashboard-hero-copy,
	.dashboard-metric-copy,
	.dashboard-recent-copy,
	.dashboard-search-empty {
		margin: 0.65rem 0 0;
		line-height: 1.7;
		color: rgba(71, 85, 105, 0.9);
	}

	.dark .dashboard-sidebar-copy,
	.dark .dashboard-guide-copy,
	.dark .dashboard-hero-copy,
	.dark .dashboard-metric-copy,
	.dark .dashboard-recent-copy,
	.dark .dashboard-search-empty {
		color: rgba(203, 213, 225, 0.82);
	}

	.dashboard-main {
		display: grid;
		gap: 1rem;
	}

	.dashboard-topbar {
		justify-content: space-between;
		gap: 1rem;
	}

	.dashboard-topbar-title {
		font-size: clamp(1.35rem, 2.5vw, 1.8rem);
		font-weight: 800;
	}

	.dashboard-topbar-actions {
		gap: 0.9rem;
	}

	.dashboard-search {
		position: relative;
		width: min(28rem, 100%);
	}

	.dashboard-search-input {
		width: 100%;
		height: 3rem;
		padding: 0 1rem;
		border-radius: 1rem;
		border: 1px solid rgba(148, 163, 184, 0.18);
		background: rgba(255, 255, 255, 0.9);
		color: rgba(15, 23, 42, 0.92);
	}

	.dark .dashboard-search-input {
		background: rgba(15, 23, 42, 0.72);
		border-color: rgba(148, 163, 184, 0.14);
		color: rgba(248, 250, 252, 0.94);
	}

	.dashboard-search-results {
		position: absolute;
		top: calc(100% + 0.5rem);
		left: 0;
		right: 0;
		padding: 0.5rem;
		border-radius: 1rem;
		background: rgba(255, 255, 255, 0.98);
		border: 1px solid rgba(148, 163, 184, 0.18);
		box-shadow: 0 24px 50px rgba(15, 23, 42, 0.16);
		z-index: 20;
	}

	.dark .dashboard-search-results {
		background: rgba(2, 6, 23, 0.98);
		border-color: rgba(148, 163, 184, 0.14);
	}

	.dashboard-search-results-list {
		display: grid;
		gap: 0.35rem;
	}

	.dashboard-search-result {
		display: grid;
		gap: 0.2rem;
		padding: 0.75rem;
		border-radius: 0.85rem;
		text-decoration: none;
	}

	.dashboard-search-result:hover {
		background: rgba(37, 99, 235, 0.06);
	}

	.dashboard-search-result-meta {
		font-size: 0.75rem;
		color: rgba(14, 116, 144, 0.88);
	}

	.dashboard-search-result-title,
	.dashboard-profile-name,
	.dashboard-metric-link {
		margin: 0;
		font-weight: 700;
		color: rgba(15, 23, 42, 0.95);
		text-decoration: none;
	}

	.dark .dashboard-search-result-title,
	.dark .dashboard-profile-name,
	.dark .dashboard-metric-link {
		color: rgba(248, 250, 252, 0.96);
	}

	.dashboard-search-result-copy,
	.dashboard-profile-role {
		font-size: 0.82rem;
		color: rgba(100, 116, 139, 0.88);
	}

	.dark .dashboard-search-result-copy,
	.dark .dashboard-profile-role {
		color: rgba(148, 163, 184, 0.84);
	}

	.dashboard-profile-chip {
		gap: 0.7rem;
		padding: 0.45rem 0.6rem 0.45rem 0.45rem;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.78);
		border: 1px solid rgba(148, 163, 184, 0.16);
	}

	.dark .dashboard-profile-chip {
		background: rgba(15, 23, 42, 0.72);
		border-color: rgba(148, 163, 184, 0.12);
	}

	.dashboard-hero {
		display: flex;
		justify-content: space-between;
		gap: 1.25rem;
		padding: 1.4rem;
		background:
			linear-gradient(135deg, rgba(255, 255, 255, 0.94), rgba(240, 249, 255, 0.9)),
			radial-gradient(circle at top right, rgba(37, 99, 235, 0.1), transparent 15rem);
	}

	.dark .dashboard-hero {
		background:
			linear-gradient(135deg, rgba(15, 23, 42, 0.96), rgba(15, 23, 42, 0.92)),
			radial-gradient(circle at top right, rgba(37, 99, 235, 0.14), transparent 15rem);
	}

	.dashboard-hero-title {
		font-size: clamp(1.4rem, 3vw, 2rem);
		font-weight: 800;
	}

	.dashboard-hero-actions {
		gap: 0.75rem;
		align-self: flex-start;
	}

	.dashboard-primary-button,
	.dashboard-secondary-button,
	.dashboard-range-button,
	.dashboard-hint-close {
		border: 0;
		border-radius: 1rem;
		transition: 180ms ease;
	}

