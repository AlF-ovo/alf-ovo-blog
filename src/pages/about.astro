---
import { getEntry, render } from "astro:content";
import { Icon } from "astro-icon/components";
import Markdown from "@components/misc/Markdown.astro";
import ImageWrapper from "@components/misc/ImageWrapper.astro";
import { profileConfig } from "../config";
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";
import MainGridLayout from "../layouts/MainGridLayout.astro";

const aboutPost = await getEntry("spec", "about");

if (!aboutPost) {
	throw new Error("About page content not found");
}

const { Content } = await render(aboutPost);

const aboutFacts = [
	{ label: "称呼", value: "Chu" },
	{ label: "英文名", value: "AlF" },
	{ label: "一句简介", value: "404 CTFer not Found" },
	{ label: "所在地", value: "杭州" },
	{ label: "方向", value: "二进制安全 / Pwn" },
	{ label: "当前重点", value: "CTF Pwn、调试与漏洞利用基础" },
	{ label: "研究兴趣", value: "怎么在比赛里少踩坑、少爆零" },
	{ label: "技能栈", value: "栈、堆与基础利用思路" },
	{
		label: "邮箱",
		value: "3483179408@qq.com",
		href: "mailto:3483179408@qq.com",
	},
];
---
<MainGridLayout title={i18n(I18nKey.about)} description={i18n(I18nKey.about)}>
	<div class="about-grid">
		<section class="card-base about-profile">
			<div class="about-hero">
				<div class="about-avatar">
					<ImageWrapper src={profileConfig.avatar || ""} alt="Profile Image of AlF" class="h-full w-full" />
				</div>
				<div class="about-hero-copy">
					<p class="about-eyebrow">个人资料</p>
					<h1 class="about-title">Chu / AlF</h1>
					<p class="about-tagline">404 CTFer not Found</p>
					<p class="about-description">
						这里先留下最基本的自我介绍和联系方式，别的经历、记录与笔记，等它们慢慢长出来。
					</p>
				</div>
			</div>

			<div class="about-facts">
				{aboutFacts.map((item) => (
					<div class="about-fact">
						<span>{item.label}</span>
						{item.href ? (
							<a href={item.href}>{item.value}</a>
						) : (
							<strong>{item.value}</strong>
						)}
					</div>
				))}
			</div>

			{profileConfig.links.length > 0 && (
				<div class="about-links">
					{profileConfig.links.map((item) => (
						<a href={item.url} target="_blank" rel="noreferrer" class="about-link">
							<Icon name={item.icon} class="text-[1.1rem]" />
							<span>{item.name}</span>
						</a>
					))}
				</div>
			)}
		</section>

		<section class="card-base about-content">
			<Markdown class="mt-2">
				<Content />
			</Markdown>
		</section>
	</div>
</MainGridLayout>

<style>
	.about-grid {
		display: grid;
		gap: 1rem;
	}

	.about-profile,
	.about-content {
		position: relative;
		width: 100%;
		padding: 1.75rem 2rem;
		border-radius: var(--radius-large);
		overflow: hidden;
	}

	.about-profile {
		background:
			radial-gradient(circle at top right, rgba(255, 255, 255, 0.1), transparent 34%),
			radial-gradient(circle at bottom left, rgba(255, 255, 255, 0.06), transparent 32%);
	}

	.about-hero {
		display: grid;
		grid-template-columns: 7rem minmax(0, 1fr);
		gap: 1.25rem;
		align-items: center;
	}

	.about-avatar {
		width: 7rem;
		height: 7rem;
		border-radius: var(--radius-large);
		overflow: hidden;
		background: rgba(148, 163, 184, 0.12);
		box-shadow: 0 1rem 2rem rgba(15, 23, 42, 0.08);
	}

	.about-eyebrow {
		margin: 0;
		font-size: 0.78rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: rgba(71, 85, 105, 0.88);
	}

	.about-title {
		margin: 0.4rem 0 0;
		font-size: clamp(1.9rem, 4vw, 2.6rem);
		font-weight: 800;
		color: rgba(15, 23, 42, 0.94);
	}

	.about-tagline {
		margin: 0.45rem 0 0;
		font-size: 1rem;
		font-weight: 700;
		color: rgba(51, 65, 85, 0.88);
	}

	.about-description {
		margin: 0.85rem 0 0;
		max-width: 42rem;
		line-height: 1.8;
		color: rgba(71, 85, 105, 0.9);
	}

	.about-facts {
		margin-top: 1.5rem;
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.85rem;
	}

	.about-fact {
		display: grid;
		gap: 0.28rem;
		padding: 0.9rem 1rem;
		border-radius: var(--radius-medium);
		border: 1px solid var(--frame);
		background: transparent;
		box-shadow: var(--surface-shadow);
		backdrop-filter: blur(12px);
	}

	.about-fact span {
		font-size: 0.8rem;
		color: rgba(71, 85, 105, 0.84);
	}

	.about-fact strong,
	.about-fact a {
		font-size: 0.95rem;
		line-height: 1.7;
		color: rgba(15, 23, 42, 0.94);
		text-decoration: none;
		word-break: break-word;
	}

	.about-links {
		margin-top: 1rem;
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
	}

	.about-link {
		display: inline-flex;
		align-items: center;
		gap: 0.55rem;
		padding: 0.78rem 1rem;
		border-radius: 999px;
		border: 1px solid var(--frame);
		background: transparent;
		color: rgba(15, 23, 42, 0.94);
		font-weight: 700;
		text-decoration: none;
		transition: transform 180ms ease, background 180ms ease, border-color 180ms ease;
		box-shadow: var(--surface-shadow);
		backdrop-filter: blur(12px);
	}

	.about-link:hover {
		transform: translateY(-1px);
		background: var(--surface-hover);
		border-color: var(--frame-strong);
	}

	:global(.dark) .about-profile {
		background:
			radial-gradient(circle at top right, rgba(255, 255, 255, 0.08), transparent 34%),
			radial-gradient(circle at bottom left, rgba(255, 255, 255, 0.05), transparent 32%);
	}

	:global(.dark) .about-avatar {
		background: rgba(15, 23, 42, 0.72);
		box-shadow: 0 1rem 2rem rgba(2, 6, 23, 0.2);
	}

	:global(.dark) .about-title {
		color: rgba(248, 250, 252, 0.96);
	}

	:global(.dark) .about-tagline {
		color: rgba(203, 213, 225, 0.8);
	}

	:global(.dark) .about-description {
		color: rgba(203, 213, 225, 0.84);
	}

	:global(.dark) .about-fact {
		border-color: var(--frame);
	}

	:global(.dark) .about-fact strong,
	:global(.dark) .about-fact a {
		color: rgba(248, 250, 252, 0.94);
	}

	:global(.dark) .about-link {
		color: rgba(224, 242, 254, 0.94);
	}

	:global(.dark) .about-link:hover {
		background: var(--surface-hover);
	}

	:global(.dark) .about-eyebrow,
	:global(.dark) .about-fact span {
		color: rgba(203, 213, 225, 0.72);
	}

	@media (max-width: 720px) {
		.about-profile,
		.about-content {
			padding: 1.25rem;
		}

		.about-hero {
			grid-template-columns: 1fr;
		}

		.about-avatar {
			width: 6rem;
			height: 6rem;
		}

		.about-facts {
			grid-template-columns: 1fr;
		}
	}
</style>
