---
import MainGridLayout from "../layouts/MainGridLayout.astro";
import { formatDateToYYYYMMDD } from "../utils/date-utils";
import { getSortedNotesList } from "../utils/content-utils";

const notes = await getSortedNotesList();
---

<MainGridLayout title="札记" description="短记录、调试碎片与尚未扩写成长文的内容。">
	<div class="grid gap-4">
		<section class="card-base rounded-[var(--radius-large)] px-8 py-7">
			<p class="notes-eyebrow">短笔记</p>
			<h1 class="notes-title">札记</h1>
			<p class="notes-copy">
				这里专门收纳偏短的内容：调试记录、踩坑备忘、命令片段和临时想法。
			</p>
		</section>

		<section class="card-base rounded-[var(--radius-large)] px-6 py-4">
			{
				notes.length > 0 ? (
					<div class="notes-list">
						{notes.map((note) => (
							<a href={note.url} class="notes-item">
								<div class="notes-item-main">
									<div class="notes-item-head">
										<p class="notes-item-title">{note.data.title}</p>
										{note.data.series && (
											<span class="notes-item-series">{note.data.series}</span>
										)}
									</div>
									<p class="notes-item-desc">
										{note.data.description || "这条笔记暂时还没有补摘要。"}
									</p>
								</div>
								<div class="notes-item-meta">
									<span class="notes-item-date">
										{formatDateToYYYYMMDD(note.data.updated ?? note.data.published)}
									</span>
									<span class="notes-item-tags">
										{note.data.tags.slice(0, 3).join(" / ") || "无标签"}
									</span>
									<span class="notes-item-category">
										{note.data.categoryPath?.join(" / ") || note.data.category || "未分类"}
									</span>
								</div>
							</a>
						))}
					</div>
				) : (
					<div class="notes-empty">
						<p class="notes-empty-title">这里还没有单独的笔记。</p>
						<p class="notes-empty-copy">
							后续可以用 `pnpm new-post -- your-note --type note` 新建一条笔记，
							它会和文章流分开，但仍然出现在归档页和 RSS 里。
						</p>
					</div>
				)
			}
		</section>
	</div>
</MainGridLayout>

<style>
	.notes-eyebrow {
		margin: 0;
		font-size: 0.78rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: rgba(71, 85, 105, 0.88);
	}

	.notes-title {
		margin: 0.35rem 0 0;
		font-size: clamp(1.8rem, 4vw, 2.5rem);
		font-weight: 800;
		color: rgba(15, 23, 42, 0.96);
	}

	.notes-copy {
		margin: 1rem 0 0;
		max-width: 46rem;
		line-height: 1.8;
		color: rgba(71, 85, 105, 0.9);
	}

	.notes-list {
		display: grid;
	}

	.notes-item {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 1.1rem 0.75rem;
		border-bottom: 1px dashed rgba(148, 163, 184, 0.28);
		text-decoration: none;
	}

	.notes-item:last-child {
		border-bottom: 0;
	}

	.notes-item-main {
		min-width: 0;
	}

	.notes-item-head {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		flex-wrap: wrap;
	}

	.notes-item-title {
		margin: 0;
		font-size: 1.02rem;
		font-weight: 700;
		color: rgba(15, 23, 42, 0.96);
	}

	.notes-item-series {
		display: inline-flex;
		align-items: center;
		padding: 0.2rem 0.55rem;
		border-radius: 999px;
		border: 1px solid var(--frame);
		background: transparent;
		color: rgba(51, 65, 85, 0.9);
		font-size: 0.75rem;
		font-weight: 700;
		box-shadow: var(--surface-shadow);
		backdrop-filter: blur(12px);
	}

	.notes-item-desc {
		margin: 0.45rem 0 0;
		font-size: 0.9rem;
		line-height: 1.7;
		color: rgba(100, 116, 139, 0.9);
	}

	.notes-item-meta {
		flex: 0 0 15rem;
		display: grid;
		gap: 0.35rem;
		text-align: right;
	}

	.notes-item-date,
	.notes-item-tags,
	.notes-item-category {
		font-size: 0.82rem;
		color: rgba(71, 85, 105, 0.84);
	}

	.notes-item:hover .notes-item-title {
		color: rgba(15, 23, 42, 0.96);
	}

	.notes-empty {
		padding: 1.5rem 0.75rem;
	}

	.notes-empty-title {
		margin: 0;
		font-size: 1rem;
		font-weight: 700;
		color: rgba(15, 23, 42, 0.94);
	}

	.notes-empty-copy {
		margin: 0.75rem 0 0;
		line-height: 1.8;
		color: rgba(71, 85, 105, 0.9);
	}

	:global(.dark) .notes-copy,
	:global(.dark) .notes-item-desc,
	:global(.dark) .notes-empty-copy {
		color: rgba(203, 213, 225, 0.82);
	}

	:global(.dark) .notes-item-title,
	:global(.dark) .notes-empty-title,
	:global(.dark) .notes-title {
		color: rgba(248, 250, 252, 0.96);
	}

	:global(.dark) .notes-item-series {
		color: rgba(226, 232, 240, 0.9);
	}

	:global(.dark) .notes-eyebrow,
	:global(.dark) .notes-item-date,
	:global(.dark) .notes-item-tags,
	:global(.dark) .notes-item-category {
		color: rgba(203, 213, 225, 0.7);
	}

	:global(.dark) .notes-item:hover .notes-item-title {
		color: rgba(248, 250, 252, 0.96);
	}

	@media (max-width: 720px) {
		.notes-item {
			flex-direction: column;
			align-items: flex-start;
		}

		.notes-item-meta {
			flex: 0 0 auto;
			text-align: left;
		}
	}
</style>
