---
import { url } from "../utils/url-utils";

const normalSrc = url("/mascot/normal.png");
const blinkSrc = url("/mascot/blink.png");
const talkSrc = url("/mascot/talk.png");
---

<div
	id="blog-mascot"
	class="blog-mascot is-hidden"
	data-normal-src={normalSrc}
	data-blink-src={blinkSrc}
	data-talk-src={talkSrc}
	aria-hidden="true"
>
	<div class="blog-mascot__float">
		<div class="blog-mascot__drift">
			<button type="button" class="blog-mascot__button" aria-label="Mascot">
				<span class="blog-mascot__glow" aria-hidden="true"></span>
				<img
					class="blog-mascot__image"
					src={normalSrc}
					alt=""
					decoding="async"
					loading="eager"
					draggable="false"
				/>
			</button>
		</div>
	</div>
</div>

<style>
	.blog-mascot {
		--mascot-shift-x: 0px;
		--mascot-shift-y: 0px;
		position: fixed;
		left: max(0.75rem, env(safe-area-inset-left));
		bottom: max(0.75rem, env(safe-area-inset-bottom));
		z-index: 80;
		width: clamp(9rem, 18vw, 14rem);
		pointer-events: none;
		opacity: 0;
		visibility: hidden;
		transition:
			opacity 260ms ease,
			visibility 260ms ease;
	}

	.blog-mascot.is-ready {
		opacity: 1;
		visibility: visible;
	}

	.blog-mascot__float {
		animation: blog-mascot-float 4.6s ease-in-out infinite;
		transform-origin: center bottom;
	}

	.blog-mascot__drift {
		transform: translate3d(var(--mascot-shift-x), var(--mascot-shift-y), 0);
		transition: transform 180ms ease-out;
		will-change: transform;
	}

	.blog-mascot__button {
		position: relative;
		display: block;
		width: 100%;
		border: 0;
		padding: 0;
		background: transparent;
		cursor: pointer;
		pointer-events: auto;
		touch-action: manipulation;
	}

	.blog-mascot__glow {
		position: absolute;
		left: 16%;
		right: 14%;
		bottom: 2%;
		height: 18%;
		border-radius: 999px;
		background:
			radial-gradient(circle, rgb(49 196 255 / 0.28) 0%, rgb(49 196 255 / 0.12) 42%, transparent 72%),
			radial-gradient(circle, rgb(255 67 157 / 0.2) 0%, transparent 68%);
		filter: blur(14px);
		opacity: 0.9;
		transform: translateY(10%) scale(0.94);
		pointer-events: none;
	}

	.blog-mascot__image {
		position: relative;
		display: block;
		width: 100%;
		height: auto;
		user-select: none;
		filter: drop-shadow(0 16px 30px rgb(14 25 51 / 0.18));
	}

	@keyframes blog-mascot-float {
		0%,
		100% {
			transform: translateY(0) scale(1);
		}

		50% {
			transform: translateY(-0.4rem) scale(1.015);
		}
	}

	@media (max-width: 900px) {
		.blog-mascot {
			width: clamp(7.5rem, 24vw, 10rem);
			left: max(0.5rem, env(safe-area-inset-left));
			bottom: max(0.5rem, env(safe-area-inset-bottom));
		}
	}

	@media (max-width: 640px) {
		.blog-mascot {
			width: min(7.5rem, 26vw);
		}

		.blog-mascot__glow {
			opacity: 0.72;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.blog-mascot__float,
		.blog-mascot__drift {
			animation: none;
			transition: none;
		}
	}
</style>

<script>
	type MascotWindow = Window & {
		__alfMascotSetup?: boolean;
	};

	const mascotWindow = window as MascotWindow;

	if (!mascotWindow.__alfMascotSetup) {
		mascotWindow.__alfMascotSetup = true;

		const root = document.getElementById("blog-mascot");
		const image = root?.querySelector(".blog-mascot__image");
		const button = root?.querySelector(".blog-mascot__button");

		if (!(root instanceof HTMLElement) || !(image instanceof HTMLImageElement)) {
			mascotWindow.__alfMascotSetup = false;
		} else {
			const sources = {
				normal: root.dataset.normalSrc || "",
				blink: root.dataset.blinkSrc || "",
				talk: root.dataset.talkSrc || "",
			};

			const available = {
				normal: false,
				blink: false,
				talk: false,
			};

			let blinkTimer = 0;
			let talkTimer = 0;
			let currentExpression = "normal";

			const reducedMotionQuery = window.matchMedia("(prefers-reduced-motion: reduce)");

			const preloadSource = (src: string) =>
				new Promise<boolean>((resolve) => {
					if (!src) {
						resolve(false);
						return;
					}

					const preloader = new Image();
					preloader.onload = () => resolve(true);
					preloader.onerror = () => resolve(false);
					preloader.src = src;
				});

			const applyExpression = (expression: "normal" | "blink" | "talk") => {
				const nextExpression =
					expression === "normal" || available[expression] ? expression : "normal";
				if (currentExpression === nextExpression || !sources[nextExpression]) {
					return;
				}

				currentExpression = nextExpression;
				image.src = sources[nextExpression];
			};

			const resetDrift = () => {
				root.style.setProperty("--mascot-shift-x", "0px");
				root.style.setProperty("--mascot-shift-y", "0px");
			};

			const queueBlink = () => {
				window.clearTimeout(blinkTimer);
				if (!available.blink || document.hidden) {
					return;
				}

				const delay = 2800 + Math.random() * 2400;
				blinkTimer = window.setTimeout(() => {
					applyExpression("blink");
					window.setTimeout(() => applyExpression("normal"), 140);
					queueBlink();
				}, delay);
			};

			const playTalkPulse = () => {
				if (!available.talk) {
					return;
				}

				window.clearTimeout(talkTimer);
				applyExpression("talk");
				talkTimer = window.setTimeout(() => applyExpression("normal"), 220);
			};

			const handlePointerMove = (event: PointerEvent) => {
				if (reducedMotionQuery.matches) {
					return;
				}

				const viewportX = event.clientX / window.innerWidth - 0.5;
				const viewportY = event.clientY / window.innerHeight - 0.5;
				root.style.setProperty("--mascot-shift-x", `${viewportX * 10}px`);
				root.style.setProperty("--mascot-shift-y", `${viewportY * 8}px`);
			};

			const handleVisibilityChange = () => {
				if (document.hidden) {
					window.clearTimeout(blinkTimer);
					applyExpression("normal");
					return;
				}

				queueBlink();
			};

			Promise.all([
				preloadSource(sources.normal),
				preloadSource(sources.blink),
				preloadSource(sources.talk),
			]).then(([hasNormal, hasBlink, hasTalk]) => {
				available.normal = hasNormal;
				available.blink = hasBlink;
				available.talk = hasTalk;

				if (!available.normal) {
					root.remove();
					return;
				}

				root.classList.remove("is-hidden");
				root.classList.add("is-ready");
				applyExpression("normal");
				queueBlink();
			});

			document.addEventListener("pointermove", handlePointerMove, { passive: true });
			document.addEventListener("visibilitychange", handleVisibilityChange);
			button?.addEventListener("pointerenter", playTalkPulse);
			button?.addEventListener("click", playTalkPulse);
			button?.addEventListener("pointerleave", () => {
				window.clearTimeout(talkTimer);
				applyExpression("normal");
				resetDrift();
			});
			reducedMotionQuery.addEventListener("change", () => {
				if (reducedMotionQuery.matches) {
					resetDrift();
				}
			});
		}
	}
</script>
