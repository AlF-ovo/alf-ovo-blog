		const SCARECROW_BUTTON_SIZE = 46;
		const SCARECROW_HIDE_OFFSET = 18;
		const SCARECROW_RAISE_DURATION_MS = 820;
		const SCARECROW_LOWER_DURATION_MS = 700;
		const FRIES_BUTTON_GAP = 14;
		const NAMEPLATE_BUTTON_GAP = 10;
		const NAMEPLATE_BUTTON_WIDTH = 52;
		const NAMEPLATE_BUTTON_HEIGHT = 29;
		const NAMEPLATE_DRAG_ACTIVATION_DISTANCE = 12;
		const NAMEPLATE_SELECT_RADIUS = 152;
