---

---

<div id="raven-flock" class="raven-flock" aria-hidden="true">
	<button
		id="raven-fries-button"
		class="raven-fries-button"
		type="button"
		aria-label="Scatter fries"
	></button>
	<div id="raven-drumstick" class="raven-drumstick" data-mode="idle"></div>
</div>

<style is:global>
	.raven-flock {
		position: fixed;
		inset: 0;
		z-index: 65;
		pointer-events: none;
		overflow: hidden;
	}

	.raven-bird {
		position: absolute;
		left: 0;
		top: 0;
		width: 6rem;
		height: 4.5rem;
		pointer-events: auto;
		cursor: pointer;
		user-select: none;
		will-change: transform;
		filter:
			drop-shadow(0 0.65rem 1rem rgb(3 7 18 / 0.28))
			hue-rotate(var(--bird-hue-rotate, 0deg))
			saturate(var(--bird-saturate, 1))
			brightness(var(--bird-brightness, 1));
		transform-origin: 50% 88%;
	}

	.raven-bird__sprite,
	.raven-bird__sprite svg {
		display: block;
		width: 100%;
		height: 100%;
		overflow: visible;
		image-rendering: pixelated;
	}

	.raven-bird__sprite {
		transform: translate3d(
			var(--bird-body-shift-x, 0px),
			var(--bird-body-bob, 0px),
			0
		);
		transform-origin: 50% 88%;
		will-change: transform;
	}

	.raven-bird__carry {
		position: absolute;
		left: 0;
		top: 0;
		width: 2rem;
		height: 2rem;
		pointer-events: none;
		opacity: 0;
		transform: translate3d(-50%, -50%, 0) rotate(-18deg);
		transform-origin: 50% 50%;
		filter: drop-shadow(0 0.3rem 0.45rem rgb(15 23 42 / 0.22));
	}

	.raven-bird__carry[data-visible="true"] {
		opacity: 1;
	}

	.raven-bird__hunger-bubble {
		position: absolute;
		left: 50%;
		top: -0.2rem;
		width: 2.1rem;
		height: 1.55rem;
		pointer-events: none;
		opacity: 0;
		transform: translate3d(-50%, -100%, 0) scaleX(var(--bird-ui-flip, 1));
		transform-origin: 50% 100%;
		transition: opacity 180ms ease;
	}

	.raven-bird__hunger-bubble[data-visible="true"] {
		opacity: 1;
	}

	.raven-bird__hunger-bubble,
	.raven-bird__hunger-bubble svg {
		display: block;
		image-rendering: pixelated;
	}

	.raven-bird[data-state="panel-perched"] {
		filter:
			drop-shadow(0 0.45rem 0.8rem rgb(3 7 18 / 0.22))
			hue-rotate(var(--bird-hue-rotate, 0deg))
			saturate(var(--bird-saturate, 1))
			brightness(var(--bird-brightness, 1));
	}

	.raven-bird[data-state="selected-docked"] {
		filter:
			drop-shadow(0 0.55rem 0.95rem rgb(3 7 18 / 0.28))
			hue-rotate(var(--bird-hue-rotate, 0deg))
			saturate(var(--bird-saturate, 1))
			brightness(var(--bird-brightness, 1));
	}

	.raven-bird__status {
		position: absolute;
		left: 50%;
		top: -0.82rem;
		display: none;
		align-items: center;
		pointer-events: none;
		transform: translate3d(-50%, -100%, 0) scaleX(var(--bird-ui-flip, 1));
		transform-origin: 50% 100%;
		z-index: 4;
	}

	.raven-bird[data-selected="true"] .raven-bird__status {
		display: flex;
	}

	.raven-bird__crown,
	.raven-bird__crown svg {
		display: block;
		width: 100%;
		height: 100%;
		image-rendering: pixelated;
	}

	.raven-bird__crown {
		position: absolute;
		left: 50%;
		top: 0.28rem;
		display: none;
		width: 1.7rem;
		height: 1rem;
		pointer-events: none;
		transform: translate3d(-50%, -82%, 0) scaleX(var(--bird-ui-flip, 1));
		transform-origin: 50% 100%;
		filter: drop-shadow(0 0.15rem 0.3rem rgb(15 23 42 / 0.3));
		z-index: 5;
	}

	.raven-bird[data-selected="true"] .raven-bird__crown {
		display: block;
	}

	.raven-bird__nameplate {
		width: 3rem;
		height: auto;
		filter: drop-shadow(0 0.16rem 0.24rem rgb(15 23 42 / 0.28));
	}

	.raven-bird__nameplate,
	.raven-bird__nameplate svg {
		display: block;
		image-rendering: pixelated;
	}

	.raven-drumstick {
		position: absolute;
		left: 0;
		top: 0;
		width: 2.75rem;
		height: 2.75rem;
		pointer-events: auto;
		cursor: grab;
		will-change: transform;
		touch-action: none;
		transform-origin: 50% 50%;
		filter: drop-shadow(0 0.5rem 0.75rem rgb(15 23 42 / 0.24));
		opacity: 1;
		transition: opacity 220ms ease;
	}

	.raven-fries-button {
		position: absolute;
		left: 0;
		top: 0;
		width: 2.9rem;
		height: 2.9rem;
		padding: 0;
		border: 0;
		background: transparent;
		pointer-events: auto;
		cursor: pointer;
		will-change: transform;
		touch-action: manipulation;
		filter: drop-shadow(0 0.45rem 0.7rem rgb(15 23 42 / 0.22));
	}

	.raven-fries-button:active {
		transform: scale(0.96);
	}

	.raven-scarecrow {
		position: absolute;
		left: 0;
		top: 0;
		width: 75px;
		height: 83px;
		pointer-events: none;
		will-change: transform;
		transform-origin: 50% 100%;
		filter: drop-shadow(0 0.5rem 0.8rem rgb(15 23 42 / 0.24));
		opacity: 0;
		transition:
			transform 760ms cubic-bezier(0.22, 1, 0.36, 1),
			filter 220ms ease,
			opacity 240ms ease;
	}

	.raven-scarecrow[data-raised="false"] {
		opacity: 0;
		filter: drop-shadow(0 0.32rem 0.54rem rgb(15 23 42 / 0.18));
	}

	.raven-scarecrow[data-raised="true"] {
		opacity: 1;
		filter: drop-shadow(0 0.58rem 0.94rem rgb(15 23 42 / 0.3));
	}

	.raven-scarecrow__sprite,
	.raven-scarecrow__sprite svg {
		display: block;
		width: 100%;
		height: 100%;
		image-rendering: pixelated;
	}

	.raven-scarecrow-button {
		position: absolute;
		left: 0;
		top: 0;
		width: 46px;
		height: 46px;
		padding: 0;
		border: 0;
		background: transparent;
		pointer-events: auto;
		cursor: pointer;
		will-change: transform;
		touch-action: manipulation;
		filter: drop-shadow(0 0.5rem 0.8rem rgb(15 23 42 / 0.24));
		transition:
			filter 180ms ease,
			opacity 180ms ease,
			transform 160ms ease;
	}

	.raven-scarecrow-button[data-raised="false"] {
		filter: drop-shadow(0 0.32rem 0.54rem rgb(15 23 42 / 0.18));
	}

	.raven-scarecrow-button[data-raised="true"] {
		filter: drop-shadow(0 0.58rem 0.94rem rgb(15 23 42 / 0.3));
	}

	.raven-scarecrow-button__sprite,
	.raven-scarecrow-button__sprite svg {
		display: block;
		width: 100%;
		height: 100%;
		image-rendering: pixelated;
	}

	.raven-nameplate-button {
		position: absolute;
		left: 0;
		top: 0;
		width: 3.25rem;
		height: 1.8rem;
		padding: 0;
		border: 0;
		background: transparent;
		pointer-events: auto;
		cursor: grab;
		will-change: transform;
		touch-action: none;
		filter: drop-shadow(0 0.38rem 0.58rem rgb(15 23 42 / 0.2));
		transition: filter 160ms ease, opacity 160ms ease;
	}

	.raven-nameplate-button[data-mode="holding"],
	.raven-nameplate-button[data-mode="dragging"] {
		cursor: grabbing;
		filter: drop-shadow(0 0.5rem 0.82rem rgb(15 23 42 / 0.28));
	}

	.raven-nameplate-button[data-mode="cancel"] {
		cursor: pointer;
		filter: drop-shadow(0 0.42rem 0.72rem rgb(127 29 29 / 0.28));
	}

	.raven-nameplate-button__sprite,
	.raven-nameplate-button__sprite svg {
		display: block;
		width: 100%;
		height: 100%;
		image-rendering: pixelated;
	}

	.raven-fries-button__sprite,
	.raven-fries-button__sprite svg {
		display: block;
		width: 100%;
		height: 100%;
		image-rendering: pixelated;
	}

	.raven-fries-button[data-mode="holding"],
	.raven-fries-button[data-mode="dragging"] {
		cursor: grabbing;
		filter: drop-shadow(0 0.58rem 0.86rem rgb(15 23 42 / 0.28));
	}

	.raven-fries-button__count {
		position: absolute;
		right: -0.2rem;
		top: -0.26rem;
		display: none;
		min-width: 1.1rem;
		height: 1.1rem;
		padding: 0 0.24rem;
		border-radius: 999px;
		background: rgb(15 23 42 / 0.86);
		color: rgb(255 248 220 / 0.98);
		font-size: 0.64rem;
		font-weight: 800;
		line-height: 1.1rem;
		text-align: center;
		box-shadow: 0 0.18rem 0.34rem rgb(15 23 42 / 0.24);
	}

	.raven-fries-button[data-count-visible="true"] .raven-fries-button__count {
		display: block;
	}

	.raven-drumstick[data-visible="false"] {
		opacity: 0;
	}

	.raven-drumstick[data-mode="holding"] {
		cursor: grabbing;
	}

	.raven-drumstick[data-mode="dragging"],
	.raven-drumstick[data-mode="falling"],
	.raven-drumstick[data-mode="active"] {
		filter: drop-shadow(0 0.7rem 1rem rgb(15 23 42 / 0.3));
	}

	.raven-drumstick[data-mode="resetting"] {
		opacity: 0;
	}

	.raven-drumstick--ghost {
		pointer-events: none;
		opacity: 0;
		filter: drop-shadow(0 0.4rem 0.65rem rgb(15 23 42 / 0.15));
	}

	.raven-drumstick--ghost[data-visible="true"] {
		opacity: 0.92;
	}

	.raven-drumstick__sprite,
	.raven-drumstick__sprite svg {
		display: block;
		width: 100%;
		height: 100%;
		image-rendering: pixelated;
	}

	.raven-drumstick__meter {
		position: absolute;
		left: 50%;
		top: 100%;
		display: flex;
		gap: 0.15rem;
		transform: translateX(-50%);
		padding-top: 0.15rem;
	}

	.raven-drumstick__pip {
		width: 0.28rem;
		height: 0.28rem;
		background: #f3d37f;
		box-shadow: 0 0 0 1px rgb(58 40 19 / 0.9);
	}

	.raven-drumstick__pip.is-spent {
		background: rgb(90 72 52 / 0.45);
		box-shadow: 0 0 0 1px rgb(36 30 22 / 0.65);
	}

	.raven-scrap {
		position: absolute;
		left: 0;
		top: 0;
		width: 1.5rem;
		height: 1.5rem;
		pointer-events: auto;
		cursor: grab;
		touch-action: none;
		will-change: transform;
		filter: drop-shadow(0 0.28rem 0.4rem rgb(15 23 42 / 0.18));
	}

	.raven-scrap--drumstick {
		width: 2.75rem;
		height: 2.75rem;
		filter: drop-shadow(0 0.5rem 0.75rem rgb(15 23 42 / 0.22));
	}

	.raven-scrap--fries-bag {
		width: 1.9rem;
		height: 1.9rem;
		filter: drop-shadow(0 0.35rem 0.55rem rgb(15 23 42 / 0.22));
	}

	.raven-scrap--fries-loose {
		width: 2rem;
		height: 0.9rem;
		filter: drop-shadow(0 0.22rem 0.35rem rgb(15 23 42 / 0.18));
	}

	.raven-scrap__sprite,
	.raven-scrap__sprite svg {
		display: block;
		width: 100%;
		height: 100%;
		image-rendering: pixelated;
	}

	.raven-emote {
		position: absolute;
		left: 0;
		top: 0;
		pointer-events: none;
		opacity: 0;
	}

	.raven-emote svg {
		display: block;
		width: 100%;
		height: 100%;
		image-rendering: pixelated;
	}

	.raven-thought-line {
		position: absolute;
		left: 0;
		top: 0;
		pointer-events: none;
		max-width: min(22rem, 42vw);
		color: #fff;
		font-size: 0.88rem;
		line-height: 1.35;
		font-weight: 600;
		letter-spacing: 0.01em;
		text-shadow:
			0 1px 0 rgb(9 9 12 / 0.85),
			0 2px 10px rgb(9 9 12 / 0.42);
		opacity: 0;
		transform: translate3d(var(--talk-x, 0px), var(--talk-y, 0px), 0);
		animation: raven-thought-line-fade var(--thought-line-duration, 1600ms) ease forwards;
	}

	.raven-emote--heart {
		width: 1rem;
		height: 1rem;
		transform: translate3d(var(--fx-x, 0px), var(--fx-y, 0px), 0)
			scale(var(--fx-scale, 1));
		animation: raven-heart-pop 860ms steps(6, end) forwards;
		animation-delay: var(--fx-delay, 0ms);
	}

	.raven-emote--angry {
		width: 1.25rem;
		height: 1.25rem;
		transform: translate3d(var(--fx-x, 0px), var(--fx-y, 0px), 0)
			scale(var(--fx-scale, 1));
		animation: raven-angry-pop 780ms steps(5, end) forwards;
	}

	.raven-emote--thought {
		width: 2.2rem;
		height: 1.7rem;
		transform: translate3d(var(--fx-x, 0px), var(--fx-y, 0px), 0)
			scale(var(--fx-scale, 1));
		animation: raven-thought-float 2600ms steps(8, end) forwards;
	}

	@keyframes raven-heart-pop {
		0% {
			opacity: 0;
			transform: translate3d(var(--fx-x, 0px), var(--fx-y, 0px), 0)
				scale(calc(var(--fx-scale, 1) * 0.65));
		}

		18% {
			opacity: 1;
		}

		72% {
			opacity: 1;
		}

		100% {
			opacity: 0;
			transform: translate3d(
					calc(var(--fx-x, 0px) + var(--fx-drift-x, 0px)),
					calc(var(--fx-y, 0px) + var(--fx-rise, -28px)),
					0
				)
				scale(calc(var(--fx-scale, 1) * 1.08));
		}
	}

	@keyframes raven-angry-pop {
		0% {
			opacity: 0;
			transform: translate3d(var(--fx-x, 0px), var(--fx-y, 0px), 0)
				scale(calc(var(--fx-scale, 1) * 0.55));
		}

		15%,
		75% {
			opacity: 1;
		}

		100% {
			opacity: 0;
			transform: translate3d(
					calc(var(--fx-x, 0px) + var(--fx-drift-x, 0px)),
					calc(var(--fx-y, 0px) + var(--fx-rise, -22px)),
					0
				)
				scale(calc(var(--fx-scale, 1) * 1.05));
		}
	}

	@keyframes raven-thought-float {
		0% {
			opacity: 0;
			transform: translate3d(var(--fx-x, 0px), calc(var(--fx-y, 0px) + 4px), 0)
				scale(calc(var(--fx-scale, 1) * 0.88));
		}

		12%,
		82% {
			opacity: 1;
		}

		100% {
			opacity: 0;
			transform: translate3d(var(--fx-x, 0px), calc(var(--fx-y, 0px) - 10px), 0)
				scale(var(--fx-scale, 1));
		}
	}

	@keyframes raven-thought-line-fade {
		0% {
			opacity: 0;
			transform: translate3d(var(--talk-x, 0px), calc(var(--talk-y, 0px) + 6px), 0);
		}

		8%,
		78% {
			opacity: 1;
		}

		100% {
			opacity: 0;
			transform: translate3d(var(--talk-x, 0px), calc(var(--talk-y, 0px) - 10px), 0);
		}
	}

</style>

<script is:inline>
	(() => {
		if (window.__alfRavenFlockSetup) {
			return;
		}
		window.__alfRavenFlockSetup = true;

		const root = document.getElementById("raven-flock");
		const scarecrowElement = document.getElementById("raven-scarecrow");
		const scarecrowButtonElement = document.getElementById("raven-scarecrow-button");
		const nameplateButtonElement = document.getElementById("raven-nameplate-button");
		const friesButtonElement = document.getElementById("raven-fries-button");
		const drumstickElement = document.getElementById("raven-drumstick");
		if (
			!(root instanceof HTMLElement) ||
			!(friesButtonElement instanceof HTMLElement) ||
			!(drumstickElement instanceof HTMLElement)
		) {
			return;
		}

		const TARGET_SELECTOR = [
			".card-base",
			".banner-container",
