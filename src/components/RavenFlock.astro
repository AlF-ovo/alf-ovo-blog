				startFoodHover(bird);
				return;
			}

			releaseBirdFromFood(bird);
		};

		const vanishBirdWithHearts = (bird) => {
			spawnHeartBurst(bird);
			createScrapFromBird(bird);
			removeBird(bird);
			ensureAnimationLoop();
		};

		const startEscape = (bird) => {
			if (bird.state === "escaping") {
				return;
			}

			const exitPoint = getDirectExitPoint(bird);
			beginFlightSegment(bird, {
				state: "escaping",
				destination: { x: exitPoint.x, y: exitPoint.y },
				duration: randomBetween(760, 1180),
				arcHeight: randomBetween(22, 58),
				finalAction: "remove",
			});
			bird.facing = exitPoint.direction;
		};

		const handleCompletedFlightAction = (bird) => {
			if (bird.finalAction === "remove") {
				removeBird(bird);
				return;
			}

			if (bird.finalAction === "panelPerch") {
				bird.perch = bird.actionPayload?.landingSpot ?? null;
				if (!bird.perch) {
					startEscape(bird);
					return;
				}
				setBirdPanelPerched(bird);
				return;
			}

			if (bird.finalAction === "relayToPanel") {
				const landingSpot = bird.actionPayload?.landingSpot ?? null;
				if (!landingSpot) {
					startEscape(bird);
					return;
				}
				sendBirdToPanel(bird, landingSpot);
				return;
			}

			if (bird.finalAction === "foodHover") {
				bird.state = "food-hover";
				bird.element.dataset.state = "food-hover";
				return;
			}

			if (bird.finalAction === "startSkyCircling") {
				startSkyCircling(bird);
				return;
			}

			if (bird.finalAction === "foodBiteSuccess") {
				completeFoodBite(bird);
				return;
			}

			if (bird.finalAction === "foodBiteFail") {
				handleFailedFoodDash(bird);
				return;
			}

			if (bird.finalAction === "birdAttackHit") {
				resolveBirdAttack(bird);
			}
		};

		const updateMovingBird = (bird, now) => {
			const progress = clamp((now - bird.startedAt) / bird.duration, 0, 1);
			const eased =
				bird.state === "escaping" ? easeInCubic(progress) : easeOutCubic(progress);

			bird.x = lerp(bird.source.x, bird.destination.x, easeInOutSine(progress));
			bird.y =
				lerp(bird.source.y, bird.destination.y, eased) -
				Math.sin(progress * Math.PI) * bird.arcHeight;
			bird.visualShiftX = 0;
			bird.visualBob = 0;

			updateFlightFrame(bird, now);
			applyBirdFrame(bird);

			if (progress >= 1) {
				handleCompletedFlightAction(bird);
			}
		};

		const updatePanelPerchedBird = (bird, now) => {
			if (
				!isVisibleTarget(bird.perch.element) &&
				now < state.targetChangeGraceUntil
			) {
				setBirdFrame(bird, PERCHED_FRAME_INDEX);
				applyBirdFrame(bird);
				return;
			}

			if (!isVisibleTarget(bird.perch.element) || (isBirdHungry(bird) && now >= bird.leaveAt)) {
				startEscape(bird);
				return;
			}

			if (!isBirdHungry(bird)) {
				if (now >= bird.satedUntil) {
					wakeBirdHunger(bird);
					if (hasChickenLegs()) {
						startFoodHover(bird);
						return;
					}
				}
			} else if (hasChickenLegs()) {
				startFoodHover(bird);
				return;
			}

			const rect = bird.perch.element.getBoundingClientRect();
			bird.perch.y = rect.top;
			bird.y = rect.top - bird.footOffset;
			bird.x = clamp(
				bird.perch.x - bird.width / 2,
				-VIEWPORT_PADDING,
				window.innerWidth - bird.width + VIEWPORT_PADDING,
			);
			if (now >= bird.nextPerchActionAt) {
				beginPerchAction(bird, now);
			}
			const swayPhase = now * 0.0018 + bird.idlePhase;
			bird.visualShiftX = Math.round(Math.sin(swayPhase * 0.58) * 1);
			bird.visualBob = Math.round(
				Math.sin(swayPhase) * 1 + Math.sin(swayPhase * 0.47) * 0.4,
			);
			if (bird.perchAction !== "idle") {
				const elapsed = now - bird.perchActionStartedAt;
				const progress = clamp(elapsed / Math.max(1, bird.perchActionDuration), 0, 1);
				if (progress >= 1) {
					bird.perchAction = "idle";
				} else if (bird.perchAction === "hop") {
					bird.visualBob -= Math.round(Math.sin(progress * Math.PI) * 8);
					bird.visualShiftX += Math.round(Math.sin(progress * Math.PI) * 2);
				} else if (bird.perchAction === "turn-hop") {
					bird.visualBob -= Math.round(Math.sin(progress * Math.PI) * 10);
					bird.visualShiftX += Math.round(Math.cos(progress * Math.PI) * 3);
				} else if (bird.perchAction === "preen") {
					bird.visualShiftX += Math.round(Math.sin(progress * Math.PI * 3) * 3);
					bird.visualBob += Math.round(Math.sin(progress * Math.PI * 2) * 2 - 2);
				}
			}

			if (
				now - bird.perchedAt >= HUNGER_BUBBLE_DELAY_MS &&
				now - bird.lastHungerBubbleAt >= HUNGER_BUBBLE_REPEAT_MS
			) {
				bird.lastHungerBubbleAt = now;
				spawnHungerThought(bird);
			}

			setBirdFrame(bird, PERCHED_FRAME_INDEX);
			applyBirdFrame(bird);
		};

		const updateFoodHoverBird = (bird, now) => {
			if (!isBirdHungry(bird)) {
				startSatedBehavior(bird);
				return;
			}
			const sources = getFoodSources();
			const source =
				getFoodSourceByTargetKey(bird.foodTargetKey, sources) ?? sources[0] ?? null;
			if (!source) {
				releaseBirdFromFood(bird);
				return;
			}

			bird.foodTargetKey = source.targetKey;
			if (now >= bird.nextFoodHoverShiftAt) {
				retargetFoodHoverDrift(bird, source, now);
			}
			const waitPoint = getFoodWaitPoint(bird, source);
			const orbitPhase = now * 0.0032 + bird.idlePhase;
			const isGroundFood = source.mode === "active";
			const targetX = isGroundFood
				? waitPoint.x +
					bird.foodHoverOffsetX +
					Math.round(Math.sin(orbitPhase * 0.62) * 2)
				: waitPoint.x +
					bird.foodHoverOffsetX +
					Math.round(Math.cos(orbitPhase) * 5);
			const targetY = isGroundFood
				? waitPoint.y +
					bird.foodHoverOffsetY +
					Math.round(Math.sin(orbitPhase * 0.48) * 2)
				: waitPoint.y +
					bird.foodHoverOffsetY +
					Math.round(Math.sin(orbitPhase * 1.2) * 6);
			bird.facing = targetX >= bird.x ? 1 : -1;
			bird.x = lerp(bird.x, targetX, isGroundFood ? bird.hoverTightness : bird.hoverTightness * 0.74);
			bird.y = lerp(bird.y, targetY, isGroundFood ? bird.hoverTightness : bird.hoverTightness * 0.72);
			if (isGroundFood) {
				const swayPhase = now * 0.0017 + bird.idlePhase;
				bird.visualShiftX = Math.round(Math.sin(swayPhase * 0.54) * 2);
				bird.visualBob = Math.round(
					Math.sin(swayPhase) * 2 + Math.sin(swayPhase * 0.46) * 0.65,
				);
				setBirdFrame(bird, PERCHED_FRAME_INDEX);
			} else {
				bird.visualShiftX = 0;
				bird.visualBob = 0;
				updateFlightFrame(bird, now);
			}
			applyBirdFrame(bird);
		};
		const reconcileFoodDrivenFlock = () => {
			if (hasChickenLegs()) {
				state.lastHadChickenLegs = true;
				state.foodlessRetainTarget = 0;
			} else {
				if (!state.lastHadChickenLegs && state.foodlessRetainTarget === 0) {
					state.birds.forEach((bird) => {
						if (
							bird.state === "food-hover" ||
							bird.state === "food-approaching" ||
							bird.state === "food-dash" ||
							bird.state === "bird-attack" ||
							bird.state === "sky-circling"
						) {
							startEscape(bird);
						}
					});
					return;
				}
				if (state.lastHadChickenLegs) {
					state.lastHadChickenLegs = false;
					state.foodlessRetainTarget = 7 + (Math.random() < 0.5 ? 0 : 1);
				}
				const settledBirds = state.birds
					.filter((bird) => bird.state !== "escaping")
					.sort((left, right) => left.id - right.id);
				const retainedBirds = new Set(
					settledBirds.slice(0, Math.min(state.foodlessRetainTarget, settledBirds.length)),
				);
				settledBirds.forEach((bird) => {
					if (retainedBirds.has(bird)) {
						if (
							bird.state === "food-hover" ||
							bird.state === "food-approaching" ||
							bird.state === "food-dash" ||
							bird.state === "bird-attack" ||
							bird.state === "sky-circling"
						) {
							const landingSpot = chooseLandingSpot({ excludeBird: bird });
							if (landingSpot) {
								sendBirdToPanel(bird, landingSpot, { doubleHop: Math.random() < 0.28 });
							} else {
								startEscape(bird);
							}
						}
						return;
					}
					startEscape(bird);
				});
			}

			const maxBirdCount = getMaxBirdCount();
			const excessBirds = state.birds
				.filter((bird) => bird.state !== "escaping")
				.sort((left, right) => right.id - left.id)
				.slice(maxBirdCount);
			excessBirds.forEach((bird) => {
				startEscape(bird);
			});
		};

		const createBird = () => {
			const element = document.createElement("div");
			element.className = "raven-bird";

			const sprite = document.createElement("div");
			sprite.className = "raven-bird__sprite";
			element.appendChild(sprite);
			const carryElement = document.createElement("div");
			carryElement.className = "raven-bird__carry";
			carryElement.dataset.visible = "false";
			element.appendChild(carryElement);

			const sizeScale = randomBetween(0.92, 1.12);
			const initialWidth = BASE_BIRD_WIDTH * sizeScale;
			const source = getSkyEntryPoint(initialWidth);
			const rareColorRoll = Math.random();
			const colorVariant =
				rareColorRoll < 0.1
					? {
							hueRotate: randomBetween(-8, 6).toFixed(1),
							saturate: randomBetween(0.08, 0.18).toFixed(2),
							brightness: randomBetween(1.62, 1.86).toFixed(2),
						}
					: rareColorRoll < 0.2
						? {
								hueRotate: randomBetween(-28, -14).toFixed(1),
								saturate: randomBetween(1.18, 1.34).toFixed(2),
								brightness: randomBetween(1.18, 1.34).toFixed(2),
							}
						: {
								hueRotate: randomBetween(-9, 10).toFixed(1),
								saturate: randomBetween(0.94, 1.08).toFixed(2),
								brightness: randomBetween(0.94, 1.06).toFixed(2),
							};

			const bird = {
				id: state.nextBirdId++,
				element,
				sprite,
				carryElement,
				state: "spawning",
				source,
				destination: source,
				perch: null,
				x: source.x,
				y: source.y,
				width: BASE_BIRD_WIDTH * sizeScale,
				height: BASE_BIRD_HEIGHT * sizeScale,
				footOffset: BASE_FOOT_OFFSET_Y * sizeScale,
				facing: 1,
				startedAt: performance.now(),
				duration: 0,
				arcHeight: 0,
				leaveAt: 0,
				perchedAt: 0,
				frameIndex: -1,
				frameCursor: Math.floor(Math.random() * FLIGHT_SEQUENCE.length),
				nextFrameAt: performance.now(),
				finalAction: "remove",
				actionPayload: null,
				visualShiftX: 0,
				visualBob: 0,
				idlePhase: randomBetween(0, Math.PI * 2),
				foodSlotIndex: 0,
				foodTargetKey: null,
				foodHoverOffsetX: 0,
				foodHoverOffsetY: 0,
				nextFoodHoverShiftAt: 0,
				hasEatenFood: false,
				foodEatenCount: 0,
				foodBusyUntil: 0,
				lastHungerBubbleAt: 0,
				perchAction: "idle",
				perchActionStartedAt: 0,
				perchActionDuration: 0,
				nextPerchActionAt: 0,
				appetite: "hungry",
				satedUntil: 0,
				satedBehavior: "none",
				carryingFoodKind: null,
				circlingCenterX: source.x,
				circlingCenterY: source.y,
				circlingRadiusX: 0,
				circlingRadiusY: 0,
				circlingSpeed: 0,
				circlingDirection: 1,
				dashDurationFactor: randomBetween(0.84, 1.18),
				dashArcFactor: randomBetween(0.8, 1.35),
				hoverTightness: randomBetween(0.09, 0.16),
				greed: randomBetween(0, 1),
				baseScale: sizeScale,
				growthScale: 1,
				recentPerchElements: [],
				colorVariant,
			};

			updateBirdDimensions(bird);
			applyBirdColorVariant(bird);
			setBirdFrame(bird, FLIGHT_SEQUENCE[bird.frameCursor]);
			applyBirdFrame(bird);
			return bird;
		};

		const maybeSpawnBird = ({ instantPerch = false } = {}) => {
			if (state.birds.length >= getMaxBirdCount()) {
				return;
			}

			if (!hasChickenLegs()) {
				const landingSpot = chooseLandingSpot();
				if (!landingSpot) {
					return;
				}

				const bird = createBird();
				state.birds.push(bird);
				root.appendChild(bird.element);
				updateDrumstickVisibility();
				if (instantPerch) {
					bird.perch = landingSpot;
					bird.destination = getPanelDestination(landingSpot, bird);
					setBirdPanelPerched(bird);
				} else {
					sendBirdToPanel(bird, landingSpot);
				}
				ensureAnimationLoop();
				return;
			}

			const bird = createBird();
			state.birds.push(bird);
			root.appendChild(bird.element);
			updateDrumstickVisibility();
			startFoodHover(bird);
			ensureAnimationLoop();
		};

		const processScheduledSpawns = ({
			now = Date.now(),
			instantPerch = false,
		} = {}) => {
			const spawnIntervalMs = getSpawnIntervalMs();
			if (state.nextSpawnAt === 0) {
				state.nextSpawnAt = now + spawnIntervalMs;
				return;
			}
			if (hasChickenLegs()) {
				state.nextSpawnAt = Math.min(state.nextSpawnAt, now + spawnIntervalMs);
			}

			let safety = 0;
			while (now >= state.nextSpawnAt && safety < getMaxBirdCount()) {
				const batchCount = Math.min(
					getSpawnBurstCount(),
					Math.max(0, getMaxBirdCount() - state.birds.length),
				);
				for (let index = 0; index < batchCount; index += 1) {
					maybeSpawnBird({ instantPerch: instantPerch && index === 0 });
				}
				state.nextSpawnAt += getSpawnIntervalMs();
				safety += 1;
			}
		};

		const spawnInitialBird = () => {
			if (state.initialSpawnDone) {
				return;
			}

			state.initialSpawnDone = true;
			const trySpawn = () => {
				const beforeCount = state.birds.length;
				maybeSpawnBird({ instantPerch: true });
				if (state.birds.length === beforeCount) {
					window.setTimeout(trySpawn, 1800);
					return;
				}
				state.nextSpawnAt = Date.now() + getSpawnIntervalMs();
			};
			window.setTimeout(
				trySpawn,
				randomBetween(INITIAL_SPAWN_MIN_MS, INITIAL_SPAWN_MAX_MS),
			);
		};

		const targetsSharePosition = (beforeTarget, afterTarget) => {
			const dx = Math.abs(beforeTarget.rect.left - afterTarget.rect.left);
			const dy = Math.abs(beforeTarget.rect.top - afterTarget.rect.top);
			const dw = Math.abs(beforeTarget.rect.width - afterTarget.rect.width);
			const dh = Math.abs(beforeTarget.rect.height - afterTarget.rect.height);
			return (
				dx <= TARGET_POSITION_EPSILON &&
				dy <= TARGET_POSITION_EPSILON &&
				dw <= TARGET_POSITION_EPSILON &&
				dh <= TARGET_POSITION_EPSILON
			);
		};

		const reactToTargetChange = (bird, stableTargets, freshTargets) => {
			const roll = Math.random();
			const stableLandingSpot = chooseLandingSpotFromCandidates(stableTargets, {
				excludeBird: bird,
			});
			const freshLandingSpot = chooseLandingSpotFromCandidates(freshTargets, {
				excludeBird: bird,
			});

			if (roll < ESCAPE_ON_TARGET_CHANGE_PROBABILITY) {
				startEscape(bird);
				return;
			}

			if (
				roll <
				ESCAPE_ON_TARGET_CHANGE_PROBABILITY + STABLE_RELOCATION_PROBABILITY
			) {
				if (stableLandingSpot) {
					sendBirdToPanel(bird, stableLandingSpot);
					return;
				}
				startEscape(bird);
				return;
			}

			if (freshLandingSpot) {
				sendBirdToPanel(bird, freshLandingSpot, { doubleHop: true });
				return;
			}

			if (stableLandingSpot) {
				sendBirdToPanel(bird, stableLandingSpot);
				return;
			}

			startEscape(bird);
		};

		const processClickDrivenTargetChange = (beforeTargets, token) => {
			if (token !== state.targetReactionToken) {
				return;
			}

			const afterTargets = snapshotTargets();
			const beforeMap = new Map(beforeTargets.map((target) => [target.element, target]));
			const afterMap = new Map(afterTargets.map((target) => [target.element, target]));
			const removedTargets = beforeTargets.filter(
				(target) => !afterMap.has(target.element),
			);
			const stableTargets = afterTargets.filter((target) => {
				const previousTarget = beforeMap.get(target.element);
				return previousTarget && targetsSharePosition(previousTarget, target);
			});
			const freshTargets = afterTargets.filter((target) => {
				const previousTarget = beforeMap.get(target.element);
				return !previousTarget || !targetsSharePosition(previousTarget, target);
			});

			if (removedTargets.length === 0 && freshTargets.length === 0) {
				state.targetChangeGraceUntil = 0;
				return;
			}

			state.birds.slice().forEach((bird) => {
				if (bird.state !== "panel-perched" || !(bird.perch?.element instanceof HTMLElement)) {
					return;
				}

				if (!beforeMap.has(bird.perch.element) || afterMap.has(bird.perch.element)) {
					return;
				}

				reactToTargetChange(bird, stableTargets, freshTargets);
			});

			state.targetChangeGraceUntil = 0;
			if (state.birds.length > 0) {
				ensureAnimationLoop();
			}
		};

		const scheduleClickDrivenTargetChangeCheck = (event) => {
			const target = event.target;
			if (!(target instanceof Element) || root.contains(target)) {
				return;
			}

			const beforeTargets = snapshotTargets();
			const token = state.targetReactionToken + 1;
			state.targetReactionToken = token;
			state.targetChangeGraceUntil = performance.now() + TARGET_REACTION_GRACE_MS;

			window.setTimeout(() => {
				processClickDrivenTargetChange(beforeTargets, token);
			}, TARGET_REACTION_DELAY_MS);
		};

		const activateFoodDrag = () => {
			state.food.mode = "dragging";
			state.food.scale = state.food.heldScale;
			state.food.bitesTotal = calculateFoodBites(state.food.scale);
			state.food.bitesRemaining = state.food.bitesTotal;
			state.food.lastBiteAt = -FOOD_BITE_COOLDOWN_MS;
			state.food.nextContestAt =
				performance.now() + randomBetween(FOOD_WAIT_GATHER_DELAY_MS, 320);
			resetFoodMotionState(state.food);
			applyFoodFrame();
			summonBirdsToFood();
		};
		const dropDraggedFood = () => {
			state.food.dragPointerId = null;
			createDroppedFoodItem();
			resetFoodToHome();
			summonBirdsToFood();
			ensureAnimationLoop();
		};
		const liftScrapAsFood = (scrap, event) => {
			if (!(scrap?.element instanceof HTMLElement) || state.food.mode !== "idle") {
				return;
			}

			event.preventDefault();
			state.food.mode = "dragging";
			state.food.dragPointerId = event.pointerId;
			state.food.pointerStartX = event.clientX;
			state.food.pointerStartY = event.clientY;
			state.food.pendingPointerX = event.clientX;
			state.food.pendingPointerY = event.clientY;
			state.food.scale = scrap.scale;
			state.food.heldScale = scrap.scale;
			state.food.foodKind = scrap.foodKind ?? "scrap";
			state.food.bitesTotal = scrap.bitesTotal;
			state.food.bitesRemaining = scrap.bitesRemaining;
			state.food.lastBiteAt = -FOOD_BITE_COOLDOWN_MS;
			state.food.nextContestAt =
				performance.now() + randomBetween(FOOD_WAIT_GATHER_DELAY_MS, 320);
			state.food.x = scrap.x;
			state.food.y = scrap.y;
			resetFoodMotionState(state.food);
			state.food.dragOffsetX = event.clientX - state.food.x;
			state.food.dragOffsetY = event.clientY - state.food.y;
			state.food.dragSourceScrapId = scrap.id;
			try {
				drumstickElement.setPointerCapture(event.pointerId);
			} catch {
				// Pointer capture is optional but avoids getting stuck in dragging mode.
			}
			removeScrap(scrap);
			applyFoodFrame();
			summonBirdsToFood();
			ensureAnimationLoop();
		};

		const handleDrumstickPointerDown = (event) => {
			if (state.food.mode !== "idle") {
				return;
			}

			event.preventDefault();
			state.food.mode = "holding";
			state.food.dragPointerId = event.pointerId;
			state.food.pointerStartX = event.clientX;
			state.food.pointerStartY = event.clientY;
			state.food.pendingPointerX = event.clientX;
			state.food.pendingPointerY = event.clientY;
			state.food.dragOffsetX = event.clientX - state.food.x;
			state.food.dragOffsetY = event.clientY - state.food.y;
			state.food.holdStartedAt = performance.now();
			state.food.heldScale = FOOD_MIN_SCALE;
			state.food.scale = FOOD_MIN_SCALE;
			state.food.foodKind = "drumstick";
			state.food.bitesTotal = FOOD_BASE_BITES;
			state.food.bitesRemaining = FOOD_BASE_BITES;
			state.food.dragSourceScrapId = null;
			resetFoodMotionState(state.food);
			try {
				drumstickElement.setPointerCapture(event.pointerId);
			} catch {
				// Pointer capture is optional but avoids getting stuck in dragging mode.
			}
			applyFoodFrame();
			ensureAnimationLoop();
		};

		const handleScrapPointerDown = (event) => {
			const target = event.target;
			if (!(target instanceof Element)) {
				return;
			}

			const scrapElement = target.closest(".raven-scrap");
			if (!(scrapElement instanceof HTMLElement)) {
				return;
			}

			const scrap = state.scraps.find((item) => item.element === scrapElement);
			if (!scrap || (scrap.mode !== "active" && scrap.mode !== "falling")) {
				return;
			}

			liftScrapAsFood(scrap, event);
		};

		const handlePointerMove = (event) => {
			if (event.pointerId !== state.food.dragPointerId) {
				return;
			}

			state.food.pendingPointerX = event.clientX;
			state.food.pendingPointerY = event.clientY;
			if (state.food.mode === "holding") {
				const distance = Math.hypot(
					event.clientX - state.food.pointerStartX,
					event.clientY - state.food.pointerStartY,
				);
				if (distance >= FOOD_DRAG_ACTIVATION_DISTANCE) {
					activateFoodDrag();
				}
				return;
			}

			if (state.food.mode === "dragging") {
				state.food.x = clamp(
					event.clientX - state.food.dragOffsetX,
					0,
					window.innerWidth - getFoodSize(),
				);
				state.food.y = clamp(
					event.clientY - state.food.dragOffsetY,
					0,
					window.innerHeight - getFoodSize(),
				);
				applyFoodFrame();
			}
		};

		const handlePointerUp = (event) => {
			if (event.pointerId !== state.food.dragPointerId) {
				return;
			}
			releaseFoodPointerCapture(event.pointerId);

			if (state.food.mode === "holding") {
				spawnTopDroppedDrumstick();
				resetFoodToHome();
				summonBirdsToFood();
				ensureAnimationLoop();
				return;
			}

			if (state.food.mode !== "dragging") {
				state.food.dragPointerId = null;
				return;
			}

			dropDraggedFood();
		};
		const handleFoodPointerAbort = () => {
			if (state.food.dragPointerId === null) {
				return;
			}
			releaseFoodPointerCapture(state.food.dragPointerId);
			if (state.food.mode === "holding") {
				resetFoodToHome();
				return;
			}
			if (state.food.mode === "dragging") {
				dropDraggedFood();
			}
		};

		const updateFood = (now) => {
			if (state.food.mode === "idle") {
				return;
			}

			if (state.food.mode === "holding") {
				state.food.heldScale = calculateFoodScaleFromHold(
					now - state.food.holdStartedAt,
				);
				state.food.scale = state.food.heldScale;
				state.food.bitesTotal = calculateFoodBites(state.food.scale);
				state.food.bitesRemaining = state.food.bitesTotal;
				state.food.x = state.food.homeX;
				state.food.y = state.food.homeY;
				resetFoodMotionState(state.food);
				applyFoodFrame();
				return;
			}

			if (state.food.mode === "resetting") {
				if (now >= state.food.resetAt) {
					resetFoodToHome();
				}
				return;
			}

			if (state.food.mode === "spent") {
				state.food.x += state.food.impulseX;
				state.food.y += state.food.vy;
				state.food.impulseX *= 0.992;
				state.food.vy = Math.min(
					SCRAP_FALL_TERMINAL_VELOCITY,
					state.food.vy + SCRAP_FALL_GRAVITY * 0.9,
				);
				updateFoodMotionState(state.food);
				applyFoodFrame();
				if (
					state.food.y > window.innerHeight + getFoodSize() + 12 ||
					state.food.x < -getFoodSize() * 1.6 ||
					state.food.x > window.innerWidth + getFoodSize() * 1.6
				) {
					resetFoodToHome();
				}
				return;
			}

			if (state.food.mode === "dragging") {
				updateFoodMotionState(state.food);
				applyFoodFrame();
			}
		};
		const settleScrapOnSurface = (scrap, supportY, impactVy, now, isFloor = false) => {
			const size = getScrapSize(scrap);
			scrap.y = supportY - size;
			if (isFloor) {
				const edgeInset = getBottomExitInset(size);
				if (scrap.x <= edgeInset || scrap.x + size >= window.innerWidth - edgeInset) {
					sendScrapOffscreen(
						scrap,
						scrap.x + size * 0.5 < window.innerWidth * 0.5 ? -1 : 1,
					);
					return;
				}
			}

			scrap.floorBounceCount += 1;
			scrap.bounceOffsetY = Math.min(
				scrap.bounceOffsetY,
				-Math.min(18, Math.max(5, impactVy * 0.34)),
			);
			scrap.bounceVelocityY = Math.min(
				scrap.bounceVelocityY,
				-Math.max(1.4, impactVy * 0.22),
			);
			if (
				scrap.floorBounceCount >= 2 &&
				impactVy <= SCRAP_SETTLE_VELOCITY &&
				Math.abs(scrap.vx) <= SCRAP_SETTLE_DRIFT
			) {
				scrap.x = clamp(scrap.x, 0, Math.max(0, window.innerWidth - size));
				scrap.vx = 0;
				scrap.vy = 0;
				scrap.mode = "active";
				scrap.rotationVelocity *= -0.36;
				scrap.nextContestAt = now + randomBetween(280, 560);
				return;
			}

			scrap.vy = -Math.max(3.8, impactVy * SCRAP_FLOOR_BOUNCE_DAMPING);
			scrap.vx *= 0.9;
			scrap.rotationVelocity *= -0.58;
		};
		const sendScrapOffscreen = (scrap, direction) => {
			scrap.mode = "dropping";
			scrap.floorBounceCount = 0;
			scrap.vx = direction * Math.max(4.8, Math.abs(scrap.vx) * 0.82 + 1.6);
			scrap.vy = Math.max(1.6, Math.abs(scrap.vy) * 0.18);
			scrap.rotationVelocity += direction * randomBetween(0.7, 1.6);
			scrap.bounceOffsetY = 0;
			scrap.bounceVelocityY = 0;
		};
		const updateScraps = (now) => {
			state.scraps.slice().forEach((scrap) => {
				if (scrap.mode === "falling") {
					const size = getScrapSize(scrap);
					const bottomY = window.innerHeight - size - 8;
					const previousY = scrap.y;
					scrap.x += scrap.vx;
					scrap.y += scrap.vy;
					scrap.vx *= SCRAP_HORIZONTAL_DRAG;
					scrap.vy = Math.min(SCRAP_FALL_TERMINAL_VELOCITY, scrap.vy + SCRAP_FALL_GRAVITY);
					scrap.rotationVelocity +=
						(scrap.rotationVelocity >= 0 ? 0.08 : -0.08) +
						Math.sin(now * 0.006 + scrap.id) * 0.028;
					if (scrap.x <= 0) {
						scrap.x = 0;
						scrap.vx = Math.abs(scrap.vx) * SCRAP_SIDE_BOUNCE_DAMPING;
						scrap.rotationVelocity += randomBetween(0.8, 1.6);
					} else if (scrap.x + size >= window.innerWidth) {
						scrap.x = window.innerWidth - size;
						scrap.vx = -Math.abs(scrap.vx) * SCRAP_SIDE_BOUNCE_DAMPING;
						scrap.rotationVelocity -= randomBetween(0.8, 1.6);
					}
					const collidedSupport = state.scraps
						.filter(
							(other) =>
								other !== scrap &&
								other.mode !== "dropping" &&
								other.bitesRemaining > 0,
						)
						.sort((left, right) => left.y - right.y)
						.find((other) => {
							const otherSize = getScrapSize(other);
							const overlapsX =
								scrap.x + size > other.x + 6 && scrap.x < other.x + otherSize - 6;
							if (!overlapsX) {
								return false;
							}
							const previousBottom = previousY + size;
							const otherTop = other.y;
							return previousBottom <= otherTop + 10 && scrap.y + size >= otherTop;
						});
					if (collidedSupport) {
						const impactVy = Math.max(0, scrap.vy);
						settleScrapOnSurface(scrap, collidedSupport.y, impactVy, now, false);
						updateFoodMotionState(scrap);
						updateScrapFrame(scrap);
						return;
					}
					state.scraps.forEach((other) => {
						if (
							other === scrap ||
							other.mode === "dropping" ||
							other.bitesRemaining <= 0
						) {
							return;
						}
						const otherSize = getScrapSize(other);
						if (
							!rectsOverlap(
								{ x: scrap.x, y: scrap.y, width: size, height: size },
								{ x: other.x, y: other.y, width: otherSize, height: otherSize },
								-6,
							)
						) {
							return;
						}
						const scrapCenterX = scrap.x + size * 0.5;
						const otherCenterX = other.x + otherSize * 0.5;
						const pushDirection = scrapCenterX >= otherCenterX ? 1 : -1;
						scrap.x = clamp(
							scrap.x + pushDirection * Math.max(3, Math.min(10, Math.abs(scrap.vx) * 1.6 + 2)),
							0,
							Math.max(0, window.innerWidth - size),
						);
						scrap.vx = pushDirection * Math.max(0.8, Math.abs(scrap.vx) * 0.72);
					});
					updateFoodMotionState(scrap);
					if (scrap.y >= bottomY) {
						const impactVy = Math.max(0, scrap.vy);
						settleScrapOnSurface(scrap, bottomY + size, impactVy, now, true);
					}
					updateScrapFrame(scrap);
					return;
				}

				if (scrap.mode === "dropping") {
					const size = getScrapSize(scrap);
					scrap.x += scrap.vx;
					scrap.y += scrap.vy;
					scrap.vx *= 0.992;
					scrap.vy = Math.min(
						SCRAP_FALL_TERMINAL_VELOCITY + 4,
						scrap.vy + SCRAP_FALL_GRAVITY,
					);
					scrap.rotationVelocity +=
						(scrap.rotationVelocity >= 0 ? 0.05 : -0.05) * 0.9;
					updateFoodMotionState(scrap);
					if (
						scrap.y > window.innerHeight + size + 12 ||
						scrap.x < -size * 1.8 ||
						scrap.x > window.innerWidth + size * 1.8
					) {
						removeScrap(scrap);
						return;
					}
					updateScrapFrame(scrap);
					return;
				}

				if (scrap.mode === "spent") {
					const size = getScrapSize(scrap);
					scrap.x += scrap.vx;
					scrap.y += scrap.vy;
					scrap.vx *= 0.992;
					scrap.vy = Math.min(
						SCRAP_FALL_TERMINAL_VELOCITY,
						scrap.vy + SCRAP_FALL_GRAVITY * 0.9,
					);
					updateFoodMotionState(scrap);
					if (
						scrap.y > window.innerHeight + size + 12 ||
						scrap.x < -size * 1.8 ||
						scrap.x > window.innerWidth + size * 1.8
					) {
						removeScrap(scrap);
						return;
					}
					updateScrapFrame(scrap);
					return;
				}

				if (scrap.mode === "active") {
					updateFoodMotionState(scrap);
					updateScrapFrame(scrap);
				}
			});
		};

		const maybeRunFoodContest = (now) => {
			const sources = getFoodSources();
			if (sources.length === 0) {
				return;
			}

			sources.forEach((source) => {
				const foodEntity = getFoodEntityFromSource(source);
				if (!foodEntity) {
					return;
				}
				if (now < (foodEntity.nextContestAt ?? 0)) {
					return;
				}
				if (!isFoodContestable(source)) {
					foodEntity.nextContestAt = now + randomBetween(180, 320);
					return;
				}

				const candidates = shuffle(
					state.birds.filter(
						(bird) =>
							isBirdHungry(bird) &&
							bird.foodTargetKey === source.targetKey &&
							(bird.state === "food-hover" || bird.state === "food-approaching") &&
							now >= bird.foodBusyUntil &&
							!isGroundFlankBird(bird, source),
					),
				);
				if (candidates.length === 0) {
					foodEntity.nextContestAt =
						now + randomBetween(FOOD_CONTEST_MIN_MS * 0.24, FOOD_CONTEST_MAX_MS * 0.26);
					return;
				}

				let participantCount = 1;
				if (candidates.length >= 2 && Math.random() < 0.9) {
					participantCount = 2;
				}
				if (candidates.length >= 4 && Math.random() < 0.54) {
					participantCount = 3;
				}
				if (candidates.length >= 5 && Math.random() < 0.24) {
					participantCount = 4;
				}
				const participants = candidates.slice(
					0,
					Math.min(participantCount, candidates.length),
				);
				const winner = source.bitesRemaining > 0 ? participants[0] : null;

				participants.forEach((bird, index) => {
					bird.foodBusyUntil = now + randomBetween(260, 540);
					startFoodDash(bird, {
						source,
						success: bird === winner,
						index,
					});
				});
				foodEntity.nextContestAt =
					now + randomBetween(FOOD_CONTEST_MIN_MS * 0.28, FOOD_CONTEST_MAX_MS * 0.38);
			});
		};

		const reconcileBirdTargets = () => {
			state.birds.forEach((bird) => {
				if (
					bird.state === "panel-perched" &&
					!isVisibleTarget(bird.perch.element) &&
					performance.now() >= state.targetChangeGraceUntil
				) {
					startEscape(bird);
				}
			});
			if (
				state.birds.length > 0 ||
				state.food.mode !== "idle" ||
				state.scraps.length > 0
			) {
				ensureAnimationLoop();
			}
		};

		const handleBirdClick = (event) => {
			const target = event.target;
			if (!(target instanceof Element)) {
				return;
			}

			const birdElement = target.closest(".raven-bird");
			if (!(birdElement instanceof HTMLElement)) {
				return;
			}

			const bird = state.birds.find((item) => item.element === birdElement);
			if (!bird) {
				return;
			}

			event.preventDefault();
			event.stopPropagation();
			const roll = Math.random();
			const probabilities = getClickInteractionProbabilities(bird);
			const alternateLandingSpot = chooseLandingSpot({
				excludeBird: bird,
				excludeElement:
					bird.perch?.element instanceof HTMLElement ? bird.perch.element : null,
			});

			if (roll < probabilities.relocateProbability && alternateLandingSpot) {
				sendBirdToPanel(bird, alternateLandingSpot);
				ensureAnimationLoop();
				return;
			}

			if (
				roll <
				probabilities.relocateProbability + probabilities.escapeProbability
			) {
				startEscape(bird);
				ensureAnimationLoop();
				return;
			}

			vanishBirdWithHearts(bird);
			ensureAnimationLoop();
		};

		const tick = (now) => {
			updateFood(now);
			updateScraps(now);
			reconcileFoodDrivenFlock();
			maybeTriggerSharedThought(now);
			if (isFoodDetected()) {
				assignFoodSlots(getFoodSources());
				maybeRunFoodContest(now);
			}

			state.birds.slice().forEach((bird) => {
				if (
					bird.state === "approaching" ||
					bird.state === "relocating" ||
					bird.state === "escaping" ||
					bird.state === "food-approaching" ||
					bird.state === "food-dash" ||
					bird.state === "bird-attack"
				) {
					updateMovingBird(bird, now);
					return;
				}

				if (bird.state === "panel-perched") {
					updatePanelPerchedBird(bird, now);
					return;
				}

				if (bird.state === "food-hover") {
					updateFoodHoverBird(bird, now);
					return;
				}

				if (bird.state === "sky-circling") {
					updateSkyCirclingBird(bird, now);
				}
			});

			if (
				state.birds.length === 0 &&
				state.food.mode === "idle" &&
				state.scraps.length === 0
			) {
				state.rafId = 0;
				return;
			}

			state.rafId = window.requestAnimationFrame(tick);
		};

		const ensureAnimationLoop = () => {
			if (state.rafId !== 0) {
				return;
			}
			state.rafId = window.requestAnimationFrame(tick);
		};

		drumstickElement.addEventListener("pointerdown", handleDrumstickPointerDown);
		root.addEventListener("pointerdown", handleScrapPointerDown);
		window.addEventListener("pointermove", handlePointerMove, { passive: true });
		window.addEventListener("pointerup", handlePointerUp, { passive: true });
		window.addEventListener("pointercancel", handlePointerUp, { passive: true });
		window.addEventListener("blur", handleFoodPointerAbort);
		document.addEventListener("click", scheduleClickDrivenTargetChangeCheck, true);
		window.addEventListener("resize", () => {
			syncFoodHomePosition();
			if (state.food.mode === "dragging") {
				state.food.x = clamp(state.food.x, 0, window.innerWidth - getFoodSize());
				state.food.y = clamp(state.food.y, 0, getFoodBottomY());
				applyFoodFrame();
			}
			state.scraps.forEach((scrap) => {
				const scrapSize = getScrapSize(scrap);
				scrap.x = clamp(scrap.x, 0, window.innerWidth - scrapSize);
				scrap.y = clamp(scrap.y, 0, getFoodBottomY(scrapSize));
				updateScrapFrame(scrap);
			});
			reconcileBirdTargets();
		});
		document.addEventListener("astro:page-load", () => {
			reconcileBirdTargets();
			processScheduledSpawns();
		});
		document.addEventListener("DOMContentLoaded", () => {
			reconcileBirdTargets();
			processScheduledSpawns();
		});
		document.addEventListener("visibilitychange", () => {
			if (document.hidden) {
				handleFoodPointerAbort();
				return;
			}
			if (!document.hidden) {
				processScheduledSpawns({ instantPerch: true });
			}
		});
		root.addEventListener("click", handleBirdClick);

		syncFoodHomePosition();
		resetFoodToHome();
		scheduleNextThought();
		spawnInitialBird();
		state.spawnHeartbeatId = window.setInterval(() => {
			processScheduledSpawns();
		}, SPAWN_HEARTBEAT_MS);
	})();
</script>
