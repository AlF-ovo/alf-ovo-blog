			if (hasChickenLegs()) {
				startFoodHover(bird);
				return;
			}

			releaseBirdFromFood(bird);
		};

		const vanishBirdWithHearts = (bird) => {
			spawnHeartBurst(bird);
			createScrapFromBird(bird);
			removeBird(bird);
			ensureAnimationLoop();
		};

		const startEscape = (bird, options = {}) => {
			if (isSelectedBird(bird) && options.force !== true) {
				if (state.selection.scrollActive) {
					dockSelectedBirdForScroll(bird);
					return;
				}
				const landingSpot = getPreferredSelectedLandingSpot(bird);
				if (landingSpot) {
					bird.perch = landingSpot;
					bird.destination = getPanelDestination(landingSpot, bird);
					setBirdPanelPerched(bird);
					return;
				}
				startSkyCircling(bird, bird.carryingFoodKind ?? "drumstick");
				return;
			}
			if (bird.state === "escaping") {
				return;
			}

			const exitPoint = getDirectExitPoint(bird);
			beginFlightSegment(bird, {
				state: "escaping",
				destination: { x: exitPoint.x, y: exitPoint.y },
				duration: randomBetween(760, 1180),
				arcHeight: randomBetween(22, 58),
				finalAction: "remove",
			});
			bird.facing = exitPoint.direction;
			updateBirdHungerBubble(bird);
		};

		const handleCompletedFlightAction = (bird) => {
			if (bird.finalAction === "remove") {
				removeBird(bird);
				return;
			}
			if (bird.finalAction === "carryAwayReturn") {
				clearBirdCarry(bird);
				startSkyCircling(bird, bird.actionPayload?.sourceFoodKind ?? "fries");
				return;
			}

			if (bird.finalAction === "panelPerch") {
				bird.perch = bird.actionPayload?.landingSpot ?? null;
				if (!bird.perch) {
					startEscape(bird);
					return;
				}
				setBirdPanelPerched(bird);
				return;
			}

			if (bird.finalAction === "relayToPanel") {
				const landingSpot = bird.actionPayload?.landingSpot ?? null;
				if (!landingSpot) {
					startEscape(bird);
					return;
				}
				sendBirdToPanel(bird, landingSpot);
				return;
			}

			if (bird.finalAction === "foodHover") {
				bird.state = "food-hover";
				bird.element.dataset.state = "food-hover";
				return;
			}

			if (bird.finalAction === "startSkyCircling") {
				startSkyCircling(bird, bird.actionPayload?.sourceFoodKind ?? "drumstick");
				return;
			}

			if (bird.finalAction === "alfSupplyStart") {
				bird.state = "alf-supplying";
				bird.element.dataset.state = "alf-supplying";
				if (!bird.alfSupplyPlan) {
					bird.alfSupplyPlan = bird.actionPayload?.plan ?? chooseAlfSupplyPlan();
				}
				if (bird.alfSupplyPlan) {
					bird.alfSupplyPlan.totalDrops =
						bird.alfSupplyPlan.totalDrops ?? bird.alfSupplyPlan.remaining;
					bird.alfSupplyPlan.dropped = bird.alfSupplyPlan.dropped ?? 0;
					bird.alfSupplyPlan.returnPoint =
						bird.alfSupplyPlan.returnPoint ?? getAlfControlPoint(bird, bird.alfSupplyPlan.kind);
					bird.alfSupplyPlan.stepAt = performance.now() + 220;
				}
				return;
			}

			if (bird.finalAction === "alfSupplyDrop") {
				const activePlan = bird.alfSupplyPlan;
				clearBirdCarry(bird);
				spawnAlfCenteredDrumstickDrop(activePlan);
				if (activePlan) {
					activePlan.dropped = (activePlan.dropped ?? 0) + 1;
					activePlan.remaining -= 1;
					if (activePlan.remaining <= 0) {
						finishAlfSupplyRun(bird);
						return;
					}
					beginFlightSegment(bird, {
						state: "relocating",
						destination:
							activePlan.returnPoint ?? getAlfControlPoint(bird, "drumstick"),
						duration: randomBetween(420, 620),
						arcHeight: randomBetween(16, 34),
						finalAction: "alfSupplyStart",
						payload: { plan: activePlan },
					});
					return;
				}
				finishAlfSupplyRun(bird);
				return;
			}

			if (bird.finalAction === "foodBiteSuccess") {
				completeFoodBite(bird);
				return;
			}

			if (bird.finalAction === "foodBiteFail") {
				handleFailedFoodDash(bird);
				return;
			}

			if (bird.finalAction === "birdAttackHit") {
				resolveBirdAttack(bird);
			}
		};

		const updateMovingBird = (bird, now) => {
			const progress = clamp((now - bird.startedAt) / bird.duration, 0, 1);
			const eased =
				bird.state === "escaping" ? easeInCubic(progress) : easeOutCubic(progress);

			bird.x = lerp(bird.source.x, bird.destination.x, easeInOutSine(progress));
			bird.y =
				lerp(bird.source.y, bird.destination.y, eased) -
				Math.sin(progress * Math.PI) * bird.arcHeight;
			bird.visualShiftX = 0;
			bird.visualBob = 0;

			updateFlightFrame(bird, now);
			applyBirdFrame(bird);

			if (progress >= 1) {
				handleCompletedFlightAction(bird);
			}
		};

		const updatePanelPerchedBird = (bird, now) => {
			if (shouldHungryBirdLeave(bird, now)) {
				startEscape(bird, { force: true });
				return;
			}
			if (
				!isVisibleTarget(bird.perch.element) &&
				now < state.targetChangeGraceUntil
			) {
				setBirdFrame(bird, PERCHED_FRAME_INDEX);
				applyBirdFrame(bird);
				return;
			}

			if (!isVisibleTarget(bird.perch.element) || (isBirdHungry(bird) && now >= bird.leaveAt)) {
				startEscape(bird);
				return;
			}

			if (!isBirdHungry(bird)) {
				if (now >= bird.satedUntil) {
					wakeBirdHunger(bird);
					if (hasFoodForBird(bird)) {
						startFoodHover(bird);
						return;
					}
				}
			} else if (
				hasFoodForBird(bird) &&
				!isPreviewLockedBird(bird) &&
				(!isSelectedBird(bird) || now >= bird.selectedDockSettledUntil)
			) {
				startFoodHover(bird);
				return;
			}
			if (isAlfBird(bird) && now >= bird.nextAlfSupplyAt) {
				startAlfSupplyRun(bird);
				return;
			}

			const rect = bird.perch.element.getBoundingClientRect();
			bird.perch.y = rect.top;
			bird.y = rect.top - bird.footOffset;
			bird.x = clamp(
				bird.perch.x - bird.width / 2,
				-VIEWPORT_PADDING,
				window.innerWidth - bird.width + VIEWPORT_PADDING,
			);
			if (resolvePerchedCrowding(bird, now)) {
				return;
			}
			if (now >= bird.nextPerchActionAt) {
				beginPerchAction(bird, now);
			}
			const swayPhase = now * 0.0018 + bird.idlePhase;
			bird.visualShiftX = Math.round(Math.sin(swayPhase * 0.58) * 1);
			bird.visualBob = Math.round(
				Math.sin(swayPhase) * 1 + Math.sin(swayPhase * 0.47) * 0.4,
			);
			if (bird.perchAction !== "idle") {
				const elapsed = now - bird.perchActionStartedAt;
				const progress = clamp(elapsed / Math.max(1, bird.perchActionDuration), 0, 1);
				if (progress >= 1) {
					bird.perchAction = "idle";
				} else if (bird.perchAction === "hop") {
					const hopLift = Math.sin(progress * Math.PI);
					const hopTravel = easeOutCubic(progress);
					bird.visualBob -= Math.round(hopLift * 8);
					bird.visualShiftX += Math.round(hopTravel * 8) * bird.facing;
				} else if (bird.perchAction === "turn-hop") {
					const hopLift = Math.sin(progress * Math.PI);
					const hopTravel = easeOutCubic(progress);
					bird.visualBob -= Math.round(hopLift * 10);
					bird.visualShiftX += Math.round(hopTravel * 6) * bird.facing;
				} else if (bird.perchAction === "preen") {
					bird.visualShiftX += Math.round(Math.sin(progress * Math.PI * 3) * 3);
					bird.visualBob += Math.round(Math.sin(progress * Math.PI * 2) * 2 - 2);
				} else if (bird.perchAction === "chief-hop") {
					const hopLift = Math.sin(progress * Math.PI);
					const hopTravel = easeOutCubic(progress);
					bird.visualBob -= Math.round(hopLift * 9);
					bird.visualShiftX += Math.round(hopTravel * 7) * bird.facing;
				} else if (bird.perchAction === "crown-preen") {
