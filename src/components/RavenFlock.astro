		};

		const chooseLandingSpotFromCandidates = (candidates, options = {}) => {
			const { excludeBird = null, excludeElement = null } = options;
			if (candidates.length === 0) {
				return null;
			}

			const sourceCandidates =
				excludeElement instanceof HTMLElement
					? (() => {
							const filtered = candidates.filter(
								(candidate) => candidate.element !== excludeElement,
							);
							return filtered.length > 0 ? filtered : candidates;
						})()
					: candidates;

			let bestSpot = null;
			let bestScore = Number.NEGATIVE_INFINITY;

			sourceCandidates.forEach((candidate) => {
				const minX = candidate.rect.left + 22;
				const maxX = candidate.rect.right - 22;
				if (maxX <= minX) {
					return;
				}

				const sampleCount = Math.max(
					LANDING_SAMPLES_PER_TARGET,
					Math.floor((maxX - minX) / 72),
				);

				for (let index = 0; index < sampleCount; index += 1) {
					const progress = (index + 0.5) / sampleCount;
					const sampledX = clamp(
						lerp(minX, maxX, progress) + randomBetween(-10, 10),
						minX,
						maxX,
					);
					const spot = {
						element: candidate.element,
						x: sampledX,
						y: candidate.rect.top,
					};
					const score = scoreLandingSpot(spot, { excludeBird });
					if (score > bestScore) {
						bestScore = score;
						bestSpot = spot;
					}
				}
			});

			if (bestSpot) {
				return bestSpot;
			}

			const fallback =
				sourceCandidates[Math.floor(Math.random() * sourceCandidates.length)];
			return {
				element: fallback.element,
				x: (fallback.rect.left + fallback.rect.right) / 2,
				y: fallback.rect.top,
			};
		};

		const chooseLandingSpot = (options = {}) =>
			chooseLandingSpotFromCandidates(getTargetCandidates(), options);
