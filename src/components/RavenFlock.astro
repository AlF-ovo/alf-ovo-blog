				const burstCount = state.fries.burstCount;
				const wasDragging = state.fries.mode === "dragging";
				const releaseX = state.fries.x + friesButtonElement.offsetWidth * 0.5;
				const releaseY = state.fries.y + friesButtonElement.offsetHeight * 0.5;
				const pointerVelocityX = state.fries.pointerVelocityX;
				const pointerVelocityY = state.fries.pointerVelocityY;
