---

---

<div id="raven-flock" class="raven-flock" aria-hidden="true">
	<div id="raven-drumstick" class="raven-drumstick" data-mode="idle"></div>
</div>

<style is:global>
	.raven-flock {
		position: fixed;
		inset: 0;
		z-index: 65;
		pointer-events: none;
		overflow: hidden;
	}

	.raven-bird {
		position: absolute;
		left: 0;
		top: 0;
		width: 6rem;
		height: 4.5rem;
		pointer-events: auto;
		cursor: pointer;
		user-select: none;
		will-change: transform;
		filter:
			drop-shadow(0 0.65rem 1rem rgb(3 7 18 / 0.28))
			hue-rotate(var(--bird-hue-rotate, 0deg))
			saturate(var(--bird-saturate, 1))
			brightness(var(--bird-brightness, 1));
		transform-origin: 50% 88%;
	}

	.raven-bird__sprite,
	.raven-bird__sprite svg {
		display: block;
		width: 100%;
		height: 100%;
		overflow: visible;
		image-rendering: pixelated;
	}

	.raven-bird__sprite {
		transform: translate3d(
			var(--bird-body-shift-x, 0px),
			var(--bird-body-bob, 0px),
			0
		);
		transform-origin: 50% 88%;
		will-change: transform;
	}

	.raven-bird__carry {
		position: absolute;
		left: 58%;
		top: 52%;
		width: 2rem;
		height: 2rem;
		pointer-events: none;
		opacity: 0;
		transform: translate3d(-50%, -50%, 0) rotate(-18deg);
		transform-origin: 50% 50%;
		filter: drop-shadow(0 0.3rem 0.45rem rgb(15 23 42 / 0.22));
	}

	.raven-bird__carry[data-visible="true"] {
		opacity: 1;
	}

	.raven-bird[data-state="panel-perched"] {
		filter:
			drop-shadow(0 0.45rem 0.8rem rgb(3 7 18 / 0.22))
			hue-rotate(var(--bird-hue-rotate, 0deg))
			saturate(var(--bird-saturate, 1))
			brightness(var(--bird-brightness, 1));
	}

	.raven-drumstick {
		position: absolute;
		left: 0;
		top: 0;
		width: 2.75rem;
		height: 2.75rem;
		pointer-events: auto;
		cursor: grab;
		will-change: transform;
		touch-action: none;
		transform-origin: 50% 50%;
		filter: drop-shadow(0 0.5rem 0.75rem rgb(15 23 42 / 0.24));
		opacity: 1;
		transition: opacity 220ms ease;
	}

	.raven-drumstick[data-visible="false"] {
		opacity: 0;
	}

	.raven-drumstick[data-mode="holding"] {
		cursor: grabbing;
	}

	.raven-drumstick[data-mode="dragging"],
	.raven-drumstick[data-mode="falling"],
	.raven-drumstick[data-mode="active"] {
		filter: drop-shadow(0 0.7rem 1rem rgb(15 23 42 / 0.3));
	}

	.raven-drumstick[data-mode="resetting"] {
		opacity: 0;
	}

	.raven-drumstick--ghost {
		pointer-events: none;
		opacity: 0;
		filter: drop-shadow(0 0.4rem 0.65rem rgb(15 23 42 / 0.15));
	}

	.raven-drumstick--ghost[data-visible="true"] {
		opacity: 0.92;
	}

	.raven-drumstick__sprite,
	.raven-drumstick__sprite svg {
		display: block;
		width: 100%;
		height: 100%;
		image-rendering: pixelated;
	}

	.raven-drumstick__meter {
		position: absolute;
		left: 50%;
		top: 100%;
		display: flex;
		gap: 0.15rem;
		transform: translateX(-50%);
		padding-top: 0.15rem;
	}

	.raven-drumstick__pip {
		width: 0.28rem;
		height: 0.28rem;
		background: #f3d37f;
		box-shadow: 0 0 0 1px rgb(58 40 19 / 0.9);
	}

	.raven-drumstick__pip.is-spent {
		background: rgb(90 72 52 / 0.45);
		box-shadow: 0 0 0 1px rgb(36 30 22 / 0.65);
	}

	.raven-scrap {
		position: absolute;
		left: 0;
		top: 0;
		width: 1.5rem;
		height: 1.5rem;
		pointer-events: auto;
		cursor: grab;
		touch-action: none;
		will-change: transform;
		filter: drop-shadow(0 0.28rem 0.4rem rgb(15 23 42 / 0.18));
	}

	.raven-scrap--drumstick {
		width: 2.75rem;
		height: 2.75rem;
		filter: drop-shadow(0 0.5rem 0.75rem rgb(15 23 42 / 0.22));
	}

	.raven-scrap__sprite,
	.raven-scrap__sprite svg {
		display: block;
		width: 100%;
		height: 100%;
		image-rendering: pixelated;
	}

	.raven-emote {
		position: absolute;
		left: 0;
		top: 0;
		pointer-events: none;
		opacity: 0;
	}

	.raven-emote svg {
		display: block;
		width: 100%;
		height: 100%;
		image-rendering: pixelated;
	}

	.raven-thought-line {
		position: absolute;
		left: 0;
		top: 0;
		pointer-events: none;
		max-width: min(22rem, 42vw);
		color: #fff;
		font-size: 0.88rem;
		line-height: 1.35;
		font-weight: 600;
		letter-spacing: 0.01em;
		text-shadow:
			0 1px 0 rgb(9 9 12 / 0.85),
			0 2px 10px rgb(9 9 12 / 0.42);
		opacity: 0;
		transform: translate3d(var(--talk-x, 0px), var(--talk-y, 0px), 0);
		animation: raven-thought-line-fade 4800ms ease forwards;
	}

	.raven-emote--heart {
		width: 1rem;
		height: 1rem;
		transform: translate3d(var(--fx-x, 0px), var(--fx-y, 0px), 0)
			scale(var(--fx-scale, 1));
		animation: raven-heart-pop 860ms steps(6, end) forwards;
		animation-delay: var(--fx-delay, 0ms);
	}

	.raven-emote--angry {
		width: 1.25rem;
		height: 1.25rem;
		transform: translate3d(var(--fx-x, 0px), var(--fx-y, 0px), 0)
			scale(var(--fx-scale, 1));
		animation: raven-angry-pop 780ms steps(5, end) forwards;
	}

	.raven-emote--thought {
		width: 2.2rem;
		height: 1.7rem;
		transform: translate3d(var(--fx-x, 0px), var(--fx-y, 0px), 0)
			scale(var(--fx-scale, 1));
		animation: raven-thought-float 2600ms steps(8, end) forwards;
	}

	@keyframes raven-heart-pop {
		0% {
			opacity: 0;
			transform: translate3d(var(--fx-x, 0px), var(--fx-y, 0px), 0)
				scale(calc(var(--fx-scale, 1) * 0.65));
		}

		18% {
			opacity: 1;
		}

		72% {
			opacity: 1;
		}

		100% {
			opacity: 0;
			transform: translate3d(
					calc(var(--fx-x, 0px) + var(--fx-drift-x, 0px)),
					calc(var(--fx-y, 0px) + var(--fx-rise, -28px)),
					0
				)
				scale(calc(var(--fx-scale, 1) * 1.08));
		}
	}

	@keyframes raven-angry-pop {
		0% {
			opacity: 0;
			transform: translate3d(var(--fx-x, 0px), var(--fx-y, 0px), 0)
				scale(calc(var(--fx-scale, 1) * 0.55));
		}

		15%,
		75% {
			opacity: 1;
		}

		100% {
			opacity: 0;
			transform: translate3d(
					calc(var(--fx-x, 0px) + var(--fx-drift-x, 0px)),
					calc(var(--fx-y, 0px) + var(--fx-rise, -22px)),
					0
				)
				scale(calc(var(--fx-scale, 1) * 1.05));
		}
	}

	@keyframes raven-thought-float {
		0% {
			opacity: 0;
			transform: translate3d(var(--fx-x, 0px), calc(var(--fx-y, 0px) + 4px), 0)
				scale(calc(var(--fx-scale, 1) * 0.88));
		}

		12%,
		82% {
			opacity: 1;
		}

		100% {
			opacity: 0;
			transform: translate3d(var(--fx-x, 0px), calc(var(--fx-y, 0px) - 10px), 0)
				scale(var(--fx-scale, 1));
		}
	}

	@keyframes raven-thought-line-fade {
		0% {
			opacity: 0;
			transform: translate3d(var(--talk-x, 0px), calc(var(--talk-y, 0px) + 6px), 0);
		}

		8%,
		78% {
			opacity: 1;
		}

		100% {
			opacity: 0;
			transform: translate3d(var(--talk-x, 0px), calc(var(--talk-y, 0px) - 10px), 0);
		}
	}
</style>

<script is:inline>
