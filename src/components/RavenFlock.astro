				...bird.recentPerchElements.filter((item) => item !== element),
			].slice(0, 3);
		};

		const updateBirdDimensions = (bird) => {
			const previousWidth = bird.width;
			const previousFootOffset = bird.footOffset;
			const centerX = bird.x + previousWidth / 2;
			const footY = bird.y + previousFootOffset;
			const compositeScale = bird.baseScale * bird.growthScale;

			bird.width = BASE_BIRD_WIDTH * compositeScale;
			bird.height = BASE_BIRD_HEIGHT * compositeScale;
			bird.footOffset = BASE_FOOT_OFFSET_Y * compositeScale;
			bird.element.style.width = `${bird.width}px`;
			bird.element.style.height = `${bird.height}px`;
			bird.x = centerX - bird.width / 2;
			bird.y = footY - bird.footOffset;
		};

		const applyBirdColorVariant = (bird) => {
			bird.element.style.setProperty(
				"--bird-hue-rotate",
				`${bird.colorVariant.hueRotate}deg`,
			);
			bird.element.style.setProperty(
				"--bird-saturate",
				`${bird.colorVariant.saturate}`,
			);
			bird.element.style.setProperty(
				"--bird-brightness",
				`${bird.colorVariant.brightness}`,
			);
		};

		const scoreLandingSpot = (spot, options = {}) => {
			const { excludeBird = null } = options;
			const occupiedBirds = state.birds.filter(
				(bird) => bird !== excludeBird && bird.state !== "escaping",
			);
			if (occupiedBirds.length === 0) {
				return Math.random() * 0.1;
			}

			return occupiedBirds.reduce((score, bird) => {
				const anchor = getBirdLandingAnchor(bird);
				const dx = Math.abs(spot.x - anchor.x);
				const dy = Math.abs(spot.y - anchor.y);
				const columnPenalty =
					dx < MIN_COLUMN_GAP ? (1 - dx / MIN_COLUMN_GAP) * 1.8 : 0;
				const rowPenalty = dy < MIN_ROW_GAP ? (1 - dy / MIN_ROW_GAP) * 1.4 : 0;
				const sameElementPenalty =
					anchor.element === spot.element ? 1.15 : 0;
				const collisionPenalty =
					anchor.element === spot.element && dx < MIN_COLUMN_GAP * 0.92
						? (1 - dx / (MIN_COLUMN_GAP * 0.92)) * 3.8
						: 0;
				const recentElementPenalty =
					excludeBird && excludeBird.recentPerchElements.includes(spot.element)
						? 1.35 - excludeBird.recentPerchElements.indexOf(spot.element) * 0.3
						: 0;
				const spreadScore =
					Math.min(dx / MIN_COLUMN_GAP, 1.4) +
					Math.min(dy / MIN_ROW_GAP, 1.2);

				return (
					score +
					spreadScore -
					columnPenalty -
					rowPenalty -
					sameElementPenalty -
					collisionPenalty -
					recentElementPenalty
