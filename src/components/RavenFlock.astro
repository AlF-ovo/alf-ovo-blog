			});

			if (
				state.birds.length === 0 &&
				state.fries.mode === "idle" &&
				state.food.mode === "idle" &&
				state.scraps.length === 0
			) {
				state.rafId = 0;
				return;
			}

			state.rafId = window.requestAnimationFrame(tick);
		};

		const ensureAnimationLoop = () => {
			if (state.rafId !== 0) {
				return;
			}
			state.rafId = window.requestAnimationFrame(tick);
		};
		window.__alfRavenWeatherState = () => ({
			birdCount: state.birds.filter((bird) => bird.state !== "escaping").length,
			maxBirdCount: getMaxBirdCount(),
			foodDetected: hasChickenLegs(),
		});

		scarecrowButtonElement?.addEventListener("pointerdown", handleScarecrowButtonPointerDown);
		nameplateButtonElement?.addEventListener("pointerdown", handleNameplatePointerDown);
		friesButtonElement.addEventListener("pointerdown", handleFriesButtonPointerDown);
		drumstickElement.addEventListener("pointerdown", handleDrumstickPointerDown);
		root.addEventListener("pointerdown", handleScrapPointerDown);
		window.addEventListener("pointermove", handlePointerMove, { passive: true });
		window.addEventListener("pointerup", handlePointerUp, { passive: true });
		window.addEventListener("pointercancel", handlePointerUp, { passive: true });
		window.addEventListener("scroll", flushBirdsForReading, { passive: true });
		window.addEventListener("blur", handleFoodPointerAbort);
		document.addEventListener("click", scheduleClickDrivenTargetChangeCheck, true);
		window.addEventListener("resize", () => {
			syncFoodHomePosition();
			if (state.selection.mode === "dragging") {
				state.selection.x = clamp(
					state.selection.x,
					0,
					window.innerWidth - NAMEPLATE_BUTTON_WIDTH,
				);
				state.selection.y = clamp(
					state.selection.y,
					0,
					window.innerHeight - NAMEPLATE_BUTTON_HEIGHT,
				);
				updateNameplateButtonFrame();
			}
			if (state.food.mode === "dragging") {
				state.food.x = clamp(state.food.x, 0, window.innerWidth - getFoodSize());
				state.food.y = clamp(state.food.y, 0, getFoodBottomY());
				applyFoodFrame();
			}
			if (state.fries.mode === "dragging") {
				state.fries.x = clamp(
					state.fries.x,
					0,
					window.innerWidth - friesButtonElement.offsetWidth,
				);
				state.fries.y = clamp(
					state.fries.y,
					0,
					window.innerHeight - friesButtonElement.offsetHeight,
				);
				applyFriesButtonFrame();
			}
			state.scraps.forEach((scrap) => {
				const scrapSize = getScrapSize(scrap);
				if (scrap.mode === "active") {
					scrap.x = clamp(scrap.x, 0, window.innerWidth - scrapSize);
					scrap.y = clamp(scrap.y, 0, getScrapFloorY(scrapSize));
				}
				updateScrapFrame(scrap);
			});
			const selectedBird = getSelectedBird();
			if (selectedBird?.scrollDocked) {
				dockSelectedBirdForScroll(selectedBird);
			}
			reconcileBirdTargets();
		});
		document.addEventListener("astro:page-load", () => {
			reconcileBirdTargets();
			processScheduledSpawns();
		});
		document.addEventListener("DOMContentLoaded", () => {
			reconcileBirdTargets();
			processScheduledSpawns();
		});
		document.addEventListener("visibilitychange", () => {
			if (document.hidden) {
				handleFoodPointerAbort();
				return;
			}
			if (!document.hidden) {
				processScheduledSpawns({ instantPerch: true });
			}
		});
		root.addEventListener("click", handleBirdClick);

		syncFoodHomePosition();
		resetFoodToHome();
		scheduleNextThought();
		spawnInitialBird();
		state.spawnHeartbeatId = window.setInterval(() => {
			processScheduledSpawns();
		}, SPAWN_HEARTBEAT_MS);
	})();
</script>
