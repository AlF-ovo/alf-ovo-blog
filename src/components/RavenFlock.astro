				duration: randomBetween(180, 300),
				arcHeight: randomBetween(5, 14),
				finalAction: "birdAttackHit",
				payload: { targetId: target.id },
			});
			return true;
		};

		const resolveBirdAttack = (bird) => {
			const targetId = bird.actionPayload?.targetId;
			const target = state.birds.find((item) => item.id === targetId);
			if (target && target !== bird && target.state !== "escaping") {
				spawnAngryBurst(bird);
				if (!target.hasEatenFood) {
					spawnAngryBurst(target);
				}
				target.visualShiftX += randomBetween(-3.5, 3.5);
				target.visualBob -= randomBetween(1.2, 3.2);
				target.foodBusyUntil = Math.max(
					target.foodBusyUntil,
					performance.now() + randomBetween(420, 760),
				);
				if (hasChickenLegs()) {
					startFoodHover(target);
