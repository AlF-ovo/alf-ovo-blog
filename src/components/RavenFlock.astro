		const getBirdLandingAnchor = (bird) => {
			const pendingLandingSpot =
				bird.actionPayload?.landingSpot?.element instanceof HTMLElement
					? bird.actionPayload.landingSpot
					: null;
			return {
				x: bird.perch?.x ?? pendingLandingSpot?.x ?? bird.destination.x + bird.width / 2,
				y: bird.perch?.y ?? pendingLandingSpot?.y ?? bird.destination.y + bird.footOffset,
				element: bird.perch?.element ?? pendingLandingSpot?.element ?? null,
			};
		};

		const rememberBirdPerchElement = (bird, element) => {
			if (!(element instanceof HTMLElement)) {
