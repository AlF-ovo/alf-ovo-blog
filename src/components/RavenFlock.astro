				return false;
			}

			const rect = element.getBoundingClientRect();
			if (rect.width < MIN_TARGET_WIDTH || rect.height < MIN_TARGET_HEIGHT) {
				return false;
			}

			if (
				rect.bottom < 0 ||
				rect.top > window.innerHeight ||
				rect.right < 0 ||
				rect.left > window.innerWidth
