---

---

<div id="raven-flock" class="raven-flock" aria-hidden="true"></div>

<style is:global>
	.raven-flock {
		position: fixed;
		inset: 0;
		z-index: 65;
		pointer-events: none;
		overflow: hidden;
	}

	.raven-bird {
		position: absolute;
		left: 0;
		top: 0;
		width: 6rem;
		height: 4.5rem;
		pointer-events: auto;
		cursor: pointer;
		user-select: none;
		will-change: transform;
		filter: drop-shadow(0 0.65rem 1rem rgb(3 7 18 / 0.28));
	}

	.raven-bird__sprite,
	.raven-bird__sprite svg {
		display: block;
		width: 100%;
		height: 100%;
		overflow: visible;
		image-rendering: pixelated;
	}

	.raven-bird[data-state="perched"] {
		filter: drop-shadow(0 0.45rem 0.8rem rgb(3 7 18 / 0.22));
	}
</style>

<script is:inline>
	(() => {
		if (window.__alfRavenFlockSetup) {
			return;
		}
		window.__alfRavenFlockSetup = true;

		const root = document.getElementById("raven-flock");
		if (!(root instanceof HTMLElement)) {
			return;
		}

		const TARGET_SELECTOR = [
			".card-base",
			".sidebar-widget",
			".float-panel",
			".dashboard-sidebar",
			".dashboard-panel",
			".dashboard-metric-card",
			".dashboard-hero",
		].join(",");

		const SPRITE_WIDTH = 24;
		const SPRITE_HEIGHT = 18;
		const BASE_BIRD_WIDTH = 96;
		const BASE_BIRD_HEIGHT = 72;
		const BASE_FOOT_OFFSET_Y = 58;
		const VIEWPORT_PADDING = 12;
		const MAX_BIRDS = 6;
		const SPAWN_INTERVAL_MS = 32000;
		const SPAWN_HEARTBEAT_MS = 4000;
		const MIN_TARGET_WIDTH = 112;
		const MIN_TARGET_HEIGHT = 56;
		const MIN_DWELL_MS = 26000;
		const MAX_DWELL_MS = 46000;
		const FLIGHT_FRAME_INTERVAL_MS = 92;
		const MIN_ROW_GAP = 84;
		const MIN_COLUMN_GAP = 132;
		const LANDING_SAMPLES_PER_TARGET = 5;
		const PERCHED_FRAME_INDEX = 0;
		const FLIGHT_SEQUENCE = [1, 2, 3, 4, 5, 4, 3, 2];

		const palette = {
			body: "#17181d",
			shadow: "#09090c",
			highlight: "#2b2e36",
			beak: "#b69357",
			eye: "#f1ead3",
		};

		const frameDefinitions = [
			[
				[7, 6, 7, 1, "highlight"],
				[8, 7, 9, 4, "body"],
				[10, 8, 7, 3, "shadow"],
				[15, 5, 3, 2, "body"],
				[17, 4, 3, 3, "body"],
				[18, 5, 2, 2, "shadow"],
				[20, 5, 2, 1, "beak"],
				[4, 9, 4, 2, "shadow"],
				[3, 10, 2, 1, "body"],
				[11, 11, 1, 3, "shadow"],
				[14, 11, 1, 3, "shadow"],
				[10, 14, 3, 1, "shadow"],
				[13, 14, 3, 1, "shadow"],
				[19, 5, 1, 1, "eye"],
			],
			[
				[7, 9, 8, 3, "body"],
				[9, 10, 6, 2, "shadow"],
				[14, 7, 3, 2, "body"],
				[17, 6, 3, 3, "body"],
				[18, 7, 2, 2, "shadow"],
				[20, 7, 2, 1, "beak"],
				[4, 8, 3, 2, "shadow"],
				[2, 7, 3, 1, "highlight"],
				[10, 6, 4, 2, "body"],
				[12, 4, 3, 3, "body"],
				[11, 5, 2, 4, "shadow"],
				[10, 12, 2, 2, "shadow"],
				[13, 12, 2, 2, "shadow"],
				[19, 7, 1, 1, "eye"],
			],
			[
				[7, 7, 6, 1, "highlight"],
				[7, 8, 7, 4, "body"],
				[9, 9, 6, 3, "shadow"],
				[14, 6, 3, 2, "body"],
				[17, 5, 3, 3, "body"],
				[18, 6, 2, 2, "shadow"],
				[20, 6, 2, 1, "beak"],
				[3, 9, 4, 4, "body"],
				[2, 10, 2, 3, "shadow"],
				[14, 8, 6, 5, "body"],
				[16, 9, 4, 4, "shadow"],
				[5, 8, 2, 1, "highlight"],
				[8, 12, 2, 1, "shadow"],
				[12, 12, 2, 1, "shadow"],
				[19, 6, 1, 1, "eye"],
			],
			[
				[7, 7, 6, 1, "highlight"],
				[7, 8, 7, 4, "body"],
				[9, 9, 6, 3, "shadow"],
				[14, 6, 3, 2, "body"],
				[17, 5, 3, 3, "body"],
				[18, 6, 2, 2, "shadow"],
				[20, 6, 2, 1, "beak"],
				[1, 7, 6, 3, "body"],
				[0, 8, 4, 2, "shadow"],
				[14, 6, 8, 4, "body"],
				[18, 7, 4, 3, "shadow"],
				[5, 6, 2, 1, "highlight"],
				[19, 6, 1, 1, "eye"],
			],
			[
				[8, 8, 7, 3, "body"],
				[10, 9, 5, 2, "shadow"],
				[15, 6, 3, 2, "body"],
				[18, 5, 3, 3, "body"],
				[19, 6, 2, 2, "shadow"],
				[21, 6, 2, 1, "beak"],
				[7, 1, 3, 7, "body"],
				[6, 2, 2, 6, "shadow"],
				[14, 0, 4, 8, "body"],
				[16, 1, 2, 7, "shadow"],
				[4, 9, 4, 2, "shadow"],
				[3, 10, 2, 1, "body"],
				[19, 6, 1, 1, "eye"],
			],
			[
				[8, 7, 8, 4, "body"],
				[10, 8, 6, 3, "shadow"],
				[16, 5, 3, 3, "body"],
				[19, 6, 2, 2, "shadow"],
				[21, 6, 2, 1, "beak"],
				[6, 5, 10, 2, "highlight"],
				[2, 7, 6, 2, "body"],
				[1, 8, 4, 2, "shadow"],
				[16, 6, 6, 2, "body"],
				[18, 7, 4, 2, "shadow"],
				[4, 9, 4, 1, "shadow"],
				[3, 10, 2, 1, "body"],
				[18, 6, 1, 1, "eye"],
			],
		];

		const buildSpriteMarkup = (rects) => {
			const spriteRects = rects
				.map(
					([x, y, width, height, color]) =>
						`<rect x="${x}" y="${y}" width="${width}" height="${height}" fill="${palette[color]}" />`,
				)
				.join("");

			return `<svg viewBox="0 0 ${SPRITE_WIDTH} ${SPRITE_HEIGHT}" role="presentation" focusable="false" shape-rendering="crispEdges">${spriteRects}</svg>`;
		};

		const spriteMarkup = frameDefinitions.map(buildSpriteMarkup);

		const state = {
			birds: [],
			rafId: 0,
			spawnHeartbeatId: 0,
			initialSpawnDone: false,
			nextSpawnAt: 0,
		};

		const randomBetween = (min, max) => min + Math.random() * (max - min);
		const clamp = (value, min, max) => Math.min(max, Math.max(min, value));
		const lerp = (start, end, progress) => start + (end - start) * progress;
		const easeOutCubic = (progress) => 1 - (1 - progress) ** 3;
		const easeInCubic = (progress) => progress ** 3;
		const easeInOutSine = (progress) =>
			-(Math.cos(Math.PI * progress) - 1) / 2;

		const isVisibleTarget = (element) => {
			if (!(element instanceof HTMLElement) || !element.isConnected) {
				return false;
			}

			if (root.contains(element)) {
				return false;
			}

			const style = window.getComputedStyle(element);
			if (
				style.display === "none" ||
				style.visibility === "hidden" ||
				Number.parseFloat(style.opacity || "1") === 0
			) {
				return false;
			}

			const rect = element.getBoundingClientRect();
			if (rect.width < MIN_TARGET_WIDTH || rect.height < MIN_TARGET_HEIGHT) {
				return false;
			}

			if (
				rect.bottom < 0 ||
				rect.top > window.innerHeight ||
				rect.right < 0 ||
				rect.left > window.innerWidth
			) {
				return false;
			}

			return rect.top >= BASE_FOOT_OFFSET_Y - 10;
		};

		const getTargetCandidates = () => {
			const seen = new Set();
			return Array.from(document.querySelectorAll(TARGET_SELECTOR))
				.filter((element) => {
					if (!(element instanceof HTMLElement) || seen.has(element)) {
						return false;
					}
					seen.add(element);
					return isVisibleTarget(element);
				})
				.map((element) => ({
					element,
					rect: element.getBoundingClientRect(),
				}));
		};

		const getBirdLandingAnchor = (bird) => ({
			x: bird.perch?.x ?? bird.destination.x + bird.width / 2,
			y: bird.perch?.y ?? bird.destination.y + bird.footOffset,
			element: bird.perch?.element ?? null,
		});

		const scoreLandingSpot = (spot) => {
			const occupiedBirds = state.birds.filter((bird) => bird.state !== "escaping");
			if (occupiedBirds.length === 0) {
				return Math.random() * 0.1;
			}

			return occupiedBirds.reduce((score, bird) => {
				const anchor = getBirdLandingAnchor(bird);
				const dx = Math.abs(spot.x - anchor.x);
				const dy = Math.abs(spot.y - anchor.y);
				const columnPenalty =
					dx < MIN_COLUMN_GAP ? (1 - dx / MIN_COLUMN_GAP) * 1.8 : 0;
				const rowPenalty = dy < MIN_ROW_GAP ? (1 - dy / MIN_ROW_GAP) * 1.4 : 0;
				const sameElementPenalty =
					anchor.element === spot.element ? 0.75 : 0;
				const spreadScore =
					Math.min(dx / MIN_COLUMN_GAP, 1.4) +
					Math.min(dy / MIN_ROW_GAP, 1.2);

				return score + spreadScore - columnPenalty - rowPenalty - sameElementPenalty;
			}, 0);
		};

		const chooseLandingSpot = () => {
			const candidates = getTargetCandidates();
			if (candidates.length === 0) {
				return null;
			}

			let bestSpot = null;
			let bestScore = Number.NEGATIVE_INFINITY;

			candidates.forEach((candidate) => {
				const minX = candidate.rect.left + 22;
				const maxX = candidate.rect.right - 22;
				if (maxX <= minX) {
					return;
				}

				const sampleCount = Math.max(
					LANDING_SAMPLES_PER_TARGET,
					Math.floor((maxX - minX) / 72),
				);

				for (let index = 0; index < sampleCount; index += 1) {
					const progress = (index + 0.5) / sampleCount;
					const sampledX = clamp(
						lerp(minX, maxX, progress) + randomBetween(-10, 10),
						minX,
						maxX,
					);
					const spot = {
						element: candidate.element,
						x: sampledX,
						y: candidate.rect.top,
					};
					const score = scoreLandingSpot(spot);
					if (score > bestScore) {
						bestScore = score;
						bestSpot = spot;
					}
				}
			});

			if (bestSpot) {
				return bestSpot;
			}

			const fallback = candidates[Math.floor(Math.random() * candidates.length)];
			return {
				element: fallback.element,
				x: (fallback.rect.left + fallback.rect.right) / 2,
				y: fallback.rect.top,
			};
		};

		const getSkyEntryPoint = (birdWidth) => ({
			x: randomBetween(-birdWidth * 0.25, window.innerWidth - birdWidth * 0.75),
			y: randomBetween(-200, -100),
		});

		const getDirectExitPoint = (bird) => {
			const direction =
				bird.x + bird.width / 2 < window.innerWidth / 2 ? -1 : 1;
			return {
				x:
					direction < 0
						? -bird.width * 1.8
						: window.innerWidth + bird.width * 0.8,
				y: Math.max(-bird.height * 2, bird.y - randomBetween(140, 260)),
				direction,
			};
		};

		const setBirdFrame = (bird, frameIndex) => {
			if (bird.frameIndex === frameIndex) {
				return;
			}
			bird.frameIndex = frameIndex;
			bird.sprite.innerHTML = spriteMarkup[frameIndex];
		};

		const updateFlightFrame = (bird, now) => {
			if (now < bird.nextFrameAt) {
				return;
			}

			bird.frameCursor = (bird.frameCursor + 1) % FLIGHT_SEQUENCE.length;
			bird.nextFrameAt = now + FLIGHT_FRAME_INTERVAL_MS;
			setBirdFrame(bird, FLIGHT_SEQUENCE[bird.frameCursor]);
		};

		const applyBirdFrame = (bird) => {
			bird.element.style.transform = `translate3d(${bird.x}px, ${bird.y}px, 0) scaleX(${bird.facing})`;
			bird.element.style.zIndex = String(
				Math.max(1, Math.round(bird.y + bird.footOffset)),
			);
		};

		const removeBird = (bird) => {
			if (bird.element.isConnected) {
				bird.element.remove();
			}
			state.birds = state.birds.filter((item) => item !== bird);
		};

		const setBirdPerched = (bird) => {
			bird.state = "perched";
			bird.element.dataset.state = "perched";
			bird.x = bird.destination.x;
			bird.y = bird.destination.y;
			bird.leaveAt = performance.now() + randomBetween(MIN_DWELL_MS, MAX_DWELL_MS);
			setBirdFrame(bird, PERCHED_FRAME_INDEX);
			applyBirdFrame(bird);
		};

		const startEscape = (bird) => {
			if (bird.state === "escaping") {
				return;
			}

			const exitPoint = getDirectExitPoint(bird);
			bird.state = "escaping";
			bird.element.dataset.state = "escaping";
			bird.source = { x: bird.x, y: bird.y };
			bird.destination = { x: exitPoint.x, y: exitPoint.y };
			bird.facing = exitPoint.direction;
			bird.startedAt = performance.now();
			bird.duration = randomBetween(760, 1180);
			bird.arcHeight = randomBetween(22, 58);
			bird.nextFrameAt = bird.startedAt;
		};

		const updateApproachingBird = (bird, now) => {
			const progress = clamp((now - bird.startedAt) / bird.duration, 0, 1);
			const eased = easeOutCubic(progress);

			bird.x = lerp(bird.source.x, bird.destination.x, easeInOutSine(progress));
			bird.y =
				lerp(bird.source.y, bird.destination.y, eased) -
				Math.sin(progress * Math.PI) * bird.arcHeight;

			updateFlightFrame(bird, now);
			applyBirdFrame(bird);

			if (progress >= 1) {
				setBirdPerched(bird);
			}
		};

		const updateEscapingBird = (bird, now) => {
			const progress = clamp((now - bird.startedAt) / bird.duration, 0, 1);
			const eased = easeInCubic(progress);

			bird.x = lerp(bird.source.x, bird.destination.x, eased);
			bird.y =
				lerp(bird.source.y, bird.destination.y, eased) -
				Math.sin(progress * Math.PI) * bird.arcHeight;

			updateFlightFrame(bird, now);
			applyBirdFrame(bird);

			if (progress >= 1) {
				removeBird(bird);
			}
		};

		const updatePerchedBird = (bird, now) => {
			if (!isVisibleTarget(bird.perch.element) || now >= bird.leaveAt) {
				startEscape(bird);
				return;
			}

			const rect = bird.perch.element.getBoundingClientRect();
			bird.perch.y = rect.top;
			bird.y = rect.top - bird.footOffset;
			bird.x = clamp(
				bird.perch.x - bird.width / 2,
				-VIEWPORT_PADDING,
				window.innerWidth - bird.width + VIEWPORT_PADDING,
			);
			setBirdFrame(bird, PERCHED_FRAME_INDEX);
			applyBirdFrame(bird);
		};

		const tick = (now) => {
			state.birds.slice().forEach((bird) => {
				if (bird.state === "approaching") {
					updateApproachingBird(bird, now);
					return;
				}

				if (bird.state === "escaping") {
					updateEscapingBird(bird, now);
					return;
				}

				if (bird.state === "perched") {
					updatePerchedBird(bird, now);
				}
			});

			if (state.birds.length === 0) {
				state.rafId = 0;
				return;
			}

			state.rafId = window.requestAnimationFrame(tick);
		};

		const ensureAnimationLoop = () => {
			if (state.rafId !== 0) {
				return;
			}
			state.rafId = window.requestAnimationFrame(tick);
		};

		const createBird = (landingSpot) => {
			const element = document.createElement("div");
			element.className = "raven-bird";
			element.dataset.state = "approaching";

			const sprite = document.createElement("div");
			sprite.className = "raven-bird__sprite";
			element.appendChild(sprite);

			const sizeScale = randomBetween(0.92, 1.12);
			const width = BASE_BIRD_WIDTH * sizeScale;
			const height = BASE_BIRD_HEIGHT * sizeScale;
			const footOffset = BASE_FOOT_OFFSET_Y * sizeScale;
			element.style.width = `${width}px`;
			element.style.height = `${height}px`;

			const source = getSkyEntryPoint(width);
			const destination = {
				x: clamp(
					landingSpot.x - width / 2,
					-VIEWPORT_PADDING,
					window.innerWidth - width + VIEWPORT_PADDING,
				),
				y: landingSpot.y - footOffset,
			};

			const bird = {
				element,
				sprite,
				state: "approaching",
				source,
				destination,
				perch: landingSpot,
				x: source.x,
				y: source.y,
				width,
				height,
				footOffset,
				facing: destination.x >= source.x ? 1 : -1,
				startedAt: performance.now(),
				duration: randomBetween(1500, 2300),
				arcHeight: randomBetween(20, 54),
				leaveAt: 0,
				frameIndex: -1,
				frameCursor: Math.floor(Math.random() * FLIGHT_SEQUENCE.length),
				nextFrameAt: performance.now(),
			};

			setBirdFrame(bird, FLIGHT_SEQUENCE[bird.frameCursor]);
			applyBirdFrame(bird);
			return bird;
		};

		const maybeSpawnBird = ({ instantPerch = false } = {}) => {
			if (state.birds.length >= MAX_BIRDS) {
				return;
			}

			const landingSpot = chooseLandingSpot();
			if (!landingSpot) {
				return;
			}

			const bird = createBird(landingSpot);
			state.birds.push(bird);
			root.appendChild(bird.element);

			if (instantPerch) {
				setBirdPerched(bird);
			}

			ensureAnimationLoop();
		};

		const processScheduledSpawns = ({
			now = Date.now(),
			instantPerch = false,
		} = {}) => {
			if (state.nextSpawnAt === 0) {
				state.nextSpawnAt = now + SPAWN_INTERVAL_MS;
				return;
			}

			let safety = 0;
			while (now >= state.nextSpawnAt && safety < MAX_BIRDS) {
				maybeSpawnBird({ instantPerch });
				state.nextSpawnAt += SPAWN_INTERVAL_MS;
				safety += 1;
			}
		};

		const spawnInitialBird = () => {
			if (state.initialSpawnDone) {
				return;
			}

			state.initialSpawnDone = true;
			window.requestAnimationFrame(() => {
				window.requestAnimationFrame(() => {
					maybeSpawnBird();
					state.nextSpawnAt = Date.now() + SPAWN_INTERVAL_MS;
				});
			});
		};

		const escapeAllBirds = () => {
			state.birds.forEach((bird) => {
				startEscape(bird);
			});
			if (state.birds.length > 0) {
				ensureAnimationLoop();
			}
		};

		const reconcileBirdTargets = () => {
			state.birds.forEach((bird) => {
				if (bird.state === "perched" && !isVisibleTarget(bird.perch.element)) {
					startEscape(bird);
				}
			});
			if (state.birds.length > 0) {
				ensureAnimationLoop();
			}
		};

		const handleBirdClick = (event) => {
			const target = event.target;
			if (!(target instanceof Element)) {
				return;
			}

			const birdElement = target.closest(".raven-bird");
			if (!(birdElement instanceof HTMLElement)) {
				return;
			}

			const bird = state.birds.find((item) => item.element === birdElement);
			if (!bird) {
				return;
			}

			event.preventDefault();
			event.stopPropagation();
			startEscape(bird);
			ensureAnimationLoop();
		};

		let scrollTriggerArmed = true;
		window.addEventListener(
			"scroll",
			() => {
				if (!scrollTriggerArmed) {
					return;
				}

				scrollTriggerArmed = false;
				escapeAllBirds();
				window.setTimeout(() => {
					scrollTriggerArmed = true;
				}, 120);
			},
			{ passive: true },
		);

		window.addEventListener("resize", reconcileBirdTargets);
		document.addEventListener("astro:page-load", () => {
			reconcileBirdTargets();
			processScheduledSpawns();
		});
		document.addEventListener("DOMContentLoaded", () => {
			reconcileBirdTargets();
			processScheduledSpawns();
		});
		document.addEventListener("visibilitychange", () => {
			if (!document.hidden) {
				processScheduledSpawns({ instantPerch: true });
			}
		});
		root.addEventListener("click", handleBirdClick);

		spawnInitialBird();
		state.spawnHeartbeatId = window.setInterval(() => {
			processScheduledSpawns();
		}, SPAWN_HEARTBEAT_MS);
	})();
</script>
