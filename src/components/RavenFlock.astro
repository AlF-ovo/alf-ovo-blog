			const [offsetX, offsetY] = offsets[index % offsets.length];
			return {
				x: centerX + offsetX * source.scale,
				y: centerY + offsetY * source.scale,
			};
		};

		const setBirdFrame = (bird, frameIndex) => {
			if (bird.frameIndex === frameIndex) {
				return;
			}
			bird.frameIndex = frameIndex;
			bird.sprite.innerHTML = spriteMarkup[frameIndex];
		};

		const updateFlightFrame = (bird, now) => {
			if (now < bird.nextFrameAt) {
				return;
			}

			bird.frameCursor = (bird.frameCursor + 1) % FLIGHT_SEQUENCE.length;
			bird.nextFrameAt = now + FLIGHT_FRAME_INTERVAL_MS;
			setBirdFrame(bird, FLIGHT_SEQUENCE[bird.frameCursor]);
		};

		const applyBirdFrame = (bird) => {
			bird.element.style.transform = `translate3d(${bird.x}px, ${bird.y}px, 0) scaleX(${bird.facing})`;
			bird.element.style.zIndex = String(
				Math.max(1, Math.round(bird.y + bird.footOffset)),
			);
			bird.element.style.setProperty(
				"--bird-body-shift-x",
				`${bird.visualShiftX}px`,
			);
			bird.element.style.setProperty("--bird-body-bob", `${bird.visualBob}px`);
		};

		const removeBird = (bird) => {
			if (bird.element.isConnected) {
				bird.element.remove();
			}
			state.birds = state.birds.filter((item) => item !== bird);
			assignFoodSlots();
			updateDrumstickVisibility();
		};

		const beginFlightSegment = (bird, options) => {
			const {
				state: nextState,
				destination,
				duration,
				arcHeight,
				finalAction,
				payload = null,
			} = options;

			bird.state = nextState;
			bird.element.dataset.state = nextState;
			bird.source = { x: bird.x, y: bird.y };
			bird.destination = destination;
			bird.startedAt = performance.now();
			bird.duration = duration;
			bird.arcHeight = arcHeight;
			bird.facing = destination.x >= bird.x ? 1 : -1;
			bird.nextFrameAt = bird.startedAt;
			bird.finalAction = finalAction;
			bird.actionPayload = payload;
		};

		const spawnEmote = (markup, className, options) => {
			const emote = document.createElement("div");
			emote.className = `raven-emote ${className}`;
			emote.innerHTML = markup;
			emote.style.setProperty("--fx-x", `${options.x}px`);
			emote.style.setProperty("--fx-y", `${options.y}px`);
			emote.style.setProperty(
				"--fx-rise",
				`${(options.rise ?? -24).toFixed(1)}px`,
			);
			emote.style.setProperty(
				"--fx-drift-x",
				`${(options.driftX ?? 0).toFixed(1)}px`,
			);
			emote.style.setProperty(
				"--fx-scale",
				`${(options.scale ?? 1).toFixed(2)}`,
			);
			if (typeof options.delay === "number") {
				emote.style.setProperty("--fx-delay", `${options.delay}ms`);
			}
			root.appendChild(emote);
			window.setTimeout(() => {
				emote.remove();
			}, options.lifetime ?? 2400);
		};

		const spawnHeartBurst = (bird) => {
			const heartCount = 3 + Math.floor(Math.random() * 3);
			const centerX = bird.x + bird.width * 0.52;
			const centerY = bird.y + bird.height * 0.3;

			for (let index = 0; index < heartCount; index += 1) {
				spawnEmote(heartMarkup, "raven-emote--heart", {
					x: centerX + randomBetween(-8, 8),
					y: centerY + randomBetween(-4, 10),
					rise: -randomBetween(20, 38),
					driftX: randomBetween(-12, 12),
					scale: randomBetween(0.82, 1.18),
					delay: index * 90,
					lifetime: 1280 + index * 90,
				});
			}
		};

		const spawnAngryBurst = (bird) => {
			spawnEmote(angryMarkup, "raven-emote--angry", {
				x: bird.x + bird.width * 0.42,
				y: bird.y + bird.height * 0.08,
				rise: -18,
				driftX: randomBetween(-4, 4),
				scale: randomBetween(0.92, 1.08),
				lifetime: 960,
			});
		};

		const spawnHungerThought = (bird) => {
			spawnEmote(thoughtMarkup, "raven-emote--thought", {
				x: bird.x + bird.width * 0.32,
				y: bird.y - 28,
				scale: 1,
				lifetime: 2800,
			});
		};

		const scheduleNextThought = (now = performance.now()) => {
			state.nextThoughtAt =
				now + randomBetween(THOUGHT_INTERVAL_MIN_MS, THOUGHT_INTERVAL_MAX_MS);
		};

		const getThoughtText = () => {
			const pool = Math.random() < 0.58 ? BLOG_THOUGHTS : RAVEN_PHILOSOPHY;
			return pool[Math.floor(Math.random() * pool.length)];
		};

		const spawnThoughtLine = (bird, text) => {
			const line = document.createElement("div");
			line.className = "raven-thought-line";
			line.textContent = text;
			const aheadX = bird.x + bird.width * (bird.facing > 0 ? 0.72 : -0.08);
			const offsetX = bird.facing > 0 ? 12 : -12;
			const y = bird.y - 16;
			line.style.setProperty("--talk-x", `${aheadX + offsetX}px`);
			line.style.setProperty("--talk-y", `${y}px`);
			root.appendChild(line);
			window.setTimeout(() => {
				line.remove();
			}, 5000);
		};

		const maybeTriggerSharedThought = (now) => {
			if (state.nextThoughtAt === 0) {
				scheduleNextThought(now);
				return;
			}

			if (now < state.nextThoughtAt) {
				return;
			}

			const candidates = state.birds.filter(
				(bird) => bird.state === "panel-perched" || bird.state === "food-hover",
			);
			if (candidates.length > 0) {
				const totalWeight = candidates.reduce(
					(sum, bird) => sum + clamp(bird.growthScale ** 2, 1, 3.2),
					0,
				);
				let roll = Math.random() * totalWeight;
				let bird = candidates[candidates.length - 1];
				for (const candidate of candidates) {
					roll -= clamp(candidate.growthScale ** 2, 1, 3.2);
					if (roll <= 0) {
						bird = candidate;
						break;
					}
				}
				spawnThoughtLine(bird, getThoughtText());
			}
			scheduleNextThought(now);
		};

		const getClickInteractionProbabilities = (bird) => {
			const eatenBonus = clamp(bird.foodEatenCount * 0.045, 0, 0.16);
			const relocateProbability = Math.min(
				0.9,
				CLICK_RELOCATE_PROBABILITY + eatenBonus,
			);
			const heartProbability = CLICK_HEART_PROBABILITY;
			const escapeProbability = Math.max(
				0.05,
				CLICK_ESCAPE_PROBABILITY - eatenBonus,
			);
			return {
				relocateProbability,
				escapeProbability,
				heartProbability,
			};
		};

		const createScrapFromBird = (bird) => {
			const element = document.createElement("div");
			element.className = "raven-scrap";
			element.innerHTML = scrapMarkup;

			const scale = clamp(
				0.76 + bird.foodEatenCount * 0.12 + (bird.baseScale - 1) * 0.7,
				0.72,
				1.55,
			);
			const x = bird.x + bird.width * 0.46 - (SCRAP_BASE_SIZE * scale) / 2;
			const y = bird.y + bird.height * 0.18;
			const scrap = {
				id: state.nextScrapId++,
				element,
				scale,
				x,
				y,
				vy: 2.4,
				mode: "falling",
				bitesTotal: Math.max(
					1,
					Math.round(1 + bird.foodEatenCount * 0.6 + (scale - 0.72) * 1.8),
				),
				bitesRemaining: 0,
				visualOffsetX: 0,
				visualOffsetY: 0,
				impulseX: 0,
				impulseY: 0,
				visualRotation: randomBetween(-4.5, 4.5),
				rotationVelocity: randomBetween(-1.4, 1.4),
				bounceOffsetY: 0,
				bounceVelocityY: 0,
			};

			scrap.bitesRemaining = scrap.bitesTotal;
			state.scraps.push(scrap);
			root.appendChild(scrap.element);
			scrap.element.style.transform = `translate3d(${scrap.x}px, ${scrap.y}px, 0) rotate(${scrap.visualRotation}deg) scale(${scrap.scale})`;
			return scrap;
		};

		const updateScrapFrame = (scrap) => {
			scrap.element.style.transform = `translate3d(${scrap.x + scrap.visualOffsetX}px, ${scrap.y + scrap.visualOffsetY + scrap.bounceOffsetY}px, 0) rotate(${scrap.visualRotation}deg) scale(${scrap.scale})`;
		};

		const removeScrap = (scrap) => {
			if (scrap.element.isConnected) {
				scrap.element.remove();
			}
			state.scraps = state.scraps.filter((item) => item.id !== scrap.id);
		};
		const releaseFoodPointerCapture = (pointerId) => {
			if (typeof pointerId !== "number") {
				return;
			}
			try {
				if (drumstickElement.hasPointerCapture(pointerId)) {
					drumstickElement.releasePointerCapture(pointerId);
				}
			} catch {
				// Ignore capture mismatches and continue the state transition.
			}
		};

		const dropAllScrapsOffscreen = () => {
			state.scraps.forEach((scrap) => {
				scrap.mode = "dropping";
				scrap.vy = Math.max(scrap.vy, SCRAP_DROP_SCROLL_VELOCITY);
			});
			if (state.scraps.length > 0) {
				ensureAnimationLoop();
			}
		};

		const setBirdPanelPerched = (bird) => {
			bird.state = "panel-perched";
			bird.element.dataset.state = "panel-perched";
			bird.x = bird.destination.x;
			bird.y = bird.destination.y;
			bird.visualShiftX = 0;
			bird.visualBob = 0;
			bird.leaveAt = performance.now() + randomBetween(MIN_DWELL_MS, MAX_DWELL_MS);
			bird.perchedAt = performance.now();
			bird.lastHungerBubbleAt = bird.lastHungerBubbleAt || 0;
			rememberBirdPerchElement(bird, bird.perch?.element ?? null);
			setBirdFrame(bird, PERCHED_FRAME_INDEX);
			applyBirdFrame(bird);
		};

		const sendBirdToPanel = (bird, landingSpot, options = {}) => {
			const { doubleHop = false } = options;
			if (!landingSpot) {
				startEscape(bird);
				return;
			}

			const destination = getPanelDestination(landingSpot, bird);
			if (doubleHop) {
				const relay = {
					x: clamp(
						(bird.x + destination.x) / 2 + randomBetween(-60, 60),
						-bird.width * 0.4,
						window.innerWidth - bird.width * 0.6,
					),
					y: Math.max(
						-bird.height * 2,
						Math.min(bird.y, destination.y) - randomBetween(110, 170),
					),
				};
				beginFlightSegment(bird, {
					state: "relocating",
					destination: relay,
					duration: randomBetween(420, 620),
					arcHeight: randomBetween(24, 52),
					finalAction: "relayToPanel",
					payload: { landingSpot },
				});
				return;
			}

			beginFlightSegment(bird, {
				state: "approaching",
				destination,
				duration: randomBetween(760, 1180),
				arcHeight: randomBetween(24, 52),
				finalAction: "panelPerch",
				payload: { landingSpot },
			});
		};

		const releaseBirdFromFood = (bird) => {
			const landingSpot = chooseLandingSpot({
				excludeBird: bird,
			});
			if (landingSpot) {
				sendBirdToPanel(bird, landingSpot);
				return;
			}
			startEscape(bird);
		};

		const assignFoodSlots = () => {
			const foodBirds = state.birds
				.filter((bird) => bird.state !== "escaping")
				.sort((left, right) => left.id - right.id);
			foodBirds.forEach((bird, index) => {
				bird.foodSlotIndex = index;
			});
		};

		const startFoodHover = (bird, options = {}) => {
			const source = getCurrentFoodSource();
			if (!source) {
				releaseBirdFromFood(bird);
				return;
			}

			assignFoodSlots();
			const waitPoint = getFoodWaitPoint(bird, source);
			if (options.direct) {
				bird.state = "food-hover";
				bird.element.dataset.state = "food-hover";
				bird.x = waitPoint.x;
				bird.y = waitPoint.y;
				bird.visualShiftX = 0;
				bird.visualBob = 0;
				applyBirdFrame(bird);
				return;
			}

			beginFlightSegment(bird, {
				state: "food-approaching",
				destination: waitPoint,
				duration: randomBetween(640, 980),
				arcHeight: randomBetween(18, 38),
				finalAction: "foodHover",
				payload: { source },
			});
		};

		const summonBirdsToFood = () => {
			if (!isFoodDetected()) {
				return;
			}

			const acceleratedSpawnAt = Date.now() + FOOD_SPAWN_INTERVAL_MS;
			if (state.nextSpawnAt === 0 || state.nextSpawnAt > acceleratedSpawnAt) {
				state.nextSpawnAt = acceleratedSpawnAt;
			}
			assignFoodSlots();
			state.birds.forEach((bird) => {
				if (bird.state === "escaping") {
					return;
				}
				startFoodHover(bird);
			});
			ensureAnimationLoop();
		};

		const startFoodDash = (bird, options) => {
			if (!isFoodContestable(options.source)) {
				startFoodHover(bird, { direct: true });
				return;
			}

			const slotIndex = options.index ?? bird.foodSlotIndex ?? 0;
			const bitePoint = getFoodBitePoint(slotIndex, options.source);
			const isGroundFood = options.source?.mode === "active";
			const sourceCenterX = options.source.x + options.source.size * 0.5;
			const sourceCenterY = options.source.y + options.source.size * 0.54;
			const contestOffsetX =
				(slotIndex % 2 === 0 ? -1 : 1) *
				(options.source.size * randomBetween(0.72, 1.05));
			const contestOffsetY = isGroundFood
				? randomBetween(-10, 12)
				: randomBetween(-24, 18);
			const destination = {
				x: options.success
					? bitePoint.x - bird.width * 0.42 + randomBetween(-10, 10)
					: sourceCenterX + contestOffsetX - bird.width * 0.5 + randomBetween(-8, 8),
				y: options.success
					? isGroundFood
						? bitePoint.y - bird.footOffset + randomBetween(-3, 3)
						: bitePoint.y - bird.height * 0.38 + randomBetween(-8, 8)
					: isGroundFood
						? sourceCenterY + contestOffsetY - bird.footOffset
						: sourceCenterY + contestOffsetY - bird.height * 0.46,
			};
			beginFlightSegment(bird, {
				state: "food-dash",
				destination,
				duration: isGroundFood
					? randomBetween(220, 360)
					: randomBetween(340, 560),
				arcHeight: isGroundFood ? randomBetween(2, 8) : randomBetween(10, 26),
				finalAction: options.success ? "foodBiteSuccess" : "foodBiteFail",
				payload: { source: options.source, success: options.success },
			});
		};

		const completeFoodBite = (bird) => {
			const source = bird.actionPayload?.source ?? getCurrentFoodSource();
			if (!source) {
				releaseBirdFromFood(bird);
				return;
			}

			if (source.kind === "main") {
				state.food.bitesRemaining = Math.max(0, state.food.bitesRemaining - 1);
			} else {
				const scrap = state.scraps.find((item) => item.id === source.id);
				if (!scrap) {
					releaseBirdFromFood(bird);
					return;
				}
				scrap.bitesRemaining = Math.max(0, scrap.bitesRemaining - 1);
			}

			bird.hasEatenFood = true;
			bird.foodEatenCount += 1;
			bird.growthScale = clamp(1 + bird.foodEatenCount * 0.065, 1, 1.28);
			updateBirdDimensions(bird);
			spawnHeartBurst(bird);
			applyFoodSourceImpulse(
				source,
				bird.x + bird.width * 0.48,
				bird.y + bird.height * 0.42,
				{ success: true },
			);
			applyFoodFrame();

			if (source.kind === "main" && state.food.bitesRemaining === 0) {
				state.food.mode = "resetting";
				state.food.resetAt = performance.now() + FOOD_RESET_DELAY_MS;
				applyFoodFrame();
				state.birds.forEach((otherBird) => {
					if (otherBird !== bird && otherBird.state.startsWith("food")) {
						releaseBirdFromFood(otherBird);
					}
				});
				releaseBirdFromFood(bird);
				return;
			}

			if (source.kind === "scrap") {
				const scrap = state.scraps.find((item) => item.id === source.id);
				if (!scrap || scrap.bitesRemaining === 0) {
					if (scrap?.element.isConnected) {
						scrap.element.remove();
					}
					state.scraps = state.scraps.filter((item) => item.id !== source.id);
					if (!isFoodDetected()) {
						releaseBirdFromFood(bird);
						return;
					}
				}
			}

			startFoodHover(bird);
		};

		const startBirdAttack = (bird, target) => {
			if (!target || target === bird || target.state === "escaping") {
				return false;
			}

			bird.foodBusyUntil = performance.now() + randomBetween(520, 920);
			target.foodBusyUntil = Math.max(
				target.foodBusyUntil,
				performance.now() + randomBetween(360, 680),
			);
			beginFlightSegment(bird, {
				state: "bird-attack",
				destination: {
					x: target.x + randomBetween(-8, 8),
					y: target.y + randomBetween(-6, 6),
				},
				duration: randomBetween(180, 300),
				arcHeight: randomBetween(5, 14),
				finalAction: "birdAttackHit",
				payload: { targetId: target.id },
			});
			return true;
		};

		const resolveBirdAttack = (bird) => {
			const targetId = bird.actionPayload?.targetId;
			const target = state.birds.find((item) => item.id === targetId);
			if (target && target !== bird && target.state !== "escaping") {
				spawnAngryBurst(bird);
				if (!target.hasEatenFood) {
					spawnAngryBurst(target);
				}
				target.visualShiftX += randomBetween(-3.5, 3.5);
				target.visualBob -= randomBetween(1.2, 3.2);
				target.foodBusyUntil = Math.max(
					target.foodBusyUntil,
					performance.now() + randomBetween(420, 760),
				);
				if (isFoodDetected()) {
					startFoodHover(target);
				}
			}

			if (isFoodDetected()) {
				startFoodHover(bird);
				return;
			}
			releaseBirdFromFood(bird);
		};

		const handleFailedFoodDash = (bird) => {
			if (!bird.hasEatenFood) {
				spawnAngryBurst(bird);
				const attackTarget = shuffle(
					state.birds.filter(
						(otherBird) =>
							otherBird !== bird &&
							otherBird.state !== "escaping" &&
							otherBird.state !== "bird-attack" &&
							otherBird.state.startsWith("food") &&
							Math.hypot(otherBird.x - bird.x, otherBird.y - bird.y) < 180,
					),
				)[0];
				if (attackTarget && Math.random() < 0.42) {
					if (startBirdAttack(bird, attackTarget)) {
						return;
					}
				}
			}

			if (isFoodDetected()) {
				startFoodHover(bird);
				return;
			}

			releaseBirdFromFood(bird);
		};

		const vanishBirdWithHearts = (bird) => {
			spawnHeartBurst(bird);
			createScrapFromBird(bird);
			removeBird(bird);
			ensureAnimationLoop();
		};

		const startEscape = (bird) => {
			if (bird.state === "escaping") {
				return;
			}

			const exitPoint = getDirectExitPoint(bird);
			beginFlightSegment(bird, {
				state: "escaping",
				destination: { x: exitPoint.x, y: exitPoint.y },
				duration: randomBetween(760, 1180),
				arcHeight: randomBetween(22, 58),
				finalAction: "remove",
			});
			bird.facing = exitPoint.direction;
		};

		const handleCompletedFlightAction = (bird) => {
			if (bird.finalAction === "remove") {
				removeBird(bird);
				return;
			}

			if (bird.finalAction === "panelPerch") {
				bird.perch = bird.actionPayload?.landingSpot ?? null;
				if (!bird.perch) {
					startEscape(bird);
					return;
				}
				setBirdPanelPerched(bird);
				return;
			}

			if (bird.finalAction === "relayToPanel") {
				const landingSpot = bird.actionPayload?.landingSpot ?? null;
				if (!landingSpot) {
					startEscape(bird);
					return;
				}
				sendBirdToPanel(bird, landingSpot);
				return;
			}

			if (bird.finalAction === "foodHover") {
				bird.state = "food-hover";
				bird.element.dataset.state = "food-hover";
				return;
			}

			if (bird.finalAction === "foodBiteSuccess") {
				completeFoodBite(bird);
				return;
			}

			if (bird.finalAction === "foodBiteFail") {
				handleFailedFoodDash(bird);
				return;
			}

			if (bird.finalAction === "birdAttackHit") {
				resolveBirdAttack(bird);
			}
		};

		const updateMovingBird = (bird, now) => {
			const progress = clamp((now - bird.startedAt) / bird.duration, 0, 1);
			const eased =
				bird.state === "escaping" ? easeInCubic(progress) : easeOutCubic(progress);

			bird.x = lerp(bird.source.x, bird.destination.x, easeInOutSine(progress));
			bird.y =
				lerp(bird.source.y, bird.destination.y, eased) -
				Math.sin(progress * Math.PI) * bird.arcHeight;
			bird.visualShiftX = 0;
			bird.visualBob = 0;

			updateFlightFrame(bird, now);
			applyBirdFrame(bird);

			if (progress >= 1) {
				handleCompletedFlightAction(bird);
			}
		};

		const updatePanelPerchedBird = (bird, now) => {
			if (
				!isVisibleTarget(bird.perch.element) &&
				now < state.targetChangeGraceUntil
			) {
				setBirdFrame(bird, PERCHED_FRAME_INDEX);
				applyBirdFrame(bird);
				return;
			}

			if (!isVisibleTarget(bird.perch.element) || now >= bird.leaveAt) {
				startEscape(bird);
				return;
			}

			if (isFoodDetected()) {
				startFoodHover(bird);
				return;
			}

			const rect = bird.perch.element.getBoundingClientRect();
			bird.perch.y = rect.top;
			bird.y = rect.top - bird.footOffset;
			bird.x = clamp(
				bird.perch.x - bird.width / 2,
				-VIEWPORT_PADDING,
				window.innerWidth - bird.width + VIEWPORT_PADDING,
			);
			const swayPhase = now * 0.0018 + bird.idlePhase;
			bird.visualShiftX = Math.round(Math.sin(swayPhase * 0.58) * 1);
			bird.visualBob = Math.round(
				Math.sin(swayPhase) * 1 + Math.sin(swayPhase * 0.47) * 0.4,
			);

			if (
				now - bird.perchedAt >= HUNGER_BUBBLE_DELAY_MS &&
				now - bird.lastHungerBubbleAt >= HUNGER_BUBBLE_REPEAT_MS
			) {
				bird.lastHungerBubbleAt = now;
				spawnHungerThought(bird);
			}

			setBirdFrame(bird, PERCHED_FRAME_INDEX);
			applyBirdFrame(bird);
		};

		const updateFoodHoverBird = (bird, now) => {
			const source = getCurrentFoodSource();
			if (!source) {
				releaseBirdFromFood(bird);
				return;
			}

			assignFoodSlots();
			const waitPoint = getFoodWaitPoint(bird, source);
			const orbitPhase = now * 0.0032 + bird.idlePhase;
			const isGroundFood = source.mode === "active";
			const targetX = isGroundFood
				? waitPoint.x + Math.round(Math.sin(orbitPhase * 0.62) * 1)
				: waitPoint.x + Math.round(Math.cos(orbitPhase) * 2);
			const targetY = isGroundFood
				? waitPoint.y + Math.round(Math.sin(orbitPhase * 0.48) * 1)
				: waitPoint.y + Math.round(Math.sin(orbitPhase * 1.2) * 3);
			bird.facing = targetX >= bird.x ? 1 : -1;
			bird.x = lerp(bird.x, targetX, isGroundFood ? 0.18 : 0.12);
			bird.y = lerp(bird.y, targetY, isGroundFood ? 0.18 : 0.12);
			if (isGroundFood) {
				const swayPhase = now * 0.0017 + bird.idlePhase;
				bird.visualShiftX = Math.round(Math.sin(swayPhase * 0.54) * 1);
				bird.visualBob = Math.round(
					Math.sin(swayPhase) * 1 + Math.sin(swayPhase * 0.46) * 0.35,
				);
				setBirdFrame(bird, PERCHED_FRAME_INDEX);
			} else {
				bird.visualShiftX = 0;
				bird.visualBob = 0;
				updateFlightFrame(bird, now);
			}
			applyBirdFrame(bird);
		};

		const createBird = () => {
			const element = document.createElement("div");
			element.className = "raven-bird";

			const sprite = document.createElement("div");
			sprite.className = "raven-bird__sprite";
			element.appendChild(sprite);

			const sizeScale = randomBetween(0.92, 1.12);
			const initialWidth = BASE_BIRD_WIDTH * sizeScale;
			const source = getSkyEntryPoint(initialWidth);
			const rareColorRoll = Math.random();
			const colorVariant =
				rareColorRoll < 0.018
					? {
							hueRotate: randomBetween(-8, 6).toFixed(1),
							saturate: randomBetween(0.08, 0.18).toFixed(2),
							brightness: randomBetween(1.62, 1.86).toFixed(2),
						}
					: rareColorRoll < 0.036
						? {
								hueRotate: randomBetween(-28, -14).toFixed(1),
								saturate: randomBetween(1.18, 1.34).toFixed(2),
								brightness: randomBetween(1.18, 1.34).toFixed(2),
							}
						: {
								hueRotate: randomBetween(-9, 10).toFixed(1),
								saturate: randomBetween(0.94, 1.08).toFixed(2),
								brightness: randomBetween(0.94, 1.06).toFixed(2),
							};

			const bird = {
				id: state.nextBirdId++,
				element,
				sprite,
				state: "spawning",
				source,
				destination: source,
				perch: null,
				x: source.x,
				y: source.y,
				width: BASE_BIRD_WIDTH * sizeScale,
				height: BASE_BIRD_HEIGHT * sizeScale,
				footOffset: BASE_FOOT_OFFSET_Y * sizeScale,
				facing: 1,
				startedAt: performance.now(),
				duration: 0,
				arcHeight: 0,
				leaveAt: 0,
				perchedAt: 0,
				frameIndex: -1,
				frameCursor: Math.floor(Math.random() * FLIGHT_SEQUENCE.length),
				nextFrameAt: performance.now(),
				finalAction: "remove",
				actionPayload: null,
				visualShiftX: 0,
				visualBob: 0,
				idlePhase: randomBetween(0, Math.PI * 2),
				foodSlotIndex: 0,
				hasEatenFood: false,
				foodEatenCount: 0,
				foodBusyUntil: 0,
				lastHungerBubbleAt: 0,
				baseScale: sizeScale,
				growthScale: 1,
				recentPerchElements: [],
				colorVariant,
			};

			updateBirdDimensions(bird);
			applyBirdColorVariant(bird);
			setBirdFrame(bird, FLIGHT_SEQUENCE[bird.frameCursor]);
			applyBirdFrame(bird);
			return bird;
		};

		const maybeSpawnBird = ({ instantPerch = false } = {}) => {
			if (state.birds.length >= MAX_BIRDS) {
				return;
			}

			if (!isFoodDetected()) {
				const landingSpot = chooseLandingSpot();
				if (!landingSpot) {
					return;
				}

				const bird = createBird();
				state.birds.push(bird);
				root.appendChild(bird.element);
				updateDrumstickVisibility();
				if (instantPerch) {
					bird.perch = landingSpot;
					bird.destination = getPanelDestination(landingSpot, bird);
					setBirdPanelPerched(bird);
				} else {
					sendBirdToPanel(bird, landingSpot);
				}
				ensureAnimationLoop();
				return;
			}

			const bird = createBird();
			state.birds.push(bird);
			root.appendChild(bird.element);
			updateDrumstickVisibility();
			startFoodHover(bird);
			ensureAnimationLoop();
		};

		const processScheduledSpawns = ({
			now = Date.now(),
			instantPerch = false,
		} = {}) => {
			const spawnIntervalMs = getSpawnIntervalMs();
			if (state.nextSpawnAt === 0) {
				state.nextSpawnAt = now + spawnIntervalMs;
				return;
			}
			if (isFoodDetected()) {
				state.nextSpawnAt = Math.min(state.nextSpawnAt, now + spawnIntervalMs);
			}

			let safety = 0;
			while (now >= state.nextSpawnAt && safety < MAX_BIRDS) {
				maybeSpawnBird({ instantPerch });
				state.nextSpawnAt += getSpawnIntervalMs();
				safety += 1;
			}
		};

		const spawnInitialBird = () => {
			if (state.initialSpawnDone) {
				return;
			}

			state.initialSpawnDone = true;
			window.requestAnimationFrame(() => {
				window.requestAnimationFrame(() => {
					maybeSpawnBird();
					state.nextSpawnAt = Date.now() + getSpawnIntervalMs();
				});
			});
		};

		const escapeAllBirds = () => {
			state.birds.forEach((bird) => {
				startEscape(bird);
			});
			if (state.birds.length > 0) {
				ensureAnimationLoop();
			}
		};

		const targetsSharePosition = (beforeTarget, afterTarget) => {
			const dx = Math.abs(beforeTarget.rect.left - afterTarget.rect.left);
			const dy = Math.abs(beforeTarget.rect.top - afterTarget.rect.top);
			const dw = Math.abs(beforeTarget.rect.width - afterTarget.rect.width);
			const dh = Math.abs(beforeTarget.rect.height - afterTarget.rect.height);
			return (
				dx <= TARGET_POSITION_EPSILON &&
				dy <= TARGET_POSITION_EPSILON &&
				dw <= TARGET_POSITION_EPSILON &&
				dh <= TARGET_POSITION_EPSILON
			);
		};

		const reactToTargetChange = (bird, stableTargets, freshTargets) => {
			const roll = Math.random();
			const stableLandingSpot = chooseLandingSpotFromCandidates(stableTargets, {
				excludeBird: bird,
			});
			const freshLandingSpot = chooseLandingSpotFromCandidates(freshTargets, {
				excludeBird: bird,
			});

			if (roll < ESCAPE_ON_TARGET_CHANGE_PROBABILITY) {
				startEscape(bird);
				return;
			}

			if (
				roll <
				ESCAPE_ON_TARGET_CHANGE_PROBABILITY + STABLE_RELOCATION_PROBABILITY
			) {
				if (stableLandingSpot) {
					sendBirdToPanel(bird, stableLandingSpot);
					return;
				}
				startEscape(bird);
				return;
			}

			if (freshLandingSpot) {
				sendBirdToPanel(bird, freshLandingSpot, { doubleHop: true });
				return;
			}

			if (stableLandingSpot) {
				sendBirdToPanel(bird, stableLandingSpot);
				return;
			}

			startEscape(bird);
		};

		const processClickDrivenTargetChange = (beforeTargets, token) => {
			if (token !== state.targetReactionToken) {
				return;
			}

			const afterTargets = snapshotTargets();
			const beforeMap = new Map(beforeTargets.map((target) => [target.element, target]));
			const afterMap = new Map(afterTargets.map((target) => [target.element, target]));
			const removedTargets = beforeTargets.filter(
				(target) => !afterMap.has(target.element),
			);
			const stableTargets = afterTargets.filter((target) => {
				const previousTarget = beforeMap.get(target.element);
				return previousTarget && targetsSharePosition(previousTarget, target);
			});
			const freshTargets = afterTargets.filter((target) => {
				const previousTarget = beforeMap.get(target.element);
				return !previousTarget || !targetsSharePosition(previousTarget, target);
			});

			if (removedTargets.length === 0 && freshTargets.length === 0) {
				state.targetChangeGraceUntil = 0;
				return;
			}

			state.birds.slice().forEach((bird) => {
				if (bird.state !== "panel-perched" || !(bird.perch?.element instanceof HTMLElement)) {
					return;
				}

				if (!beforeMap.has(bird.perch.element) || afterMap.has(bird.perch.element)) {
					return;
				}

				reactToTargetChange(bird, stableTargets, freshTargets);
			});

			state.targetChangeGraceUntil = 0;
			if (state.birds.length > 0) {
				ensureAnimationLoop();
			}
		};

		const scheduleClickDrivenTargetChangeCheck = (event) => {
			const target = event.target;
			if (!(target instanceof Element) || root.contains(target)) {
				return;
			}

			const beforeTargets = snapshotTargets();
			const token = state.targetReactionToken + 1;
			state.targetReactionToken = token;
			state.targetChangeGraceUntil = performance.now() + TARGET_REACTION_GRACE_MS;

			window.setTimeout(() => {
				processClickDrivenTargetChange(beforeTargets, token);
			}, TARGET_REACTION_DELAY_MS);
		};

		const activateFoodDrag = () => {
			state.food.mode = "dragging";
			state.food.scale = state.food.heldScale;
			state.food.bitesTotal = calculateFoodBites(state.food.scale);
			state.food.bitesRemaining = state.food.bitesTotal;
			state.food.lastBiteAt = -FOOD_BITE_COOLDOWN_MS;
			state.food.nextContestAt =
				performance.now() + randomBetween(FOOD_WAIT_GATHER_DELAY_MS, 320);
			resetFoodMotionState(state.food);
			applyFoodFrame();
			summonBirdsToFood();
		};
		const dropDraggedFood = () => {
			state.food.dragPointerId = null;
			state.food.mode = "falling";
			state.food.vy = 2.2;
			state.food.rotationVelocity =
				randomBetween(-1.6, 1.6) + (Math.random() < 0.5 ? -0.9 : 0.9);
			state.food.bounceOffsetY = 0;
			state.food.bounceVelocityY = 0;
			applyFoodFrame();
			ensureAnimationLoop();
		};
		const liftScrapAsFood = (scrap, event) => {
			if (!(scrap?.element instanceof HTMLElement) || state.food.mode !== "idle") {
				return;
			}

			event.preventDefault();
			state.food.mode = "dragging";
			state.food.dragPointerId = event.pointerId;
			state.food.pointerStartX = event.clientX;
			state.food.pointerStartY = event.clientY;
			state.food.pendingPointerX = event.clientX;
			state.food.pendingPointerY = event.clientY;
			state.food.scale = scrap.scale;
			state.food.heldScale = scrap.scale;
			state.food.bitesTotal = scrap.bitesTotal;
			state.food.bitesRemaining = scrap.bitesRemaining;
			state.food.lastBiteAt = -FOOD_BITE_COOLDOWN_MS;
			state.food.nextContestAt =
				performance.now() + randomBetween(FOOD_WAIT_GATHER_DELAY_MS, 320);
			state.food.x = scrap.x;
			state.food.y = scrap.y;
			resetFoodMotionState(state.food);
			state.food.dragOffsetX = event.clientX - state.food.x;
			state.food.dragOffsetY = event.clientY - state.food.y;
			try {
				drumstickElement.setPointerCapture(event.pointerId);
			} catch {
				// Pointer capture is optional but avoids getting stuck in dragging mode.
			}
			removeScrap(scrap);
			applyFoodFrame();
			summonBirdsToFood();
			ensureAnimationLoop();
		};

		const handleDrumstickPointerDown = (event) => {
			if (state.food.mode !== "idle") {
				return;
			}

			event.preventDefault();
			state.food.mode = "holding";
			state.food.dragPointerId = event.pointerId;
			state.food.pointerStartX = event.clientX;
			state.food.pointerStartY = event.clientY;
			state.food.pendingPointerX = event.clientX;
			state.food.pendingPointerY = event.clientY;
			state.food.dragOffsetX = event.clientX - state.food.x;
			state.food.dragOffsetY = event.clientY - state.food.y;
			state.food.holdStartedAt = performance.now();
			state.food.heldScale = FOOD_MIN_SCALE;
			state.food.scale = FOOD_MIN_SCALE;
			state.food.bitesTotal = FOOD_BASE_BITES;
			state.food.bitesRemaining = FOOD_BASE_BITES;
			resetFoodMotionState(state.food);
			try {
				drumstickElement.setPointerCapture(event.pointerId);
			} catch {
				// Pointer capture is optional but avoids getting stuck in dragging mode.
			}
			applyFoodFrame();
			ensureAnimationLoop();
		};

		const handleScrapPointerDown = (event) => {
			const target = event.target;
			if (!(target instanceof Element)) {
				return;
			}

			const scrapElement = target.closest(".raven-scrap");
			if (!(scrapElement instanceof HTMLElement)) {
				return;
			}

			const scrap = state.scraps.find((item) => item.element === scrapElement);
			if (!scrap || (scrap.mode !== "active" && scrap.mode !== "falling")) {
				return;
			}

			liftScrapAsFood(scrap, event);
		};

		const handlePointerMove = (event) => {
			if (event.pointerId !== state.food.dragPointerId) {
				return;
			}

			state.food.pendingPointerX = event.clientX;
			state.food.pendingPointerY = event.clientY;
			if (state.food.mode === "holding") {
				const distance = Math.hypot(
					event.clientX - state.food.pointerStartX,
					event.clientY - state.food.pointerStartY,
				);
				if (distance >= FOOD_DRAG_ACTIVATION_DISTANCE) {
					activateFoodDrag();
				}
				return;
			}

			if (state.food.mode === "dragging") {
				state.food.x = clamp(
					event.clientX - state.food.dragOffsetX,
					0,
					window.innerWidth - getFoodSize(),
				);
				state.food.y = clamp(
					event.clientY - state.food.dragOffsetY,
					0,
					window.innerHeight - getFoodSize(),
				);
				applyFoodFrame();
			}
		};

		const handlePointerUp = (event) => {
			if (event.pointerId !== state.food.dragPointerId) {
				return;
			}
			releaseFoodPointerCapture(event.pointerId);

			if (state.food.mode === "holding") {
				resetFoodToHome();
				return;
			}

			if (state.food.mode !== "dragging") {
				state.food.dragPointerId = null;
				return;
			}

			dropDraggedFood();
		};
		const handleFoodPointerAbort = () => {
			if (state.food.dragPointerId === null) {
				return;
			}
			releaseFoodPointerCapture(state.food.dragPointerId);
			if (state.food.mode === "holding") {
				resetFoodToHome();
				return;
			}
			if (state.food.mode === "dragging") {
				dropDraggedFood();
			}
		};

		const updateFood = (now) => {
			if (state.food.mode === "idle") {
				return;
			}

			if (state.food.mode === "holding") {
				state.food.heldScale = calculateFoodScaleFromHold(
					now - state.food.holdStartedAt,
				);
				state.food.scale = state.food.heldScale;
				state.food.bitesTotal = calculateFoodBites(state.food.scale);
				state.food.bitesRemaining = state.food.bitesTotal;
				state.food.x = state.food.homeX;
				state.food.y = state.food.homeY;
				resetFoodMotionState(state.food);
				applyFoodFrame();
				return;
			}

			if (state.food.mode === "falling") {
				state.food.y = Math.min(getFoodBottomY(), state.food.y + state.food.vy);
				state.food.vy = Math.min(
					FOOD_FALL_TERMINAL_VELOCITY,
					state.food.vy + FOOD_FALL_GRAVITY,
				);
				state.food.rotationVelocity +=
					(state.food.rotationVelocity >= 0 ? 0.08 : -0.08) +
					Math.sin(now * 0.006 + state.food.scale) * 0.03;
				updateFoodMotionState(state.food);
				if (state.food.y >= getFoodBottomY()) {
					state.food.y = getFoodBottomY();
					state.food.mode = "active";
					state.food.bounceOffsetY = -Math.min(10, Math.max(4, state.food.vy * 0.46));
					state.food.bounceVelocityY = Math.max(1.2, state.food.vy * 0.16);
					state.food.rotationVelocity *= -0.44;
					state.food.nextContestAt = now + randomBetween(320, 620);
				}
				applyFoodFrame();
				return;
			}

			if (state.food.mode === "resetting") {
				if (now >= state.food.resetAt) {
					resetFoodToHome();
				}
				return;
			}

			if (state.food.mode === "active" || state.food.mode === "dragging") {
				updateFoodMotionState(state.food);
				applyFoodFrame();
			}
		};

		const updateScraps = () => {
			state.scraps.slice().forEach((scrap) => {
				if (scrap.mode === "falling") {
					const bottomY = window.innerHeight - getScrapSize(scrap) - 8;
					scrap.y = Math.min(bottomY, scrap.y + scrap.vy);
					scrap.vy = Math.min(
						SCRAP_FALL_TERMINAL_VELOCITY,
						scrap.vy + SCRAP_FALL_GRAVITY,
					);
					scrap.rotationVelocity +=
						(scrap.rotationVelocity >= 0 ? 0.06 : -0.06) +
						Math.sin(performance.now() * 0.005 + scrap.id) * 0.02;
					updateFoodMotionState(scrap);
					if (scrap.y >= bottomY) {
						scrap.y = bottomY;
						scrap.mode = "active";
						scrap.bounceOffsetY = -Math.min(8, Math.max(3, scrap.vy * 0.42));
						scrap.bounceVelocityY = Math.max(0.9, scrap.vy * 0.14);
						scrap.rotationVelocity *= -0.42;
						if (!isMainFoodDetected()) {
							state.food.nextContestAt =
								performance.now() + randomBetween(280, 560);
						}
					}
					updateScrapFrame(scrap);
					return;
				}

				if (scrap.mode === "dropping") {
					scrap.y += scrap.vy;
					scrap.vy = Math.min(
						SCRAP_FALL_TERMINAL_VELOCITY + 4,
						scrap.vy + SCRAP_FALL_GRAVITY,
					);
					scrap.rotationVelocity +=
						(scrap.rotationVelocity >= 0 ? 0.05 : -0.05) * 0.9;
					updateFoodMotionState(scrap);
					if (scrap.y > window.innerHeight + getScrapSize(scrap) + 12) {
						removeScrap(scrap);
						return;
					}
					updateScrapFrame(scrap);
					return;
				}

				if (scrap.mode === "active") {
					updateFoodMotionState(scrap);
					updateScrapFrame(scrap);
				}
			});
		};

		const maybeRunFoodContest = (now) => {
			const source = getCurrentFoodSource();
			if (!source || now < state.food.nextContestAt) {
				return;
			}
			if (!isFoodContestable(source)) {
				state.food.nextContestAt = now + randomBetween(180, 320);
				return;
			}

			const candidates = shuffle(
				state.birds.filter(
					(bird) =>
						(bird.state === "food-hover" || bird.state === "food-approaching") &&
						now >= bird.foodBusyUntil,
				),
			);
			if (candidates.length === 0) {
				state.food.nextContestAt = now + randomBetween(420, 920);
				return;
			}

			let participantCount = 1;
			if (candidates.length >= 2 && Math.random() < 0.82) {
				participantCount = 2;
			}
			if (candidates.length >= 4 && Math.random() < 0.28) {
				participantCount = 3;
			}
			const participants = candidates.slice(
				0,
				Math.min(participantCount, candidates.length),
			);
			const canBite =
				now - state.food.lastBiteAt >= FOOD_BITE_COOLDOWN_MS &&
				source.bitesRemaining > 0;
			const winner = canBite ? participants[0] : null;

			participants.forEach((bird, index) => {
				bird.foodBusyUntil = now + randomBetween(260, 540);
				startFoodDash(bird, {
					source,
					success: bird === winner,
					index,
				});
			});

			if (winner) {
				state.food.lastBiteAt = now;
			}

			state.food.nextContestAt =
				now +
				randomBetween(
					FOOD_CONTEST_MIN_MS,
					FOOD_CONTEST_MAX_MS,
				);
		};

		const reconcileBirdTargets = () => {
			state.birds.forEach((bird) => {
				if (
					bird.state === "panel-perched" &&
					!isVisibleTarget(bird.perch.element) &&
					performance.now() >= state.targetChangeGraceUntil
				) {
					startEscape(bird);
				}
			});
			if (
				state.birds.length > 0 ||
				state.food.mode !== "idle" ||
				state.scraps.length > 0
			) {
				ensureAnimationLoop();
			}
		};

		const handleBirdClick = (event) => {
			const target = event.target;
			if (!(target instanceof Element)) {
				return;
			}

			const birdElement = target.closest(".raven-bird");
			if (!(birdElement instanceof HTMLElement)) {
				return;
			}

			const bird = state.birds.find((item) => item.element === birdElement);
			if (!bird) {
				return;
			}

			event.preventDefault();
			event.stopPropagation();
			const roll = Math.random();
			const probabilities = getClickInteractionProbabilities(bird);
			const alternateLandingSpot = chooseLandingSpot({
				excludeBird: bird,
				excludeElement:
					bird.perch?.element instanceof HTMLElement ? bird.perch.element : null,
			});

			if (roll < probabilities.relocateProbability && alternateLandingSpot) {
				sendBirdToPanel(bird, alternateLandingSpot);
				ensureAnimationLoop();
				return;
			}

			if (
				roll <
				probabilities.relocateProbability + probabilities.escapeProbability
			) {
				startEscape(bird);
				ensureAnimationLoop();
				return;
			}

			vanishBirdWithHearts(bird);
			ensureAnimationLoop();
		};

		const tick = (now) => {
			updateFood(now);
			updateScraps();
			maybeTriggerSharedThought(now);
			if (isFoodDetected()) {
				assignFoodSlots();
				maybeRunFoodContest(now);
			}

			state.birds.slice().forEach((bird) => {
				if (
					bird.state === "approaching" ||
					bird.state === "relocating" ||
					bird.state === "escaping" ||
					bird.state === "food-approaching" ||
					bird.state === "food-dash" ||
					bird.state === "bird-attack"
				) {
					updateMovingBird(bird, now);
					return;
				}

				if (bird.state === "panel-perched") {
					updatePanelPerchedBird(bird, now);
					return;
				}

				if (bird.state === "food-hover") {
					updateFoodHoverBird(bird, now);
				}
			});

			if (
				state.birds.length === 0 &&
				state.food.mode === "idle" &&
				state.scraps.length === 0
			) {
				state.rafId = 0;
				return;
			}

			state.rafId = window.requestAnimationFrame(tick);
		};

		const ensureAnimationLoop = () => {
			if (state.rafId !== 0) {
				return;
			}
			state.rafId = window.requestAnimationFrame(tick);
		};

		let scrollTriggerArmed = true;
		window.addEventListener(
			"scroll",
			() => {
				if (!scrollTriggerArmed) {
					return;
				}

				scrollTriggerArmed = false;
				escapeAllBirds();
				dropAllScrapsOffscreen();
				window.setTimeout(() => {
					scrollTriggerArmed = true;
				}, 120);
			},
			{ passive: true },
		);

		drumstickElement.addEventListener("pointerdown", handleDrumstickPointerDown);
		root.addEventListener("pointerdown", handleScrapPointerDown);
		window.addEventListener("pointermove", handlePointerMove, { passive: true });
		window.addEventListener("pointerup", handlePointerUp, { passive: true });
		window.addEventListener("pointercancel", handlePointerUp, { passive: true });
		window.addEventListener("blur", handleFoodPointerAbort);
		document.addEventListener("click", scheduleClickDrivenTargetChangeCheck, true);
		window.addEventListener("resize", () => {
			syncFoodHomePosition();
			if (
				["dragging", "falling", "active"].includes(state.food.mode)
			) {
				state.food.x = clamp(state.food.x, 0, window.innerWidth - getFoodSize());
				state.food.y = clamp(state.food.y, 0, getFoodBottomY());
				applyFoodFrame();
			}
			reconcileBirdTargets();
		});
		document.addEventListener("astro:page-load", () => {
			reconcileBirdTargets();
			processScheduledSpawns();
		});
		document.addEventListener("DOMContentLoaded", () => {
			reconcileBirdTargets();
			processScheduledSpawns();
		});
		document.addEventListener("visibilitychange", () => {
			if (document.hidden) {
				handleFoodPointerAbort();
				return;
			}
			if (!document.hidden) {
				processScheduledSpawns({ instantPerch: true });
			}
		});
		root.addEventListener("click", handleBirdClick);

		syncFoodHomePosition();
		resetFoodToHome();
		scheduleNextThought();
		spawnInitialBird();
		state.spawnHeartbeatId = window.setInterval(() => {
			processScheduledSpawns();
		}, SPAWN_HEARTBEAT_MS);
	})();
</script>
