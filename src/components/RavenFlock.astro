			}

			if (hasChickenLegs()) {
				startFoodHover(bird);
				return;
			}
			releaseBirdFromFood(bird);
		};

		const handleFailedFoodDash = (bird) => {
			if (isBirdHungry(bird)) {
				spawnAngryBurst(bird);
				const attackTarget = shuffle(
					state.birds.filter(
						(otherBird) =>
							otherBird !== bird &&
							otherBird.state !== "escaping" &&
							otherBird.state !== "bird-attack" &&
							otherBird.state.startsWith("food") &&
							isBirdHungry(otherBird) &&
							Math.hypot(otherBird.x - bird.x, otherBird.y - bird.y) < 180,
					),
				)[0];
				if (attackTarget && Math.random() < 0.42) {
					if (startBirdAttack(bird, attackTarget)) {
						return;
					}
				}
