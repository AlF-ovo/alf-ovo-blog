			),
			y: landingSpot.y - bird.footOffset,
		});
		const getSelectedDockPosition = (bird) => ({
			x: SELECTED_SCROLL_DOCK_MARGIN,
			y: window.innerHeight - bird.height - SELECTED_SCROLL_DOCK_MARGIN,
		});
		const getAlfControlPoint = (bird, kind = "drumstick") => {
			const baseX =
				kind === "fries"
					? state.food.homeX + 4
					: state.food.homeX + FOOD_HOME_SIZE * 0.15;
			const baseY =
				kind === "fries"
					? state.selection.homeY + NAMEPLATE_BUTTON_HEIGHT + 8
					: state.food.homeY + FOOD_HOME_SIZE * 0.15;
			return {
