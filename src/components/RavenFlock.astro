			}

			bird.foodBusyUntil = performance.now() + randomBetween(520, 920);
			target.foodBusyUntil = Math.max(
				target.foodBusyUntil,
				performance.now() + randomBetween(360, 680),
			);
			beginFlightSegment(bird, {
				state: "bird-attack",
				destination: {
					x: target.x + randomBetween(-8, 8),
					y: target.y + randomBetween(-6, 6),
