			const candidates = getTargetCandidates();
			if (candidates.length === 0) {
				return null;
			}
			const sortedCandidates = [...candidates].sort((left, right) => {
				const leftCenterX = (left.rect.left + left.rect.right) / 2;
				const leftCenterY = left.rect.top;
				const rightCenterX = (right.rect.left + right.rect.right) / 2;
				const rightCenterY = right.rect.top;
				const birdCenterX = bird.x + bird.width * 0.5;
				const birdCenterY = bird.y + bird.footOffset;
				const leftDistance = Math.hypot(leftCenterX - birdCenterX, leftCenterY - birdCenterY);
				const rightDistance = Math.hypot(rightCenterX - birdCenterX, rightCenterY - birdCenterY);
				return leftDistance - rightDistance;
			});
			return chooseLandingSpotFromCandidates(sortedCandidates.slice(0, 3), options);
		};

		const getSkyEntryPoint = (birdWidth) => ({
			x: randomBetween(-birdWidth * 0.25, window.innerWidth - birdWidth * 0.75),
			y: randomBetween(-200, -100),
		});

		const getDirectExitPoint = (bird) => {
			const direction =
				bird.x + bird.width / 2 < window.innerWidth / 2 ? -1 : 1;
