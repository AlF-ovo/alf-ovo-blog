		};

		const getClickInteractionProbabilities = (bird) => {
			const eatenBonus = clamp(bird.foodEatenCount * 0.045, 0, 0.16);
			const relocateProbability = Math.min(
				0.9,
				CLICK_RELOCATE_PROBABILITY + eatenBonus,
			);
			const heartProbability = CLICK_HEART_PROBABILITY;
			const escapeProbability = Math.max(
				0.05,
				CLICK_ESCAPE_PROBABILITY - eatenBonus,
			);
			return {
				relocateProbability,
				escapeProbability,
				heartProbability,
			};
		};

		const createScrapFromBird = (bird) => {
			const element = document.createElement("div");
			element.className = "raven-scrap";
			element.innerHTML = buildFoodSpriteWrapper("raven-scrap__sprite");

			const scale = clamp(
				0.76 + bird.foodEatenCount * 0.12 + (bird.baseScale - 1) * 0.7,
				0.72,
				1.55,
			);
			const x = bird.x + bird.width * 0.46 - (SCRAP_BASE_SIZE * scale) / 2;
			const y = bird.y + bird.height * 0.18;
			const scrap = {
				id: state.nextScrapId++,
				element,
				foodKind: "scrap",
				scale,
				x,
				y,
				vx: randomBetween(-0.45, 0.45),
				vy: 2.4,
				mode: "falling",
				bitesTotal: Math.max(
					1,
					Math.round(1 + bird.foodEatenCount * 0.6 + (scale - 0.72) * 1.8),
				),
				bitesRemaining: 0,
				visualOffsetX: 0,
				visualOffsetY: 0,
				impulseX: 0,
				impulseY: 0,
				visualRotation: randomBetween(-4.5, 4.5),
				rotationVelocity: randomBetween(-1.4, 1.4),
				bounceOffsetY: 0,
				bounceVelocityY: 0,
				lastBiteAt: -FOOD_BITE_COOLDOWN_MS,
				nextContestAt: performance.now() + randomBetween(320, 620),
				floorBounceCount: 0,
				restX: null,
			};

			scrap.bitesRemaining = scrap.bitesTotal;
			state.scraps.push(scrap);
			root.appendChild(scrap.element);
			scrap.element.style.transform = `translate3d(${scrap.x}px, ${scrap.y}px, 0) rotate(${scrap.visualRotation}deg) scale(${scrap.scale})`;
			return scrap;
		};
		const createDroppedFoodItem = (options = {}) => {
			const element = document.createElement("div");
			const foodKind = options.foodKind ?? state.food.foodKind;
			const scale = options.scale ?? state.food.scale;
			const isDrumstick = foodKind === "drumstick";
			element.className = isDrumstick
				? "raven-scrap raven-scrap--drumstick"
				: "raven-scrap";
			element.innerHTML = buildFoodSpriteWrapper(
				isDrumstick ? "raven-scrap__sprite" : "raven-scrap__sprite",
			);

			const item = {
				id: state.nextScrapId++,
				element,
				foodKind,
				scale,
				x: options.x ?? state.food.x,
				y: options.y ?? state.food.y,
				vx: options.vx ?? 0,
				vy: options.vy ?? 2.2,
				mode: options.mode ?? "falling",
				bitesTotal: options.bitesTotal ?? state.food.bitesTotal,
				bitesRemaining: options.bitesRemaining ?? state.food.bitesRemaining,
				visualOffsetX: options.visualOffsetX ?? state.food.visualOffsetX,
				visualOffsetY: options.visualOffsetY ?? state.food.visualOffsetY,
				impulseX: options.impulseX ?? state.food.impulseX,
				impulseY: options.impulseY ?? state.food.impulseY,
				visualRotation: options.visualRotation ?? state.food.visualRotation,
				rotationVelocity:
					(options.rotationVelocity ?? state.food.rotationVelocity) +
					randomBetween(-1.2, 1.2) +
					(Math.random() < 0.5 ? -0.8 : 0.8),
				bounceOffsetY: 0,
				bounceVelocityY: 0,
				lastBiteAt: -FOOD_BITE_COOLDOWN_MS,
				nextContestAt:
					performance.now() + randomBetween(options.contestDelayMin ?? 280, options.contestDelayMax ?? 560),
				floorBounceCount: 0,
				restX: options.restX ?? null,
			};

			state.scraps.push(item);
			root.appendChild(item.element);
			updateScrapFrame(item);
			return item;
		};
		const getBottomExitInset = (size) =>
			Math.min(
				SCRAP_BOTTOM_EXIT_EDGE_MAX,
				Math.max(
					SCRAP_BOTTOM_EXIT_EDGE_MIN,
					size * 1.45,
					window.innerWidth * SCRAP_BOTTOM_EXIT_EDGE_RATIO,
				),
			);
		const rectsOverlap = (left, right, padding = 0) =>
			left.x < right.x + right.width + padding &&
			left.x + left.width > right.x - padding &&
			left.y < right.y + right.height + padding &&
			left.y + left.height > right.y - padding;
		const getTopDropSpawnX = (size) => {
			const maxX = Math.max(0, window.innerWidth - size);
			if (maxX <= 0) {
				return 0;
			}
			return randomBetween(0, maxX);
		};
		const findSideDropSpawnY = (size, side) => {
			const maxY = Math.max(
				18,
				Math.min(window.innerHeight - size - 160, window.innerHeight * 0.42),
			);
			const edgeX = side === "left" ? 0 : Math.max(0, window.innerWidth - size);
			for (let attempt = 0; attempt < 18; attempt += 1) {
				const candidateY = randomBetween(18, maxY);
				const overlaps = state.scraps.some((scrap) => {
					if (scrap.mode === "dropping" || scrap.bitesRemaining <= 0) {
						return false;
					}
					const otherSize = getScrapSize(scrap);
					return rectsOverlap(
						{
							x: edgeX,
							y: candidateY,
							width: size,
							height: size,
						},
						{
							x: scrap.x,
							y: scrap.y,
							width: otherSize,
							height: otherSize,
						},
						Math.max(10, Math.min(size, otherSize) * 0.16),
					);
				});
				if (!overlaps) {
					return candidateY;
				}
			}
			return randomBetween(18, maxY);
		};
		const chooseRandomDroppedDrumstickSpawn = (size) => {
			const preferredX = getTopDropSpawnX(size);
			const spawnSide = ["left", "right", "top"][Math.floor(Math.random() * 3)];
			if (spawnSide === "top") {
				return {
					x: preferredX,
					y: -size - randomBetween(18, 56),
					vx: randomBetween(-0.9, 0.9),
					vy: randomBetween(RANDOM_DROP_TOP_SPEED_MIN, RANDOM_DROP_TOP_SPEED_MAX),
					restX: preferredX,
				};
			}

			const inwardDirection = spawnSide === "left" ? 1 : -1;
			const launchAngle = randomBetween(-0.16, 0.12);
			const launchSpeed = randomBetween(
				RANDOM_DROP_SIDE_SPEED_MIN,
				RANDOM_DROP_SIDE_SPEED_MAX,
			);
			return {
				x:
					spawnSide === "left"
						? -size - randomBetween(RANDOM_DROP_SIDE_ENTRY_MIN, RANDOM_DROP_SIDE_ENTRY_MAX)
						: window.innerWidth +
							randomBetween(RANDOM_DROP_SIDE_ENTRY_MIN, RANDOM_DROP_SIDE_ENTRY_MAX),
				y: findSideDropSpawnY(size, spawnSide),
				vx: inwardDirection * Math.cos(launchAngle) * launchSpeed,
				vy: Math.sin(launchAngle) * launchSpeed,
				restX: preferredX,
			};
		};
		const spawnTopDroppedDrumstick = () => {
			const scale = state.food.scale;
			const size = FOOD_HOME_SIZE * scale;
			const spawn = chooseRandomDroppedDrumstickSpawn(size);
			createDroppedFoodItem({
				foodKind: "drumstick",
				scale,
				x: spawn.x,
				y: spawn.y,
				vx: spawn.vx,
				vy: spawn.vy,
				bitesTotal: calculateFoodBites(scale),
				bitesRemaining: calculateFoodBites(scale),
				visualOffsetX: 0,
				visualOffsetY: 0,
				impulseX: randomBetween(-0.55, 0.55),
				impulseY: 0,
				visualRotation: randomBetween(-8, 8),
				rotationVelocity: randomBetween(-2.2, 2.2),
				contestDelayMin: 360,
				contestDelayMax: 680,
				restX: spawn.restX,
			});
		};

		const updateScrapFrame = (scrap) => {
			setSpriteHostMarkup(
				scrap.element.firstElementChild,
				scrap.foodKind ?? "scrap",
				getFoodVisualStage(scrap),
			);
			scrap.element.style.transform = `translate3d(${scrap.x + scrap.visualOffsetX}px, ${scrap.y + scrap.visualOffsetY + scrap.bounceOffsetY}px, 0) rotate(${scrap.visualRotation}deg) scale(${scrap.scale})`;
		};

		const removeScrap = (scrap) => {
			if (scrap.element.isConnected) {
				scrap.element.remove();
			}
			state.scraps = state.scraps.filter((item) => item.id !== scrap.id);
		};
		const releaseFoodPointerCapture = (pointerId) => {
			if (typeof pointerId !== "number") {
				return;
			}
			try {
				if (drumstickElement.hasPointerCapture(pointerId)) {
					drumstickElement.releasePointerCapture(pointerId);
				}
			} catch {
				// Ignore capture mismatches and continue the state transition.
			}
		};

		const setBirdPanelPerched = (bird) => {
			bird.state = "panel-perched";
			bird.element.dataset.state = "panel-perched";
			bird.x = bird.destination.x;
			bird.y = bird.destination.y;
			bird.visualShiftX = 0;
			bird.visualBob = 0;
			bird.leaveAt = performance.now() + randomBetween(MIN_DWELL_MS, MAX_DWELL_MS);
			bird.perchedAt = performance.now();
			bird.lastHungerBubbleAt = bird.lastHungerBubbleAt || 0;
			bird.perchAction = "idle";
			bird.perchActionStartedAt = 0;
			bird.perchActionDuration = 0;
			bird.nextPerchActionAt =
				performance.now() + randomBetween(PERCH_ACTION_MIN_MS, PERCH_ACTION_MAX_MS);
			rememberBirdPerchElement(bird, bird.perch?.element ?? null);
			setBirdFrame(bird, PERCHED_FRAME_INDEX);
			applyBirdFrame(bird);
		};
		const beginPerchAction = (bird, now) => {
			const actions = ["hop", "turn-hop", "preen"];
			bird.perchAction = actions[Math.floor(Math.random() * actions.length)] ?? "hop";
			bird.perchActionStartedAt = now;
			bird.perchActionDuration = randomBetween(520, 980);
			bird.nextPerchActionAt =
				now +
				bird.perchActionDuration +
				randomBetween(PERCH_ACTION_MIN_MS, PERCH_ACTION_MAX_MS);
			if (bird.perchAction === "turn-hop") {
				bird.facing *= -1;
			}
		};

		const sendBirdToPanel = (bird, landingSpot, options = {}) => {
			const { doubleHop = false } = options;
			if (!landingSpot) {
				startEscape(bird);
				return;
			}

			const destination = getPanelDestination(landingSpot, bird);
			if (doubleHop) {
				const relay = {
					x: clamp(
						(bird.x + destination.x) / 2 + randomBetween(-60, 60),
						-bird.width * 0.4,
						window.innerWidth - bird.width * 0.6,
					),
					y: Math.max(
						-bird.height * 2,
						Math.min(bird.y, destination.y) - randomBetween(110, 170),
					),
				};
				beginFlightSegment(bird, {
					state: "relocating",
					destination: relay,
					duration: randomBetween(420, 620),
					arcHeight: randomBetween(24, 52),
					finalAction: "relayToPanel",
					payload: { landingSpot },
				});
				return;
			}

			beginFlightSegment(bird, {
				state: "approaching",
				destination,
				duration: randomBetween(760, 1180),
				arcHeight: randomBetween(24, 52),
				finalAction: "panelPerch",
				payload: { landingSpot },
			});
		};

		const releaseBirdFromFood = (bird) => {
			if (!hasChickenLegs()) {
				startEscape(bird);
				return;
			}
			const landingSpot = chooseLandingSpot({
				excludeBird: bird,
			});
			if (landingSpot) {
				sendBirdToPanel(bird, landingSpot);
				return;
			}
			startEscape(bird);
		};

		const assignFoodSlots = (sources = getFoodSources()) => {
			const foodBirds = state.birds
				.filter((bird) => bird.state !== "escaping")
				.sort((left, right) => left.id - right.id);
			if (sources.length === 0) {
				foodBirds.forEach((bird) => {
					bird.foodTargetKey = null;
					bird.foodSlotIndex = 0;
				});
				return;
			}

			const assignedCounts = new Map();
			foodBirds.forEach((bird) => {
				const source = chooseFoodSourceForBird(bird, sources, assignedCounts);
				if (!source) {
					bird.foodTargetKey = null;
					bird.foodSlotIndex = 0;
					return;
				}
				const slotIndex = assignedCounts.get(source.targetKey) ?? 0;
				assignedCounts.set(source.targetKey, slotIndex + 1);
				bird.foodTargetKey = source.targetKey;
				bird.foodSlotIndex = slotIndex;
			});
		};

		const startFoodHover = (bird, options = {}) => {
			if (!isBirdHungry(bird) && options.force !== true) {
				return;
			}
			const sources = options.sources ?? getFoodSources();
			const source =
				options.source ??
				getFoodSourceByTargetKey(bird.foodTargetKey, sources) ??
				sources[0] ??
				null;
			if (!source) {
				releaseBirdFromFood(bird);
				return;
			}

			bird.foodTargetKey = source.targetKey;
			const waitPoint = getFoodWaitPoint(bird, source);
			retargetFoodHoverDrift(bird, source);
			if (options.direct) {
				bird.state = "food-hover";
				bird.element.dataset.state = "food-hover";
				applyBirdFrame(bird);
				return;
			}

			beginFlightSegment(bird, {
				state: "food-approaching",
				destination: waitPoint,
				duration: randomBetween(640, 980),
				arcHeight: randomBetween(18, 38),
				finalAction: "foodHover",
				payload: { source },
			});
		};

		const summonBirdsToFood = () => {
			const sources = getFoodSources();
			if (!hasChickenLegs() || sources.length === 0) {
				return;
			}

			const acceleratedSpawnAt = Date.now() + getSpawnIntervalMs();
			if (state.nextSpawnAt === 0 || state.nextSpawnAt > acceleratedSpawnAt) {
				state.nextSpawnAt = acceleratedSpawnAt;
			}
			assignFoodSlots(sources);
			state.birds.forEach((bird) => {
				if (bird.state === "escaping" || !isBirdHungry(bird)) {
					return;
				}
				startFoodHover(bird, { source: getAssignedFoodSource(bird, sources), sources });
			});
			ensureAnimationLoop();
		};

		const startFoodDash = (bird, options) => {
			if (!isFoodContestable(options.source)) {
				startFoodHover(bird, { direct: true });
				return;
			}

			const slotIndex = options.index ?? bird.foodSlotIndex ?? 0;
			const bitePoint = getFoodBitePoint(slotIndex, options.source);
			const isGroundFood = options.source?.mode === "active";
			const sourceCenterX = options.source.x + options.source.size * 0.5;
			const sourceCenterY = options.source.y + options.source.size * 0.54;
			const contestOffsetX =
				(slotIndex % 2 === 0 ? -1 : 1) *
				(options.source.size * randomBetween(0.72, 1.05));
			const contestOffsetY = isGroundFood
				? randomBetween(-10, 12)
				: randomBetween(-24, 18);
			const destination = {
				x: options.success
					? bitePoint.x - bird.width * 0.42 + randomBetween(-10, 10)
					: sourceCenterX + contestOffsetX - bird.width * 0.5 + randomBetween(-8, 8),
				y: options.success
					? isGroundFood
						? bitePoint.y - bird.footOffset + randomBetween(-3, 3)
						: bitePoint.y - bird.height * 0.38 + randomBetween(-8, 8)
					: isGroundFood
						? sourceCenterY + contestOffsetY - bird.footOffset
						: sourceCenterY + contestOffsetY - bird.height * 0.46,
			};
			beginFlightSegment(bird, {
				state: "food-dash",
				destination,
				duration: isGroundFood
					? randomBetween(220, 360) * bird.dashDurationFactor
					: randomBetween(320, 620) * bird.dashDurationFactor,
				arcHeight:
					(isGroundFood ? randomBetween(2, 10) : randomBetween(12, 34)) *
					bird.dashArcFactor,
				finalAction: options.success ? "foodBiteSuccess" : "foodBiteFail",
				payload: { source: options.source, success: options.success },
			});
		};

		const completeFoodBite = (bird) => {
			const source = bird.actionPayload?.source ?? getCurrentFoodSource();
			if (!source) {
				releaseBirdFromFood(bird);
				return;
			}

			const foodEntity = getFoodEntityFromSource(source);
			if (!foodEntity) {
				releaseBirdFromFood(bird);
				return;
			}

			foodEntity.bitesRemaining = Math.max(0, foodEntity.bitesRemaining - 1);

			bird.hasEatenFood = true;
			bird.foodEatenCount += 1;
			bird.growthScale = clamp(1 + bird.foodEatenCount * 0.065, 1, 1.28);
			updateBirdDimensions(bird);
			spawnHeartBurst(bird);
			applyFoodSourceImpulse(
				source,
				bird.x + bird.width * 0.48,
				bird.y + bird.height * 0.42,
				{ success: true },
			);
			applyFoodFrame();

			if (source.kind === "main" && foodEntity.bitesRemaining === 0) {
				startMainFoodSpentExit();
				state.birds.forEach((otherBird) => {
					if (otherBird !== bird && otherBird.state.startsWith("food")) {
						releaseBirdFromFood(otherBird);
					}
				});
				startSatedBehavior(bird, source);
				return;
			}

			if (source.kind === "scrap" && foodEntity.bitesRemaining === 0) {
