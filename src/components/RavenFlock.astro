				x:
					direction < 0
						? -bird.width * 1.8
						: window.innerWidth + bird.width * 0.8,
				y: Math.max(-bird.height * 2, bird.y - randomBetween(140, 260)),
				direction,
			};
		};

		const getPanelDestination = (landingSpot, bird) => ({
			x: clamp(
				landingSpot.x - bird.width / 2,
