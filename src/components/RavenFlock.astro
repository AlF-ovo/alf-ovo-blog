			const y = Math.max(28, window.innerHeight * 0.22 + Math.abs(slotOffset) * 6);
			return { x, y, slotOffset, totalDrops, dropped };
		};
		const getAlfDropPoint = (bird, plan = bird.alfSupplyPlan) => {
