			bird.x = lerp(bird.x, targetX, isGroundFood ? bird.hoverTightness : bird.hoverTightness * 0.74);
			bird.y = lerp(bird.y, targetY, isGroundFood ? bird.hoverTightness : bird.hoverTightness * 0.72);
