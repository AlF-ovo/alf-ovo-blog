			const dropped = Math.max(0, plan?.dropped ?? 0);
			const slotOffset = dropped - (totalDrops - 1) / 2;
			const baseX = window.innerWidth * 0.5 - size * 0.5;
			const x = clamp(
				baseX + slotOffset * ALF_DROP_SLOT_SPACING,
				12,
				Math.max(12, window.innerWidth - size - 12),
