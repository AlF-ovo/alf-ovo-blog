---
import "@fontsource-variable/jetbrains-mono";
import "@fontsource-variable/jetbrains-mono/wght-italic.css";

interface Props {
	class: string;
}
const className = Astro.props.class;
---
<div data-pagefind-body class={`prose dark:prose-invert prose-base !max-w-none custom-md ${className}`}>
    <!--<div class="prose dark:prose-invert max-w-none custom-md">-->
    <!--<div class="max-w-none custom-md">-->
    <slot/>
</div>

<script>
const MARKDOWN_COPY_SETUP_KEY = "alfMarkdownCopySetup";
const COPY_FEEDBACK_DURATION_MS = 1000;

function clearCopyFeedback(button: HTMLElement) {
	const timeoutId = button.getAttribute("data-timeout-id");
	if (timeoutId) {
		clearTimeout(Number.parseInt(timeoutId, 10));
		button.removeAttribute("data-timeout-id");
	}

	button.classList.remove("success");
}

function scheduleCopyFeedbackReset(button: HTMLElement) {
	const timeoutId = window.setTimeout(() => {
		button.classList.remove("success");
		button.removeAttribute("data-timeout-id");
	}, COPY_FEEDBACK_DURATION_MS);

	button.setAttribute("data-timeout-id", timeoutId.toString());
}

function fallbackCopyText(text: string): boolean {
	const textarea = document.createElement("textarea");
	textarea.value = text;
	textarea.setAttribute("readonly", "true");
	textarea.style.position = "fixed";
	textarea.style.top = "0";
	textarea.style.left = "-9999px";
	textarea.style.opacity = "0";

	document.body.appendChild(textarea);
	textarea.focus();
	textarea.select();

	let copied = false;
	try {
		copied = document.execCommand("copy");
	} catch (_error) {
		copied = false;
	}

	textarea.remove();
	return copied;
}

async function copyText(text: string): Promise<boolean> {
	if (navigator.clipboard?.writeText) {
		try {
			await navigator.clipboard.writeText(text);
			return true;
		} catch (_error) {
			// Fall back to execCommand below.
		}
	}

	return fallbackCopyText(text);
}

const markdownCopyWindow = window as typeof window & Record<string, unknown>;

if (!markdownCopyWindow[MARKDOWN_COPY_SETUP_KEY]) {
	markdownCopyWindow[MARKDOWN_COPY_SETUP_KEY] = true;

	document.addEventListener("click", async (e: MouseEvent) => {
		const target = e.target as Element | null;
		const button = target?.closest(".copy-btn");
		if (!(button instanceof HTMLElement)) {
			return;
		}

		const preEle = button.closest("pre");
		const codeEle = preEle?.querySelector("code");
		const code = Array.from(codeEle?.querySelectorAll(".code:not(summary *)") ?? [])
			.map((el) => el.textContent)
			.map((text) => (text === "\n" ? "" : text))
			.join("\n");

		const copied = await copyText(code);
		if (!copied) {
			clearCopyFeedback(button);
			console.error("Failed to copy code block contents.");
			return;
		}

		clearCopyFeedback(button);
		button.classList.add("success");
		scheduleCopyFeedbackReset(button);
	});
}
</script>
