---
import { profileConfig } from "../../config";
import DashboardActivityPanel from "./DashboardActivityPanel.astro";
import DashboardGuidePanel from "./DashboardGuidePanel.astro";
import DashboardHero from "./DashboardHero.astro";
import DashboardMetricsGrid from "./DashboardMetricsGrid.astro";
import DashboardRecentUpdates from "./DashboardRecentUpdates.astro";
import DashboardSidebar from "./DashboardSidebar.astro";
import DashboardTopbar from "./DashboardTopbar.astro";

type ActivityPoint = {
	label: string;
	publish: number;
	update: number;
	delete: number;
};

type ActivityMetric = ActivityPoint & {
	total: number;
	x: number;
	publishY: number;
	updateY: number;
	deleteY: number;
};

interface DashboardItem {
	title: string;
	time: string;
	url: string;
	description: string;
	kindLabel: "文章" | "笔记";
}

interface DashboardMetrics {
	updatedEntries: number;
	updatedWords: number;
	contentBreakdown: string;
	contentBreakdownNote: string;
	latestPost: { title: string; url: string; excerpt: string; kindLabel: string };
	latestNote: { title: string; url: string; excerpt: string; kindLabel: string };
	lastUpdatedEntry: { title: string; url: string; excerpt: string; kindLabel: string };
}

interface Props {
	chartDatasets: Record<string, { label: string; points: ActivityPoint[] }>;
	recentUpdates: DashboardItem[];
	dashboardMetrics: DashboardMetrics;
	compact?: boolean;
	showSidebar?: boolean;
}

const {
	chartDatasets,
	recentUpdates,
	dashboardMetrics,
	compact = false,
	showSidebar = true,
}: Props = Astro.props;

const dashboardHeroQuotes = [
	"Keep the logs clean and the routes short.",
	"Small changes compound faster than rewrites.",
	"Ship the page, then tune the edges.",
	"Make the structure obvious before making it clever.",
	"The home page should answer first and decorate second.",
	"Fast navigation is a feature, not a detail.",
];

const dashboardHints = {
	write: {
		title: "Write Flow",
		content: `1. Create long posts with: pnpm new-post -- your-slug
2. Create short notes with: pnpm new-post -- your-note --type note
3. Prefer folder-based content:
   src/content/posts/your-slug/index.md
   src/content/notes/your-note/index.md
4. Keep images and attachments next to index.md
5. Fill title, description, tags, category, categoryPath, and series early
6. Run pnpm build before publishing`,
	},
	organize: {
		title: "Structure Rules",
		content: `1. Keep category as the top-level bucket
2. Use categoryPath for nested navigation paths
3. Use series for connected writeups
4. Keep long-form in posts and short-form in notes
5. Prefer colocated assets over dumping into public
6. Preserve searchable titles, excerpts, and taxonomy`,
	},
};

const dashboardSearchItems = [
	{
		title: dashboardMetrics.lastUpdatedEntry.title,
		type: `Latest update - ${dashboardMetrics.lastUpdatedEntry.kindLabel}`,
		description: dashboardMetrics.lastUpdatedEntry.excerpt,
		url: dashboardMetrics.lastUpdatedEntry.url,
	},
	{
		title: dashboardMetrics.latestPost.title,
		type: `Latest post - ${dashboardMetrics.latestPost.kindLabel}`,
		description: dashboardMetrics.latestPost.excerpt,
		url: dashboardMetrics.latestPost.url,
	},
	{
		title: dashboardMetrics.latestNote.title,
		type: `Latest note - ${dashboardMetrics.latestNote.kindLabel}`,
		description: dashboardMetrics.latestNote.excerpt,
		url: dashboardMetrics.latestNote.url,
	},
	...recentUpdates.map((item) => ({
		title: item.title,
		type: `Recent - ${item.kindLabel}`,
		description: item.description,
		time: item.time,
		url: item.url,
	})),
];

const chartPalette = {
	publish: {
		line: "rgb(59, 130, 246)",
		area: "rgba(59, 130, 246, 0.12)",
	},
	update: {
		line: "rgb(14, 165, 233)",
		area: "rgba(14, 165, 233, 0.12)",
	},
	delete: {
		line: "rgb(245, 158, 11)",
		area: "rgba(245, 158, 11, 0.12)",
	},
};

const getChartMetrics = (points: ActivityPoint[]): ActivityMetric[] => {
	const maxTotal = Math.max(
		...points.map((point) => point.publish + point.update + point.delete),
		1,
	);
	const denominator = Math.max(points.length - 1, 1);

	return points.map((point, index) => ({
		...point,
		total: point.publish + point.update + point.delete,
		x: (index / denominator) * 100,
		publishY: 100 - (point.publish / maxTotal) * 100,
		updateY: 100 - (point.update / maxTotal) * 100,
		deleteY: 100 - (point.delete / maxTotal) * 100,
	}));
};

const summarizeDataset = (dataset: (typeof chartDatasets)["week"]) =>
	`${dataset.label}: ${dataset.points.reduce((sum, point) => sum + point.publish, 0)} published, ${dataset.points.reduce((sum, point) => sum + point.update, 0)} updated, ${dataset.points.reduce((sum, point) => sum + point.delete, 0)} deleted.`;

const defaultRange = "week";
const defaultDataset = chartDatasets[defaultRange];
const defaultMetrics = getChartMetrics(defaultDataset.points);
const defaultSummary = summarizeDataset(defaultDataset);
---

<div class:list={["dashboard-shell", { "dashboard-shell--compact": compact, "dashboard-shell--sidebarless": !showSidebar }]}>
	<div class="dashboard-main">
		<DashboardTopbar profileName={profileConfig.name} />
		<DashboardHero greeting={`Welcome, ${profileConfig.name}`} />
		<DashboardMetricsGrid metrics={dashboardMetrics} />

		<div class="dashboard-grid">
			<DashboardActivityPanel
				chartPalette={chartPalette}
				defaultRange={defaultRange}
				defaultMetrics={defaultMetrics}
				defaultSummary={defaultSummary}
			/>
			<DashboardRecentUpdates recentUpdates={recentUpdates} />
			<DashboardGuidePanel />
		</div>
	</div>

	{showSidebar && <DashboardSidebar />}
</div>

<div class="dashboard-hint-overlay" data-dashboard-hint-overlay hidden>
	<section class="dashboard-hint-card" data-dashboard-hint-root role="dialog" aria-modal="true" aria-labelledby="dashboard-hint-title">
		<div class="dashboard-hint-head">
			<div>
				<p class="dashboard-panel-eyebrow">Hint</p>
				<h3 class="dashboard-hint-title" id="dashboard-hint-title" data-dashboard-hint-title>Content Hint</h3>
			</div>
			<button class="dashboard-hint-close" type="button" aria-label="Close hint" data-dashboard-hint-close>
				x
			</button>
		</div>
		<textarea class="dashboard-hint-textbox" data-dashboard-hint-content readonly spellcheck="false"></textarea>
	</section>
</div>

<script id="dashboard-chart-data" type="application/json" is:inline set:html={JSON.stringify(chartDatasets)}></script>
<script id="dashboard-hint-data" type="application/json" is:inline set:html={JSON.stringify(dashboardHints)}></script>
<script id="dashboard-search-data" type="application/json" is:inline set:html={JSON.stringify(dashboardSearchItems)}></script>
<script id="dashboard-hero-quotes" type="application/json" is:inline set:html={JSON.stringify(dashboardHeroQuotes)}></script>

<script is:inline>
	const buildMetrics = (points) => {
		const maxTotal = Math.max(...points.map((point) => point.publish + point.update + point.delete), 1);
		const denominator = Math.max(points.length - 1, 1);
		return points.map((point, index) => ({
			...point,
			x: (index / denominator) * 100,
			publishY: 100 - (point.publish / maxTotal) * 100,
			updateY: 100 - (point.update / maxTotal) * 100,
			deleteY: 100 - (point.delete / maxTotal) * 100,
		}));
	};

	const buildAreaPath = (metrics, key) => `M 0 100 ${metrics.map((point) => `L ${point.x} ${point[key]}`).join(" ")} L 100 100 Z`;
	const buildLinePath = (metrics, key) => `M ${metrics.map((point) => `${point.x} ${point[key]}`).join(" L ")}`;
	const summarizeDataset = (dataset) =>
		`${dataset.label}: ${dataset.points.reduce((sum, point) => sum + point.publish, 0)} published, ${dataset.points.reduce((sum, point) => sum + point.update, 0)} updated, ${dataset.points.reduce((sum, point) => sum + point.delete, 0)} deleted.`;

	const initDashboardTypewriter = () => {
		const node = document.querySelector("[data-dashboard-typewriter]");
		const quoteNode = document.querySelector("[data-dashboard-hero-quote]");
		const quoteShell = document.querySelector("[data-dashboard-hero-quote-shell]");
		const quotesNode = document.querySelector("#dashboard-hero-quotes");

		if (!node || !quoteNode || !quoteShell || !quotesNode) {
			return;
		}

		const fullText = node.dataset.dashboardTypewriterText || "";
		const previousTimer = Number(node.dataset.dashboardTypewriterTimer || "0");
		const previousExpandTimer = Number(node.dataset.dashboardQuoteShellTimer || "0");
		const previousRevealTimer = Number(node.dataset.dashboardQuoteTimer || "0");
		const quotes = JSON.parse(quotesNode.textContent || "[]");
		const randomQuote =
			Array.isArray(quotes) && quotes.length > 0
				? quotes[Math.floor(Math.random() * quotes.length)]
				: "";

		if (previousTimer) {
			window.clearTimeout(previousTimer);
		}

		if (previousExpandTimer) {
			window.clearTimeout(previousExpandTimer);
		}

		if (previousRevealTimer) {
			window.clearTimeout(previousRevealTimer);
		}

		node.textContent = "";
		quoteShell.hidden = true;
		quoteShell.classList.remove("is-expanded");
		quoteNode.hidden = true;
		quoteNode.classList.remove("is-visible");
		quoteNode.textContent = randomQuote;

		let index = 0;

		const tick = () => {
			node.textContent = fullText.slice(0, index);
			index += 1;

			if (index <= fullText.length) {
				const timer = window.setTimeout(tick, 120);
				node.dataset.dashboardTypewriterTimer = String(timer);
				return;
			}

			node.dataset.dashboardTypewriterTimer = "";

			if (randomQuote) {
				const expandTimer = window.setTimeout(() => {
					quoteShell.hidden = false;
					window.requestAnimationFrame(() => {
						quoteShell.classList.add("is-expanded");
					});

					const revealTimer = window.setTimeout(() => {
						quoteNode.hidden = false;
						window.requestAnimationFrame(() => {
							quoteNode.classList.add("is-visible");
						});
					}, 320);
					node.dataset.dashboardQuoteTimer = String(revealTimer);
				}, 220);
				node.dataset.dashboardQuoteShellTimer = String(expandTimer);
				return;
			}

			node.dataset.dashboardQuoteShellTimer = "";
			node.dataset.dashboardQuoteTimer = "";
		};

		tick();
	};

	const initDashboardSearch = () => {
		const root = document.querySelector("[data-dashboard-search]");
		const input = document.querySelector("[data-dashboard-search-input]");
		const results = document.querySelector("[data-dashboard-search-results]");
		const listNode = document.querySelector("[data-dashboard-search-list]");
		const emptyNode = document.querySelector("[data-dashboard-search-empty]");
		const dataNode = document.querySelector("#dashboard-search-data");

		if (!root || !input || !results || !listNode || !emptyNode || !dataNode) {
			return;
		}

		if (root.dataset.dashboardSearchInitialized === "true") {
			return;
		}
		root.dataset.dashboardSearchInitialized = "true";

		const items = JSON.parse(dataNode.textContent || "[]");
		const normalize = (value) => String(value || "").trim().toLowerCase();
		const dashboardWindow = window;
		const outsideClickHandlerKey = "__alfDashboardSearchOutsideClickBound";
		const createResultNode = (item) => {
			const link = document.createElement("a");
			link.className = "dashboard-search-result";
			link.href = item.url;

			const meta = document.createElement("div");
			meta.className = "dashboard-search-result-meta";
			meta.textContent = `${item.type}${item.time ? ` - ${item.time}` : ""}`;

			const title = document.createElement("div");
			title.className = "dashboard-search-result-title";
			title.textContent = item.title;

			const copy = document.createElement("div");
			copy.className = "dashboard-search-result-copy";
			copy.textContent = item.description;

			link.append(meta, title, copy);
			return link;
		};

		const renderResults = (query = "") => {
			const keyword = normalize(query);
			const matchedItems = items
				.filter((item) => {
					if (!keyword) {
						return true;
					}

					return [item.title, item.type, item.description, item.time].some((field) =>
						normalize(field).includes(keyword),
					);
				})
				.slice(0, 5);

			listNode.replaceChildren();

			if (matchedItems.length === 0) {
				emptyNode.hidden = false;
				results.hidden = false;
				return;
			}

			emptyNode.hidden = true;
			matchedItems.forEach((item) => {
				listNode.appendChild(createResultNode(item));
			});

			results.hidden = false;
		};

		input.onfocus = () => renderResults(input.value);
		input.oninput = () => renderResults(input.value);

		if (!dashboardWindow[outsideClickHandlerKey]) {
			dashboardWindow[outsideClickHandlerKey] = true;
			document.addEventListener("click", (event) => {
				const currentRoot = document.querySelector("[data-dashboard-search]");
				const currentResults = document.querySelector("[data-dashboard-search-results]");
				if (!(currentRoot instanceof HTMLElement) || !(currentResults instanceof HTMLElement)) {
					return;
				}

				if (!currentRoot.contains(event.target)) {
					currentResults.hidden = true;
				}
			});
		}
	};

	const initDashboardHints = () => {
		const dataNode = document.querySelector("#dashboard-hint-data");
		const overlay = document.querySelector("[data-dashboard-hint-overlay]");
		const titleNode = document.querySelector("[data-dashboard-hint-title]");
		const contentNode = document.querySelector("[data-dashboard-hint-content]");
		const closeButton = document.querySelector("[data-dashboard-hint-close]");
		const triggers = document.querySelectorAll("[data-dashboard-hint-trigger]");

		if (!dataNode || !overlay || !titleNode || !contentNode || !closeButton || triggers.length === 0) {
			return;
		}

		const hints = JSON.parse(dataNode.textContent || "{}");

		const openHint = (key) => {
			const hint = hints[key];
			if (!hint) {
				return;
			}

			titleNode.textContent = hint.title;
			contentNode.value = hint.content;
			overlay.hidden = false;
		};

		const closeHint = () => {
			overlay.hidden = true;
		};

		triggers.forEach((trigger) => {
			trigger.onclick = () => openHint(trigger.dataset.dashboardHintTrigger);
		});

		closeButton.onclick = closeHint;
		overlay.onclick = (event) => {
			if (event.target === overlay) {
				closeHint();
			}
		};
	};

	const initDashboardChart = () => {
		const dataNode = document.querySelector("#dashboard-chart-data");
		const chartRoot = document.querySelector("[data-chart-root]");
		const switchRoot = document.querySelector("[data-chart-switch]");
		const summaryNode = document.querySelector("[data-chart-summary]");
		const svg = document.querySelector("[data-chart-svg]");
		const labels = document.querySelector("[data-chart-labels]");
		if (!dataNode || !chartRoot || !switchRoot || !summaryNode || !svg || !labels) {
			return;
		}

		const datasets = JSON.parse(dataNode.textContent || "{}");
		const [publishArea, updateArea, deleteArea, publishLine, updateLine, deleteLine] = svg.querySelectorAll("path");

		const renderChart = (range) => {
			const dataset = datasets[range];
			if (!dataset) {
				return;
			}

			const metrics = buildMetrics(dataset.points);
			switchRoot.dataset.activeIndex = range === "week" ? "0" : range === "month" ? "1" : "2";
			switchRoot.querySelectorAll("[data-range-option]").forEach((button) => {
				const active = button.dataset.rangeOption === range;
				button.classList.toggle("is-active", active);
				button.setAttribute("aria-selected", active ? "true" : "false");
			});

			publishArea.setAttribute("d", buildAreaPath(metrics, "publishY"));
			updateArea.setAttribute("d", buildAreaPath(metrics, "updateY"));
			deleteArea.setAttribute("d", buildAreaPath(metrics, "deleteY"));
			publishLine.setAttribute("d", buildLinePath(metrics, "publishY"));
			updateLine.setAttribute("d", buildLinePath(metrics, "updateY"));
			deleteLine.setAttribute("d", buildLinePath(metrics, "deleteY"));
			summaryNode.textContent = summarizeDataset(dataset);
			labels.style.gridTemplateColumns = `repeat(${metrics.length}, minmax(0, 1fr))`;
			labels.replaceChildren(
				...metrics.map((point) => {
					const item = document.createElement("span");
					item.className = "dashboard-chart-label";
					item.textContent = point.label;
					return item;
				}),
			);
		};

		switchRoot.querySelectorAll("[data-range-option]").forEach((button) => {
			button.onclick = () => renderChart(button.dataset.rangeOption);
		});

		renderChart(chartRoot.dataset.defaultRange || "week");
	};

	const bootDashboard = () => {
		initDashboardTypewriter();
		initDashboardSearch();
		initDashboardHints();
		initDashboardChart();
	};

	document.addEventListener("astro:page-load", bootDashboard);
	document.addEventListener("DOMContentLoaded", bootDashboard);
</script>

<style is:global>
	.dashboard-shell {
		--dashboard-frame: rgba(255, 255, 255, 0.76);
		--dashboard-frame-strong: rgba(255, 255, 255, 0.96);
		--dashboard-surface-hover: rgba(255, 255, 255, 0.08);
		--dashboard-shadow: 0 18px 48px rgba(15, 23, 42, 0.12);
		--dashboard-text: rgba(15, 23, 42, 0.92);
		--dashboard-muted: rgba(51, 65, 85, 0.84);
		--dashboard-subtle: rgba(71, 85, 105, 0.78);
		max-width: 1280px;
		margin: 0 auto;
		padding: 1rem;
		display: grid;
		grid-template-columns: minmax(0, 1fr) 280px;
		gap: 1rem;
	}

	.dark .dashboard-shell {
		--dashboard-frame: rgba(255, 255, 255, 0.24);
		--dashboard-frame-strong: rgba(255, 255, 255, 0.42);
		--dashboard-surface-hover: rgba(255, 255, 255, 0.06);
		--dashboard-shadow: 0 18px 48px rgba(2, 6, 23, 0.32);
		--dashboard-text: rgba(248, 250, 252, 0.96);
		--dashboard-muted: rgba(226, 232, 240, 0.84);
		--dashboard-subtle: rgba(203, 213, 225, 0.72);
	}

	.dashboard-shell--compact {
		max-width: none;
		padding: 0;
		grid-template-columns: minmax(0, 1fr) 14.5rem;
		gap: 0.85rem;
	}

	.dashboard-shell--sidebarless,
	.dashboard-shell--compact.dashboard-shell--sidebarless {
		grid-template-columns: minmax(0, 1fr);
	}

	.dashboard-sidebar,
	.dashboard-panel,
	.dashboard-hero,
	.dashboard-metric-card {
		border-radius: 1.5rem;
		border: 1px solid var(--dashboard-frame);
		background: transparent;
		box-shadow: var(--dashboard-shadow);
		backdrop-filter: blur(12px);
	}

	.dashboard-shell--compact .dashboard-sidebar,
	.dashboard-shell--compact .dashboard-panel,
	.dashboard-shell--compact .dashboard-hero,
	.dashboard-shell--compact .dashboard-metric-card {
		border-radius: 1.2rem;
	}

	.dashboard-sidebar {
		position: sticky;
		top: 1rem;
		align-self: start;
		display: grid;
		gap: 1rem;
		padding: 1.25rem;
	}

	.dashboard-shell--compact .dashboard-sidebar {
		top: 0.5rem;
		padding: 1rem;
		gap: 0.75rem;
	}

	.dashboard-brand,
	.dashboard-nav-link,
	.dashboard-topbar,
	.dashboard-topbar-actions,
	.dashboard-profile-chip,
	.dashboard-panel-head,
	.dashboard-chart-meta,
	.dashboard-chart-legend span,
	.dashboard-hero-actions {
		display: flex;
		align-items: center;
	}

	.dashboard-brand {
		gap: 0.9rem;
	}

	.dashboard-brand-mark,
	.dashboard-profile-avatar {
		width: 3rem;
		height: 3rem;
		display: grid;
		place-items: center;
		border-radius: 1rem;
		border: 1px solid var(--dashboard-frame);
		background: transparent;
		box-shadow: var(--dashboard-shadow);
		backdrop-filter: blur(12px);
		color: var(--dashboard-text);
		font-weight: 800;
	}

	.dashboard-shell--compact .dashboard-brand-mark,
	.dashboard-shell--compact .dashboard-profile-avatar {
		width: 2.6rem;
		height: 2.6rem;
		border-radius: 0.85rem;
	}

	.dashboard-brand-eyebrow,
	.dashboard-panel-eyebrow,
	.dashboard-topbar-label,
	.dashboard-hero-eyebrow {
		margin: 0;
		font-size: 0.78rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--dashboard-subtle);
	}

	.dashboard-brand-title,
	.dashboard-topbar-title,
	.dashboard-panel-title,
	.dashboard-hero-title,
	.dashboard-recent-title {
		margin: 0.35rem 0 0;
		color: var(--dashboard-text);
	}

	.dashboard-nav {
		display: grid;
		gap: 0.45rem;
	}

	.dashboard-nav-link {
		gap: 0.7rem;
		padding: 0.8rem 0.9rem;
		border-radius: 1rem;
		border: 1px solid var(--dashboard-frame);
		text-decoration: none;
		font-weight: 700;
		color: var(--dashboard-text);
		background: transparent;
	}

	.dashboard-nav-link:hover {
		background: var(--dashboard-surface-hover);
		border-color: var(--dashboard-frame-strong);
	}

	.dashboard-sidebar-card,
	.dashboard-guide-card {
		padding: 1rem;
		border-radius: 1.1rem;
		border: 1px solid var(--dashboard-frame);
		background: transparent;
		box-shadow: var(--dashboard-shadow);
		backdrop-filter: blur(12px);
	}

	.dashboard-sidebar-title,
	.dashboard-guide-title {
		margin: 0;
		font-size: 0.95rem;
		font-weight: 700;
		color: var(--dashboard-text);
	}

	.dashboard-sidebar-copy,
	.dashboard-guide-copy,
	.dashboard-hero-copy,
	.dashboard-metric-copy,
	.dashboard-recent-copy,
	.dashboard-search-empty {
		margin: 0.65rem 0 0;
		line-height: 1.7;
		color: var(--dashboard-muted);
	}

	.dashboard-main {
		display: grid;
		gap: 1rem;
		min-width: 0;
	}

	.dashboard-shell--compact .dashboard-main {
		gap: 0.85rem;
	}

	.dashboard-topbar {
		justify-content: space-between;
		gap: 1rem;
	}

	.dashboard-topbar-title {
		font-size: clamp(1.35rem, 2.5vw, 1.8rem);
		font-weight: 800;
	}

	.dashboard-shell--compact .dashboard-topbar-title {
		font-size: clamp(1.05rem, 1.9vw, 1.35rem);
	}

	.dashboard-topbar-actions {
		gap: 0.9rem;
	}

	.dashboard-search {
		position: relative;
		width: min(28rem, 100%);
	}

	.dashboard-shell--compact .dashboard-search {
		width: min(20rem, 100%);
	}

	.dashboard-search-input {
		width: 100%;
		height: 3rem;
		padding: 0 1rem;
		border-radius: 1rem;
		border: 1px solid var(--dashboard-frame);
		background: transparent;
		box-shadow: var(--dashboard-shadow);
		backdrop-filter: blur(12px);
		color: var(--dashboard-text);
	}

