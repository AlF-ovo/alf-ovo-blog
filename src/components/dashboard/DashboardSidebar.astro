---
import { Icon } from "astro-icon/components";
import { url } from "@utils/url-utils";

const links = [
	{ label: "总览", href: "#overview", icon: "fa6-solid:table-columns" },
	{ label: "活动", href: "#activity", icon: "fa6-solid:chart-line" },
	{ label: "更新", href: "#updates", icon: "fa6-solid:clock-rotate-left" },
	{ label: "首页", href: url("/"), icon: "fa6-solid:house" },
	{ label: "札记", href: url("/notes/"), icon: "fa6-regular:note-sticky" },
];
---

<aside class="dashboard-sidebar">
	<div class="dashboard-brand">
		<div class="dashboard-brand-mark">
			<Icon name="fa6-solid:terminal" />
		</div>
		<div>
			<p class="dashboard-brand-eyebrow">Control Panel</p>
			<h1 class="dashboard-brand-title">AlF Blog</h1>
		</div>
	</div>

	<nav class="dashboard-nav">
		{
			links.map((link) => (
				<a class="dashboard-nav-link" href={link.href}>
					<Icon name={link.icon} />
					<span>{link.label}</span>
				</a>
			))
		}
	</nav>

	<div class="dashboard-sidebar-card">
		<p class="dashboard-sidebar-title">本页作用</p>
		<p class="dashboard-sidebar-copy">
			这里集中展示内容结构、最近更新和发布习惯。
		</p>
	</div>
</aside>
