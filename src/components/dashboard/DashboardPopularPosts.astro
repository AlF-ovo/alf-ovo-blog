---
interface PopularPost {
	title: string;
	url: string;
	description: string;
}

interface Props {
	posts: PopularPost[];
}

const { posts }: Props = Astro.props;
---

<article id="popular" class="card-base dashboard-panel">
	<div class="dashboard-panel-head">
		<div>
			<p class="dashboard-panel-eyebrow">热度</p>
			<h3 class="dashboard-panel-title">访问最多文章</h3>
		</div>
		<p class="dashboard-chart-summary" data-popular-posts-status>正在统计羽毛落点...</p>
	</div>

	<div
		class="dashboard-popular-shell"
		data-popular-posts-root
		data-counter-api="https://busuanzi.9420.ltd/api"
		data-counter-origin={Astro.site ? String(Astro.site).replace(/\/$/, "") : "https://alf-ovo.cn"}
	>
		<div class="dashboard-popular-podium" data-popular-posts-podium>
			{
				Array.from({ length: Math.min(3, posts.length) }, (_, index) => (
					<a class="dashboard-popular-card is-loading" href={posts[index]?.url || "#"} data-popular-post-card data-rank={index + 1}>
						<div class="dashboard-popular-medal" data-popular-post-medal>{index + 1}</div>
						<div class="dashboard-popular-copy">
							<p class="dashboard-popular-rank-label">
								{index === 0 ? "金牌席" : index === 1 ? "银牌席" : "铜牌席"}
							</p>
							<h4 class="dashboard-popular-title" data-popular-post-title>
								{posts[index]?.title || "暂无文章"}
							</h4>
							<p class="dashboard-popular-description" data-popular-post-description>
								{posts[index]?.description || "等待更多内容加入排行。"}
							</p>
						</div>
						<div class="dashboard-popular-count" data-popular-post-count>统计中</div>
					</a>
				))
			}
		</div>

		<div class="dashboard-popular-list" data-popular-posts-list>
			{
				Array.from({ length: Math.max(posts.length - 3, 0) }, (_, listIndex) => {
					const post = posts[listIndex + 3];
					return (
						<a class="dashboard-popular-list-item is-loading" href={post?.url || "#"} data-popular-post-item data-rank={listIndex + 4}>
							<div class="dashboard-popular-list-rank" data-popular-post-medal>{listIndex + 4}</div>
							<div class="dashboard-popular-list-copy">
								<h4 class="dashboard-popular-list-title" data-popular-post-title>{post?.title || "暂无文章"}</h4>
								<p class="dashboard-popular-list-description" data-popular-post-description>
									{post?.description || "等待更多内容加入排行。"}
								</p>
							</div>
							<div class="dashboard-popular-list-count" data-popular-post-count>统计中</div>
						</a>
					);
				})
			}
		</div>
	</div>
</article>
