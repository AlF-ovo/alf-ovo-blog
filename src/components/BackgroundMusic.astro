---
import { Icon } from "astro-icon/components";
import { siteConfig } from "../config";
import { url } from "../utils/url-utils";

const playerId = "background-music-player";
const audioId = "background-music-audio";
const toggleId = "background-music-toggle";
const statusId = "background-music-status";
const listId = "background-music-list";
const drawerId = "background-music-drawer";
const drawerToggleId = "background-music-drawer-toggle";
const volumeId = "background-music-volume";
const volumeValueId = "background-music-volume-value";
const foregroundOpacityId = "system-foreground-opacity";
const foregroundOpacityValueId = "system-foreground-opacity-value";
const mascotScaleId = "live2d-mascot-scale";
const mascotScaleValueId = "live2d-mascot-scale-value";
const mascotVisibilityId = "live2d-mascot-visibility";
const mascotVisibilityValueId = "live2d-mascot-visibility-value";
const panelHintId = "system-panel-hint";

const backgroundMusic = siteConfig.backgroundMusic;
const normalizedTracks = backgroundMusic.tracks.map((track) => {
	const rawSrc = track.src.trim();
	const isRemoteSrc = /^(?:[a-z]+:)?\/\//i.test(rawSrc);
	const src = !rawSrc
		? ""
		: isRemoteSrc
			? rawSrc
			: url(`/${rawSrc.replace(/^\/+/, "")}`);

	return {
		...track,
		src,
		group: track.group?.trim() || track.id,
		hasSource: src.length > 0,
	};
});

const defaultTrack =
	normalizedTracks.find((track) => track.id === backgroundMusic.defaultTrackId) ??
	normalizedTracks[0] ??
	null;

const systemPanels = [
	{ id: "audio", label: "音频", icon: "fa6-solid:wave-square" },
	{ id: "playlist", label: "曲目", icon: "fa6-solid:list" },
	{ id: "mascot", label: "看板娘", icon: "fa6-solid:user-astronaut" },
	{ id: "display", label: "显示", icon: "fa6-solid:image" },
];
---

{
	backgroundMusic.enable && (
		<div
			id={playerId}
			class="system-control"
			data-autoplay={backgroundMusic.autoplay ? "true" : "false"}
			data-default-track-id={defaultTrack?.id ?? ""}
			data-playlist-loop={backgroundMusic.loop ? "true" : "false"}
			data-storage-key="background-music:selected-track"
			data-playing-key="background-music:playing"
			data-volume-key="background-music:volume"
			data-foreground-opacity-key="system:foreground-opacity"
			data-mascot-scale-key="system:mascot-scale"
			data-mascot-hidden-key="system:mascot-hidden"
			data-default-volume="0.20"
			data-default-foreground-opacity="0.8"
			data-default-mascot-scale="1"
			data-default-mascot-hidden="false"
		>
			<audio id={audioId} preload={defaultTrack?.hasSource ? "metadata" : "none"} playsinline></audio>

			<button
				id={drawerToggleId}
				type="button"
				class="system-control-launch"
				aria-label="打开系统面板"
				aria-controls={drawerId}
				aria-expanded="false"
			>
				<span class="system-control-launch__icon" aria-hidden="true">
					<Icon name="fa6-solid:sliders" />
				</span>
			</button>

			<section id={drawerId} class="system-control-drawer" hidden aria-label="系统面板">
				<div class="system-control-header">
					<div>
						<p class="system-control-heading">系统</p>
						<p id={statusId} class="system-control-status">
							{normalizedTracks.length > 0 ? "已就绪" : "还没有可用曲目"}
						</p>
					</div>
				</div>

				<div class="system-control-modes" role="tablist" aria-label="系统控制">
					{
						systemPanels.map((panel) => (
							<button
								type="button"
								class="system-control-mode"
								role="tab"
								aria-selected="false"
								aria-controls={`${drawerId}-${panel.id}`}
								data-system-panel-trigger={panel.id}
							>
								<span class="system-control-mode__icon" aria-hidden="true">
									<Icon name={panel.icon} />
								</span>
								<span class="system-control-mode__label">{panel.label}</span>
							</button>
						))
					}
				</div>

				<p id={panelHintId} class="system-control-panel-hint">
					点一个图标，展开对应的控制项。
				</p>

				<section
					id={`${drawerId}-audio`}
					class="system-control-detail"
					data-system-panel="audio"
					hidden
				>
					<div class="system-control-section">
						<div class="system-control-section__row">
							<div>
								<p class="system-control-section__title">播放</p>
								<p class="system-control-section__copy">暂停或继续当前背景音乐。</p>
							</div>
							<button
								id={toggleId}
								type="button"
								class="system-control-play"
								aria-label="切换背景音乐播放状态"
								aria-pressed="false"
								disabled={normalizedTracks.length === 0}
							>
								<span class="system-control-play__icon system-control-play__icon--play" aria-hidden="true">
									<Icon name="fa6-solid:play" />
								</span>
								<span class="system-control-play__icon system-control-play__icon--pause" aria-hidden="true">
									<Icon name="fa6-solid:pause" />
								</span>
							</button>
						</div>
					</div>

					<div class="system-control-section">
						<div class="system-control-section__row">
							<div>
								<p class="system-control-section__title">音量</p>
								<p class="system-control-section__copy">调整当前背景音乐的音量。</p>
							</div>
							<span id={volumeValueId} class="system-control-value">20%</span>
						</div>
						<input
							id={volumeId}
							class="system-control-slider"
							type="range"
							min="0"
							max="100"
							step="1"
							value="20"
							aria-label="音乐音量"
						/>
					</div>
				</section>

				<section
					id={`${drawerId}-display`}
					class="system-control-detail"
					data-system-panel="display"
					hidden
				>
					<div class="system-control-section">
						<div class="system-control-section__row">
							<div>
								<p class="system-control-section__title">前景透明度</p>
								<p class="system-control-section__copy">调整前景界面的透明度，壁纸保持完整显示。</p>
							</div>
							<span id={foregroundOpacityValueId} class="system-control-value">80%</span>
						</div>
						<input
							id={foregroundOpacityId}
							class="system-control-slider"
							type="range"
							min="30"
							max="100"
							step="1"
							value="80"
							aria-label="前景透明度"
						/>
					</div>
				</section>

				<section
					id={`${drawerId}-mascot`}
					class="system-control-detail"
					data-system-panel="mascot"
					hidden
				>
					<div class="system-control-section">
						<div class="system-control-section__row">
							<div>
								<p class="system-control-section__title">看板娘显示</p>
								<p class="system-control-section__copy">在这里隐藏或恢复 Live2D 看板娘。</p>
							</div>
							<span id={mascotVisibilityValueId} class="system-control-value">显示中</span>
						</div>
						<button
							id={mascotVisibilityId}
							type="button"
							class="system-control-action"
						>
							隐藏看板娘
						</button>
					</div>

					<div class="system-control-section">
						<div class="system-control-section__row">
							<div>
								<p class="system-control-section__title">看板娘大小</p>
								<p class="system-control-section__copy">单独调整 Live2D 看板娘尺寸，不影响其余布局。</p>
							</div>
							<span id={mascotScaleValueId} class="system-control-value">100%</span>
						</div>
						<input
							id={mascotScaleId}
							class="system-control-slider"
							type="range"
							min="60"
							max="150"
							step="1"
							value="100"
							aria-label="看板娘大小"
						/>
					</div>
				</section>

				<section
					id={`${drawerId}-playlist`}
					class="system-control-detail"
					data-system-panel="playlist"
					hidden
				>
					<div class="system-control-section">
						<div class="system-control-section__row">
							<div>
								<p class="system-control-section__title">当前曲目</p>
								<p class="system-control-section__copy">手动切换当前播放的背景音乐。</p>
							</div>
						</div>

						<div id={listId} class="system-control-track-list" role="listbox" aria-label="背景音乐列表">
							{normalizedTracks.length > 0 ? (
								normalizedTracks.map((track) => (
									<button
										type="button"
										class:list={["system-control-track", { "is-unavailable": !track.hasSource }]}
										role="option"
										data-track-id={track.id}
										data-track-src={track.src}
										data-track-title={track.title}
										data-track-artist={track.artist ?? ""}
										data-track-group={track.group}
										aria-selected="false"
										disabled={!track.hasSource}
									>
										<span class="system-control-track__copy">
											<span class="system-control-track__title">{track.title}</span>
											<span class="system-control-track__meta">
												{track.artist ? track.artist : track.hasSource ? "已就绪" : "缺少音源"}
											</span>
										</span>
										<span class="system-control-track__icon" aria-hidden="true">
											<Icon name="fa6-solid:wave-square" />
										</span>
									</button>
								))
							) : (
								<div class="system-control-empty">去 `src/config.ts` 里补充可用曲目。</div>
							)}
						</div>
					</div>
				</section>
			</section>
		</div>
	)
}

<style>
	.system-control {
		position: fixed;
		right: 0.85rem;
		bottom: 1rem;
		z-index: 95;
		display: flex;
		align-items: flex-end;
		opacity: var(--system-foreground-opacity, 0.8);
		transition: opacity 180ms ease;
	}

	.system-control-launch,
	.system-control-mode,
	.system-control-play,
	.system-control-track,
	.system-control-action {
		border: 1px solid rgba(255, 255, 255, 0.1);
		background: linear-gradient(180deg, rgba(12, 12, 16, 0.92), rgba(20, 20, 24, 0.82));
		box-shadow: 0 24px 60px rgba(0, 0, 0, 0.28);
		color: rgba(248, 250, 252, 0.96);
		backdrop-filter: blur(20px);
		transition:
			transform 180ms ease,
			border-color 180ms ease,
			box-shadow 180ms ease,
			background 180ms ease,
			opacity 180ms ease;
	}

	.system-control-launch:hover,
	.system-control-mode:hover,
	.system-control-play:hover:not(:disabled),
	.system-control-track:hover:not(:disabled),
	.system-control-action:hover {
		transform: translateY(-2px);
		border-color: rgba(255, 255, 255, 0.18);
		box-shadow: 0 28px 68px rgba(0, 0, 0, 0.34);
	}

	.system-control-launch {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 3.25rem;
		height: 3.25rem;
		padding: 0;
		border-radius: 1.15rem;
	}

	.system-control-launch__icon,
	.system-control-mode__icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
	}

	.system-control-launch__icon {
		width: 2.55rem;
		height: 2.55rem;
		border-radius: 0.95rem;
		background: rgba(255, 255, 255, 0.08);
		color: rgba(255, 255, 255, 0.96);
	}

	.system-control-launch__icon :global(svg) {
		width: 1rem;
		height: 1rem;
	}

	.system-control-drawer {
		position: absolute;
		right: 0;
		bottom: calc(100% + 0.75rem);
		width: min(22rem, calc(100vw - 1.7rem));
		padding: 0.95rem;
		border-radius: 1.35rem;
		border: 1px solid rgba(255, 255, 255, 0.1);
		background:
			linear-gradient(180deg, rgba(10, 10, 12, 0.94), rgba(18, 18, 22, 0.88)),
			radial-gradient(circle at top right, rgba(255, 255, 255, 0.06), transparent 35%);
		box-shadow: 0 28px 80px rgba(0, 0, 0, 0.35);
		backdrop-filter: blur(22px);
		color: rgba(248, 250, 252, 0.96);
	}

	.system-control-header {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 0.9rem;
	}

	.system-control-heading {
		margin: 0;
		font-size: 0.96rem;
		font-weight: 700;
		letter-spacing: 0.02em;
	}

	.system-control-status {
		margin: 0.5rem 0 0;
		padding: 0.62rem 0.78rem;
		border-radius: 0.95rem;
		background: rgba(255, 255, 255, 0.06);
		font-size: 0.76rem;
		line-height: 1.5;
		color: rgba(226, 232, 240, 0.84);
	}

	.system-control-modes {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 0.6rem;
		margin-top: 0.8rem;
	}

	.system-control-mode {
		display: grid;
		justify-items: center;
		gap: 0.38rem;
		padding: 0.72rem 0.5rem 0.62rem;
		border-radius: 1rem;
		text-align: center;
	}

	.system-control-mode[aria-selected="true"] {
		border-color: rgba(255, 255, 255, 0.2);
		background: linear-gradient(180deg, rgba(34, 36, 46, 0.96), rgba(18, 18, 24, 0.92));
	}

	.system-control-mode__icon {
		width: 2.35rem;
		height: 2.35rem;
		border-radius: 0.8rem;
		background: rgba(255, 255, 255, 0.08);
	}

	.system-control-mode__icon :global(svg) {
		width: 0.95rem;
		height: 0.95rem;
	}

	.system-control-mode__label {
		font-size: 0.72rem;
		font-weight: 700;
		color: rgba(248, 250, 252, 0.92);
		letter-spacing: 0.03em;
	}

	.system-control-panel-hint {
		margin: 0.8rem 0 0;
		padding: 0.78rem 0.85rem;
		border-radius: 1rem;
		background: rgba(255, 255, 255, 0.04);
		font-size: 0.76rem;
		line-height: 1.55;
		color: rgba(226, 232, 240, 0.68);
	}

	.system-control-detail {
		margin-top: 0.8rem;
	}

	.system-control-section {
		padding: 0.85rem;
		border-radius: 1.1rem;
		background: rgba(255, 255, 255, 0.04);
	}

	.system-control-section + .system-control-section {
		margin-top: 0.75rem;
	}

	.system-control-section__row {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 0.8rem;
	}

	.system-control-section__title {
		margin: 0;
		font-size: 0.84rem;
		font-weight: 700;
		color: rgba(248, 250, 252, 0.96);
	}

	.system-control-section__copy {
		margin: 0.22rem 0 0;
		font-size: 0.74rem;
		line-height: 1.5;
		color: rgba(226, 232, 240, 0.62);
	}

	.system-control-value {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 3rem;
		padding: 0.28rem 0.5rem;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.08);
		font-size: 0.74rem;
		font-weight: 700;
		color: rgba(248, 250, 252, 0.92);
	}

	.system-control-slider {
		width: 100%;
		margin-top: 0.75rem;
		accent-color: rgb(226, 232, 240);
	}

	.system-control-action,
	.system-control-play {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 2.9rem;
		border-radius: 1rem;
	}

	.system-control-action {
		width: 100%;
		margin-top: 0.75rem;
		padding: 0.8rem 0.9rem;
		font-size: 0.8rem;
		font-weight: 700;
	}

	.system-control-play {
		width: 3rem;
		height: 3rem;
		padding: 0;
		flex-shrink: 0;
	}

	.system-control-play:disabled {
		opacity: 0.4;
		cursor: not-allowed;
	}

	.system-control-play__icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
	}

	.system-control-play__icon :global(svg) {
		width: 0.95rem;
		height: 0.95rem;
	}

	.system-control-play.is-playing .system-control-play__icon--play {
		display: none;
	}

	.system-control-play:not(.is-playing) .system-control-play__icon--pause {
		display: none;
	}

	.system-control-track-list {
		display: flex;
		flex-direction: column;
		gap: 0.55rem;
		max-height: min(18rem, 40vh);
		margin-top: 0.8rem;
		overflow: auto;
	}

	.system-control-track {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.8rem;
		width: 100%;
		padding: 0.78rem 0.85rem;
		border-radius: 1rem;
		text-align: left;
	}

	.system-control-track[aria-selected="true"] {
		border-color: rgba(255, 255, 255, 0.22);
		background: linear-gradient(180deg, rgba(38, 38, 48, 0.96), rgba(18, 18, 24, 0.92));
	}

	.system-control-track:disabled {
		opacity: 0.36;
		cursor: not-allowed;
	}

	.system-control-track__copy {
		display: flex;
		flex-direction: column;
		min-width: 0;
	}

	.system-control-track__title {
		font-size: 0.84rem;
		font-weight: 600;
		color: rgba(248, 250, 252, 0.96);
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	.system-control-track__meta {
		margin-top: 0.2rem;
		font-size: 0.74rem;
		color: rgba(226, 232, 240, 0.6);
	}

	.system-control-track__icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		color: rgba(226, 232, 240, 0.84);
		flex-shrink: 0;
	}

	.system-control-track__icon :global(svg) {
		width: 0.88rem;
		height: 0.88rem;
	}

	.system-control-empty {
		margin-top: 0.8rem;
		padding: 0.8rem 0.85rem;
		border-radius: 1rem;
		background: rgba(255, 255, 255, 0.05);
		font-size: 0.78rem;
		line-height: 1.5;
		color: rgba(226, 232, 240, 0.7);
	}

	@media (max-width: 720px) {
		.system-control {
			right: 0.7rem;
			bottom: 0.85rem;
		}

		.system-control-launch {
			width: 3rem;
			height: 3rem;
		}

		.system-control-drawer {
			width: min(21rem, calc(100vw - 1.4rem));
			padding: 0.85rem;
		}

		.system-control-modes {
			gap: 0.5rem;
		}

		.system-control-mode {
			padding-inline: 0.35rem;
		}
	}
</style>

<script is:inline>
	const playerId = "background-music-player";
	const audioId = "background-music-audio";
	const toggleId = "background-music-toggle";
	const statusId = "background-music-status";
	const listId = "background-music-list";
	const drawerId = "background-music-drawer";
	const drawerToggleId = "background-music-drawer-toggle";
	const volumeId = "background-music-volume";
	const volumeValueId = "background-music-volume-value";
	const foregroundOpacityId = "system-foreground-opacity";
	const foregroundOpacityValueId = "system-foreground-opacity-value";
	const mascotScaleId = "live2d-mascot-scale";
	const mascotScaleValueId = "live2d-mascot-scale-value";
	const mascotVisibilityId = "live2d-mascot-visibility";
	const mascotVisibilityValueId = "live2d-mascot-visibility-value";
	const panelHintId = "system-panel-hint";

	const initBackgroundMusic = () => {
		const root = document.getElementById(playerId);
		const audio = document.getElementById(audioId);
		const toggle = document.getElementById(toggleId);
		const status = document.getElementById(statusId);
		const trackList = document.getElementById(listId);
		const drawer = document.getElementById(drawerId);
		const drawerToggle = document.getElementById(drawerToggleId);
		const volumeInput = document.getElementById(volumeId);
		const volumeValue = document.getElementById(volumeValueId);
		const foregroundOpacityInput = document.getElementById(foregroundOpacityId);
		const foregroundOpacityValue = document.getElementById(foregroundOpacityValueId);
		const mascotScaleInput = document.getElementById(mascotScaleId);
		const mascotScaleValue = document.getElementById(mascotScaleValueId);
		const mascotVisibilityButton = document.getElementById(mascotVisibilityId);
		const mascotVisibilityValue = document.getElementById(mascotVisibilityValueId);
		const panelHint = document.getElementById(panelHintId);
		const panelTriggers = Array.from(
			document.querySelectorAll("[data-system-panel-trigger]"),
		);
		const panelSections = Array.from(
			document.querySelectorAll("[data-system-panel]"),
		);

		if (
			!(root instanceof HTMLElement) ||
			!(audio instanceof HTMLAudioElement) ||
			!(toggle instanceof HTMLButtonElement) ||
			!(status instanceof HTMLElement) ||
			!(trackList instanceof HTMLElement) ||
			!(drawer instanceof HTMLElement) ||
			!(drawerToggle instanceof HTMLButtonElement) ||
			!(volumeInput instanceof HTMLInputElement) ||
			!(volumeValue instanceof HTMLElement) ||
			!(foregroundOpacityInput instanceof HTMLInputElement) ||
			!(foregroundOpacityValue instanceof HTMLElement) ||
			!(mascotScaleInput instanceof HTMLInputElement) ||
			!(mascotScaleValue instanceof HTMLElement) ||
			!(mascotVisibilityButton instanceof HTMLButtonElement) ||
			!(mascotVisibilityValue instanceof HTMLElement) ||
			!(panelHint instanceof HTMLElement)
		) {
			return;
		}

		if (root.dataset.initialized === "true") {
			return;
		}
		root.dataset.initialized = "true";

		const clamp = (value, min, max) => Math.min(max, Math.max(min, value));
		const formatPercent = (value) => `${Math.round(value * 100)}%`;
		const selectionKey = root.dataset.storageKey || "background-music:selected-track";
		const playingKey = root.dataset.playingKey || "background-music:playing";
		const volumeKey = root.dataset.volumeKey || "background-music:volume";
		const foregroundOpacityKey =
			root.dataset.foregroundOpacityKey || "system:foreground-opacity";
		const mascotScaleKey =
			root.dataset.mascotScaleKey || "system:mascot-scale";
		const mascotHiddenKey =
			root.dataset.mascotHiddenKey || "system:mascot-hidden";
		const defaultTrackId = root.dataset.defaultTrackId || "";
		const playlistLoop = root.dataset.playlistLoop !== "false";
		const shouldAutoplay = root.dataset.autoplay === "true";
		const defaultVolume = clamp(
			Number.parseFloat(root.dataset.defaultVolume || "0.20") || 0.2,
			0,
			1,
		);
		const defaultForegroundOpacity = clamp(
			Number.parseFloat(root.dataset.defaultForegroundOpacity || "0.8") || 0.8,
			0.3,
			1,
		);
		const defaultMascotScale = clamp(
			Number.parseFloat(root.dataset.defaultMascotScale || "1") || 1,
			0.6,
			1.5,
		);
		const defaultMascotHidden = root.dataset.defaultMascotHidden === "true";
		const trackButtons = Array.from(trackList.querySelectorAll("[data-track-id]")).filter(
			(button) => button instanceof HTMLButtonElement,
		);
		const availableTrackButtons = trackButtons.filter(
			(button) => Boolean(button.dataset.trackSrc),
		);
		const safePanelTriggers = panelTriggers.filter(
			(button) => button instanceof HTMLButtonElement,
		);
		const safePanelSections = panelSections.filter(
			(section) => section instanceof HTMLElement,
		);
		let currentButton = null;
		let currentVolume = defaultVolume;
		let isTrackSwitching = false;
		let autoplayBlocked = false;
		let unlockEventsBound = false;
		let activePanel = "";

		const getRememberedValue = (key) => {
			try {
				return localStorage.getItem(key);
			} catch {
				return null;
			}
		};

		const setRememberedValue = (key, value) => {
			try {
				localStorage.setItem(key, value);
			} catch {
				// Ignore storage failures and keep the control usable.
			}
		};

		const getTrackData = (button) => {
			if (!button) {
				return null;
			}

			return {
				id: button.dataset.trackId || "",
				src: button.dataset.trackSrc || "",
				title: button.dataset.trackTitle || "未命名曲目",
				artist: button.dataset.trackArtist?.trim() || "",
				group: button.dataset.trackGroup?.trim() || "",
			};
		};

		const getTrackLabel = (track) => {
			if (!track) {
				return "当前未选择曲目";
			}

			return track.artist ? `${track.title} · ${track.artist}` : track.title;
		};

		const setStatusText = (prefix, track = getTrackData(currentButton)) => {
			status.textContent = track ? `${prefix} · ${getTrackLabel(track)}` : prefix;
		};

		const setActivePanel = (panelId) => {
			activePanel = panelId;

			for (const button of safePanelTriggers) {
				const isActive = button.dataset.systemPanelTrigger === panelId;
				button.setAttribute("aria-selected", isActive ? "true" : "false");
			}

			for (const section of safePanelSections) {
				section.hidden = section.dataset.systemPanel !== panelId;
			}

			panelHint.hidden = panelId.length > 0;
		};

		const applyForegroundOpacity = (nextOpacity, shouldPersist = true) => {
			const normalizedOpacity = clamp(nextOpacity, 0.3, 1);
			document.documentElement.style.setProperty(
				"--system-wallpaper-opacity",
				"1",
			);
			document.documentElement.style.setProperty(
				"--system-foreground-opacity",
				`${normalizedOpacity}`,
			);
			foregroundOpacityInput.value = String(Math.round(normalizedOpacity * 100));
			foregroundOpacityValue.textContent = formatPercent(normalizedOpacity);

			if (shouldPersist) {
				setRememberedValue(foregroundOpacityKey, String(normalizedOpacity));
			}
		};

		const applyVolume = (nextVolume, shouldPersist = true) => {
			currentVolume = clamp(nextVolume, 0, 1);
			audio.volume = currentVolume;
			volumeInput.value = String(Math.round(currentVolume * 100));
			volumeValue.textContent = formatPercent(currentVolume);
			exposeWeatherState();

			if (shouldPersist) {
				setRememberedValue(volumeKey, String(currentVolume));
			}
		};
		const exposeWeatherState = () => {
			window.__alfMusicWeatherState = () => ({
				playing: !audio.paused && !audio.ended && Boolean(audio.src),
				volume: currentVolume,
				intensity:
					!audio.paused && !audio.ended && Boolean(audio.src) ? currentVolume : 0,
			});
		};

		const applyMascotScale = (nextScale, shouldPersist = true) => {
			const normalizedScale = clamp(nextScale, 0.6, 1.5);
			document.documentElement.style.setProperty(
				"--live2d-scale",
				`${normalizedScale}`,
			);
			mascotScaleInput.value = String(Math.round(normalizedScale * 100));
			mascotScaleValue.textContent = formatPercent(normalizedScale);
			window.dispatchEvent(new Event("alf:live2d-resize"));

			if (shouldPersist) {
				setRememberedValue(mascotScaleKey, String(normalizedScale));
			}
		};

		const applyMascotVisibility = (hidden, shouldPersist = true) => {
			document.documentElement.dataset.mascotHidden = hidden ? "true" : "false";
			mascotVisibilityValue.textContent = hidden ? "已隐藏" : "显示中";
			mascotVisibilityButton.textContent = hidden ? "显示看板娘" : "隐藏看板娘";
			window.dispatchEvent(
				new CustomEvent("alf:live2d-visibility", {
					detail: { hidden },
				}),
			);

			if (shouldPersist) {
				setRememberedValue(mascotHiddenKey, hidden ? "true" : "false");
			}
		};

		const pickRandomButton = (buttons) => {
			if (buttons.length === 0) {
				return null;
			}

			return buttons[Math.floor(Math.random() * buttons.length)] || null;
		};

		const pickNextRandomButton = (fromButton) => {
			if (availableTrackButtons.length === 0) {
				return null;
			}

			const currentGroup = fromButton?.dataset.trackGroup?.trim() || "";
			let candidates = availableTrackButtons.filter((button) => {
				if (button === fromButton && availableTrackButtons.length > 1) {
					return false;
				}

				if (!currentGroup) {
					return true;
				}

				return (button.dataset.trackGroup?.trim() || "") !== currentGroup;
			});

			if (candidates.length === 0) {
				candidates = availableTrackButtons.filter(
					(button) => button !== fromButton || availableTrackButtons.length === 1,
				);
			}

			return pickRandomButton(candidates);
		};

		const updateTrackSelection = (selectedButton) => {
			for (const button of trackButtons) {
				button.setAttribute(
					"aria-selected",
					button === selectedButton ? "true" : "false",
				);
			}

			if (!selectedButton) {
				currentButton = null;
				toggle.disabled = true;
				status.textContent = "还没有可用曲目";
				audio.removeAttribute("src");
				audio.load();
				return null;
			}

			const track = getTrackData(selectedButton);
			if (!track) {
				return null;
			}

			currentButton = selectedButton;
			isTrackSwitching = true;
			audio.src = track.src;
			audio.muted = false;
			audio.load();
			queueMicrotask(() => {
				isTrackSwitching = false;
			});
			toggle.disabled = !track.src;
			setStatusText("已暂停", track);
			setRememberedValue(selectionKey, track.id);
			return track;
		};

		const updatePlaybackUi = (isPlaying) => {
			toggle.classList.toggle("is-playing", isPlaying);
			toggle.setAttribute("aria-pressed", isPlaying ? "true" : "false");
			setRememberedValue(playingKey, isPlaying ? "playing" : "paused");
		};

		const closeDrawer = () => {
			drawer.hidden = true;
			drawerToggle.setAttribute("aria-expanded", "false");
			setActivePanel("");
		};

		const openDrawer = () => {
			drawer.hidden = false;
			drawerToggle.setAttribute("aria-expanded", "true");
			setActivePanel("");
		};

		const removeUnlockEvents = () => {
			document.removeEventListener("pointerdown", handleAutoplayUnlock, true);
			document.removeEventListener("keydown", handleAutoplayUnlock, true);
			unlockEventsBound = false;
		};

		const playCurrentTrack = async (fromAutoplay = false) => {
			if (!audio.src) {
				return false;
			}

			try {
				audio.muted = false;
				audio.volume = currentVolume;
				await audio.play();
				autoplayBlocked = false;
				setStatusText("播放中");
				removeUnlockEvents();
				return true;
			} catch {
				if (fromAutoplay) {
					autoplayBlocked = true;
					status.textContent = "自动播放被拦截 · 点击页面任意位置开始播放";
					if (!unlockEventsBound) {
						document.addEventListener("pointerdown", handleAutoplayUnlock, true);
						document.addEventListener("keydown", handleAutoplayUnlock, true);
						unlockEventsBound = true;
					}
				} else {
					updatePlaybackUi(false);
					setStatusText("已暂停");
				}
				return false;
			}
		};

		async function handleAutoplayUnlock() {
			if (!autoplayBlocked) {
				removeUnlockEvents();
				return;
			}

			await playCurrentTrack(false);
		}

		const rememberedForegroundOpacity = Number.parseFloat(
			getRememberedValue(foregroundOpacityKey) || "",
		);
		const rememberedVolume = Number.parseFloat(getRememberedValue(volumeKey) || "");
		const rememberedMascotScale = Number.parseFloat(
			getRememberedValue(mascotScaleKey) || "",
		);
		const rememberedMascotHidden = getRememberedValue(mascotHiddenKey);

		applyForegroundOpacity(
			Number.isFinite(rememberedForegroundOpacity)
				? rememberedForegroundOpacity
				: defaultForegroundOpacity,
			false,
		);
		applyVolume(Number.isFinite(rememberedVolume) ? rememberedVolume : defaultVolume, false);
		applyMascotScale(
			Number.isFinite(rememberedMascotScale)
				? rememberedMascotScale
				: defaultMascotScale,
			false,
		);
		applyMascotVisibility(
			rememberedMascotHidden === null
				? defaultMascotHidden
				: rememberedMascotHidden === "true",
			false,
		);

		const rememberedTrackId = getRememberedValue(selectionKey);
		const initialButton =
			availableTrackButtons.find((button) => button.dataset.trackId === rememberedTrackId) ||
			availableTrackButtons.find((button) => button.dataset.trackId === defaultTrackId) ||
			pickRandomButton(availableTrackButtons) ||
			trackButtons[0] ||
			null;

		updateTrackSelection(initialButton);
		updatePlaybackUi(false);
		setActivePanel("");

		drawerToggle.addEventListener("click", () => {
			if (drawer.hidden) {
				openDrawer();
			} else {
				closeDrawer();
			}
		});

		document.addEventListener("click", (event) => {
			const target = event.target;
			if (!(target instanceof Node)) {
				return;
			}

			if (root.contains(target)) {
				return;
			}

			closeDrawer();
		});

		for (const button of safePanelTriggers) {
			button.addEventListener("click", () => {
				const nextPanel = button.dataset.systemPanelTrigger || "";
				setActivePanel(activePanel === nextPanel ? "" : nextPanel);
			});
		}

		foregroundOpacityInput.addEventListener("input", () => {
			applyForegroundOpacity(Number.parseFloat(foregroundOpacityInput.value) / 100);
		});

		volumeInput.addEventListener("input", () => {
			applyVolume(Number.parseFloat(volumeInput.value) / 100);
		});

		mascotScaleInput.addEventListener("input", () => {
			applyMascotScale(Number.parseFloat(mascotScaleInput.value) / 100);
		});

		mascotVisibilityButton.addEventListener("click", () => {
			const nextHidden = document.documentElement.dataset.mascotHidden !== "true";
			applyMascotVisibility(nextHidden);
		});

		for (const button of trackButtons) {
			button.addEventListener("click", async () => {
				const wasPlaying = !audio.paused;
				const selection = updateTrackSelection(button);

				if (!selection?.src) {
					return;
				}

				if (wasPlaying || shouldAutoplay) {
					await playCurrentTrack(false);
				}
			});
		}

		toggle.addEventListener("click", async () => {
			if (!audio.src) {
				return;
			}

			if (audio.paused) {
				await playCurrentTrack(false);
			} else {
				autoplayBlocked = false;
				removeUnlockEvents();
				audio.pause();
			}
		});

		audio.addEventListener("play", () => {
			updatePlaybackUi(true);
			setStatusText("播放中");
			exposeWeatherState();
		});

		audio.addEventListener("pause", () => {
			if (audio.ended || isTrackSwitching) {
				return;
			}

			updatePlaybackUi(false);
			setStatusText("已暂停");
			exposeWeatherState();
		});

		audio.addEventListener("ended", async () => {
			if (!playlistLoop) {
				updatePlaybackUi(false);
				setStatusText("播放结束");
				exposeWeatherState();
				return;
			}

			const nextButton = pickNextRandomButton(currentButton);
			const nextTrack = updateTrackSelection(nextButton);

			if (!nextTrack?.src) {
				updatePlaybackUi(false);
				return;
			}

			await playCurrentTrack(false);
		});

		audio.addEventListener("error", () => {
			updatePlaybackUi(false);
			status.textContent = "音频加载失败";
			exposeWeatherState();
		});

		exposeWeatherState();
		if (shouldAutoplay) {
			void playCurrentTrack(shouldAutoplay);
		}
	};

	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", initBackgroundMusic, { once: true });
	} else {
		initBackgroundMusic();
	}
</script>
