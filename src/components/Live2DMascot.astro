---
import { url } from "../utils/url-utils";

const modelPath = url("/live2d/models/ug/ugofficial.model3.json");
const localCorePath = url("/live2d/vendor/live2dcubismcore.min.js");
const officialCoreUrl =
	"https://cubism.live2d.com/sdk-web/cubismcore/live2dcubismcore.min.js";
const pixiUrl = "https://cdn.jsdelivr.net/npm/pixi.js@6.5.10/dist/browser/pixi.min.js";
const live2dUrl =
	"https://cdn.jsdelivr.net/npm/pixi-live2d-display@0.4.0/dist/cubism4.min.js";
const expressionNames = [
	"1desk",
	"2mic",
	"3clever",
	"4OAO",
	"5QAQ",
	"6i gi a ri",
	"7keyboard",
	"8punch",
	"9",
];
---

<div
	id="live2d-mascot"
	class="live2d-mascot"
	data-expression-names={JSON.stringify(expressionNames)}
	aria-live="polite"
>
	<button
		type="button"
		class="live2d-mascot__toggle"
		data-live2d-toggle
		aria-label="Show mascot"
	>
		Mascot
	</button>

	<section class="live2d-mascot__panel" aria-label="Live2D mascot">
		<button
			type="button"
			class="live2d-mascot__close"
			data-live2d-close
			aria-label="Hide mascot"
		>
			x
		</button>
		<div class="live2d-mascot__status" data-live2d-status>Mascot loading</div>
		<canvas
			class="live2d-mascot__canvas"
			data-live2d-canvas
			width="320"
			height="420"
			aria-hidden="true"
		></canvas>
	</section>
</div>

<style>
	.live2d-mascot {
		position: fixed;
		right: max(0.4rem, env(safe-area-inset-right));
		bottom: max(0.25rem, env(safe-area-inset-bottom));
		z-index: 70;
		pointer-events: none;
	}

	.live2d-mascot__toggle,
	.live2d-mascot__close {
		pointer-events: auto;
	}

	.live2d-mascot__toggle {
		display: none;
		align-items: center;
		justify-content: center;
		padding: 0.6rem 0.85rem;
		border: 1px solid rgb(15 23 42 / 0.1);
		border-radius: 999px;
		background: rgb(255 255 255 / 0.78);
		backdrop-filter: blur(8px);
		box-shadow: 0 0.45rem 1.2rem rgb(15 23 42 / 0.12);
		color: rgb(15 23 42 / 0.88);
		font-size: 0.78rem;
		font-weight: 600;
		letter-spacing: 0.06em;
	}

	.dark .live2d-mascot__toggle {
		border-color: rgb(148 163 184 / 0.12);
		background: rgb(15 23 42 / 0.68);
		color: rgb(226 232 240 / 0.9);
	}

	.live2d-mascot__panel {
		position: relative;
		width: clamp(11rem, 16vw, 16rem);
		aspect-ratio: 32 / 42;
		background: transparent;
		border: 0;
		box-shadow: none;
		overflow: visible;
		pointer-events: none;
	}

	.live2d-mascot__status {
		position: absolute;
		top: 0.5rem;
		left: 0.5rem;
		z-index: 2;
		max-width: calc(100% - 3rem);
		padding: 0.3rem 0.55rem;
		border-radius: 999px;
		background: rgb(255 255 255 / 0.28);
		color: rgb(51 65 85 / 0.82);
		font-size: 0.7rem;
		letter-spacing: 0.03em;
		backdrop-filter: blur(8px);
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
		pointer-events: none;
	}

	.dark .live2d-mascot__status {
		background: rgb(15 23 42 / 0.3);
		color: rgb(226 232 240 / 0.84);
	}

	.live2d-mascot__status[data-mode="error"] {
		color: rgb(185 28 28 / 0.92);
		background: rgb(254 242 242 / 0.5);
	}

	.dark .live2d-mascot__status[data-mode="error"] {
		color: rgb(254 202 202 / 0.94);
		background: rgb(69 10 10 / 0.4);
	}

	.live2d-mascot__close {
		position: absolute;
		top: 0.5rem;
		right: 0.5rem;
		z-index: 3;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 1.55rem;
		height: 1.55rem;
		border: 0;
		border-radius: 999px;
		background: rgb(255 255 255 / 0.34);
		color: rgb(71 85 105 / 0.9);
		font-size: 0.95rem;
		line-height: 1;
		cursor: pointer;
		backdrop-filter: blur(8px);
		transition: background-color 160ms ease;
	}

	.live2d-mascot__close:hover {
		background: rgb(255 255 255 / 0.55);
	}

	.dark .live2d-mascot__close {
		background: rgb(15 23 42 / 0.34);
		color: rgb(226 232 240 / 0.92);
	}

	.live2d-mascot__canvas {
		position: absolute;
		inset: 0;
		display: block;
		width: 100%;
		height: 100%;
		pointer-events: auto;
		cursor: pointer;
		filter: drop-shadow(0 1rem 2rem rgb(15 23 42 / 0.16));
	}

	.live2d-mascot.is-collapsed .live2d-mascot__panel {
		display: none;
	}

	.live2d-mascot.is-collapsed .live2d-mascot__toggle {
		display: inline-flex;
	}

	@media (max-width: 1023px) {
		.live2d-mascot {
			right: max(0.2rem, env(safe-area-inset-right));
			bottom: max(0.1rem, env(safe-area-inset-bottom));
		}

		.live2d-mascot__panel {
			width: clamp(8.5rem, 30vw, 11rem);
		}

		.live2d-mascot__status {
			display: none;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.live2d-mascot__close {
			transition: none;
		}
	}
</style>

<script
	is:inline
	define:vars={{
		live2dUrl,
		localCorePath,
		modelPath,
		officialCoreUrl,
		pixiUrl,
	}}
>
	(() => {
		if (window.__alfLive2DMascotSetup) {
			return;
		}
		window.__alfLive2DMascotSetup = true;

		const root = document.getElementById("live2d-mascot");
		if (!(root instanceof HTMLElement)) {
			return;
		}

		const expressionNames = JSON.parse(root.dataset.expressionNames || "[]");
		const panel = root.querySelector(".live2d-mascot__panel");
		const canvas = root.querySelector("[data-live2d-canvas]");
		const status = root.querySelector("[data-live2d-status]");
		const toggleButton = root.querySelector("[data-live2d-toggle]");
		const closeButton = root.querySelector("[data-live2d-close]");

		if (
			!(panel instanceof HTMLElement) ||
			!(canvas instanceof HTMLCanvasElement) ||
			!(status instanceof HTMLElement) ||
			!(toggleButton instanceof HTMLButtonElement) ||
			!(closeButton instanceof HTMLButtonElement)
		) {
			return;
		}

		const state = {
			app: null,
			model: null,
			initPromise: null,
			baseSize: null,
			expressionIndex: 0,
		};

		const setStatus = (message, mode = "info") => {
			status.textContent = message;
			status.dataset.mode = mode;
			status.hidden = message.length === 0;
		};

		const setCollapsed = (collapsed) => {
			root.classList.toggle("is-collapsed", collapsed);
		};

		const scriptCache =
			window.__alfLive2DScriptCache || (window.__alfLive2DScriptCache = new Map());

		const ensureScript = (src, test) => {
			if (typeof test === "function" && test()) {
				return Promise.resolve();
			}

			if (scriptCache.has(src)) {
				return scriptCache.get(src);
			}

			const pending = new Promise((resolve, reject) => {
				const script = document.createElement("script");
				script.src = src;
				script.async = true;
				script.onload = () => {
					if (!test || test()) {
						resolve();
						return;
					}

					reject(new Error(`Script loaded but runtime was unavailable: ${src}`));
				};
				script.onerror = () => reject(new Error(`Failed to load script: ${src}`));
				document.head.appendChild(script);
			});

			scriptCache.set(src, pending);
			return pending;
		};

		const ensureCubismCore = async () => {
			if (window.Live2DCubismCore) {
				return;
			}

			try {
				await ensureScript(localCorePath, () => Boolean(window.Live2DCubismCore));
			} catch (_error) {
				await ensureScript(officialCoreUrl, () => Boolean(window.Live2DCubismCore));
			}
		};

		const fitModel = () => {
			if (!state.app || !state.model) {
				return;
			}

			const width = Math.max(panel.clientWidth, 1);
			const height = Math.max(panel.clientHeight, 1);
			state.app.renderer.resize(width, height);

			const baseWidth = state.baseSize?.width || state.model.width;
			const baseHeight = state.baseSize?.height || state.model.height;
			const scale = Math.min((width * 0.78) / baseWidth, (height * 0.92) / baseHeight);
			state.model.anchor.set(0.5, 1);
			state.model.scale.set(scale);
			state.model.position.set(width * 0.5, height * 0.99);
		};

		const cycleExpression = () => {
			if (
				!state.model ||
				typeof state.model.expression !== "function" ||
				expressionNames.length === 0
			) {
				return;
			}

			const expressionName = expressionNames[state.expressionIndex % expressionNames.length];
			state.expressionIndex += 1;
			state.model.expression(expressionName);
		};

		const initMascot = async () => {
			if (state.initPromise) {
				return state.initPromise;
			}

			state.initPromise = (async () => {
				setStatus("Mascot loading");

				await ensureScript(pixiUrl, () => Boolean(window.PIXI?.Application));
				await ensureCubismCore();
				await ensureScript(
					live2dUrl,
					() => Boolean(window.PIXI?.live2d?.Live2DModel),
				);

				if (!state.app) {
					state.app = new window.PIXI.Application({
						view: canvas,
						autoStart: true,
						autoDensity: true,
						antialias: true,
						backgroundAlpha: 0,
						width: Math.max(panel.clientWidth, 1),
						height: Math.max(panel.clientHeight, 1),
						resolution: Math.min(window.devicePixelRatio || 1, 2),
					});
				}

				if (!state.model) {
					state.model = await window.PIXI.live2d.Live2DModel.from(modelPath, {
						autoInteract: false,
						idleMotionGroup: "",
					});
					state.baseSize = {
						width: state.model.width,
						height: state.model.height,
					};
					state.app.stage.addChild(state.model);
				}

				fitModel();
				setStatus("");
				setCollapsed(false);
			})().catch((error) => {
				state.initPromise = null;
				console.error("Live2D mascot failed to initialize", error);
				setStatus("Mascot load failed", "error");
				throw error;
			});

			return state.initPromise;
		};

		window.addEventListener("resize", fitModel);
		canvas.addEventListener("click", cycleExpression);

		toggleButton.addEventListener("click", () => {
			setCollapsed(false);
			void initMascot();
		});

		closeButton.addEventListener("click", () => {
			setCollapsed(true);
		});

		setCollapsed(false);
		void initMascot();
	})();
</script>
