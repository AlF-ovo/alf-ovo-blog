---
import { url } from "../utils/url-utils";

const modelPath = url("/live2d/models/ug/ugofficial.model3.json");
const localCorePath = url("/live2d/vendor/live2dcubismcore.min.js");
const officialCoreUrl =
	"https://cubism.live2d.com/sdk-web/cubismcore/live2dcubismcore.min.js";
const pixiUrl = "https://cdn.jsdelivr.net/npm/pixi.js@6.5.10/dist/browser/pixi.min.js";
const live2dUrl =
	"https://cdn.jsdelivr.net/npm/pixi-live2d-display@0.4.0/dist/cubism4.min.js";
const expressionNames = [
	"1desk",
	"2mic",
	"3clever",
	"4OAO",
	"5QAQ",
	"6i gi a ri",
	"7keyboard",
	"8punch",
	"9",
];
---

<div
	id="live2d-mascot"
	class="live2d-mascot is-collapsed"
	data-expression-names={JSON.stringify(expressionNames)}
	aria-live="polite"
>
	<button
		type="button"
		class="live2d-mascot__toggle"
		data-live2d-toggle
		aria-label="Show mascot"
	>
		看板娘
	</button>

	<section class="live2d-mascot__panel" aria-label="Live2D mascot">
		<button
			type="button"
			class="live2d-mascot__close"
			data-live2d-close
			aria-label="Hide mascot"
		>
			×
		</button>
		<div class="live2d-mascot__status" data-live2d-status>看板娘待机中</div>
		<canvas
			class="live2d-mascot__canvas"
			data-live2d-canvas
			width="320"
			height="420"
			aria-hidden="true"
		></canvas>
	</section>
</div>

<style>
	.live2d-mascot {
		position: fixed;
		left: max(0.75rem, env(safe-area-inset-left));
		bottom: max(0.75rem, env(safe-area-inset-bottom));
		z-index: 70;
		pointer-events: none;
	}

	.live2d-mascot__toggle,
	.live2d-mascot__panel,
	.live2d-mascot__close {
		pointer-events: auto;
	}

	.live2d-mascot__toggle {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.65rem 0.9rem;
		border: 1px solid rgb(15 23 42 / 0.12);
		border-radius: 999px;
		background: rgb(255 255 255 / 0.88);
		backdrop-filter: blur(12px);
		box-shadow: 0 0.6rem 1.6rem rgb(15 23 42 / 0.12);
		color: rgb(15 23 42 / 0.88);
		font-size: 0.82rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		opacity: 0;
		transform: translateY(0.5rem);
		transition:
			opacity 180ms ease,
			transform 180ms ease,
			background-color 180ms ease,
			border-color 180ms ease;
	}

	.live2d-mascot__toggle:hover {
		background: rgb(255 255 255 / 0.96);
	}

	.dark .live2d-mascot__toggle {
		border-color: rgb(148 163 184 / 0.18);
		background: rgb(15 23 42 / 0.82);
		box-shadow: 0 0.75rem 2rem rgb(2 6 23 / 0.45);
		color: rgb(226 232 240 / 0.94);
	}

	.live2d-mascot__panel {
		position: relative;
		width: clamp(12rem, 19vw, 18rem);
		aspect-ratio: 32 / 42;
		border: 1px solid rgb(148 163 184 / 0.18);
		border-radius: 1.35rem;
		background:
			radial-gradient(circle at 50% 18%, rgb(255 255 255 / 0.5), transparent 44%),
			linear-gradient(180deg, rgb(255 255 255 / 0.82), rgb(248 250 252 / 0.6));
		backdrop-filter: blur(18px);
		box-shadow:
			0 1rem 2.6rem rgb(15 23 42 / 0.2),
			inset 0 1px 0 rgb(255 255 255 / 0.5);
		opacity: 1;
		transform: translateY(0);
		transition:
			opacity 220ms ease,
			transform 220ms ease,
			visibility 220ms ease;
		overflow: hidden;
	}

	.dark .live2d-mascot__panel {
		border-color: rgb(148 163 184 / 0.16);
		background:
			radial-gradient(circle at 50% 18%, rgb(148 163 184 / 0.1), transparent 44%),
			linear-gradient(180deg, rgb(15 23 42 / 0.72), rgb(2 6 23 / 0.62));
		box-shadow:
			0 1.1rem 2.8rem rgb(2 6 23 / 0.48),
			inset 0 1px 0 rgb(255 255 255 / 0.05);
	}

	.live2d-mascot__panel::after {
		content: "";
		position: absolute;
		inset: auto 16% 0.75rem;
		height: 1rem;
		border-radius: 999px;
		background: radial-gradient(circle, rgb(14 116 144 / 0.24), transparent 68%);
		filter: blur(18px);
		pointer-events: none;
	}

	.live2d-mascot__status {
		position: absolute;
		top: 0.85rem;
		left: 0.9rem;
		right: 2.75rem;
		z-index: 2;
		padding: 0.35rem 0.6rem;
		border-radius: 999px;
		background: rgb(255 255 255 / 0.64);
		color: rgb(51 65 85 / 0.9);
		font-size: 0.72rem;
		letter-spacing: 0.04em;
		backdrop-filter: blur(10px);
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	.dark .live2d-mascot__status {
		background: rgb(15 23 42 / 0.62);
		color: rgb(226 232 240 / 0.86);
	}

	.live2d-mascot__status[data-mode="error"] {
		color: rgb(185 28 28 / 0.92);
	}

	.dark .live2d-mascot__status[data-mode="error"] {
		color: rgb(254 202 202 / 0.94);
	}

	.live2d-mascot__close {
		position: absolute;
		top: 0.85rem;
		right: 0.85rem;
		z-index: 3;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 1.65rem;
		height: 1.65rem;
		border: 0;
		border-radius: 999px;
		background: rgb(255 255 255 / 0.72);
		color: rgb(71 85 105 / 0.92);
		font-size: 1rem;
		line-height: 1;
		cursor: pointer;
		backdrop-filter: blur(10px);
		transition:
			transform 160ms ease,
			background-color 160ms ease;
	}

	.live2d-mascot__close:hover {
		transform: scale(1.06);
		background: rgb(255 255 255 / 0.92);
	}

	.dark .live2d-mascot__close {
		background: rgb(15 23 42 / 0.72);
		color: rgb(226 232 240 / 0.92);
	}

	.live2d-mascot__canvas {
		position: absolute;
		inset: 0;
		display: block;
		width: 100%;
		height: 100%;
		cursor: pointer;
	}

	.live2d-mascot.is-collapsed .live2d-mascot__panel {
		opacity: 0;
		visibility: hidden;
		transform: translateY(0.75rem) scale(0.98);
	}

	.live2d-mascot.is-collapsed .live2d-mascot__toggle {
		opacity: 1;
		transform: translateY(0);
	}

	.live2d-mascot:not(.is-collapsed) .live2d-mascot__toggle {
		opacity: 0;
		visibility: hidden;
		transform: translateY(0.5rem);
	}

	.live2d-mascot.is-viewport-hidden {
		display: none;
	}

	@media (max-width: 1279px) {
		.live2d-mascot__panel {
			width: clamp(11.2rem, 18vw, 15rem);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.live2d-mascot__panel,
		.live2d-mascot__toggle,
		.live2d-mascot__close {
			transition: none;
		}
	}
</style>

<script
	is:inline
	define:vars={{
		live2dUrl,
		localCorePath,
		modelPath,
		officialCoreUrl,
		pixiUrl,
	}}
>
	(() => {
		if (window.__alfLive2DMascotSetup) {
			return;
		}
		window.__alfLive2DMascotSetup = true;

		const root = document.getElementById("live2d-mascot");
		if (!(root instanceof HTMLElement)) {
			return;
		}

		const expressionNames = JSON.parse(root.dataset.expressionNames || "[]");

		const panel = root.querySelector(".live2d-mascot__panel");
		const canvas = root.querySelector("[data-live2d-canvas]");
		const status = root.querySelector("[data-live2d-status]");
		const toggleButton = root.querySelector("[data-live2d-toggle]");
		const closeButton = root.querySelector("[data-live2d-close]");

		if (
			!(panel instanceof HTMLElement) ||
			!(canvas instanceof HTMLCanvasElement) ||
			!(status instanceof HTMLElement) ||
			!(toggleButton instanceof HTMLButtonElement) ||
			!(closeButton instanceof HTMLButtonElement)
		) {
			return;
		}

		const state = {
			app: null,
			model: null,
			initPromise: null,
			expressionIndex: 0,
			baseSize: null,
		};

		const hiddenStorageKey = "alf.live2d.hidden";
		const desktopQuery = window.matchMedia("(max-width: 1023px)");

		const setStatus = (message, mode = "info") => {
			status.textContent = message;
			status.dataset.mode = mode;
			status.hidden = message.length === 0;
		};

		const setCollapsed = (nextValue) => {
			root.classList.toggle("is-collapsed", nextValue);
			try {
				localStorage.setItem(hiddenStorageKey, nextValue ? "1" : "0");
			} catch (_error) {
				// Ignore storage failures and keep the current UI state.
			}
		};

		const syncViewportMode = () => {
			const hiddenByViewport = desktopQuery.matches;
			root.classList.toggle("is-viewport-hidden", hiddenByViewport);
			if (!hiddenByViewport && !root.classList.contains("is-collapsed")) {
				void initMascot();
			}
		};

		const scriptCache =
			window.__alfLive2DScriptCache || (window.__alfLive2DScriptCache = new Map());

		const ensureScript = (src, test) => {
			if (typeof test === "function" && test()) {
				return Promise.resolve();
			}

			if (scriptCache.has(src)) {
				return scriptCache.get(src);
			}

			const pending = new Promise((resolve, reject) => {
				const script = document.createElement("script");
				script.src = src;
				script.async = true;
				script.onload = () => {
					if (!test || test()) {
						resolve();
						return;
					}

					reject(new Error(`Script loaded but runtime was unavailable: ${src}`));
				};
				script.onerror = () => reject(new Error(`Failed to load script: ${src}`));
				document.head.appendChild(script);
			});

			scriptCache.set(src, pending);
			return pending;
		};

		const ensureCubismCore = async () => {
			if (window.Live2DCubismCore) {
				return;
			}

			try {
				await ensureScript(localCorePath, () => Boolean(window.Live2DCubismCore));
			} catch (_error) {
				await ensureScript(officialCoreUrl, () => Boolean(window.Live2DCubismCore));
			}
		};

		const fitModel = () => {
			if (!state.app || !state.model) {
				return;
			}

			const width = Math.max(panel.clientWidth, 1);
			const height = Math.max(panel.clientHeight, 1);
			state.app.renderer.resize(width, height);

			const baseWidth = state.baseSize?.width || state.model.width;
			const baseHeight = state.baseSize?.height || state.model.height;
			const scale = Math.min((width * 0.78) / baseWidth, (height * 0.9) / baseHeight);
			state.model.anchor.set(0.5, 1);
			state.model.scale.set(scale);
			state.model.position.set(width * 0.5, height * 0.98);
		};

		const focusModel = (event) => {
			if (!state.model || typeof state.model.focus !== "function") {
				return;
			}

			const rect = canvas.getBoundingClientRect();
			const normalizedX = ((event.clientX - rect.left) / rect.width) * 2 - 1;
			const normalizedY = ((event.clientY - rect.top) / rect.height) * 2 - 1;
			state.model.focus(normalizedX, normalizedY);
		};

		const resetFocus = () => {
			if (!state.model || typeof state.model.focus !== "function") {
				return;
			}

			state.model.focus(0, 0);
		};

		const cycleExpression = () => {
			if (!state.model || typeof state.model.expression !== "function") {
				return;
			}

			const expressionName = expressionNames[state.expressionIndex % expressionNames.length];
			state.expressionIndex += 1;
			state.model.expression(expressionName);
		};

		const initMascot = async () => {
			if (state.initPromise) {
				return state.initPromise;
			}

			state.initPromise = (async () => {
				setStatus("看板娘加载中");

				await ensureScript(pixiUrl, () => Boolean(window.PIXI?.Application));
				await ensureCubismCore();
				await ensureScript(
					live2dUrl,
					() => Boolean(window.PIXI?.live2d?.Live2DModel),
				);

				if (!state.app) {
					state.app = new window.PIXI.Application({
						view: canvas,
						autoStart: true,
						autoDensity: true,
						antialias: true,
						backgroundAlpha: 0,
						width: Math.max(panel.clientWidth, 1),
						height: Math.max(panel.clientHeight, 1),
						resolution: Math.min(window.devicePixelRatio || 1, 2),
					});
				}

				if (!state.model) {
					state.model = await window.PIXI.live2d.Live2DModel.from(modelPath, {
						autoInteract: false,
						idleMotionGroup: "",
					});
					state.baseSize = {
						width: state.model.width,
						height: state.model.height,
					};
					state.app.stage.addChild(state.model);
				}

				fitModel();
				setStatus("");
				root.classList.remove("is-collapsed");
			})().catch((error) => {
				state.initPromise = null;
				console.error("Live2D mascot failed to initialize", error);
				setStatus("看板娘加载失败，请补本地 Core", "error");
				throw error;
			});

			return state.initPromise;
		};

		canvas.addEventListener("pointermove", focusModel, { passive: true });
		canvas.addEventListener("pointerleave", resetFocus);
		canvas.addEventListener("click", cycleExpression);

		toggleButton.addEventListener("click", () => {
			setCollapsed(false);
			if (!desktopQuery.matches) {
				void initMascot();
			}
		});

		closeButton.addEventListener("click", () => {
			setCollapsed(true);
		});

		window.addEventListener("resize", fitModel);
		desktopQuery.addEventListener("change", syncViewportMode);

		try {
			const initiallyHidden = localStorage.getItem(hiddenStorageKey) === "1";
			setCollapsed(initiallyHidden);
		} catch (_error) {
			setCollapsed(false);
		}

		syncViewportMode();
	})();
</script>
