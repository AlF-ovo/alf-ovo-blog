---
import { url } from "../utils/url-utils";

const modelPath = url("/live2d/models/ug/ugofficial.model3.json");
const localCorePath = url("/live2d/vendor/live2dcubismcore.min.js");
const officialCoreUrl =
	"https://cubism.live2d.com/sdk-web/cubismcore/live2dcubismcore.min.js";
const pixiUrl = "https://cdn.jsdelivr.net/npm/pixi.js@6.5.10/dist/browser/pixi.min.js";
const live2dUrl =
	"https://cdn.jsdelivr.net/npm/pixi-live2d-display@0.4.0/dist/cubism4.min.js";
const expressionNames = [
	"1desk",
	"2mic",
	"3clever",
	"4OAO",
	"5QAQ",
	"6i gi a ri",
	"7keyboard",
	"8punch",
	"9",
];
---

<div
	id="live2d-mascot"
	class="live2d-mascot"
	data-expression-names={JSON.stringify(expressionNames)}
	aria-live="polite"
>
	<section class="live2d-mascot__panel" aria-label="Live2D 看板娘">
		<div class="live2d-mascot__status" data-live2d-status>看板娘加载中</div>
		<canvas
			class="live2d-mascot__canvas"
			data-live2d-canvas
			width="320"
			height="420"
			aria-hidden="true"
		></canvas>
	</section>
</div>

<style>
	.live2d-mascot {
		position: fixed;
		left: 0;
		top: 0;
		z-index: 70;
		pointer-events: none;
		touch-action: none;
	}

	.live2d-mascot__panel {
		position: relative;
		width: calc(clamp(11rem, 16vw, 16rem) * var(--live2d-scale, 1));
		aspect-ratio: 32 / 42;
		background: transparent;
		border: 0;
		box-shadow: none;
		overflow: visible;
		pointer-events: none;
		transition: width 180ms ease;
	}

	.live2d-mascot__status {
		position: absolute;
		top: 0.5rem;
		left: 0.5rem;
		z-index: 2;
		max-width: calc(100% - 1rem);
		padding: 0.3rem 0.55rem;
		border-radius: 999px;
		background: rgb(255 255 255 / 0.28);
		color: rgb(51 65 85 / 0.82);
		font-size: 0.7rem;
		letter-spacing: 0.03em;
		backdrop-filter: blur(8px);
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
		pointer-events: none;
	}

	.dark .live2d-mascot__status {
		background: rgb(15 23 42 / 0.3);
		color: rgb(226 232 240 / 0.84);
	}

	.live2d-mascot__status[data-mode="error"] {
		color: rgb(185 28 28 / 0.92);
		background: rgb(254 242 242 / 0.5);
	}

	.dark .live2d-mascot__status[data-mode="error"] {
		color: rgb(254 202 202 / 0.94);
		background: rgb(69 10 10 / 0.4);
	}

	.live2d-mascot__canvas {
		position: absolute;
		inset: 0;
		display: block;
		width: 100%;
		height: 100%;
		pointer-events: auto;
		cursor: pointer;
		filter: drop-shadow(0 1rem 2rem rgb(15 23 42 / 0.16));
	}

	@media (max-width: 1023px) {
		.live2d-mascot__panel {
			width: calc(clamp(8.5rem, 30vw, 11rem) * var(--live2d-scale, 1));
		}

		.live2d-mascot__status {
			display: none;
		}
	}
</style>

<script
	is:inline
	define:vars={{
		live2dUrl,
		localCorePath,
		modelPath,
		officialCoreUrl,
		pixiUrl,
	}}
>
	(() => {
		if (window.__alfLive2DMascotSetup) {
			return;
		}
		window.__alfLive2DMascotSetup = true;

		const root = document.getElementById("live2d-mascot");
		if (!(root instanceof HTMLElement)) {
			return;
		}

		const expressionNames = JSON.parse(root.dataset.expressionNames || "[]");
		const panel = root.querySelector(".live2d-mascot__panel");
		const canvas = root.querySelector("[data-live2d-canvas]");
		const status = root.querySelector("[data-live2d-status]");

		if (
			!(panel instanceof HTMLElement) ||
			!(canvas instanceof HTMLCanvasElement) ||
			!(status instanceof HTMLElement)
		) {
			return;
		}

		const state = {
			app: null,
			model: null,
			initPromise: null,
			baseSize: null,
			expressionIndex: 0,
			expressionTimer: null,
			position: null,
			dragPointerId: null,
			dragStartX: 0,
			dragStartY: 0,
			dragOriginX: 0,
			dragOriginY: 0,
			dragMoved: false,
		};

		const positionStorageKey = "alf.live2d.position";
		const visibilityStorageKey = "system:mascot-hidden";
		const viewportPadding = 8;
		const expressionIntervalMs = 15000;

		const setStatus = (message, mode = "info") => {
			status.textContent = message;
			status.dataset.mode = mode;
			status.hidden = message.length === 0;
		};

		const persistPlacement = () => {
			if (!state.position) {
				return;
			}

			try {
				localStorage.setItem(positionStorageKey, JSON.stringify(state.position));
			} catch (_error) {
				// Ignore storage failures.
			}
		};

		const getPanelSize = () => ({
			width: Math.max(panel.offsetWidth || 0, 1),
			height: Math.max(panel.offsetHeight || 0, 1),
		});

		const clampPosition = (x, y) => {
			const size = getPanelSize();
			const maxX = Math.max(window.innerWidth - size.width - viewportPadding, viewportPadding);
			const maxY = Math.max(
				window.innerHeight - size.height - viewportPadding,
				viewportPadding,
			);
			return {
				x: Math.min(Math.max(x, viewportPadding), maxX),
				y: Math.min(Math.max(y, viewportPadding), maxY),
			};
		};

		const applyPosition = (x, y) => {
			const nextPosition = clampPosition(x, y);
			state.position = nextPosition;
			root.style.left = `${nextPosition.x}px`;
			root.style.top = `${nextPosition.y}px`;
		};

		const restorePlacement = () => {
			const size = getPanelSize();
			const fallback = clampPosition(
				window.innerWidth - size.width - 12,
				window.innerHeight - size.height - 4,
			);

			let restoredPosition = fallback;

			try {
				const storedPosition = localStorage.getItem(positionStorageKey);
				if (storedPosition) {
					const parsed = JSON.parse(storedPosition);
					if (
						parsed &&
						typeof parsed.x === "number" &&
						typeof parsed.y === "number"
					) {
						restoredPosition = clampPosition(parsed.x, parsed.y);
					}
				}
			} catch (_error) {
				restoredPosition = fallback;
			}

			applyPosition(restoredPosition.x, restoredPosition.y);
		};

		const scriptCache =
			window.__alfLive2DScriptCache || (window.__alfLive2DScriptCache = new Map());

		const ensureScript = (src, test) => {
			if (typeof test === "function" && test()) {
				return Promise.resolve();
			}

			if (scriptCache.has(src)) {
				return scriptCache.get(src);
			}

			const pending = new Promise((resolve, reject) => {
				const script = document.createElement("script");
				script.src = src;
				script.async = true;
				script.onload = () => {
					if (!test || test()) {
						resolve();
						return;
					}

					reject(new Error(`Script loaded but runtime was unavailable: ${src}`));
				};
				script.onerror = () => reject(new Error(`Failed to load script: ${src}`));
				document.head.appendChild(script);
			});

			scriptCache.set(src, pending);
			return pending;
		};

		const ensureCubismCore = async () => {
			if (window.Live2DCubismCore) {
				return;
			}

			try {
				await ensureScript(localCorePath, () => Boolean(window.Live2DCubismCore));
			} catch (_error) {
				await ensureScript(officialCoreUrl, () => Boolean(window.Live2DCubismCore));
			}
		};

		const fitModel = () => {
			if (!state.app || !state.model) {
				return;
			}

			const width = Math.max(panel.clientWidth, 1);
			const height = Math.max(panel.clientHeight, 1);
			state.app.renderer.resize(width, height);

			const baseWidth = state.baseSize?.width || state.model.width;
			const baseHeight = state.baseSize?.height || state.model.height;
			const scale = Math.min((width * 0.78) / baseWidth, (height * 0.92) / baseHeight);
			state.model.anchor.set(0.5, 1);
			state.model.scale.set(scale);
			state.model.position.set(width * 0.5, height * 0.99);
		};

		const updatePlacementForViewport = () => {
			if (!state.position) {
				restorePlacement();
				return;
			}

			const nextPosition = clampPosition(state.position.x, state.position.y);
			applyPosition(nextPosition.x, nextPosition.y);
			persistPlacement();
		};

		const persistVisibility = (hidden) => {
			try {
				localStorage.setItem(visibilityStorageKey, hidden ? "true" : "false");
			} catch (_error) {
				// Ignore storage failures.
			}
		};

		const setHiddenState = (hidden, shouldPersist = true) => {
			root.hidden = hidden;
			root.setAttribute("aria-hidden", hidden ? "true" : "false");
			document.documentElement.dataset.mascotHidden = hidden ? "true" : "false";

			if (shouldPersist) {
				persistVisibility(hidden);
			}

			if (!hidden) {
				window.requestAnimationFrame(() => {
					fitModel();
					updatePlacementForViewport();
				});
			}
		};

		const cycleExpression = () => {
			if (
				!state.model ||
				typeof state.model.expression !== "function" ||
				expressionNames.length === 0
			) {
				return;
			}

			const expressionName = expressionNames[state.expressionIndex % expressionNames.length];
			state.expressionIndex += 1;
			state.model.expression(expressionName);
		};

		const playRandomExpression = () => {
			if (
				!state.model ||
				typeof state.model.expression !== "function" ||
				expressionNames.length === 0
			) {
				return;
			}

			const randomIndex = Math.floor(Math.random() * expressionNames.length);
			state.expressionIndex = randomIndex + 1;
			state.model.expression(expressionNames[randomIndex]);
		};

		const startExpressionTimer = () => {
			if (state.expressionTimer) {
				window.clearInterval(state.expressionTimer);
			}

			state.expressionTimer = window.setInterval(() => {
				playRandomExpression();
			}, expressionIntervalMs);
		};

		const isPointInsideRect = (x, y, rect) =>
			x >= rect.left && x <= rect.right && y >= rect.top && y <= rect.bottom;

		const handOffToMusicControl = (event) => {
			const musicLaunchButton = document.getElementById(
				"background-music-drawer-toggle",
			);
			if (!(musicLaunchButton instanceof HTMLButtonElement)) {
				return false;
			}

			const rect = musicLaunchButton.getBoundingClientRect();
			if (!isPointInsideRect(event.clientX, event.clientY, rect)) {
				return false;
			}

			event.preventDefault();
			event.stopPropagation();
			musicLaunchButton.click();
			return true;
		};

		const beginDrag = (event) => {
			if (!(event instanceof PointerEvent)) {
				return;
			}

			if (handOffToMusicControl(event)) {
				return;
			}

			state.dragPointerId = event.pointerId;
			state.dragStartX = event.clientX;
			state.dragStartY = event.clientY;
			state.dragOriginX = state.position?.x || 0;
			state.dragOriginY = state.position?.y || 0;
			state.dragMoved = false;
			canvas.setPointerCapture?.(event.pointerId);
		};

		const handleDragMove = (event) => {
			if (!(event instanceof PointerEvent) || state.dragPointerId !== event.pointerId) {
				return;
			}

			const deltaX = event.clientX - state.dragStartX;
			const deltaY = event.clientY - state.dragStartY;
			if (Math.abs(deltaX) > 4 || Math.abs(deltaY) > 4) {
				state.dragMoved = true;
			}

			applyPosition(state.dragOriginX + deltaX, state.dragOriginY + deltaY);
		};

		const endDrag = (event) => {
			if (!(event instanceof PointerEvent) || state.dragPointerId !== event.pointerId) {
				return;
			}

			canvas.releasePointerCapture?.(event.pointerId);
			const wasDrag = state.dragMoved;
			state.dragPointerId = null;

			if (wasDrag) {
				persistPlacement();
				return;
			}

			cycleExpression();
			startExpressionTimer();
		};

		const initMascot = async () => {
			if (state.initPromise) {
				return state.initPromise;
			}

			state.initPromise = (async () => {
				setStatus("看板娘加载中");

				await ensureScript(pixiUrl, () => Boolean(window.PIXI?.Application));
				await ensureCubismCore();
				await ensureScript(
					live2dUrl,
					() => Boolean(window.PIXI?.live2d?.Live2DModel),
				);

				if (!state.app) {
					state.app = new window.PIXI.Application({
						view: canvas,
						autoStart: true,
						autoDensity: true,
						antialias: true,
						backgroundAlpha: 0,
						width: Math.max(panel.clientWidth, 1),
						height: Math.max(panel.clientHeight, 1),
						resolution: Math.min(window.devicePixelRatio || 1, 2),
					});
				}

				if (!state.model) {
					state.model = await window.PIXI.live2d.Live2DModel.from(modelPath, {
						autoInteract: false,
						idleMotionGroup: "",
					});
					state.baseSize = {
						width: state.model.width,
						height: state.model.height,
					};
					state.app.stage.addChild(state.model);
				}

				fitModel();
				restorePlacement();
				startExpressionTimer();
				setStatus("");
			})().catch((error) => {
				state.initPromise = null;
				console.error("Live2D mascot failed to initialize", error);
				setStatus("看板娘加载失败", "error");
				throw error;
			});

			return state.initPromise;
		};

		const handleViewportResize = () => {
			fitModel();
			updatePlacementForViewport();
		};

		window.addEventListener("resize", handleViewportResize);
		window.addEventListener("alf:live2d-resize", handleViewportResize);
		window.addEventListener("alf:live2d-visibility", (event) => {
			const hidden = Boolean(event?.detail?.hidden);
			setHiddenState(hidden, false);

			if (!hidden) {
				void initMascot();
			}
		});
		canvas.addEventListener("pointerdown", beginDrag);
		canvas.addEventListener("pointermove", handleDragMove);
		canvas.addEventListener("pointerup", endDrag);
		canvas.addEventListener("pointercancel", endDrag);
		canvas.addEventListener("lostpointercapture", () => {
			state.dragPointerId = null;
		});

		const initiallyHidden = (() => {
			try {
				const rememberedVisibility = localStorage.getItem(visibilityStorageKey);
				if (rememberedVisibility === "true") {
					return true;
				}
				if (rememberedVisibility === "false") {
					return false;
				}
			} catch (_error) {
				// Ignore storage failures.
			}

			return document.documentElement.dataset.mascotHidden === "true";
		})();

		setHiddenState(initiallyHidden, false);
		if (!initiallyHidden) {
			void initMascot();
		}
	})();
</script>
