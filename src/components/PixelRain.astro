<div id="pixel-rain" class="pixel-rain" aria-hidden="true"></div>

<style is:global>
	.pixel-rain {
		position: fixed;
		inset: 0;
		z-index: 0;
		pointer-events: none;
		overflow: hidden;
	}

	.pixel-rain__drop {
		position: absolute;
		left: 0;
		top: 0;
		pointer-events: none;
		image-rendering: pixelated;
	}

	.pixel-rain__drop {
		width: var(--rain-drop-width, 2px);
		height: var(--rain-drop-length, 22px);
		background:
			linear-gradient(
				180deg,
				rgba(244, 246, 248, 0.14) 0 28%,
				rgba(220, 225, 229, 0.24) 28% 72%,
				rgba(188, 194, 200, 0.34) 72% 100%
			);
		box-shadow: 0 0 0 1px rgba(228, 233, 237, 0.05);
		opacity: 0.42;
	}
</style>

<script is:inline>
	(() => {
		if (window.__alfPixelRainSetup) {
			return;
		}
		window.__alfPixelRainSetup = true;

		const root = document.getElementById("pixel-rain");
		if (!(root instanceof HTMLElement)) {
			return;
		}

		const MIN_DROP_COUNT = 16;
		const MAX_DROP_COUNT = 60;
		const MIN_DROP_WIDTH = 1.05;
		const MAX_DROP_WIDTH = 2.35;
		const MIN_DROP_LENGTH = 18;
		const MAX_DROP_LENGTH = 37;
		const MIN_DROP_SPEED = 6.6;
		const MAX_DROP_SPEED = 12.4;
		const MIN_DROP_DRIFT = -0.16;
		const MAX_DROP_DRIFT = -0.56;
		const MIN_DROP_OPACITY = 0.16;
		const MAX_DROP_OPACITY = 0.46;
		const RAIN_END_BAND_MIN = 0.83;
		const RAIN_END_BAND_MAX = 0.91;
		const INTENSITY_BASELINE = 0.14;
		const MUSIC_WEIGHT = 0.4;
		const RAVEN_WEIGHT = 0.3;
		const BALANCE_WEIGHT = 0.2;
		const AMBIENT_WEIGHT = 0.1;
		const INTENSITY_SMOOTHING = 0.992;
		const DROP_VISIBILITY_SMOOTHING = 0.945;

		const randomBetween = (min, max) => min + Math.random() * (max - min);
		const clamp = (value, min, max) => Math.min(max, Math.max(min, value));
		const lerp = (start, end, progress) => start + (end - start) * progress;

		const state = {
			width: window.innerWidth,
			height: window.innerHeight,
			lastTickAt: performance.now(),
			rafId: 0,
			rainIntensity: 0.28,
			targetRainIntensity: 0.28,
			ambientPhase: randomBetween(0, Math.PI * 2),
			drops: [],
		};

		const getRavenHeadHitboxes = () => {
			if (typeof window.__alfRavenHeadHitboxes === "function") {
				return window.__alfRavenHeadHitboxes();
			}
			return [];
		};
		const getMusicWeatherState = () => {
			if (typeof window.__alfMusicWeatherState === "function") {
				return window.__alfMusicWeatherState();
			}
			return { playing: false, volume: 0, intensity: 0 };
		};
		const getRavenWeatherState = () => {
			if (typeof window.__alfRavenWeatherState === "function") {
				return window.__alfRavenWeatherState();
			}
			return { birdCount: 0, maxBirdCount: 14, foodDetected: false };
		};
		const getRainMetrics = (intensity) => ({
			desiredCount: Math.round(lerp(MIN_DROP_COUNT, MAX_DROP_COUNT, intensity)),
			width: lerp(MIN_DROP_WIDTH, MAX_DROP_WIDTH, intensity),
			length: lerp(MIN_DROP_LENGTH, MAX_DROP_LENGTH, intensity),
			speed: lerp(MIN_DROP_SPEED, MAX_DROP_SPEED, intensity),
			drift: lerp(MIN_DROP_DRIFT, MAX_DROP_DRIFT, intensity),
			opacity: lerp(MIN_DROP_OPACITY, MAX_DROP_OPACITY, intensity),
			endBandStart: lerp(RAIN_END_BAND_MAX, RAIN_END_BAND_MIN, intensity),
		});
		const computeTargetRainIntensity = (now) => {
			const musicState = getMusicWeatherState();
			const ravenState = getRavenWeatherState();
			const musicFactor = clamp(musicState?.intensity ?? 0, 0, 1);
			const ravenFactor = clamp(
				(ravenState?.birdCount ?? 0) /
					Math.max(6, Math.min(10, ravenState?.maxBirdCount ?? 10)),
				0,
				1,
			);
			const balancedFactor = Math.min(musicFactor, ravenFactor);
			const ambientFactor =
				(Math.sin(now * 0.00016 + state.ambientPhase) +
					Math.cos(now * 0.00009 + state.ambientPhase * 0.7)) *
				0.5;
			return clamp(
				INTENSITY_BASELINE +
					musicFactor * MUSIC_WEIGHT +
					ravenFactor * RAVEN_WEIGHT +
					balancedFactor * BALANCE_WEIGHT +
					(ambientFactor * 0.5 + 0.5) * AMBIENT_WEIGHT,
				0.08,
				1,
			);
		};

		const resetDrop = (drop, metrics, options = {}) => {
			const { fresh = false } = options;
			drop.x = randomBetween(-state.width * 0.08, state.width * 1.02);
			drop.y = fresh
				? randomBetween(-state.height, state.height)
				: randomBetween(-state.height * 0.22, -12);
			drop.speed = metrics.speed * drop.speedScale;
			drop.drift = metrics.drift * drop.driftScale;
			drop.endY = randomBetween(
				state.height * metrics.endBandStart,
				state.height + metrics.length * 0.35,
			);
		};

		const applyDropFrame = (drop, metrics) => {
			const width = metrics.width * drop.widthScale;
			const length = metrics.length * drop.lengthScale;
			drop.width = width;
			drop.length = length;
			drop.element.style.width = `${width.toFixed(2)}px`;
			drop.element.style.height = `${length.toFixed(2)}px`;
			drop.element.style.opacity = `${(
				metrics.opacity *
				drop.opacityScale *
				drop.visibleStrength
			).toFixed(3)}`;
			drop.element.style.transform = `translate3d(${drop.x}px, ${drop.y}px, 0)`;
		};

		const buildDropPool = (metrics) => {
			for (let index = 0; index < MAX_DROP_COUNT; index += 1) {
				const element = document.createElement("div");
				element.className = "pixel-rain__drop";
				const drop = {
					element,
					index,
					x: 0,
					y: 0,
					speed: metrics.speed,
					drift: metrics.drift,
					width: metrics.width,
					length: metrics.length,
					endY: state.height,
					widthScale: randomBetween(0.9, 1.08),
					lengthScale: randomBetween(0.82, 1.18),
					speedScale: randomBetween(0.9, 1.12),
					driftScale: randomBetween(0.86, 1.14),
					opacityScale: randomBetween(0.82, 1.08),
					visibleStrength: index < metrics.desiredCount ? 1 : 0,
					targetVisible: index < metrics.desiredCount,
				};
				resetDrop(drop, metrics, { fresh: true });
				applyDropFrame(drop, metrics);
				state.drops.push(drop);
				root.appendChild(element);
			}
		};

		const intersectsRavenHead = (dropCenterX, dropBottomY, hitboxes) =>
			hitboxes.some(
				(box) =>
					dropCenterX >= box.x &&
					dropCenterX <= box.x + box.width &&
					dropBottomY >= box.y &&
					dropBottomY <= box.y + box.height,
			);

		const tick = (now) => {
			const dt = clamp((now - state.lastTickAt) / 16.6667, 0.45, 2.1);
			state.lastTickAt = now;
			state.targetRainIntensity = computeTargetRainIntensity(now);
			state.rainIntensity = lerp(
				state.rainIntensity,
				state.targetRainIntensity,
				1 - INTENSITY_SMOOTHING ** dt,
			);
			const metrics = getRainMetrics(state.rainIntensity);

			const hitboxes = getRavenHeadHitboxes();
			for (const drop of state.drops) {
				const shouldBeVisible = drop.index < metrics.desiredCount;
				if (shouldBeVisible && !drop.targetVisible) {
					resetDrop(drop, metrics);
				}
				drop.targetVisible = shouldBeVisible;
				drop.visibleStrength = lerp(
					drop.visibleStrength,
					shouldBeVisible ? 1 : 0,
					1 - DROP_VISIBILITY_SMOOTHING ** dt,
				);
				drop.speed = metrics.speed * drop.speedScale;
				drop.drift = metrics.drift * drop.driftScale;
				drop.x += drop.drift * dt;
				drop.y += drop.speed * dt;

				const dropCenterX = drop.x + drop.width * 0.5;
				const dropBottomY = drop.y + drop.length;
				if (intersectsRavenHead(dropCenterX, dropBottomY, hitboxes)) {
					resetDrop(drop, metrics);
					applyDropFrame(drop, metrics);
					continue;
				}

				if (dropBottomY >= drop.endY) {
					resetDrop(drop, metrics);
					applyDropFrame(drop, metrics);
					continue;
				}

				if (
					drop.x < -Math.max(18, drop.width * 8) ||
					drop.x > state.width + Math.max(18, drop.width * 8) ||
					drop.y > state.height + Math.max(20, drop.length * 1.2)
				) {
					resetDrop(drop, metrics);
				}
				applyDropFrame(drop, metrics);
			}

			state.rafId = window.requestAnimationFrame(tick);
		};

		const handleResize = () => {
			state.width = window.innerWidth;
			state.height = window.innerHeight;
		};

		buildDropPool(getRainMetrics(state.rainIntensity));
		window.addEventListener("resize", handleResize, { passive: true });
		state.rafId = window.requestAnimationFrame(tick);
	})();
</script>
